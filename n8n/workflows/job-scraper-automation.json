    {
      "parameters": {
        "jsCode": "// No jobs found - log and continue\nconst config = $('Setup Configuration').first().json;\n\nconsole.log('⚠️ No valid jobs found in this scrape run');\nconsole.log(`Config: ${JSON.stringify(config)}`);\n\nreturn [{ \n  json: { \n    message: 'No valid jobs found',\n    startedAt: config.startedAt,\n    completedAt: new Date().toISOString(),\n    portalUrl: config.portalUrl\n  } \n}];"
