    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Store start time and configuration\nconst config = {\n  startedAt: new Date().toISOString(),\n  location: 'India',\n  keywords: ['actuarial analyst', 'actuary', 'actuarial scientist', 'risk analyst', 'insurance analyst'],\n  maxPages: 5,\n  // CHANGE THIS to your actual host IP address\n  // Read IP from an environment variable.\n  portalHost: $json.PORTAL_HOST || '192.168.1.104',\n  portalPort: $json.PORTAL_PORT || 4321,\n  scraperHost: $json.SCRAPER_HOST || 'scraper-api',\n  scraperPort: $json.SCRAPER_PORT || 5000\n};\n\nconfig.portalUrl = `http://${config.portalHost}:${config.portalPort}`;\nconfig.scraperUrl = `http://${config.scraperHost}:${config.scraperPort}`;\n\nconsole.log('🚀 Starting job scraper automation');\nconsole.log(`Portal URL: ${config.portalUrl}`);\nconsole.log(`Scraper URL: ${config.scraperUrl}`);\n\nreturn { json: config };"
      },
