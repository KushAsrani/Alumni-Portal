# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/alumni_portal

# Session secret for alumni auth
SESSION_SECRET=change-this-secret-key-in-production

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-password
SMTP_FROM=Alumni Portal <noreply@example.com>

# Cron security secret
CRON_SECRET=your-secret-token

# App public URL (used in cron workflow)
# APP_URL=https://your-app.vercel.app
