---
import type { CompletenessSection } from '../lib/profile-completeness';

interface Props {
  score: number;
  sections: CompletenessSection[];
  missingFields: string[];
}

const { score, sections, missingFields } = Astro.props;
const radius = 44;
const circumference = 2 * Math.PI * radius;
const offset = circumference * (1 - score / 100);
const ringColor = score >= 80 ? '#16a34a' : score >= 40 ? '#f59e0b' : '#dc2626';
const isComplete = score === 100;
---

<section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
  <div class="flex flex-col gap-6 lg:flex-row lg:items-center">
    <div class="flex justify-center lg:w-44 lg:flex-shrink-0">
      <div class="relative h-32 w-32">
        <svg class="h-32 w-32 -rotate-90" viewBox="0 0 120 120" aria-hidden="true">
          <circle cx="60" cy="60" r={radius} fill="none" stroke="#e2e8f0" stroke-width="10"></circle>
          <circle
            cx="60"
            cy="60"
            r={radius}
            fill="none"
            stroke={ringColor}
            stroke-width="10"
            stroke-linecap="round"
            stroke-dasharray={circumference}
            stroke-dashoffset={offset}
          ></circle>
        </svg>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <span class="text-2xl font-bold text-slate-900">{score}%</span>
          <span class="text-[10px] font-semibold uppercase tracking-[0.24em] text-slate-500">Complete</span>
        </div>
      </div>
    </div>

    <div class="flex-1 space-y-5">
      <div>
        <h2 class="text-lg font-semibold text-slate-900">Profile completeness</h2>
        <p class="mt-1 text-sm text-slate-600">
          {isComplete
            ? 'Your profile is complete!'
            : `Complete ${missingFields.length} more field${missingFields.length === 1 ? '' : 's'} to strengthen your profile.`}
        </p>
      </div>

      <div class="space-y-3">
        {sections.map((section) => (
          <div class="grid grid-cols-[minmax(110px,auto)_1fr_auto] items-center gap-3 sm:grid-cols-[150px_1fr_auto]">
            <span class="text-sm font-medium text-slate-700">{section.name}</span>
            <div class="h-1.5 overflow-hidden rounded-full bg-slate-200">
              <div
                class="h-full rounded-full bg-[#2e4096] transition-all"
                style={`width: ${section.score}%`}
              ></div>
            </div>
            <span class="text-sm font-medium text-slate-500">{section.score}%</span>
          </div>
        ))}
      </div>

      {missingFields.length > 0 && (
        <div>
          <p class="mb-2 text-sm font-medium text-slate-700">Suggested next fields</p>
          <div class="flex flex-wrap gap-2">
            {missingFields.map((field) => (
              <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm text-slate-600">
                + {field}
              </span>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</section>
