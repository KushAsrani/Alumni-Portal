---
import type { CompletenessResult } from '../lib/profile-completeness';

interface Props {
  result: CompletenessResult;
  compact?: boolean;
}

const { result, compact = false } = Astro.props;
const circumference = 2 * Math.PI * 52;
const dashOffset = circumference - (result.score / 100) * circumference;
const ringColor = result.score >= 80 ? '#16a34a' : result.score >= 50 ? '#eab308' : '#dc2626';
---

<div class={`rounded-2xl border border-slate-200 bg-white shadow-sm ${compact ? 'p-5' : 'p-6'}`}>
  <div class={`flex ${compact ? 'flex-col gap-4' : 'flex-col lg:flex-row gap-6'} lg:items-center`}>
    <div class="flex items-center gap-4">
      <div class="relative h-32 w-32 shrink-0">
        <svg class="h-32 w-32 -rotate-90" viewBox="0 0 120 120" aria-hidden="true">
          <circle cx="60" cy="60" r="52" stroke="#e2e8f0" stroke-width="10" fill="none"></circle>
          <circle
            cx="60"
            cy="60"
            r="52"
            stroke={ringColor}
            stroke-width="10"
            fill="none"
            stroke-linecap="round"
            stroke-dasharray={circumference}
            stroke-dashoffset={dashOffset}
          ></circle>
        </svg>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <span class="text-3xl font-bold text-slate-900">{result.score}%</span>
          <span class="text-xs font-medium uppercase tracking-[0.2em] text-slate-500">Complete</span>
        </div>
      </div>
      <div>
        <h3 class="text-lg font-semibold text-slate-900">Profile completeness</h3>
        <p class="mt-1 text-sm text-slate-600">
          {result.missing.length === 0 ? 'Your profile is fully complete.' : `Complete ${result.missing.length} more field${result.missing.length === 1 ? '' : 's'} to strengthen your profile.`}
        </p>
      </div>
    </div>

    <div class="flex-1 space-y-4">
      <div class="grid gap-3 md:grid-cols-2">
        {result.sections.map((section) => (
          <div class="rounded-xl bg-slate-50 p-4">
            <div class="mb-2 flex items-center justify-between">
              <span class="text-sm font-semibold text-slate-800">{section.name}</span>
              <span class="text-sm text-slate-500">{section.score}%</span>
            </div>
            <div class="h-2 overflow-hidden rounded-full bg-slate-200">
              <div class="h-full rounded-full bg-primary-600" style={`width:${section.score}%`}></div>
            </div>
          </div>
        ))}
      </div>

      {result.missing.length > 0 && (
        <div>
          <p class="mb-2 text-sm font-semibold text-slate-800">Suggested next fields</p>
          <ul class="space-y-2 text-sm text-slate-600">
            {result.missing.slice(0, 6).map((field) => (
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4 text-primary-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10.293 15.707a1 1 0 010-1.414L13.586 11H4a1 1 0 110-2h9.586l-3.293-3.293a1 1 0 111.414-1.414l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>{field}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </div>
</div>
