<div id="share-modal-overlay" class="hidden fixed inset-0 z-50 bg-black/50 p-4">
  <div id="share-modal" class="ml-auto mr-auto mt-auto md:mt-16 w-full max-w-md rounded-2xl border border-accent-200 bg-white p-5 shadow-xl">
    <div class="mb-4 flex items-center justify-between">
      <h3 class="text-lg font-semibold text-accent-900">Share Profile</h3>
      <button id="share-close" type="button" class="h-11 w-11 rounded-lg border border-accent-200 text-accent-700" aria-label="Close share modal">
        <svg class="mx-auto h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 6l12 12M18 6l-12 12"></path>
        </svg>
      </button>
    </div>
    <p id="share-target" class="mb-4 text-sm text-accent-600"></p>
    <div class="grid grid-cols-1 gap-2">
      <button id="share-copy" type="button" class="btn btn-primary">Copy Profile Link</button>
      <a id="share-email" href="#" class="btn btn-outline text-center">Share via Email</a>
      <a id="share-linkedin" href="#" target="_blank" rel="noopener noreferrer" class="btn btn-outline text-center">Share on LinkedIn</a>
      <a id="share-twitter" href="#" target="_blank" rel="noopener noreferrer" class="btn btn-outline text-center">Share on Twitter</a>
    </div>
  </div>
</div>
