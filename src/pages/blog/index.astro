---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a,b)=> new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Blog' },
];
---

<Layout title="Blog">
  <Breadcrumbs items={breadcrumbItems} />
  <section class="section bg-gray-50">
    <div class="container-custom">
      <header class="mb-14 text-center"><p class="text-sm font-semibold uppercase tracking-wider text-orange-500 mb-3">PrepSOM Blogs</p><h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-blue-700 mb-4">Ideas for smarter hiring &amp; careers</h1><p class="text-lg text-gray-600 max-w-2xl mx-auto">Product updates, interview tips, and perspectives on AI-powered assessments and campus placements.</p></header>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {posts.map(p => (
          <a href={`/blog/${p.slug}`} class="card card-hover block">
            <div class="p-6">
              <h3 class="text-xl font-semibold mb-2">{p.data.title}</h3>
              <p class="text-gray-600 mb-4">{p.data.description}</p>
              <p class="text-sm text-gray-500">{new Date(p.data.publishDate).toDateString()}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
