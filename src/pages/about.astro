---
import Layout from '../layouts/Layout.astro';
import { getSiteConfig } from '../utils/config';
import Icon from '../components/Icon.astro';

const config = getSiteConfig();
---

<Layout title="About" description="Learn about our alumni network, mission, and the team behind the Open Alumns Portal.">
  <!-- Page Header
  <section class="bg-gradient-to-r from-primary-600 to-primary-700 text-white py-16">
    <div class="container-custom text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">About Our Alumni Network</h1>
      <p class="text-xl text-gray-100 max-w-3xl mx-auto">
        Building bridges between past, present, and future generations of graduates
      </p>
    </div>
  </section>
   -->

  <!-- Breadcrumb -->
  <section class="bg-gray-50 py-4">
    <div class="container-custom">
      <nav class="flex" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2">
          <li>
            <a href="/" class="text-gray-500 hover:text-primary-600 transition-colors">Home</a>
          </li>
          <li class="flex items-center">
            <svg class="w-4 h-4 text-gray-400 mx-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="text-gray-900 font-medium">About</span>
          </li>
        </ol>
      </nav>
    </div>
  </section>

  <div class="bg-gray-50 min-h-screen pt-16"><div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16"><div class="text-center mb-16"><h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-blue-700 mb-4">About PrepSOM</h1><p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto">Bridging the gap between talent and opportunity through AI-powered preparation and assessment.</p></div><section class="mb-16"><h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">Our Mission</h2><p class="text-gray-700 leading-relaxed text-lg mb-4">PrepSOM is an AI-powered interview preparation and campus placement management platform. We help students ace their interviews with personalised mock interviews and aptitude tests, while enabling colleges and corporates to run smarter, faster, and more objective hiring processes.</p><p class="text-gray-700 leading-relaxed text-lg">Our vision is a world where every candidate is evaluated on their true potential — not on how well they were coached for a specific format, and where every hiring decision is data-driven and bias-free.</p></section><section class="mb-16"><h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">What We Do</h2><div class="grid grid-cols-1 md:grid-cols-3 gap-6"><div class="bg-white rounded-xl p-6 shadow-md"><h3 class="text-xl font-semibold text-blue-700 mb-3">For Students</h3><p class="text-gray-600">AI mock interviews, unlimited aptitude tests, personalised feedback reports, and improved answer suggestions to help you land your dream job.</p></div><div class="bg-white rounded-xl p-6 shadow-md"><h3 class="text-xl font-semibold text-blue-700 mb-3">For Colleges</h3><p class="text-gray-600">End-to-end campus placement management — student onboarding, skill evaluation, corporate connects, and placement analytics in one platform.</p></div><div class="bg-white rounded-xl p-6 shadow-md"><h3 class="text-xl font-semibold text-blue-700 mb-3">For Companies</h3><p class="text-gray-600">AI-powered candidate screening, bulk resume analysis, structured aptitude and interview assessments to reduce hiring time and subjectivity.</p></div></div></section><section class="mb-16"><h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">Our Founders</h2><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="bg-white rounded-xl p-6 shadow-md"><h3 class="text-xl font-bold text-gray-900 mb-1">Aman Loharuka</h3><p class="text-blue-600 font-medium mb-3">Co-Founder &amp; CEO</p><p class="text-gray-600">Leading product strategy and growth at PrepSOM, focused on building the most effective AI-powered career preparation platform in India.</p></div><div class="bg-white rounded-xl p-6 shadow-md"><h3 class="text-xl font-bold text-gray-900 mb-1">Vidya Makwana</h3><p class="text-blue-600 font-medium mb-3">Co-Founder &amp; CTO</p><p class="text-gray-600">Driving the technology vision and AI infrastructure behind PrepSOM's interview simulation, assessment, and analytics capabilities.</p></div></div></section><section class="mb-16"><h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">Backed By</h2><div class="bg-white rounded-xl p-6 shadow-md"><p class="text-gray-700 leading-relaxed text-lg">PrepSOM is proud to be supported by <strong>IIM Ahmedabad Ventures</strong> — the startup incubation programme of one of India's premier management institutions. This backing reflects our commitment to building meaningful, high-impact technology for the Indian education and hiring ecosystem.</p><p class="text-gray-500 text-sm mt-4">Registered as: PrepSOM Labs Private Limited | CIN: U72900GJ2024PTC152393</p></div></section><section><h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">Get in Touch</h2><div class="bg-white rounded-xl p-6 shadow-md"><div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-gray-700"><div><p class="font-semibold mb-1">Email</p><a href="mailto:contact@prepsom.com" class="text-blue-600 hover:underline">contact@prepsom.com</a></div><div><p class="font-semibold mb-1">Phone</p><a href="tel:+918758076106" class="text-blue-600 hover:underline">+91 8758076106</a></div><div><p class="font-semibold mb-1">Address</p><p class="text-sm">IIM Ahmedabad Ventures, Vastrapur, Ahmedabad, Gujarat 380015</p></div></div></div></section></div></div>
</Layout>