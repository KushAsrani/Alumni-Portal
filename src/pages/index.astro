---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getSiteConfig } from "../utils/config";
import Icon from "../components/Icon.astro";

const config = getSiteConfig();

// Get sample data for preview
const alumni = await getCollection("alumni");
const blogPosts = await getCollection("blog");
const jobs = await getCollection("jobs");

// Get featured alumni (first 3)
const featuredAlumni = alumni.slice(0, 3);

// Fetch live upcoming events from MongoDB
let latestEvents: any[] = [];
try {
  const eventsRes = await fetch(`${Astro.url.origin}/api/events?status=upcoming&limit=3`);
  if (eventsRes.ok) {
    const eventsData = await eventsRes.json();
    latestEvents = eventsData.events || [];
  }
} catch (e) {
  latestEvents = [];
}

// Get latest blog posts (first 3)
const latestBlogPosts = blogPosts
  .filter((post) => !post.data.draft)
  .sort(
    (a, b) =>
      new Date(b.data.publishDate).getTime() -
      new Date(a.data.publishDate).getTime()
  )
  .slice(0, 3);

// Get featured jobs (first 3)
const featuredJobs = jobs
  .filter((job) => job.data.featured)
  .sort((a, b) => {
    const dateA = new Date(a.data.posted_date).getTime();
    const dateB = new Date(b.data.posted_date).getTime();
    return dateB - dateA;
  })
  .slice(0, 3);
