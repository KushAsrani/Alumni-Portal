---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getSiteConfig } from "../utils/config";
import Icon from "../components/Icon.astro";

const config = getSiteConfig();
const blogPosts = await getCollection("blog");

let latestEvents: any[] = [];
try {
  const eventsRes = await fetch(`${Astro.url.origin}/api/events?status=upcoming&limit=3`);
  if (eventsRes.ok) {
    const eventsData = await eventsRes.json();
    latestEvents = eventsData.events || [];
  }
} catch (e) {
  latestEvents = [];
}

const latestBlogPosts = blogPosts
  .filter((post) => !post.data.draft)
  .sort(
    (a, b) =>
      new Date(b.data.publishDate).getTime() -
      new Date(a.data.publishDate).getTime()
  )
  .slice(0, 2);

const heroStats = [
  { value: "1:1", label: "Alumni mentoring" },
  { value: "AI", label: "Career support" },
  { value: "360°", label: "Network growth" },
];

const portalFeatures = [
  {
    icon: "mdi:account-group-outline",
    title: "Build meaningful connections",
    description:
      "Reconnect with peers, discover alumni in your field, and grow relationships beyond graduation.",
  },
  {
    icon: "mdi:briefcase-search-outline",
    title: "Unlock career opportunities",
    description:
      "Explore curated jobs, internships, referrals, and readiness tools designed around your profile.",
  },
  {
    icon: "mdi:handshake-outline",
    title: "Learn through mentorship",
    description:
      "Find alumni mentors for interview prep, role transitions, domain guidance, and growth plans.",
  },
  {
    icon: "mdi:calendar-star",
    title: "Attend alumni experiences",
    description:
      "Register for webinars, workshops, reunions, and networking events in one connected calendar.",
  },
];

const careerTools = [
  {
    icon: "mdi:account-edit-outline",
    title: "Profile readiness",
    description: "Keep your alumni profile, skills, resume, and career interests polished and discoverable.",
  },
  {
    icon: "mdi:send-check-outline",
    title: "Smart job matching",
    description: "Use profile signals to find relevant opportunities faster and prioritize where to apply.",
  },
  {
    icon: "mdi:microphone-message",
    title: "Interview preparation",
    description: "Practice with mock interviews and feedback loops that help convert preparation into confidence.",
  },
];

const jobFeatures = [
  {
    icon: "mdi:tune-variant",
    title: "Smart filters",
    description: "Filter opportunities by skills, interest, readiness level, location, and alumni relevance.",
  },
  {
    icon: "mdi:lightning-bolt-outline",
    title: "One-click workflows",
    description: "Move from discovery to action with saved roles, quick applications, and profile-based context.",
  },
  {
    icon: "mdi:chart-timeline-variant",
    title: "Match scores",
    description: "See how closely each role aligns with your skills so you can focus on the best-fit openings.",
  },
];

const directoryFeatures = [
  {
    icon: "mdi:account-details-outline",
    title: "Rich alumni profiles",
    description: "Browse education, skills, experience, goals, and verified profile details in a consistent format.",
  },
  {
    icon: "mdi:tag-multiple-outline",
    title: "Skill tags and readiness",
    description: "Find alumni by domain expertise, hiring readiness, mentorship availability, and shared interests.",
  },
  {
    icon: "mdi:filter-check-outline",
    title: "Advanced discovery",
    description: "Search across batch, branch, industry, company, status, and career path to find the right people.",
  },
  {
    icon: "mdi:account-switch-outline",
    title: "Admin-friendly actions",
    description: "Support moderation, tagging, outreach, and engagement programs without spreadsheet chaos.",
  },
];

const mentorshipFeatures = [
  {
    icon: "mdi:target-account",
    title: "Goal-based matching",
    description: "Share your career goals and get connected with alumni mentors who are relevant to your path.",
  },
  {
    icon: "mdi:message-text-clock-outline",
    title: "1:1 career guidance",
    description: "Get practical advice on interviews, internships, job switches, portfolios, and domain learning paths.",
  },
  {
    icon: "mdi:rocket-launch-outline",
    title: "Faster outcomes",
    description: "Learn from real experiences, avoid common mistakes, and build momentum with structured support.",
  },
];
---

<Layout title={config.site.name} description={config.site.description}>
  <main class="home-page">
    <section class="hero-section relative overflow-hidden bg-[radial-gradient(circle_at_top_left,#dbe4ff,transparent_34%),linear-gradient(135deg,#f8fafc_0%,#ffffff_45%,#eef2ff_100%)]">
      <div class="container-custom py-16 md:py-24 lg:py-28">
        <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
          <div>
            <span class="eyebrow">
              <Icon name="mdi:sparkles" class="h-4 w-4" />
              AI-powered alumni growth platform
            </span>
            <h1 class="mt-6 max-w-4xl text-4xl font-black tracking-tight text-accent-900 md:text-6xl lg:text-7xl">
              Connect alumni, careers, events, and mentorship in one polished portal.
            </h1>
            <p class="mt-6 max-w-2xl text-lg leading-8 text-accent-600 md:text-xl">
              PrepSOM helps graduates stay connected, discover opportunities, prepare for interviews, and learn from alumni who have already walked the path.
            </p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a href="/alumni/register" class="btn btn-primary btn-lg">
                <Icon name="mdi:account-plus" class="mr-2 h-5 w-5" />
                Join the Network
              </a>
              <a href="/alumni" class="btn btn-outline btn-lg bg-white/80">
                <Icon name="mdi:account-search" class="mr-2 h-5 w-5" />
                Explore Directory
              </a>
            </div>
            <dl class="mt-10 grid max-w-2xl grid-cols-3 gap-3">
              {heroStats.map((stat) => (
                <div class="rounded-2xl border border-white/80 bg-white/75 p-4 shadow-sm backdrop-blur">
                  <dt class="text-2xl font-black text-primary-700 md:text-3xl">{stat.value}</dt>
                  <dd class="mt-1 text-xs font-semibold uppercase tracking-wide text-accent-500">{stat.label}</dd>
                </div>
              ))}
            </dl>
          </div>

          <div class="relative">
            <div class="absolute -left-6 -top-6 h-28 w-28 rounded-full bg-secondary-200/70 blur-3xl"></div>
            <div class="absolute -bottom-8 -right-8 h-36 w-36 rounded-full bg-primary-300/40 blur-3xl"></div>
            <div class="relative rounded-[2rem] border border-white bg-white/85 p-5 shadow-2xl backdrop-blur">
              <div class="rounded-[1.5rem] bg-accent-900 p-5 text-white">
                <div class="flex items-center justify-between border-b border-white/10 pb-5">
                  <div>
                    <p class="text-sm text-white/60">Career command center</p>
                    <p class="mt-1 text-xl font-bold">Alumni Success Snapshot</p>
                  </div>
                  <span class="rounded-full bg-emerald-400/15 px-3 py-1 text-sm font-semibold text-emerald-200">Live</span>
                </div>
                <div class="mt-6 grid gap-4 sm:grid-cols-2">
                  <div class="rounded-2xl bg-white/10 p-4">
                    <Icon name="mdi:briefcase-check" class="h-7 w-7 text-secondary-300" />
                    <p class="mt-4 text-3xl font-black">92%</p>
                    <p class="text-sm text-white/65">Profile-match clarity</p>
                  </div>
                  <div class="rounded-2xl bg-white/10 p-4">
                    <Icon name="mdi:account-heart" class="h-7 w-7 text-primary-200" />
                    <p class="mt-4 text-3xl font-black">24h</p>
                    <p class="text-sm text-white/65">Mentor response target</p>
                  </div>
                </div>
                <div class="mt-5 rounded-2xl bg-gradient-to-r from-primary-600 to-primary-500 p-5">
                  <p class="text-sm font-semibold text-primary-100">Recommended next step</p>
                  <p class="mt-2 text-lg font-bold">Update skills and book a mock interview before applying.</p>
                  <div class="mt-4 h-2 rounded-full bg-white/20">
                    <div class="h-2 w-3/4 rounded-full bg-secondary-300"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="section bg-white">
      <div class="container-custom">
        <div class="section-heading mx-auto max-w-3xl text-center">
          <span class="eyebrow mx-auto">What needed improvement</span>
          <h2>Cleaner hierarchy, tighter spacing, and clearer actions.</h2>
          <p>
            The screenshots showed strong content, but the homepage felt text-heavy, unevenly spaced, and visually repetitive. The updated design creates a professional rhythm with concise copy, consistent cards, stronger CTAs, and responsive section layouts.
          </p>
        </div>

        <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          {portalFeatures.map((feature) => (
            <article class="feature-card">
              <div class="feature-icon"><Icon name={feature.icon} class="h-6 w-6" /></div>
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section bg-accent-50">
      <div class="container-custom">
        <div class="rounded-[2rem] border border-accent-200 bg-white p-6 shadow-xl shadow-accent-200/50 md:p-10 lg:p-12">
          <div class="grid items-center gap-10 lg:grid-cols-[0.95fr_1.05fr]">
            <div>
              <span class="eyebrow"><Icon name="mdi:lightning-bolt" class="h-4 w-4" /> AI career coordinator</span>
              <h2 class="mt-5 text-3xl font-black tracking-tight text-accent-900 md:text-5xl">Your personal career coordinator</h2>
              <p class="mt-5 text-lg leading-8 text-accent-600">
                Replace scattered tools with one guided career workflow: complete your profile, identify best-fit roles, practice interviews, and get alumni-backed guidance.
              </p>
              <div class="mt-8 space-y-4">
                {careerTools.map((tool) => (
                  <article class="tool-row">
                    <div class="tool-icon"><Icon name={tool.icon} class="h-5 w-5" /></div>
                    <div>
                      <h3>{tool.title}</h3>
                      <p>{tool.description}</p>
                    </div>
                  </article>
                ))}
              </div>
            </div>
            <div class="rounded-[1.75rem] bg-gradient-to-br from-primary-700 via-primary-600 to-accent-900 p-8 text-white shadow-2xl">
              <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-100">AI suite</p>
              <h3 class="mt-3 text-3xl font-black">Ace your next interview</h3>
              <ul class="mt-8 space-y-4">
                {[
                  "Industry-leading mock interview practice",
                  "AI-powered job and mentor matching",
                  "Skill assessments with readiness signals",
                  "Real-time career progress insights",
                ].map((item) => (
                  <li class="flex items-center gap-3 text-white/90">
                    <Icon name="mdi:check-circle" class="h-5 w-5 text-emerald-300" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container-custom">
        <div class="section-heading mx-auto max-w-3xl text-center">
          <span class="eyebrow mx-auto">Jobs and internships</span>
          <h2>Find roles that match your profile.</h2>
          <p>
            A professional job board should quickly explain how alumni discover, qualify, and act on opportunities without overwhelming them with long paragraphs.
          </p>
        </div>
        <div class="mt-12 grid gap-6 lg:grid-cols-3">
          {jobFeatures.map((feature) => (
            <article class="feature-card feature-card--tall">
              <div class="feature-icon"><Icon name={feature.icon} class="h-6 w-6" /></div>
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
            </article>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a href="/jobs" class="btn btn-primary btn-lg">
            <Icon name="mdi:briefcase" class="mr-2 h-5 w-5" />
            View Job Opportunities
          </a>
        </div>
      </div>
    </section>

    <section class="section bg-gradient-to-br from-accent-50 to-primary-50">
      <div class="container-custom">
        <div class="grid items-start gap-10 lg:grid-cols-[0.8fr_1.2fr]">
          <div class="section-heading section-heading--left sticky-block">
            <span class="eyebrow">Alumni Directory</span>
            <h2>Make the network easier to explore.</h2>
            <p>
              The directory now uses compact cards, cleaner descriptions, and stronger visual structure so students, alumni, and admins understand its value immediately.
            </p>
            <a href="/alumni" class="btn btn-primary mt-8">
              <Icon name="mdi:account-group" class="mr-2 h-5 w-5" />
              View Alumni Directory
            </a>
          </div>
          <div class="grid gap-5 sm:grid-cols-2">
            {directoryFeatures.map((feature) => (
              <article class="feature-card bg-white/90">
                <div class="feature-icon feature-icon--solid"><Icon name={feature.icon} class="h-6 w-6" /></div>
                <h3>{feature.title}</h3>
                <p>{feature.description}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container-custom">
        <div class="section-heading mx-auto max-w-4xl text-center">
          <span class="eyebrow mx-auto">Alumni Mentorship</span>
          <h2>Learn directly from alumni who have been there.</h2>
          <p>
            Get practical 1:1 guidance on careers, interviews, skills, internships, job switches, and domain-specific learning paths.
          </p>
        </div>
        <div class="mt-12 grid gap-6 lg:grid-cols-3">
          {mentorshipFeatures.map((feature) => (
            <article class="feature-card text-left">
              <div class="feature-icon"><Icon name={feature.icon} class="h-6 w-6" /></div>
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
            </article>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a href="/alumni/mentorship" class="btn btn-primary btn-lg">Find My Mentor</a>
        </div>
      </div>
    </section>

    <section class="section bg-accent-50">
      <div class="container-custom">
        <div class="section-heading mx-auto max-w-3xl text-center">
          <span class="eyebrow mx-auto">Events and webinars</span>
          <h2>Keep the community active.</h2>
          <p>
            Upcoming events are presented with cleaner cards, stronger date hierarchy, consistent imagery, and obvious next actions.
          </p>
        </div>

        <div class="mt-12 grid gap-6 lg:grid-cols-3">
          {latestEvents.length === 0 ? (
            <div class="empty-state lg:col-span-3">
              <Icon name="mdi:calendar-blank" class="mx-auto h-14 w-14 text-accent-300" />
              <p>No upcoming events at the moment. Check back soon!</p>
            </div>
          ) : (
            latestEvents.map((event) => (
              <article class="event-card group">
                <div class="event-card__media">
                  <Icon name="mdi:calendar-star" class="h-14 w-14 text-primary-500/70" />
                  <span class="badge badge-secondary absolute left-4 top-4 uppercase">{event.eventType || "Event"}</span>
                  <span class="badge badge-primary absolute right-4 top-4">
                    {new Date(event.startTime).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                  </span>
                </div>
                <h3 class="mt-5 text-xl font-bold text-accent-900 transition-colors group-hover:text-primary-700">{event.title}</h3>
                <p class="mt-3 line-clamp-2 text-accent-600">{event.description}</p>
                <div class="mt-6 flex items-center justify-between text-sm">
                  <span class="text-accent-500">{event.confirmedCount ?? 0} / {event.capacity} registered</span>
                  <a href={`/events/${event.slug}`} class="font-semibold text-primary-700 hover:text-primary-900">Learn More →</a>
                </div>
              </article>
            ))
          )}
        </div>
        <div class="mt-10 text-center">
          <a href="/events" class="btn btn-outline btn-lg bg-white">
            <Icon name="mdi:calendar-multiple" class="mr-2 h-5 w-5" />
            View All Events
          </a>
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="container-custom">
        <div class="section-heading mx-auto max-w-3xl text-center">
          <span class="eyebrow mx-auto">News and insights</span>
          <h2>Share practical stories from the alumni community.</h2>
          <p>
            Blog cards now feel more editorial, with cleaner metadata, balanced card widths, and a consistent call to read more.
          </p>
        </div>
        <div class="mt-12 grid gap-6 lg:grid-cols-2">
          {latestBlogPosts.map((post) => (
            <article class="blog-card group overflow-hidden p-0">
              <div class="grid h-full md:grid-cols-[0.95fr_1.05fr]">
                <div class="relative min-h-56 overflow-hidden bg-gradient-to-br from-primary-100 to-accent-100">
                  {post.data.image ? (
                    <img src={post.data.image} alt={post.data.title} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
                  ) : (
                    <div class="flex h-full items-center justify-center">
                      <Icon name="mdi:newspaper-variant-outline" class="h-16 w-16 text-primary-400" />
                    </div>
                  )}
                  <span class="badge badge-secondary absolute left-4 top-4">{post.data.category}</span>
                </div>
                <div class="flex flex-col p-6">
                  <h3 class="text-xl font-bold text-accent-900 transition-colors group-hover:text-primary-700">{post.data.title}</h3>
                  <p class="mt-3 line-clamp-3 text-accent-600">{post.data.description}</p>
                  <div class="mt-6 flex flex-wrap items-center justify-between gap-3 text-sm text-accent-500">
                    <span>{new Date(post.data.publishDate).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}</span>
                    <span>By {post.data.author}</span>
                  </div>
                  <a href={`/blog/${post.slug}`} class="mt-auto pt-6 font-semibold text-primary-700 hover:text-primary-900">Read More →</a>
                </div>
              </div>
            </article>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a href="/blog" class="btn btn-outline btn-lg bg-white">
            <Icon name="mdi:newspaper" class="mr-2 h-5 w-5" />
            View More Posts
          </a>
        </div>
      </div>
    </section>

    <section class="section bg-gradient-to-br from-primary-700 via-primary-600 to-accent-900">
      <div class="container-custom text-center">
        <span class="mx-auto inline-flex items-center rounded-full bg-white/10 px-4 py-2 text-sm font-semibold text-primary-100 ring-1 ring-white/15">Ready to connect?</span>
        <h2 class="mx-auto mt-6 max-w-3xl text-4xl font-black tracking-tight text-white md:text-6xl">Build a stronger alumni network today.</h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-white/80">
          Join the PrepSOM Alumni Portal to discover opportunities, share experiences, and create relationships that continue after graduation.
        </p>
        <div class="mt-9 flex flex-col justify-center gap-4 sm:flex-row">
          <a href="/alumni/register" class="btn btn-secondary btn-lg">
            <Icon name="mdi:account-plus" class="mr-2 h-5 w-5" />
            Sign Up Now
          </a>
          <a href="/about" class="btn btn-outline btn-lg border-white text-white hover:bg-white hover:text-primary-700">
            <Icon name="mdi:information-outline" class="mr-2 h-5 w-5" />
            Learn More
          </a>
        </div>
      </div>
    </section>
  </main>

  <style>
    .home-page :global(.section) {
      scroll-margin-top: 5rem;
    }

    .eyebrow {
      @apply inline-flex items-center gap-2 rounded-full border border-primary-200 bg-primary-50 px-4 py-2 text-sm font-bold uppercase tracking-[0.16em] text-primary-700;
    }

    .section-heading h2,
    .section-heading--left h2 {
      @apply mt-4 text-3xl font-black tracking-tight text-accent-900 md:text-5xl;
    }

    .section-heading p,
    .section-heading--left p {
      @apply mt-5 text-lg leading-8 text-accent-600;
    }

    .feature-card {
      @apply rounded-3xl border border-accent-200 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary-200 hover:shadow-xl;
    }

    .feature-card--tall {
      @apply min-h-[260px];
    }

    .feature-card h3 {
      @apply mt-5 text-xl font-bold text-accent-900;
    }

    .feature-card p {
      @apply mt-3 leading-7 text-accent-600;
    }

    .feature-icon,
    .tool-icon {
      @apply flex h-12 w-12 items-center justify-center rounded-2xl bg-primary-100 text-primary-700;
    }

    .feature-icon--solid {
      @apply bg-primary-600 text-white;
    }

    .tool-row {
      @apply flex gap-4 rounded-2xl border border-accent-100 bg-accent-50 p-4;
    }

    .tool-row h3 {
      @apply font-bold text-accent-900;
    }

    .tool-row p {
      @apply mt-1 text-sm leading-6 text-accent-600;
    }

    .sticky-block {
      @apply lg:sticky lg:top-28;
    }

    .event-card__media {
      @apply relative flex h-48 items-center justify-center rounded-2xl bg-gradient-to-br from-primary-100 via-white to-accent-100;
    }

    .empty-state {
      @apply rounded-3xl border border-dashed border-accent-300 bg-white p-12 text-center text-accent-600;
    }
  </style>
</Layout>
