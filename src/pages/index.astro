      <!-- View All Jobs Button -->
      <div class="text-center">
        <a
          href="/jobs"
          class="inline-flex items-center btn btn-primary btn-lg gap-2"
        >
          <Icon name="mdi:briefcase" class="w-5 h-5" />
          View Job Opportunities
        </a>
        <p class="text-accent-600 text-sm mt-4">
          Browse actuarial positions across the industry
        </p><br/>
      </div>
    </div>
  </section>
      
  <!-- Featured Alumni Section -->
  <section class="section bg-gradient-to-br from-accent-50 to-primary-50">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-accent-900 mb-4">
          Featured Alumni
        </h2>
        <p class="text-xl text-accent-600 max-w-3xl mx-auto">
          Meet some of our outstanding alumni who are making a difference in
          their fields.
        </p>
      </div>

      <div class="grid-responsive mb-12">
        {
          featuredAlumni.map((alum) => (
            <div class="profile-card text-center group">
              <div class="relative mb-6">
                {alum.data.photo ? (
                  <img
                    src={alum.data.photo}
                    alt={alum.data.name}
                    class="profile-avatar group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                ) : (
                  <div class="profile-avatar-placeholder group-hover:scale-105 transition-transform duration-300">
                    {alum.data.name
                      .split(" ")
                      .map((n) => n[0])
                      .join("")
                      .toUpperCase()}
                  </div>
                )}
                <div class="absolute top-0 right-0">
                  <span class="badge badge-primary">{alum.data.faculty}</span>
                </div>
              </div>

              <h3 class="text-xl font-semibold text-accent-900 mb-2">
                {alum.data.name}
              </h3>
              <p class="text-accent-600 mb-4 line-clamp-3">
                {alum.data.short_bio}
              </p>

              <div class="flex items-center justify-center space-x-2 mb-4">
                {alum.data.linkedin && (
                  <a
                    href={alum.data.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent-400 hover:text-primary-600 transition-colors duration-200"
                  >
                    <Icon name="mdi:linkedin" class="w-5 h-5" />
                  </a>
                )}
                {alum.data.twitter && (
                  <a
                    href={alum.data.twitter}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent-400 hover:text-primary-600 transition-colors duration-200"
                  >
                    <Icon name="mdi:twitter" class="w-5 h-5" />
                  </a>
                )}
                {alum.data.github && (
                  <a
                    href={alum.data.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent-400 hover:text-primary-600 transition-colors duration-200"
                  >
                    <Icon name="mdi:github" class="w-5 h-5" />
                  </a>
                )}
              </div>

              <div class="text-sm text-accent-500 mb-4">
                Class of {alum.data.year}
              </div>

              <a
                href={`/alumni/profiles/${alum.data.slug}`}
                class="btn btn-primary btn-sm w-full"
              >
                View Profile
              </a>
            </div>
          ))
        }
      </div>

      <div class="text-center">
        <a href="/alumni/profiles" class="btn btn-outline btn-lg">
          <Icon name="mdi:account-multiple" class="w-6 h-6 mr-2" />
          View More Alumni
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Blog Posts Section -->
  <section class="section">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-accent-900 mb-4">
          Latest News & Insights
        </h2>
        <p class="text-xl text-accent-600 max-w-3xl mx-auto">
          Stay informed with the latest updates, stories, and insights from our
          alumni community.
        </p>
      </div>

      <div class="grid-responsive mb-12">
        {
          latestBlogPosts.map((post) => (
            <div class="blog-card group">
              <div class="relative mb-4">
                {post.data.image ? (
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-48 object-cover rounded-xl group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-48 bg-gradient-to-br from-accent-100 to-primary-100 rounded-xl flex items-center justify-center">
                    <Icon
                      name="mdi:newspaper"
                      class="w-16 h-16 text-accent-400"
                    />
                  </div>
                )}
                <div class="absolute top-4 left-4">
                  <span class="badge badge-secondary">
                    {post.data.category}
                  </span>
                </div>
              </div>

              <h3 class="text-xl font-semibold text-accent-900 mb-2 group-hover:text-primary-600 transition-colors duration-200 line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-accent-600 mb-4 line-clamp-3">
                {post.data.description}
              </p>

              <div class="flex items-center justify-between text-sm text-accent-500 mb-4">
                <span>
                  {new Date(post.data.publishDate).toLocaleDateString("en-US", {
                    month: "long",
                    day: "numeric",
                    year: "numeric",
                  })}
                </span>
                <span>By {post.data.author}</span>
              </div>

              <a
                href={`/blog/${post.slug}`}
                class="text-primary-600 hover:text-primary-700 font-medium"
              >
                Read More →
              </a>
            </div>
          ))
        }
      </div>

      <div class="text-center">
        <a href="/blog" class="btn btn-outline btn-lg">
          <Icon name="mdi:newspaper" class="w-6 h-6 mr-2" />
          View More Posts
        </a>
      </div>
    </div>
  </section>

    <!-- Latest Events Section -->
  <section class="section bg-gradient-to-br from-accent-50 to-secondary-50">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-accent-900 mb-4">
          Events and Webinars
        </h2>
        <p class="text-xl text-accent-600 max-w-3xl mx-auto text-justify">
          Stay updated with the latest events, webinars, workshops, discussions, hackathons, reunions, and networking
          opportunities in our alumni community. Explore upcoming events, register for those that interest you, and connect with fellow alumni. Whether you're looking to learn new skills, catch up with old friends, or just have fun, there's something for everyone in our vibrant event calendar. Don't miss out on the chance to engage with your alumni network and make lasting connections!
      </div>

      <div class="grid-responsive mb-12">
        {
          latestEvents.length === 0 ? (
            <div class="text-center py-12 col-span-3">
              <Icon name="mdi:calendar-blank" class="w-16 h-16 mx-auto text-accent-300 mb-4" />
              <p class="text-accent-600">No upcoming events at the moment. Check back soon!</p>
            </div>
          ) : (
            latestEvents.map((event) => {
              const eventType = event.eventType || '';
              return (
                <div class="event-card group">
                  <div class="relative mb-4">
                    <div class={`w-full h-48 rounded-xl flex items-center justify-center ${
                      eventType === 'ama' ? 'bg-gradient-to-br from-purple-100 to-purple-200' :
                      eventType === 'workshop' ? 'bg-gradient-to-br from-green-100 to-green-200' :
                      'bg-gradient-to-br from-primary-100 to-secondary-100'
                    }`}>
                      <Icon name="mdi:calendar-event" class="w-16 h-16 text-primary-400" />
                    </div>
                    <div class="absolute top-4 right-4">
                      <span class="badge badge-primary">
                        {new Date(event.startTime).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                      </span>
                    </div>
                    <div class="absolute top-4 left-4">
                      <span class="badge badge-secondary uppercase text-xs">{event.eventType}</span>
                    </div>
                  </div>

                  <h3 class="text-xl font-semibold text-accent-900 mb-2 group-hover:text-primary-600 transition-colors duration-200">
                    {event.title}
                  </h3>
                  <p class="text-accent-600 mb-4 line-clamp-2">{event.description}</p>

                  <div class="flex items-center justify-between">
                    <span class="text-sm text-accent-500">
                      {event.confirmedCount ?? 0} / {event.capacity} registered
                    </span>
                    <a href={`/events/${event.slug}`} class="text-primary-600 hover:text-primary-700 font-medium">
                      Learn More →
                    </a>
                  </div>
                </div>
              );
            })
          )
        }
      </div>

      <div class="text-center">
        <a href="/events" class="btn btn-outline btn-lg">
          <Icon name="mdi:calendar-multiple" class="w-6 h-6 mr-2" />
          View All Events
        </a>
      </div>
    </div>
  </section>

  <!-- Call to Action Section -->
  <section class="section bg-gradient-to-br from-primary-600 to-secondary-600">
    <div class="container-custom text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Ready to Connect?
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-3xl mx-auto">
        Join our thriving alumni network and stay connected with your fellow
        graduates. Discover opportunities, share experiences, and build lasting
        relationships.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/alumni"
          class="btn btn-primary btn-lg text-white hover:bg-primary-700 transition-colors duration-200"
        >
          <Icon name="mdi:account-plus" class="w-6 h-6 mr-2" />
          Join the Network
        </a>

        <a
          href="/about"
          class="btn btn-primary btn-lg text-white hover:bg-primary-700 transition-colors duration-200"
        >
          <Icon name="mdi:information" class="w-6 h-6 mr-2" />
          Learn More
        </a>
      </div>
    </div>
  </section>
</Layout>