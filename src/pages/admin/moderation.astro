---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { isAuthenticated, getCurrentUser } from '../../lib/auth';
import { connectToDatabase } from '../../lib/mongodb';
import { formatDate, timeAgo } from '../../utils/date-format';

if (!isAuthenticated(Astro.cookies)) {
  return Astro.redirect('/admin/login');
}

const currentUser = getCurrentUser(Astro.cookies);
const { db } = await connectToDatabase();
const alumniCollection = db.collection('alumni_registrations');
const testimonialsCollection = db.collection('testimonials');

const [flaggedAlumni, deletionRequests, pendingTestimonials] = await Promise.all([
  alumniCollection.find({ is_flagged: true, flag_resolved: { $ne: true } }).sort({ flag_reported_at: -1 }).toArray(),
  alumniCollection.find({ gdpr_deletion_requested: true }).sort({ gdpr_deletion_requested_at: -1 }).toArray(),
  testimonialsCollection.find({ isApproved: false }).sort({ createdAt: -1 }).toArray(),
]);
---

<Layout title="Admin Moderation | Alumni Portal">
  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <a href="/admin/dashboard" class="text-sm font-medium text-primary-700 hover:text-primary-800">Back to dashboard</a>
        <h1 class="mt-2 text-3xl font-bold text-slate-900">Moderation</h1>
        <p class="mt-2 text-slate-600">Review flagged profiles, deletion requests, and pending testimonials.</p>
      </div>
      <div class="rounded-xl bg-slate-100 px-4 py-2 text-sm text-slate-700">Signed in as {currentUser}</div>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-500">Flagged profiles</p>
        <p class="mt-2 text-3xl font-bold text-slate-900">{flaggedAlumni.length}</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-500">Deletion requests</p>
        <p class="mt-2 text-3xl font-bold text-slate-900">{deletionRequests.length}</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-500">Pending testimonials</p>
        <p class="mt-2 text-3xl font-bold text-slate-900">{pendingTestimonials.length}</p>
      </div>
    </div>

    <section class="mt-8 rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-200 px-6 py-4">
        <h2 class="text-xl font-semibold text-slate-900">Flagged alumni profiles</h2>
      </div>
      {flaggedAlumni.length === 0 ? (
        <div class="p-6 text-sm text-slate-600">No flagged profiles at the moment.</div>
      ) : (
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
              <tr>
                <th class="px-6 py-3">Profile</th>
                <th class="px-6 py-3">Reason</th>
                <th class="px-6 py-3">Reported</th>
                <th class="px-6 py-3">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 bg-white">
              {flaggedAlumni.map((entry: any) => (
                <tr>
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      {entry.photo_blob_url ? (
                        <img src={entry.photo_blob_url} alt={entry.name} class="h-12 w-12 rounded-full object-cover" />
                      ) : (
                        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary-100 text-sm font-semibold text-primary-700">
                          {entry.name.split(' ').map((part: string) => part[0]).join('').slice(0, 2).toUpperCase()}
                        </div>
                      )}
                      <div>
                        <p class="font-semibold text-slate-900">{entry.name}</p>
                        <p class="text-sm text-slate-500">{entry.email}</p>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-sm text-slate-700">{entry.flag_reason || 'No reason provided'}</td>
                  <td class="px-6 py-4 text-sm text-slate-500">
                    <div>{entry.flag_reported_at ? formatDate(entry.flag_reported_at) : '—'}</div>
                    <div>{entry.flag_reported_at ? timeAgo(entry.flag_reported_at) : ''}</div>
                  </td>
                  <td class="px-6 py-4">
                    <div class="flex flex-wrap gap-2">
                      <a href={`/alumni/profiles/${entry._id?.toString()}`} class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">View profile</a>
                      <button class="resolve-flag-btn rounded-lg bg-emerald-600 px-3 py-2 text-sm font-semibold text-white hover:bg-emerald-700" data-id={entry._id?.toString()}>Resolve flag</button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>

    <section class="mt-8 rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-200 px-6 py-4">
        <h2 class="text-xl font-semibold text-slate-900">Deletion requests</h2>
      </div>
      {deletionRequests.length === 0 ? (
        <div class="p-6 text-sm text-slate-600">No GDPR deletion requests are pending.</div>
      ) : (
        <div class="divide-y divide-slate-200">
          {deletionRequests.map((entry: any) => (
            <div class="px-6 py-4">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="font-semibold text-slate-900">{entry.name}</p>
                  <p class="text-sm text-slate-500">{entry.email}</p>
                </div>
                <div class="text-sm text-slate-500">{entry.gdpr_deletion_requested_at ? formatDate(entry.gdpr_deletion_requested_at) : '—'}</div>
              </div>
              {entry.gdpr_deletion_request_reason ? <p class="mt-3 text-sm text-slate-700">{entry.gdpr_deletion_request_reason}</p> : null}
            </div>
          ))}
        </div>
      )}
    </section>

    <section class="mt-8 rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-200 px-6 py-4">
        <h2 class="text-xl font-semibold text-slate-900">Testimonials awaiting moderation</h2>
      </div>
      {pendingTestimonials.length === 0 ? (
        <div class="p-6 text-sm text-slate-600">No testimonials are waiting for review.</div>
      ) : (
        <div class="divide-y divide-slate-200">
          {pendingTestimonials.map((item: any) => (
            <div class="px-6 py-5">
              <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div class="max-w-3xl">
                  <div class="flex flex-wrap items-center gap-2">
                    <p class="font-semibold text-slate-900">{item.alumniName}</p>
                    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">{item.category}</span>
                    <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700">Rating {item.rating}/5</span>
                  </div>
                  <p class="mt-3 text-sm leading-6 text-slate-700">{item.content}</p>
                  <p class="mt-3 text-xs text-slate-500">Submitted {item.createdAt ? formatDate(item.createdAt) : '—'}</p>
                </div>
                <div class="flex flex-wrap gap-2">
                  <button class="testimonial-action rounded-lg bg-emerald-600 px-3 py-2 text-sm font-semibold text-white hover:bg-emerald-700" data-action="approve" data-id={item._id?.toString()}>Approve</button>
                  <button class="testimonial-action rounded-lg border border-amber-300 px-3 py-2 text-sm font-semibold text-amber-700 hover:bg-amber-50" data-action="reject" data-id={item._id?.toString()}>Reject</button>
                  <button class="testimonial-action rounded-lg border border-red-300 px-3 py-2 text-sm font-semibold text-red-700 hover:bg-red-50" data-action="delete" data-id={item._id?.toString()}>Delete</button>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </section>
  </main>
</Layout>

<script>
  document.querySelectorAll('.resolve-flag-btn').forEach((button) => {
    button.addEventListener('click', async () => {
      const alumniId = button.getAttribute('data-id');
      if (!alumniId) return;
      try {
        const response = await fetch('/api/admin/flag-profile', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ alumniId, action: 'unflag' }),
        });
        const result = await response.json();
        if (!response.ok || !result.success) {
          throw new Error(result.message || 'Failed to resolve flag.');
        }
        window.location.reload();
      } catch (error) {
        console.error('Resolve flag error:', error);
        window.alert(error instanceof Error ? error.message : 'Failed to resolve flag.');
      }
    });
  });

  document.querySelectorAll('.testimonial-action').forEach((button) => {
    button.addEventListener('click', async () => {
      const testimonialId = button.getAttribute('data-id');
      const action = button.getAttribute('data-action');
      if (!testimonialId || !action) return;

      try {
        const response = await fetch('/api/admin/testimonials', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ testimonialId, action }),
        });
        const result = await response.json();
        if (!response.ok || !result.success) {
          throw new Error(result.message || 'Failed to update testimonial.');
        }
        window.location.reload();
      } catch (error) {
        console.error('Testimonial moderation error:', error);
        window.alert(error instanceof Error ? error.message : 'Failed to update testimonial.');
      }
    });
  });
</script>
