  async function loadAdminPolls(eventId, hostEmail) {
    $('adminPollsList').innerHTML = '<p class="text-gray-400 text-sm">Loading polls…</p>';
    try {
      const res = await fetch(`/api/events/${eventId}/polls?all=true`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const polls = data.polls || [];

      if (polls.length === 0) {
        $('adminPollsList').innerHTML = '<p class="text-gray-400 text-sm">No polls yet. Create one above.</p>';
        return;
      }

      $('adminPollsList').innerHTML = polls.map(poll => {
        const totalVotes = poll.results.reduce((s, r) => s + r.count, 0);
        const optionsHtml = poll.options.map((opt, i) => {
          const count = poll.results[i] ? poll.results[i].count : 0;
          const pct = totalVotes > 0 ? Math.round((count / totalVotes) * 100) : 0;
          return `
            <div class="space-y-1">
              <div class="flex justify-between text-xs">
                <span>${escHtml(opt)}</span>
                <span class="text-gray-500">${count} vote${count !== 1 ? 's' : ''} (${pct}%)</span>
              </div>
              <div class="w-full bg-gray-100 rounded-full h-1.5">
                <div class="bg-indigo-500 h-1.5 rounded-full transition-all" style="width:${pct}%"></div>
              </div>
            </div>`;
        }).join('');

        return `
          <div class="border border-gray-100 rounded-xl p-4 space-y-3">
            <div class="flex justify-between items-start gap-3">
              <p class="font-medium text-sm text-gray-900 flex-1">${escHtml(poll.question)}</p>
              <div class="flex items-center gap-2 shrink-0">
                <label class="relative inline-flex items-center cursor-pointer" title="${poll.isActive ? 'Active — click to deactivate' : 'Inactive — click to activate'}">
                  <input type="checkbox" class="sr-only poll-active-toggle peer" data-poll-id="${escHtml(poll._id)}" ${poll.isActive ? 'checked' : ''} />
                  <div class="w-8 h-4 bg-gray-200 rounded-full peer peer-checked:after:translate-x-4 peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:border after:border-gray-300 after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-indigo-500"></div>
                </label>
                <span class="text-xs text-gray-400">${poll.isActive ? 'Active' : 'Inactive'}</span>
                <button class="poll-delete-btn px-2 py-1 bg-red-50 text-red-700 rounded-lg text-xs font-medium hover:bg-red-100 transition-colors" data-poll-id="${escHtml(poll._id)}">🗑</button>
              </div>
            </div>
            <div class="space-y-2">${optionsHtml}</div>
            <p class="text-xs text-gray-400">${totalVotes} total vote${totalVotes !== 1 ? 's' : ''}</p>
          </div>`;
      }).join('');

      // Toggle active status
      $('adminPollsList').querySelectorAll('.poll-active-toggle').forEach(chk => {
        chk.addEventListener('change', async () => {
          const pollId = chk.dataset.pollId;
          try {
            const res = await fetch(`/api/events/${activeLivePanelEventId}/polls`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ pollId, action: 'toggle', hostEmail: activeLivePanelHostEmail }),
            });
            const d = await res.json();
            if (!res.ok) { chk.checked = !chk.checked; throw new Error(d.message || `HTTP ${res.status}`); }
            await loadAdminPolls(activeLivePanelEventId, activeLivePanelHostEmail);
          } catch (err) {
            alert('Failed to toggle poll: ' + err.message);
          }
        });
      });

      // Delete poll
      $('adminPollsList').querySelectorAll('.poll-delete-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const pollId = btn.dataset.pollId;
          if (!confirm('Delete this poll?')) return;
          try {
            const res = await fetch(`/api/events/${activeLivePanelEventId}/polls`, {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ pollId, hostEmail: activeLivePanelHostEmail }),
            });
            const d = await res.json();
            if (!res.ok) throw new Error(d.message || `HTTP ${res.status}`);
            await loadAdminPolls(activeLivePanelEventId, activeLivePanelHostEmail);
          } catch (err) {
            alert('Failed to delete poll: ' + err.message);
          }
        });
      });

    } catch (e) {
      $('adminPollsList').innerHTML = `<p class="text-red-500 text-sm">Failed to load polls: ${e.message}</p>`;
    }
  }

  // Live tab switching
  document.querySelectorAll('.live-tab').forEach(btn => {
    btn.addEventListener('click', () => showLiveTab(btn.dataset.tab));
  });

  // Refresh Q&A button
  $('refreshQABtn').addEventListener('click', () => {
    if (activeLivePanelEventId) loadAdminQA(activeLivePanelEventId, activeLivePanelHostEmail);
  });

  // Add poll option
  $('addPollOptionBtn').addEventListener('click', () => {
    const container = $('pollOptionsContainer');
    const count = container.querySelectorAll('.poll-option').length;
    if (count >= 6) { alert('Maximum 6 options allowed.'); return; }
    const input = document.createElement('input');
    input.type = 'text';
    input.className = 'poll-option w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300';
    input.placeholder = `Option ${count + 1}`;
    container.appendChild(input);
  });

  // Remove poll option
  $('removePollOptionBtn').addEventListener('click', () => {
    const container = $('pollOptionsContainer');
    const options = container.querySelectorAll('.poll-option');
    if (options.length <= 2) { alert('Minimum 2 options required.'); return; }
    options[options.length - 1].remove();
  });

  // Create poll
  $('createPollBtn').addEventListener('click', async () => {
    if (!activeLivePanelEventId) return;
    const question = $('pollQuestion').value.trim();
    const options = [...$('pollOptionsContainer').querySelectorAll('.poll-option')]
      .map(i => i.value.trim())
      .filter(Boolean);
    const msgEl = $('createPollMsg');

    if (!question) { msgEl.textContent = 'Question is required.'; msgEl.className = 'text-xs text-red-600'; msgEl.classList.remove('hidden'); return; }
    if (options.length < 2) { msgEl.textContent = 'At least 2 options are required.'; msgEl.className = 'text-xs text-red-600'; msgEl.classList.remove('hidden'); return; }

    try {
      $('createPollBtn').disabled = true;
      const res = await fetch(`/api/events/${activeLivePanelEventId}/polls`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question, options, hostEmail: activeLivePanelHostEmail }),
      });
      const d = await res.json();
      if (!res.ok) throw new Error(d.message || `HTTP ${res.status}`);
      // Reset form
      $('pollQuestion').value = '';
      $('pollOptionsContainer').innerHTML = `
        <input type="text" class="poll-option w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="Option 1" />
        <input type="text" class="poll-option w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="Option 2" />
      `;
      msgEl.textContent = 'Poll created!';
      msgEl.className = 'text-xs text-green-600';
      msgEl.classList.remove('hidden');
      setTimeout(() => msgEl.classList.add('hidden'), 3000);
      await loadAdminPolls(activeLivePanelEventId, activeLivePanelHostEmail);
    } catch (err) {
      msgEl.textContent = 'Failed to create poll: ' + err.message;
      msgEl.className = 'text-xs text-red-600';
      msgEl.classList.remove('hidden');
    } finally {
      $('createPollBtn').disabled = false;
    }
  });

  // Close live panel modal
  $('closeLivePanelModal').addEventListener('click', () => { $('livePanelModal').classList.add('hidden'); activeLivePanelEventId = null; activeLivePanelHostEmail = null; });
  $('livePanelModal').addEventListener('click', e => { if (e.target === $('livePanelModal')) { $('livePanelModal').classList.add('hidden'); activeLivePanelEventId = null; activeLivePanelHostEmail = null; } });

  // ── Export CSV ─────────────────────────────────────────────────
  $('exportEventsBtn').addEventListener('click', () => {
    if (filteredEvents.length === 0) { alert('No events to export.'); return; }
    const headers = ['Title', 'Type', 'Status', 'Start Time', 'End Time', 'Capacity', 'Host Email', 'Tags'];
    const rows = filteredEvents.map(ev => [
      `"${(ev.title || '').replace(/"/g, '""')}"`,
      ev.eventType || '',
      ev.status || '',
      ev.startTime ? new Date(ev.startTime).toISOString() : '',
      ev.endTime ? new Date(ev.endTime).toISOString() : '',
      ev.capacity ?? '',
      ev.hostEmail || '',
      `"${(Array.isArray(ev.tags) ? ev.tags.join(', ') : (ev.tags || '')).replace(/"/g, '""')}"`,
    ]);
    const csv = [headers.join(','), ...rows.map(r => r.join(','))].join('\n');
    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `events-${new Date().toISOString().split('T')[0]}.csv`;
    document.body.appendChild(a);
    a.click();
    URL.revokeObjectURL(url);
    document.body.removeChild(a);
  });

  // ── Init ───────────────────────────────────────────────────────
  // Style the active tab on load
  document.querySelector('.filter-tab[data-filter="all"]').classList.add('bg-white', 'text-indigo-700', 'shadow-sm');

  loadEvents();
</script>

</body>
</html>
