---
export const prerender = false;
import { isAuthenticated, getCurrentUser } from '../../lib/auth';
import { connectToDatabase } from '../../lib/mongodb';

if (!isAuthenticated(Astro.cookies)) {
  return Astro.redirect('/admin/login');
}
const currentUser = getCurrentUser(Astro.cookies);
const adminApiKey = import.meta.env.ADMIN_API_KEY || process.env.ADMIN_API_KEY || '';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Events Management | Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">

  <!-- Top Bar -->
  <div class="bg-white shadow-sm mb-0">
    <div class="max-w-7xl mx-auto px-6 py-3 flex justify-between items-center">
      <div class="flex items-center gap-2 text-sm text-gray-600">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
        Logged in as <strong class="ml-1">{currentUser}</strong>
      </div>
      <form action="/api/auth/logout" method="POST">
        <button type="submit" class="flex items-center gap-2 px-4 py-2 bg-red-100 text-red-800 rounded-lg text-sm font-medium hover:bg-red-200 transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
          </svg>
          Logout
        </button>
      </form>
    </div>
  </div>

  <!-- Main -->
  <div class="max-w-7xl mx-auto px-6 py-8">

    <!-- Header + Nav -->
    <div class="flex flex-wrap justify-between items-start gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 flex items-center gap-3">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-indigo-600">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          Events Management
        </h1>
        <p class="text-gray-500 mt-1">Create, manage, and monitor events</p>
      </div>
      <nav class="flex gap-2 flex-wrap">
        <a href="/admin/dashboard" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-500 hover:bg-gray-100 transition-colors">Dashboard</a>
        <a href="/admin/registrations" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-500 hover:bg-gray-100 transition-colors">Registrations</a>
        <a href="/admin/scraper-dashboard" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-500 hover:bg-gray-100 transition-colors">Job Scraper</a>
        <a href="/admin/events" class="px-4 py-2 rounded-lg text-sm font-medium bg-indigo-600 text-white">Events</a>
      </nav>
    </div>

    <!-- Action Bar -->
    <div class="flex flex-wrap gap-3 mb-6 items-center justify-between">
      <div class="flex gap-3 flex-wrap items-center">
        <!-- Search -->
        <input id="searchInput" type="text" placeholder="Search events..." class="px-4 py-2 border border-gray-200 rounded-xl text-sm w-56 focus:outline-none focus:ring-2 focus:ring-indigo-300" />
        <!-- Status filter tabs -->
        <div class="flex gap-1 bg-gray-100 rounded-xl p-1">
          <button data-filter="all" class="filter-tab active-tab px-3 py-1.5 rounded-lg text-xs font-medium transition-colors">All</button>
          <button data-filter="upcoming" class="filter-tab px-3 py-1.5 rounded-lg text-xs font-medium transition-colors text-gray-600 hover:bg-white">Upcoming</button>
          <button data-filter="live" class="filter-tab px-3 py-1.5 rounded-lg text-xs font-medium transition-colors text-gray-600 hover:bg-white">Live</button>
          <button data-filter="ended" class="filter-tab px-3 py-1.5 rounded-lg text-xs font-medium transition-colors text-gray-600 hover:bg-white">Ended</button>
        </div>
        <!-- Type filter -->
        <select id="typeFilter" class="px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
          <option value="">All Types</option>
          <option value="webinar">Webinar</option>
          <option value="ama">AMA</option>
          <option value="networking">Networking</option>
          <option value="workshop">Workshop</option>
        </select>
      </div>
      <div class="flex gap-3">
        <button id="exportEventsBtn" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-xl text-sm font-medium hover:bg-gray-200 transition-colors flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Export CSV
        </button>
        <button id="createEventBtn" class="px-4 py-2 bg-indigo-600 text-white rounded-xl text-sm font-medium hover:bg-indigo-700 transition-colors flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          + Create Event
        </button>
      </div>
    </div>

    <!-- Loading / Error / Events List -->
    <div id="loadingState" class="text-center py-12 text-gray-400">Loading events…</div>
    <div id="errorState" class="hidden text-center py-12 text-red-500"></div>
    <div id="eventsContainer" class="hidden space-y-4"></div>
    <div id="emptyState" class="hidden text-center py-12 text-gray-400">No events found.</div>

  </div>

  <!-- ─────────────────── Create / Edit Modal ─────────────────── -->
  <div id="eventModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-start justify-center p-6 overflow-y-auto">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-2xl my-8">
      <div class="flex justify-between items-center p-6 border-b">
        <h2 id="modalTitle" class="text-xl font-bold text-gray-900">Create Event</h2>
        <button id="closeModal" class="text-gray-400 hover:text-gray-600 transition-colors">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <form id="eventForm" class="p-6 space-y-4 overflow-y-auto max-h-[70vh]">
        <input type="hidden" id="editEventId" value="" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Title <span class="text-red-500">*</span></label>
            <input id="fTitle" type="text" required class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="Event title" />
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
            <textarea id="fDescription" rows="3" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="Event description"></textarea>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Event Type</label>
            <select id="fEventType" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
              <option value="webinar">Webinar</option>
              <option value="ama">AMA</option>
              <option value="networking">Networking</option>
              <option value="workshop">Workshop</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
            <select id="fStatus" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
              <option value="upcoming">Upcoming</option>
              <option value="live">Live</option>
              <option value="ended">Ended</option>
              <option value="cancelled">Cancelled</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Capacity</label>
            <input id="fCapacity" type="number" min="1" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="50" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Host Email</label>
            <input id="fHostEmail" type="email" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="host@example.com" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Host Name</label>
            <input id="fHostName" type="text" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="Dr. Jane Smith" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Start Time <span class="text-red-500">*</span></label>
            <input id="fStartTime" type="datetime-local" required class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">End Time <span class="text-red-500">*</span></label>
            <input id="fEndTime" type="datetime-local" required class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Registration Deadline
              <span class="text-gray-400 font-normal text-xs ml-1">(optional — defaults to event start time)</span>
            </label>
            <input id="fRegistrationDeadline" type="datetime-local" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Venue</label>
            <input id="fVenue" type="text" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="Main Auditorium or Online" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Location</label>
            <input id="fLocation" type="text" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="Address or Remote/Online" />
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Meeting URL</label>
            <input id="fMeetingUrl" type="url" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="https://meet.example.com/..." />
          </div>
          <div class="md:col-span-2 flex items-center gap-3">
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="fMeetingUrlActive" class="sr-only peer" />
              <div class="w-10 h-5 bg-gray-200 peer-focus:ring-2 peer-focus:ring-indigo-300 rounded-full peer peer-checked:after:translate-x-5 peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-indigo-600"></div>
            </label>
            <span class="text-sm font-medium text-gray-700">Activate meeting URL (show join link to attendees)</span>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Banner URL</label>
            <input id="fBannerUrl" type="url" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="https://example.com/banner.jpg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Tags <span class="text-gray-400 text-xs">(comma-separated)</span></label>
            <input id="fTags" type="text" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="career, tech, networking" />
          </div>
          <div id="fCreatedAtRow" class="hidden">
            <label class="block text-sm font-medium text-gray-700 mb-1">Created At <span class="text-gray-400 text-xs">(read-only)</span></label>
            <input id="fCreatedAt" type="text" disabled class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm bg-gray-50 text-gray-500 cursor-not-allowed" />
          </div>

          <!-- Featured Event -->
          <div class="md:col-span-2 flex items-center gap-3">
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="fIsFeatured" class="sr-only peer" />
              <div class="w-10 h-5 bg-gray-200 peer-focus:ring-2 peer-focus:ring-indigo-300 rounded-full peer peer-checked:after:translate-x-5 peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-amber-500"></div>
            </label>
            <span class="text-sm font-medium text-gray-700">⭐ Featured Event (shown with a highlight banner)</span>
          </div>

          <!-- Recurring Event -->
          <div class="md:col-span-2">
            <div class="flex items-center gap-3 mb-3">
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="fIsRecurring" class="sr-only peer" />
                <div class="w-10 h-5 bg-gray-200 peer-focus:ring-2 peer-focus:ring-indigo-300 rounded-full peer peer-checked:after:translate-x-5 peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-indigo-600"></div>
              </label>
              <span class="text-sm font-medium text-gray-700">🔁 Make this a recurring event</span>
            </div>
            <div id="fRecurringOptions" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4 p-4 bg-indigo-50 rounded-xl border border-indigo-100">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Frequency</label>
                <div class="flex gap-4">
                  <label class="flex items-center gap-2 text-sm cursor-pointer">
                    <input type="radio" name="fRecurrenceFreq" id="fFreqWeekly" value="weekly" checked class="accent-indigo-600" />
                    Weekly
                  </label>
                  <label class="flex items-center gap-2 text-sm cursor-pointer">
                    <input type="radio" name="fRecurrenceFreq" id="fFreqMonthly" value="monthly" class="accent-indigo-600" />
                    Monthly
                  </label>
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Interval</label>
                <div class="flex items-center gap-2">
                  <span class="text-sm text-gray-600">Every</span>
                  <input id="fRecurrenceInterval" type="number" min="1" max="52" value="1" class="w-20 px-2 py-1 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
                  <span id="fIntervalUnit" class="text-sm text-gray-600">week(s)</span>
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">End Condition</label>
                <div class="flex gap-4">
                  <label class="flex items-center gap-2 text-sm cursor-pointer">
                    <input type="radio" name="fRecurrenceEnd" id="fEndUntil" value="until" checked class="accent-indigo-600" />
                    Until date
                  </label>
                  <label class="flex items-center gap-2 text-sm cursor-pointer">
                    <input type="radio" name="fRecurrenceEnd" id="fEndOccurrences" value="occurrences" class="accent-indigo-600" />
                    Number of occurrences
                  </label>
                </div>
              </div>
              <div id="fUntilRow">
                <label class="block text-sm font-medium text-gray-700 mb-1">Until Date</label>
                <input id="fRecurrenceUntil" type="date" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
              </div>
              <div id="fOccurrencesRow" class="hidden">
                <label class="block text-sm font-medium text-gray-700 mb-1">Number of Occurrences</label>
                <input id="fRecurrenceOccurrences" type="number" min="2" max="52" value="4" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
              </div>
            </div>
          </div>
        </div>
        <div id="formError" class="hidden text-red-600 text-sm bg-red-50 px-4 py-2 rounded-xl"></div>
        <div class="flex justify-end gap-3 pt-2">
          <button type="button" id="cancelModal" class="px-5 py-2 border border-gray-200 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors">Cancel</button>
          <button type="submit" id="submitEventBtn" class="px-5 py-2 bg-indigo-600 text-white rounded-xl text-sm font-medium hover:bg-indigo-700 transition-colors">Save Event</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ─────────────────── RSVP Panel Modal ─────────────────── -->
  <div id="rsvpModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-start justify-center p-6 overflow-y-auto">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-3xl my-8">
      <div class="flex justify-between items-center p-6 border-b">
        <h2 id="rsvpModalTitle" class="text-xl font-bold text-gray-900">RSVPs</h2>
        <div class="flex items-center gap-2">
          <button id="exportRsvpsCsvBtn" class="px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg text-xs font-medium hover:bg-gray-200 transition-colors flex items-center gap-1.5">
            ⬇ Export CSV
          </button>
          <button id="closeRsvpModal" class="text-gray-400 hover:text-gray-600">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>
      <div id="rsvpContent" class="p-6">
        <!-- Check-in section -->
        <div class="mb-4 p-3 bg-green-50 rounded-xl border border-green-100">
          <p class="text-xs font-semibold text-green-700 mb-2 uppercase tracking-wide">Check In by Email</p>
          <div class="flex gap-2">
            <input id="checkinEmailInput" type="email" placeholder="attendee@example.com" class="flex-1 px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
            <button id="checkinBtn" class="px-4 py-2 bg-green-600 text-white rounded-xl text-sm font-medium hover:bg-green-700 transition-colors whitespace-nowrap">Check In</button>
          </div>
        </div>
        <div id="rsvpStatsSummary" class="mb-4 p-3 bg-indigo-50 rounded-xl border border-indigo-100 hidden"></div>
        <!-- RSVP table -->
        <div id="rsvpTableWrapper" class="overflow-x-auto">
          <p class="text-gray-400 text-sm">Loading RSVPs…</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ─────────────────── Rooms Panel Modal ─────────────────── -->
  <div id="roomsModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-start justify-center p-6 overflow-y-auto">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-4xl my-8">
      <div class="flex justify-between items-center p-6 border-b">
        <h2 id="roomsModalTitle" class="text-xl font-bold text-gray-900">Networking Rooms</h2>
        <button id="closeRoomsModal" class="text-gray-400 hover:text-gray-600">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="p-6">
        <!-- Add Room -->
        <div class="mb-4 flex gap-3">
          <input id="newRoomName" type="text" placeholder="Room name" class="flex-1 px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
          <input id="newRoomTopic" type="text" placeholder="Topic (optional)" class="flex-1 px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
          <button id="createRoomBtn" class="px-4 py-2 bg-indigo-600 text-white rounded-xl text-sm font-medium hover:bg-indigo-700 transition-colors whitespace-nowrap">+ Add Room</button>
        </div>
        <!-- Two-column layout: rooms list + messages -->
        <div class="flex gap-4">
          <div id="roomsList" class="flex-1 min-w-0"><p class="text-gray-400 text-sm">Loading rooms…</p></div>
          <!-- Messages panel (hidden until a room is selected) -->
          <div id="roomMessagesPanel" class="hidden w-72 flex-shrink-0 border-l pl-4">
            <div class="flex justify-between items-center mb-3">
              <h3 id="roomMessagesPanelTitle" class="text-sm font-semibold text-gray-800">Messages</h3>
              <button id="closeMessagesPanel" class="text-xs text-gray-400 hover:text-gray-600">✕ Close</button>
            </div>
            <div id="roomMessagesContent" class="space-y-2 max-h-80 overflow-y-auto text-sm">
              <p class="text-gray-400 text-xs">Loading messages…</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ─────────────────── Live Panel Modal ─────────────────── -->
  <div id="livePanelModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-start justify-center p-6 overflow-y-auto">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-4xl my-8">
      <div class="flex justify-between items-center p-6 border-b">
        <h2 id="livePanelModalTitle" class="text-xl font-bold text-gray-900">Live Panel</h2>
        <button id="closeLivePanelModal" class="text-gray-400 hover:text-gray-600">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="p-6">
        <!-- Tabs -->
        <div class="flex border-b mb-6">
          <button class="live-tab px-4 py-2 text-sm font-medium text-indigo-600 border-b-2 border-indigo-600 -mb-px" data-tab="qa">🎤 Q&amp;A</button>
          <button class="live-tab px-4 py-2 text-sm font-medium text-gray-500 hover:text-gray-700" data-tab="polls">🗳️ Polls</button>
        </div>

        <!-- Q&A Panel -->
        <div id="qaPanel">
          <div class="flex justify-between items-center mb-4">
            <p class="text-sm text-gray-500">Questions sorted by upvotes</p>
            <button id="refreshQABtn" class="px-3 py-1.5 bg-indigo-50 text-indigo-700 rounded-lg text-xs font-medium hover:bg-indigo-100 transition-colors">↻ Refresh</button>
          </div>
          <div id="adminQAList" class="space-y-3">
            <p class="text-gray-400 text-sm">Loading questions…</p>
          </div>
        </div>

        <!-- Polls Panel (hidden by default) -->
        <div id="pollsPanel" class="hidden">
          <!-- Create Poll Form -->
          <div class="mb-6 p-4 bg-gray-50 rounded-xl border border-gray-200">
            <h3 class="text-sm font-semibold text-gray-700 mb-3">Create Poll</h3>
            <div class="space-y-3">
              <input id="pollQuestion" type="text" placeholder="Poll question" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
              <div id="pollOptionsContainer" class="space-y-2">
                <input type="text" class="poll-option w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="Option 1" />
                <input type="text" class="poll-option w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="Option 2" />
              </div>
              <div class="flex gap-2">
                <button id="addPollOptionBtn" class="px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg text-xs font-medium hover:bg-gray-200 transition-colors">+ Add Option</button>
                <button id="removePollOptionBtn" class="px-3 py-1.5 bg-red-50 text-red-700 rounded-lg text-xs font-medium hover:bg-red-100 transition-colors">− Remove Option</button>
              </div>
              <button id="createPollBtn" class="px-4 py-2 bg-indigo-600 text-white rounded-xl text-sm font-medium hover:bg-indigo-700 transition-colors">Create Poll</button>
              <p id="createPollMsg" class="text-xs hidden"></p>
            </div>
          </div>
          <!-- Polls List -->
          <div id="adminPollsList" class="space-y-4">
            <p class="text-gray-400 text-sm">Loading polls…</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ─────────────────── Analytics Modal ─────────────────── -->
  <div id="analyticsModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-start justify-center p-6 overflow-y-auto">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-3xl my-8">
      <div class="flex justify-between items-center p-6 border-b">
        <h2 id="analyticsModalTitle" class="text-xl font-bold text-gray-900">Event Analytics</h2>
        <button id="closeAnalyticsModal" class="text-gray-400 hover:text-gray-600">✕</button>
      </div>
      <div id="analyticsContent" class="p-6">
        <p class="text-gray-400 text-sm">Loading analytics…</p>
      </div>
    </div>
  </div>

<script define:vars={{ adminApiKey }}>
  // ── State ──────────────────────────────────────────────────────
  let allEvents = [];
  let filteredEvents = [];
  let currentStatusFilter = 'all';
  let currentTypeFilter = '';
  let currentSearch = '';
  let activeRsvpEventId = null;
  let activeRoomsEventId = null;
  let activeLivePanelEventId = null;
  let activeLivePanelHostEmail = null;
  let activeAnalyticsEventId = null;

  // ── Helpers ────────────────────────────────────────────────────
  const $ = id => document.getElementById(id);

  function fmtDate(d) {
    if (!d) return '—';
    return new Date(d).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' });
  }

  function escHtml(str) {
    return String(str || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function toLocalDT(d) {
    if (!d) return '';
    const dt = new Date(d);
    const pad = n => String(n).padStart(2, '0');
    return `${dt.getFullYear()}-${pad(dt.getMonth()+1)}-${pad(dt.getDate())}T${pad(dt.getHours())}:${pad(dt.getMinutes())}`;
  }

  const typeBadgeClass = {
    webinar: 'bg-purple-100 text-purple-700',
    ama: 'bg-amber-100 text-amber-700',
    networking: 'bg-teal-100 text-teal-700',
    workshop: 'bg-indigo-100 text-indigo-700',
  };

  const statusBadgeClass = {
    upcoming: 'bg-green-100 text-green-700',
    live: 'bg-blue-100 text-blue-700',
    ended: 'bg-gray-100 text-gray-600',
  };

  // ── Load events ────────────────────────────────────────────────
  async function loadEvents() {
    $('loadingState').classList.remove('hidden');
    $('errorState').classList.add('hidden');
    $('eventsContainer').classList.add('hidden');
    $('emptyState').classList.add('hidden');

    try {
      const res = await fetch('/api/events');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      allEvents = Array.isArray(data) ? data : (data.events || data.data || []);
      applyFilters();
    } catch (e) {
      $('loadingState').classList.add('hidden');
      $('errorState').textContent = 'Failed to load events: ' + e.message;
      $('errorState').classList.remove('hidden');
    }
  }

  function applyFilters() {
    filteredEvents = allEvents.filter(ev => {
      if (currentStatusFilter !== 'all' && ev.status !== currentStatusFilter) return false;
      if (currentTypeFilter && ev.eventType !== currentTypeFilter) return false;
      if (currentSearch) {
        const q = currentSearch.toLowerCase();
        if (!(ev.title || '').toLowerCase().includes(q)) return false;
      }
      return true;
    });
    renderEvents();
  }

  function renderEvents() {
    $('loadingState').classList.add('hidden');
    const container = $('eventsContainer');

    if (filteredEvents.length === 0) {
      container.classList.add('hidden');
      $('emptyState').classList.remove('hidden');
      return;
    }

    $('emptyState').classList.add('hidden');
    container.innerHTML = filteredEvents.map(ev => {
      const typeClass = typeBadgeClass[ev.eventType] || 'bg-gray-100 text-gray-600';
      const statusClass = statusBadgeClass[ev.status] || 'bg-gray-100 text-gray-600';
      const confirmedCount = ev.confirmedCount ?? ev.rsvpCount ?? '—';
      return `
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5" data-event-id="${ev._id}">
        <div class="flex flex-wrap justify-between items-start gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap gap-2 mb-2">
              <span class="px-2.5 py-0.5 rounded-full text-xs font-medium ${typeClass}">${ev.eventType || 'event'}</span>
              <span class="px-2.5 py-0.5 rounded-full text-xs font-medium ${statusClass}">${ev.status || 'upcoming'}</span>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 truncate">${escHtml(ev.title || 'Untitled')}${ev.recurrence ? ' <span title="Recurring event" class="text-base">🔁</span>' : ''}${ev.isFeatured ? ' <span title="Featured event" class="text-base">⭐</span>' : ''}</h3>
            <div class="mt-1 flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-500">
              <span>📅 ${fmtDate(ev.startTime)}</span>
              <span>👥 Capacity: ${ev.capacity ?? '—'}</span>
              <span>✅ RSVPs: ${confirmedCount}</span>
            </div>
          </div>
          <div class="flex flex-wrap gap-2 shrink-0">
            <button class="btn-rsvps px-3 py-1.5 bg-blue-50 text-blue-700 rounded-lg text-xs font-medium hover:bg-blue-100 transition-colors" data-id="${escHtml(ev._id)}" data-title="${escHtml(ev.title)}">View RSVPs</button>
            <button class="btn-analytics px-3 py-1.5 bg-violet-50 text-violet-700 rounded-lg text-xs font-medium hover:bg-violet-100 transition-colors" data-id="${escHtml(ev._id)}" data-title="${escHtml(ev.title)}">📊 Analytics</button>
            <button class="btn-rooms px-3 py-1.5 bg-teal-50 text-teal-700 rounded-lg text-xs font-medium hover:bg-teal-100 transition-colors" data-id="${escHtml(ev._id)}" data-title="${escHtml(ev.title)}">Rooms</button>
            ${ev.status === 'live' ? `<button class="btn-live-panel px-3 py-1.5 bg-red-50 text-red-700 rounded-lg text-xs font-medium hover:bg-red-100 transition-colors" data-id="${escHtml(ev._id)}" data-title="${escHtml(ev.title)}" data-host-email="${escHtml(ev.hostEmail || '')}">🎤 Live Panel</button>` : ''}
            <button class="btn-edit px-3 py-1.5 bg-indigo-50 text-indigo-700 rounded-lg text-xs font-medium hover:bg-indigo-100 transition-colors" data-id="${escHtml(ev._id)}">Edit</button>
            <button class="btn-delete px-3 py-1.5 bg-red-50 text-red-700 rounded-lg text-xs font-medium hover:bg-red-100 transition-colors" data-id="${escHtml(ev._id)}">Delete</button>
          </div>
        </div>
      </div>`;
    }).join('');

    container.classList.remove('hidden');

    // Attach button handlers
    container.querySelectorAll('.btn-edit').forEach(btn => {
      btn.addEventListener('click', () => openEditModal(btn.dataset.id));
    });
    container.querySelectorAll('.btn-delete').forEach(btn => {
      btn.addEventListener('click', () => deleteEvent(btn.dataset.id));
    });
    container.querySelectorAll('.btn-rsvps').forEach(btn => {
      btn.addEventListener('click', () => openRsvpModal(btn.dataset.id, btn.dataset.title));
    });
    container.querySelectorAll('.btn-analytics').forEach(btn => {
      btn.addEventListener('click', () => openAnalyticsModal(btn.dataset.id, btn.dataset.title));
    });
    container.querySelectorAll('.btn-rooms').forEach(btn => {
      btn.addEventListener('click', () => openRoomsModal(btn.dataset.id, btn.dataset.title));
    });
    container.querySelectorAll('.btn-live-panel').forEach(btn => {
      btn.addEventListener('click', () => openLivePanelModal(btn.dataset.id, btn.dataset.title, btn.dataset.hostEmail));
    });
  }

  // ── Filter handlers ────────────────────────────────────────────
  document.querySelectorAll('.filter-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-tab').forEach(b => {
        b.classList.remove('active-tab', 'bg-white', 'text-indigo-700', 'shadow-sm');
        b.classList.add('text-gray-600');
      });
      btn.classList.add('active-tab', 'bg-white', 'text-indigo-700', 'shadow-sm');
      btn.classList.remove('text-gray-600');
      currentStatusFilter = btn.dataset.filter;
      applyFilters();
    });
  });

  $('typeFilter').addEventListener('change', e => {
    currentTypeFilter = e.target.value;
    applyFilters();
  });

  $('searchInput').addEventListener('input', e => {
    currentSearch = e.target.value.trim();
    applyFilters();
  });

  // ── Create / Edit Modal ────────────────────────────────────────
  function openCreateModal() {
    $('modalTitle').textContent = 'Create Event';
    $('editEventId').value = '';
    $('eventForm').reset();
    $('fMeetingUrlActive').checked = false;
    $('fIsFeatured').checked = false;
    $('fIsRecurring').checked = false;
    $('fRecurringOptions').classList.add('hidden');
    $('fCreatedAtRow').classList.add('hidden');
    $('formError').classList.add('hidden');
    $('eventModal').classList.remove('hidden');
  }

  function openEditModal(eventId) {
    const ev = allEvents.find(e => e._id === eventId || String(e._id) === String(eventId));
    if (!ev) return;
    $('modalTitle').textContent = 'Edit Event';
    $('editEventId').value = ev._id;
    $('fTitle').value = ev.title || '';
    $('fDescription').value = ev.description || '';
    $('fEventType').value = ev.eventType || 'webinar';
    $('fStatus').value = ev.status || 'upcoming';
    $('fCapacity').value = ev.capacity || '';
    $('fStartTime').value = toLocalDT(ev.startTime);
    $('fEndTime').value = toLocalDT(ev.endTime);
    if (ev.registrationDeadline) {
      $('fRegistrationDeadline').value = toLocalDT(ev.registrationDeadline);
    } else {
      $('fRegistrationDeadline').value = '';
    }
    $('fVenue').value = ev.venue || '';
    $('fLocation').value = ev.location || '';
    $('fMeetingUrl').value = ev.meetingUrl || '';
    $('fMeetingUrlActive').checked = !!ev.meetingUrlActive;
    $('fBannerUrl').value = ev.bannerUrl || '';
    $('fHostEmail').value = ev.hostEmail || '';
    $('fHostName').value = ev.hostName || '';
    $('fTags').value = Array.isArray(ev.tags) ? ev.tags.join(', ') : (ev.tags || '');
    $('fIsFeatured').checked = !!ev.isFeatured;
    $('fIsRecurring').checked = false;
    $('fRecurringOptions').classList.add('hidden');
    if (ev.createdAt) {
      $('fCreatedAt').value = fmtDate(ev.createdAt);
      $('fCreatedAtRow').classList.remove('hidden');
    } else {
      $('fCreatedAtRow').classList.add('hidden');
    }
    $('formError').classList.add('hidden');
    $('eventModal').classList.remove('hidden');
  }

  function closeModal() {
    $('eventModal').classList.add('hidden');
  }

  $('createEventBtn').addEventListener('click', openCreateModal);
  $('closeModal').addEventListener('click', closeModal);
  $('cancelModal').addEventListener('click', closeModal);
  $('eventModal').addEventListener('click', e => { if (e.target === $('eventModal')) closeModal(); });

  // ── Recurring event toggle ─────────────────────────────────────
  $('fIsRecurring').addEventListener('change', () => {
    $('fRecurringOptions').classList.toggle('hidden', !$('fIsRecurring').checked);
  });

  // Update interval unit label when frequency changes
  document.querySelectorAll('input[name="fRecurrenceFreq"]').forEach(radio => {
    radio.addEventListener('change', () => {
      $('fIntervalUnit').textContent = radio.value === 'weekly' ? 'week(s)' : 'month(s)';
    });
  });

  // Toggle until/occurrences rows
  $('fEndUntil').addEventListener('change', () => {
    $('fUntilRow').classList.remove('hidden');
    $('fOccurrencesRow').classList.add('hidden');
  });
  $('fEndOccurrences').addEventListener('change', () => {
    $('fUntilRow').classList.add('hidden');
    $('fOccurrencesRow').classList.remove('hidden');
  });

  $('eventForm').addEventListener('submit', async e => {
    e.preventDefault();
    const id = $('editEventId').value;
    const isEdit = !!id;

    const tags = $('fTags').value.split(',').map(t => t.trim()).filter(Boolean);
    const isFeatured = $('fIsFeatured').checked;
    const isRecurring = $('fIsRecurring').checked && !id; // only on create

    const payload = {
      title: $('fTitle').value.trim(),
      description: $('fDescription').value.trim(),
      eventType: $('fEventType').value,
      status: $('fStatus').value,
      capacity: parseInt($('fCapacity').value) || undefined,
      startTime: new Date($('fStartTime').value).toISOString(),
      endTime: new Date($('fEndTime').value).toISOString(),
      registrationDeadline: $('fRegistrationDeadline').value ? new Date($('fRegistrationDeadline').value).toISOString() : null,
      venue: $('fVenue').value.trim(),
      location: $('fLocation').value.trim(),
      meetingUrl: $('fMeetingUrl').value.trim(),
      meetingUrlActive: $('fMeetingUrlActive').checked,
      bannerUrl: $('fBannerUrl').value.trim(),
      hostEmail: $('fHostEmail').value.trim(),
      hostName: $('fHostName').value.trim(),
      tags,
      isFeatured,
      ...(isRecurring ? {
        recurrence: {
          frequency: document.querySelector('input[name="fRecurrenceFreq"]:checked').value,
          interval: parseInt($('fRecurrenceInterval').value) || 1,
          ...($('fEndUntil').checked && $('fRecurrenceUntil').value
            ? { until: new Date($('fRecurrenceUntil').value).toISOString() }
            : {}),
          ...($('fEndOccurrences').checked
            ? { occurrences: parseInt($('fRecurrenceOccurrences').value) || 4 }
            : {}),
        }
      } : {}),
    };

    const url = isEdit ? `/api/events/${id}` : '/api/events';
    const method = isEdit ? 'PATCH' : 'POST';

    try {
      $('submitEventBtn').disabled = true;
      $('submitEventBtn').textContent = 'Saving…';
      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);
      closeModal();
      if (data.recurring && data.childEvents) {
        alert(`✅ Recurring event created! ${data.childEvents.length} additional occurrence${data.childEvents.length !== 1 ? 's' : ''} generated.`);
      }
      await loadEvents();
    } catch (err) {
      $('formError').textContent = err.message;
      $('formError').classList.remove('hidden');
    } finally {
      $('submitEventBtn').disabled = false;
      $('submitEventBtn').textContent = 'Save Event';
    }
  });

  // ── Delete ─────────────────────────────────────────────────────
  async function deleteEvent(eventId) {
    if (!confirm('Are you sure you want to delete this event? This cannot be undone.')) return;
    try {
      const res = await fetch(`/api/events/${eventId}`, { method: 'DELETE' });
      if (!res.ok) {
        const d = await res.json().catch(() => ({}));
        throw new Error(d.message || `HTTP ${res.status}`);
      }
      await loadEvents();
    } catch (err) {
      alert('Failed to delete event: ' + err.message);
    }
  }

  // ── RSVP Modal ─────────────────────────────────────────────────
  async function openRsvpModal(eventId, title) {
    activeRsvpEventId = eventId;
    $('rsvpModalTitle').textContent = `RSVPs — ${title}`;
    $('rsvpStatsSummary').classList.add('hidden');
    $('rsvpTableWrapper').innerHTML = '<p class="text-gray-400 text-sm">Loading RSVPs…</p>';
    $('rsvpModal').classList.remove('hidden');
    await loadRsvps(eventId);
  }

  async function loadRsvps(eventId) {
    try {
      const res = await fetch(`/api/events/${eventId}/rsvps`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const rsvps = Array.isArray(data) ? data : (data.rsvps || data.data || []);
      const confirmedCount = rsvps.filter(r => r.rsvpStatus === 'confirmed').length;
      const checkedInCount = rsvps.filter(r => r.rsvpStatus === 'confirmed' && r.checkedIn).length;
      const attendanceRate = confirmedCount > 0
        ? Math.round((checkedInCount / confirmedCount) * 1000) / 10
        : 0;
      $('rsvpStatsSummary').innerHTML = `
        <div class="flex flex-wrap gap-4 text-xs text-indigo-800">
          <span class="font-semibold">Confirmed: ${confirmedCount}</span>
          <span class="font-semibold">Checked In: ${checkedInCount}</span>
          <span class="font-semibold">Attendance Rate: ${attendanceRate.toFixed(1)}%</span>
        </div>
      `;
      $('rsvpStatsSummary').classList.remove('hidden');
      if (rsvps.length === 0) {
        $('rsvpTableWrapper').innerHTML = '<p class="text-gray-400 text-sm">No RSVPs yet.</p>';
        return;
      }
      $('rsvpTableWrapper').innerHTML = `
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-left text-gray-500">
              <th class="pb-2 pr-3 font-medium">Name</th>
              <th class="pb-2 pr-3 font-medium">Email</th>
              <th class="pb-2 pr-3 font-medium">Status</th>
              <th class="pb-2 pr-3 font-medium">Checked In</th>
              <th class="pb-2 pr-3 font-medium">RSVP Time</th>
              <th class="pb-2 font-medium">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            ${rsvps.map(r => `
              <tr data-email="${escHtml(r.userEmail || r.email || '')}">
                <td class="py-2 pr-3">${escHtml(r.userName || r.name || '—')}</td>
                <td class="py-2 pr-3 text-gray-500 text-xs">${escHtml(r.userEmail || r.email || '—')}</td>
                <td class="py-2 pr-3">
                  <select class="rsvp-status-select text-xs border border-gray-200 rounded-lg px-2 py-1 focus:outline-none focus:ring-1 focus:ring-indigo-300" data-email="${escHtml(r.userEmail || r.email || '')}">
                    <option value="confirmed" ${(r.rsvpStatus === 'confirmed') ? 'selected' : ''}>Confirmed</option>
                    <option value="waitlisted" ${(r.rsvpStatus === 'waitlisted') ? 'selected' : ''}>Waitlisted</option>
                    <option value="cancelled" ${(r.rsvpStatus === 'cancelled') ? 'selected' : ''}>Cancelled</option>
                  </select>
                </td>
                <td class="py-2 pr-3">
                  <span class="px-2 py-0.5 rounded-full text-xs font-medium ${r.checkedIn ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-500'}">${r.checkedIn ? '✓ Yes' : 'No'}</span>
                </td>
                <td class="py-2 pr-3 text-gray-500 text-xs">${fmtDate(r.createdAt || r.rsvpTime)}</td>
                <td class="py-2">
                  <div class="flex gap-1">
                    <button class="rsvp-save-status px-2 py-1 bg-indigo-50 text-indigo-700 rounded-lg text-xs font-medium hover:bg-indigo-100 transition-colors" data-email="${escHtml(r.userEmail || r.email || '')}">Save</button>
                    <button class="rsvp-delete px-2 py-1 bg-red-50 text-red-700 rounded-lg text-xs font-medium hover:bg-red-100 transition-colors" data-email="${escHtml(r.userEmail || r.email || '')}">Remove</button>
                  </div>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>`;

      // Attach RSVP action handlers
      $('rsvpTableWrapper').querySelectorAll('.rsvp-save-status').forEach(btn => {
        btn.addEventListener('click', async () => {
          const email = btn.dataset.email;
          const row = btn.closest('tr');
          const select = row.querySelector('.rsvp-status-select');
          const newStatus = select.value;
          try {
            btn.disabled = true;
            btn.textContent = '…';
            const res = await fetch(`/api/events/${activeRsvpEventId}/rsvp`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ userEmail: email, rsvpStatus: newStatus }),
            });
            const d = await res.json();
            if (!res.ok) throw new Error(d.message || `HTTP ${res.status}`);
            btn.textContent = '✓';
            setTimeout(() => { btn.textContent = 'Save'; btn.disabled = false; }, 1200);
          } catch (err) {
            alert('Failed to update status: ' + err.message);
            btn.textContent = 'Save';
            btn.disabled = false;
          }
        });
      });

      $('rsvpTableWrapper').querySelectorAll('.rsvp-delete').forEach(btn => {
        btn.addEventListener('click', async () => {
          const email = btn.dataset.email;
          if (!confirm(`Remove RSVP for ${email}?`)) return;
          try {
            const res = await fetch(`/api/events/${activeRsvpEventId}/rsvp`, {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ userEmail: email }),
            });
            const d = await res.json();
            if (!res.ok) throw new Error(d.message || `HTTP ${res.status}`);
            await loadRsvps(activeRsvpEventId);
          } catch (err) {
            alert('Failed to remove RSVP: ' + err.message);
          }
        });
      });
    } catch (e) {
      $('rsvpStatsSummary').classList.add('hidden');
      $('rsvpTableWrapper').innerHTML = `<p class="text-red-500 text-sm">Failed to load RSVPs: ${e.message}</p>`;
    }
  }

  async function exportRsvpsCsv(eventId) {
    if (!eventId) return;
    try {
      const res = await fetch(`/api/events/${eventId}/rsvps/export`, {
        headers: { 'Authorization': `Bearer ${adminApiKey}` }
      });
      if (!res.ok) {
        const errorText = await res.text().catch(() => '');
        alert(`Export failed (${res.status})${errorText ? `: ${errorText}` : ''}`);
        return;
      }
      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const contentDisposition = res.headers.get('content-disposition') || '';
      const filenameMatch = contentDisposition.match(/filename="([^"]+)"/i);
      const downloadName = filenameMatch?.[1] || `event-attendees-${eventId}-${new Date().toISOString().split('T')[0]}.csv`;
      const a = document.createElement('a');
      a.href = url;
      a.download = downloadName;
      document.body.appendChild(a);
      a.click();
      URL.revokeObjectURL(url);
      a.remove();
    } catch (e) {
      alert('Export error: ' + e.message);
    }
  }

  $('checkinBtn').addEventListener('click', async () => {
    const email = $('checkinEmailInput').value.trim();
    if (!email || !activeRsvpEventId) return;
    try {
      const res = await fetch(`/api/events/${activeRsvpEventId}/checkin`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userEmail: email }),
      });
      const d = await res.json();
      if (!res.ok) throw new Error(d.message || `HTTP ${res.status}`);
      alert('Check-in successful!');
      $('checkinEmailInput').value = '';
      await loadRsvps(activeRsvpEventId);
    } catch (e) {
