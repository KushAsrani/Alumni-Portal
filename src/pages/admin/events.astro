        btn.classList.add('text-indigo-600', 'border-b-2', 'border-indigo-600');
        btn.classList.remove('text-gray-500');
      } else {
        btn.classList.remove('text-indigo-600', 'border-b-2', 'border-indigo-600');
        btn.classList.add('text-gray-500');
      }
    });
    $('qaPanel').classList.toggle('hidden', tab !== 'qa');
    $('pollsPanel').classList.toggle('hidden', tab !== 'polls');
    if (tab === 'polls' && activeLivePanelEventId) {
      loadAdminPolls(activeLivePanelEventId, activeLivePanelHostEmail);
    }
  }

  async function loadAdminQA(eventId, hostEmail) {
    $('adminQAList').innerHTML = '<p class="text-gray-400 text-sm">Loading questions…</p>';
    try {
      const res = await fetch(`/api/events/${eventId}/qa`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const questions = data.questions || [];

      if (questions.length === 0) {
        $('adminQAList').innerHTML = '<p class="text-gray-400 text-sm">No questions yet.</p>';
        return;
      }

      $('adminQAList').innerHTML = questions.map(q => `
        <div class="border border-gray-100 rounded-xl p-4 space-y-2" id="qa-item-${escHtml(q._id)}">
          <div class="flex justify-between items-start gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-medium px-2 py-0.5 bg-gray-100 rounded-full text-gray-600">▲ ${q.upvotes}</span>
                <span class="text-xs text-gray-500">${escHtml(q.isAnonymous ? 'Anonymous' : (q.authorName || q.authorEmail))}</span>
                ${q.answered ? '<span class="text-xs px-2 py-0.5 bg-green-100 text-green-700 rounded-full font-medium">✓ Answered</span>' : ''}
              </div>
              <p class="text-sm text-gray-900">${escHtml(q.text)}</p>
              ${q.answered && q.answer ? `<div class="mt-2 p-2 bg-green-50 rounded-lg border border-green-100"><p class="text-xs text-gray-500 font-medium mb-0.5">Answer:</p><p class="text-sm text-green-800">${escHtml(q.answer)}</p></div>` : ''}
            </div>
            <div class="flex gap-2 shrink-0">
              ${!q.answered ? `<button class="qa-answer-btn px-2 py-1 bg-green-50 text-green-700 rounded-lg text-xs font-medium hover:bg-green-100 transition-colors" data-id="${escHtml(q._id)}">Answer</button>` : ''}
              <button class="qa-delete-btn px-2 py-1 bg-red-50 text-red-700 rounded-lg text-xs font-medium hover:bg-red-100 transition-colors" data-id="${escHtml(q._id)}">🗑</button>
            </div>
          </div>
          <div class="answer-input-area hidden">
            <textarea class="qa-answer-text w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 mt-2" rows="2" placeholder="Type your answer…"></textarea>
            <div class="flex gap-2 mt-2">
              <button class="qa-submit-answer px-3 py-1.5 bg-indigo-600 text-white rounded-lg text-xs font-medium hover:bg-indigo-700 transition-colors" data-id="${escHtml(q._id)}">Submit Answer</button>
              <button class="qa-cancel-answer px-3 py-1.5 bg-gray-100 text-gray-600 rounded-lg text-xs font-medium hover:bg-gray-200 transition-colors">Cancel</button>
            </div>
          </div>
        </div>
      `).join('');

      // Reveal answer input
      $('adminQAList').querySelectorAll('.qa-answer-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const item = document.getElementById(`qa-item-${btn.dataset.id}`);
          if (item) { item.querySelector('.answer-input-area').classList.remove('hidden'); btn.classList.add('hidden'); }
        });
      });

      // Cancel answer input
      $('adminQAList').querySelectorAll('.qa-cancel-answer').forEach(btn => {
        btn.addEventListener('click', () => {
          const area = btn.closest('.answer-input-area');
          area.classList.add('hidden');
          const item = area.closest('[id^="qa-item-"]');
          const answerBtn = item && item.querySelector('.qa-answer-btn');
          if (answerBtn) answerBtn.classList.remove('hidden');
        });
      });

      // Submit answer
      $('adminQAList').querySelectorAll('.qa-submit-answer').forEach(btn => {
        btn.addEventListener('click', async () => {
          const questionId = btn.dataset.id;
          const area = btn.closest('.answer-input-area');
          const answer = area.querySelector('.qa-answer-text').value.trim();
          if (!answer) { alert('Please enter an answer.'); return; }
          try {
            btn.disabled = true;
            btn.textContent = '…';
            const res = await fetch(`/api/events/${activeLivePanelEventId}/qa`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ questionId, action: 'answer', answer, hostEmail: activeLivePanelHostEmail }),
            });
            const d = await res.json();
            if (!res.ok) throw new Error(d.message || `HTTP ${res.status}`);
            await loadAdminQA(activeLivePanelEventId, activeLivePanelHostEmail);
          } catch (err) {
            alert('Failed to submit answer: ' + err.message);
            btn.disabled = false;
