  function renderBreakdownPills(items) {
    if (!items.length) return '<p class="text-xs text-gray-400">No data available.</p>';
    return `<div class="flex flex-wrap gap-2">${items.map(([label, count]) => `
      <span class="px-2.5 py-1 rounded-full bg-gray-100 text-gray-700 text-xs">${escHtml(label)}: <strong>${count}</strong></span>
    `).join('')}</div>`;
  }

  function renderTimelineBars(timeline) {
    if (!timeline.length) return '<p class="text-xs text-gray-400">No confirmed RSVPs yet.</p>';
    const maxCount = Math.max(...timeline.map(item => item.count), 1);
    return `<div class="space-y-2">${timeline.map(item => {
      const width = Math.max(3, Math.round((item.count / maxCount) * 100));
      return `
        <div class="flex items-center gap-3">
          <span class="w-28 text-xs text-gray-500">${escHtml(item.date)}</span>
          <div class="flex-1 bg-gray-100 rounded-full h-2 overflow-hidden">
            <div class="h-2 bg-indigo-500 rounded-full" style="width:${width}%"></div>
          </div>
          <span class="text-xs font-medium text-gray-700 w-8 text-right">${item.count}</span>
        </div>
      `;
    }).join('')}</div>`;
  }

  async function loadAnalytics(eventId) {
    try {
      const res = await fetch(`/api/events/${eventId}/analytics`, {
        headers: { 'Authorization': `Bearer ${adminApiKey}` }
      });
      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.message || `HTTP ${res.status}`);

      const analytics = data.analytics || {};
      const facultyItems = Object.entries(analytics.facultyBreakdown || {}).sort((a, b) => b[1] - a[1]);
      const activityItems = Object.entries(analytics.activityBreakdown || {}).sort((a, b) => b[1] - a[1]);
      const yearItems = Object.entries(analytics.graduationYearBreakdown || {}).sort((a, b) => Number(a[0]) - Number(b[0]));
      const timeline = Array.isArray(analytics.rsvpTimeline) ? analytics.rsvpTimeline : [];

      $('analyticsContent').innerHTML = `
        <div class="space-y-6">
          <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
            <div class="bg-indigo-50 rounded-xl p-4 text-center"><p class="text-xs text-indigo-700">Confirmed</p><p class="text-lg font-bold text-indigo-900">${analytics.confirmedCount ?? 0}</p></div>
            <div class="bg-indigo-50 rounded-xl p-4 text-center"><p class="text-xs text-indigo-700">Waitlisted</p><p class="text-lg font-bold text-indigo-900">${analytics.waitlistCount ?? 0}</p></div>
            <div class="bg-indigo-50 rounded-xl p-4 text-center"><p class="text-xs text-indigo-700">Checked-In</p><p class="text-lg font-bold text-indigo-900">${analytics.checkedInCount ?? 0}</p></div>
            <div class="bg-indigo-50 rounded-xl p-4 text-center"><p class="text-xs text-indigo-700">Attendance Rate</p><p class="text-lg font-bold text-indigo-900">${analytics.attendanceRate ?? 0}%</p></div>
            <div class="bg-indigo-50 rounded-xl p-4 text-center"><p class="text-xs text-indigo-700">Total Guests</p><p class="text-lg font-bold text-indigo-900">${analytics.totalGuestCount ?? 0}</p></div>
          </div>

          <div class="border border-gray-100 rounded-xl p-4">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">RSVP Trend (daily confirmed sign-ups)</h3>
            ${renderTimelineBars(timeline)}
          </div>

          <div class="grid md:grid-cols-3 gap-4">
            <div class="border border-gray-100 rounded-xl p-4">
              <h3 class="text-sm font-semibold text-gray-900 mb-3">Faculty Breakdown</h3>
              ${renderBreakdownPills(facultyItems)}
            </div>
            <div class="border border-gray-100 rounded-xl p-4">
              <h3 class="text-sm font-semibold text-gray-900 mb-3">Activity Preferences</h3>
              ${renderBreakdownPills(activityItems)}
            </div>
            <div class="border border-gray-100 rounded-xl p-4">
              <h3 class="text-sm font-semibold text-gray-900 mb-3">Graduation Year Breakdown</h3>
              ${renderBreakdownPills(yearItems)}
            </div>
          </div>
        </div>
      `;
    } catch (e) {
      $('analyticsContent').innerHTML = `<p class="text-red-500 text-sm">Failed to load analytics: ${escHtml(e.message)}</p>`;
    }
  }

  $('closeAnalyticsModal').addEventListener('click', () => { $('analyticsModal').classList.add('hidden'); activeAnalyticsEventId = null; });
  $('analyticsModal').addEventListener('click', e => { if (e.target === $('analyticsModal')) { $('analyticsModal').classList.add('hidden'); activeAnalyticsEventId = null; } });

