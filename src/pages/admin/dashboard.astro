  .stat-yellow .stat-icon { background: #fffbeb; color: #f59e0b; }
  .stat-green  .stat-icon { background: #ecfdf5; color: #10b981; }
  .stat-purple .stat-icon { background: #f5f3ff; color: #8b5cf6; }

  .stat-label {
