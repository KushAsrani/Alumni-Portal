    .bottom-grid {
      grid-template-columns: 1fr;
    }
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .section-header h2 {
    margin: 0;
  }

  .view-all-link {
    font-size: 0.875rem;
    color: #4f46e5;
    text-decoration: none;
    font-weight: 500;
  }

  .view-all-link:hover {
    text-decoration: underline;
  }

  /* Table */
