---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { isAuthenticated, getCurrentUser } from '../../lib/auth';
import { connectToDatabase } from '../../lib/mongodb';

if (!isAuthenticated(Astro.cookies)) {
  return Astro.redirect('/admin/login');
}

const currentUser = getCurrentUser(Astro.cookies);
const adminApiKey = import.meta.env.ADMIN_API_KEY || process.env.ADMIN_API_KEY || '';

// --- Fetch stats from MongoDB ---
let alumniStats = { total: 0, pending: 0, approved: 0, rejected: 0 };
let eventStats = { total: 0, upcoming: 0, live: 0, ended: 0 };
let rsvpStats = { total: 0, confirmed: 0, waitlisted: 0 };
let recentRegistrations: any[] = [];
let upcomingEvents: any[] = [];

try {
  const { db } = await connectToDatabase();

  // Alumni stats
  const alumniCol = db.collection('alumni_registrations');
  const [alumniTotal, alumniPending, alumniApproved, alumniRejected] = await Promise.all([
    alumniCol.countDocuments({}),
    alumniCol.countDocuments({ status: 'pending' }),
    alumniCol.countDocuments({ status: 'approved' }),
    alumniCol.countDocuments({ status: 'rejected' }),
  ]);
  alumniStats = { total: alumniTotal, pending: alumniPending, approved: alumniApproved, rejected: alumniRejected };

  // Events stats
  const eventsCol = db.collection('events');
  const [eventsTotal, eventsUpcoming, eventsLive, eventsEnded] = await Promise.all([
    eventsCol.countDocuments({}),
    eventsCol.countDocuments({ status: 'upcoming' }),
    eventsCol.countDocuments({ status: 'live' }),
    eventsCol.countDocuments({ status: 'ended' }),
  ]);
  eventStats = { total: eventsTotal, upcoming: eventsUpcoming, live: eventsLive, ended: eventsEnded };

  // RSVP stats
  const rsvpCol = db.collection('event_rsvps');
  const [rsvpTotal, rsvpConfirmed, rsvpWaitlisted] = await Promise.all([
    rsvpCol.countDocuments({}),
    rsvpCol.countDocuments({ rsvpStatus: 'confirmed' }),
    rsvpCol.countDocuments({ rsvpStatus: 'waitlisted' }),
  ]);
  rsvpStats = { total: rsvpTotal, confirmed: rsvpConfirmed, waitlisted: rsvpWaitlisted };

  // Recent registrations (last 5)
  recentRegistrations = await alumniCol
    .find({})
    .sort({ created_at: -1 })
    .limit(5)
    .project({ name: 1, email: 1, faculty: 1, status: 1, created_at: 1 })
    .toArray();

  // Upcoming events (next 3)
  upcomingEvents = await eventsCol
    .find({ status: 'upcoming', startTime: { $gte: new Date() } })
    .sort({ startTime: 1 })
    .limit(3)
    .project({ title: 1, startTime: 1, eventType: 1, capacity: 1, slug: 1 })
    .toArray();
} catch (err) {
  console.error('Dashboard data fetch error:', err);
}

function formatDate(date: Date | string | undefined) {
  if (!date) return 'N/A';
  return new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<Layout title="Admin Dashboard | Alumni Portal">
  <main class="dashboard-page">
    <div class="container">

      <!-- Top Bar -->
      <div class="top-bar">
        <div class="user-info">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
          <span>Logged in as <strong>{currentUser}</strong></span>
        </div>
        <form action="/api/auth/logout" method="POST" style="display: inline;">
          <button type="submit" class="logout-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
              <polyline points="16 17 21 12 16 7"></polyline>
              <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
            Logout
          </button>
        </form>
      </div>

      <!-- Dashboard Header -->
      <header class="dashboard-header">
        <div>
          <h1>
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="7" height="7"></rect>
              <rect x="14" y="3" width="7" height="7"></rect>
              <rect x="14" y="14" width="7" height="7"></rect>
              <rect x="3" y="14" width="7" height="7"></rect>
            </svg>
            Admin Dashboard
          </h1>
          <p>Welcome back, {currentUser}</p>
        </div>
        <!-- Navigation -->
        <nav class="dashboard-nav">
          <a href="/admin/dashboard" class="nav-link active">Dashboard</a>
          <a href="/admin/registrations" class="nav-link">Registrations</a>
          <a href="/admin/scraper-dashboard" class="nav-link">Job Scraper</a>
          <a href="/admin/events" class="nav-link">Events</a>
        </nav>
      </header>

      <!-- Stats Grid -->
      <section class="stats-section">
        <div class="stats-grid">
          <!-- Total Alumni -->
          <div class="stat-card stat-blue">
            <div class="stat-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
            </div>
            <div class="stat-content">
              <p class="stat-label">Total Alumni</p>
              <p class="stat-value">{alumniStats.total}</p>
              <p class="stat-sub">{alumniStats.approved} approved · {alumniStats.pending} pending</p>
            </div>
          </div>

          <!-- Pending Approvals -->
          <div class="stat-card stat-yellow">
            <div class="stat-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <div class="stat-content">
              <p class="stat-label">Pending Approvals</p>
              <p class="stat-value">{alumniStats.pending}</p>
              <p class="stat-sub">{alumniStats.rejected} rejected</p>
            </div>
          </div>

          <!-- Upcoming Events -->
          <div class="stat-card stat-green">
            <div class="stat-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
            </div>
            <div class="stat-content">
              <p class="stat-label">Upcoming Events</p>
              <p class="stat-value">{eventStats.upcoming}</p>
              <p class="stat-sub">{eventStats.live} live · {eventStats.total} total</p>
            </div>
          </div>

          <!-- Total RSVPs -->
          <div class="stat-card stat-purple">
            <div class="stat-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
            </div>
            <div class="stat-content">
              <p class="stat-label">Total RSVPs</p>
              <p class="stat-value">{rsvpStats.total}</p>
              <p class="stat-sub">{rsvpStats.confirmed} confirmed · {rsvpStats.waitlisted} waitlisted</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Quick Actions -->
      <section class="actions-section">
        <div class="section-card">
          <h2>Quick Actions</h2>
          <div class="actions-grid">
            <a href="/admin/registrations" class="action-card action-blue">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
              <span>Manage Registrations</span>
              {alumniStats.pending > 0 && (
                <span class="action-badge">{alumniStats.pending}</span>
              )}
            </a>

            <a href="/admin/scraper-dashboard" class="action-card action-indigo">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
              </svg>
              <span>Job Scraper</span>
            </a>

            <a href="/admin/events" class="action-card action-green">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              <span>View All Events</span>
            </a>

            <button id="exportCsvBtn" class="action-card action-gray" style="border:none;cursor:pointer;text-align:center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              <span>Export CSV</span>
            </button>
          </div>
        </div>
      </section>

      <!-- Bottom Grid: Recent Registrations + Upcoming Events -->
      <div class="bottom-grid">

        <!-- Recent Registrations -->
        <section class="section-card">
          <div class="section-header">
            <h2>Recent Registrations</h2>
            <a href="/admin/registrations" class="view-all-link">View all →</a>
          </div>
          {recentRegistrations.length === 0 ? (
            <p class="empty-state">No registrations yet.</p>
          ) : (
            <div class="table-wrapper">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Faculty</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  {recentRegistrations.map(reg => (
                    <tr>
                      <td class="font-medium">{reg.name}</td>
                      <td class="text-muted">{reg.email}</td>
                      <td class="text-muted">{reg.faculty || '—'}</td>
                      <td>
                        <span class={`status-badge status-${reg.status}`}>
                          {reg.status}
                        </span>
                      </td>
                      <td class="text-muted">{formatDate(reg.created_at)}</td>
                      <td>
                        <a href="/admin/registrations" class="table-link">View</a>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </section>

        <!-- Upcoming Events -->
        <section class="section-card">
          <div class="section-header">
            <h2>Upcoming Events</h2>
            <a href="/admin/events" class="view-all-link">View all →</a>
          </div>
          {upcomingEvents.length === 0 ? (
            <p class="empty-state">No upcoming events scheduled.</p>
          ) : (
            <div class="events-list">
              {upcomingEvents.map(event => (
                <div class="event-item">
                  <div class="event-meta">
                    <span class={`event-type-badge type-${event.eventType}`}>
                      {event.eventType}
                    </span>
                    <span class="event-date">{formatDate(event.startTime)}</span>
                  </div>
                  <p class="event-title">{event.title}</p>
                  <p class="event-capacity">Capacity: {event.capacity}</p>
                </div>
              ))}
            </div>
          )}
        </section>

      </div>

      <!-- Footer -->
      <footer class="dashboard-footer">
        Alumni Portal Admin · Logged in as {currentUser}
      </footer>

    </div>
  </main>
</Layout>

<script define:vars={{ adminApiKey }}>
  document.getElementById('exportCsvBtn')?.addEventListener('click', async () => {
    try {
      const response = await fetch('/api/export-csv', {
        headers: {
          'Authorization': `Bearer ${adminApiKey}`
        }
      });

      if (response.ok) {
        const blob = await response.blob();
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `alumni-registrations-${new Date().toISOString().split('T')[0]}.csv`;
        document.body.appendChild(a);
        a.click();
        window.URL.revokeObjectURL(url);
        document.body.removeChild(a);
      } else {
        alert('Failed to export CSV. Please try again.');
      }
    } catch (error) {
      alert('Error exporting CSV: ' + error.message);
    }
  });
</script>

<style>
