<script>
  /* Auto-submit form when filter changes
  const filterForm = document.getElementById('filter-form') as HTMLFormElement;
  const filterSelects = filterForm?.querySelectorAll('select, input[type="checkbox"]');

  filterSelects?.forEach(element => {
    element.addEventListener('change', () => {
      filterForm?.submit();
    });
  });
  */

  // Skills filter
  const dropdown = document.getElementById('skills-dropdown');
  const selected = document.getElementById('skills-selected');
  const options = dropdown.querySelector('.dropdown-options');

// Function to update the dropdown text
function updateSelectedSkills() {
  const selectedOptions = Array.from(
    options.querySelectorAll('input[type="checkbox"]:checked')
  ).map((checkbox) => checkbox.value);

  // Update the text content
  selected.textContent = selectedOptions.length
    ? `Skills selected: ${selectedOptions.join(', ')}`
    : 'Select Skills';

  // Add the dropdown icon back to the text content
  const dropdownIcon = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
  dropdownIcon.setAttribute('class', 'dropdown-icon');
  dropdownIcon.setAttribute('width', '16');
  dropdownIcon.setAttribute('height', '16');
  dropdownIcon.setAttribute('viewBox', '0 0 24 24');
  dropdownIcon.setAttribute('fill', 'none');
  dropdownIcon.setAttribute('stroke', 'currentColor');
  dropdownIcon.setAttribute('stroke-width', '3');

  const polyline = document.createElementNS('http://www.w3.org/2000/svg', 'polyline');
  polyline.setAttribute('points', '6 9 12 15 18 9');
  dropdownIcon.appendChild(polyline);

  selected.appendChild(dropdownIcon);
}

// Update the dropdown text on page load
updateSelectedSkills();

  // Toggle dropdown open/close
  dropdown.addEventListener('click', (e) => {
    e.stopPropagation();
    dropdown.classList.toggle('open');
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', () => {
    dropdown.classList.remove('open');
  });

  // Update the dropdown text dynamically when checkboxes are changed
  options.addEventListener('change', updateSelectedSkills);

  options.addEventListener('change', () => {
    const selectedOptions = Array.from(
      options.querySelectorAll('input[type="checkbox"]:checked')
    ).map((checkbox) => checkbox.value);
    selected.textContent = selectedOptions.length
      ? selectedOptions.join(', ')
      : 'Select Skills';
  });

  // Pagination handling
  const paginationButtons = document.querySelectorAll('[data-page]');
  paginationButtons?.forEach(button => {
    button.addEventListener('click', () => {
      const page = button.getAttribute('data-page');
      const url = new URL(window.location.href);
      url.searchParams.set('page', page || '1');
      window.location.href = url.toString();
    });
  });
</script>