<script>
  /* Auto-submit form when filter changes
  const filterForm = document.getElementById('filter-form') as HTMLFormElement;
  const filterSelects = filterForm?.querySelectorAll('select, input[type="checkbox"]');

  filterSelects?.forEach(element => {
    element.addEventListener('change', () => {
      filterForm?.submit();
    });
  });
  */

  // Skills filter
  const dropdown = document.getElementById('skills-dropdown');
  const selected = document.getElementById('skills-selected');
  const options = dropdown.querySelector('.dropdown-options');

// Function to update the dropdown text
function updateSelectedSkills() {
  const selectedOptions = Array.from(
    options.querySelectorAll('input[type="checkbox"]:checked')
  ).map((checkbox) => checkbox.value);

  // Update the text content
  selected.textContent = selectedOptions.length
    ? `Skills selected: ${selectedOptions.join(', ')}`
    : 'Select Skills';

  // Add the dropdown icon back to the text content
  const dropdownIcon = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
  dropdownIcon.setAttribute('class', 'dropdown-icon');
  dropdownIcon.setAttribute('width', '16');
  dropdownIcon.setAttribute('height', '16');
  dropdownIcon.setAttribute('viewBox', '0 0 24 24');
  dropdownIcon.setAttribute('fill', 'none');
  dropdownIcon.setAttribute('stroke', 'currentColor');
  dropdownIcon.setAttribute('stroke-width', '3');

  const polyline = document.createElementNS('http://www.w3.org/2000/svg', 'polyline');
  polyline.setAttribute('points', '6 9 12 15 18 9');
  dropdownIcon.appendChild(polyline);

  selected.appendChild(dropdownIcon);
}

// Update the dropdown text on page load
updateSelectedSkills();

  // Toggle dropdown open/close
  dropdown.addEventListener('click', (e) => {
    e.stopPropagation();
    dropdown.classList.toggle('open');
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', () => {
    dropdown.classList.remove('open');
  });

  // Update the dropdown text dynamically when checkboxes are changed
  options.addEventListener('change', updateSelectedSkills);

  options.addEventListener('change', () => {
    const selectedOptions = Array.from(
      options.querySelectorAll('input[type="checkbox"]:checked')
    ).map((checkbox) => checkbox.value);
    selected.textContent = selectedOptions.length
      ? selectedOptions.join(', ')
      : 'Select Skills';
  });

  // Pagination handling
  const paginationButtons = document.querySelectorAll('[data-page]');
  paginationButtons?.forEach(button => {
    button.addEventListener('click', () => {
      const page = button.getAttribute('data-page');
      const url = new URL(window.location.href);
      url.searchParams.set('page', page || '1');
      window.location.href = url.toString();
    });
  });

  // =========================================================
  // Resume Analyzer Widget
  // =========================================================

  (function () {
    // ----- Auth check -----
    const authGate = document.getElementById('resume-auth-gate');
    const uploadForm = document.getElementById('resume-upload-form');
    const raEmailInput = document.getElementById('ra-alumni-email');

    async function checkSession() {
      try {
        // First check auth status
        const res = await fetch('/api/auth/alumni-session');
        const data = await res.json();
        if (data.authenticated) {
          authGate.style.display = 'none';
          uploadForm.style.display = '';
          // Fetch full profile to get email
          try {
            const meRes = await fetch('/api/alumni/me');
            const meData = await meRes.json();
            if (meData.success && meData.data) {
              const email = meData.data.email || meData.data.username || '';
              // Pre-fill and lock the analyze email field
              if (raEmailInput && email) {
                raEmailInput.value = email;
                raEmailInput.readOnly = true;
                raEmailInput.style.backgroundColor = '#f3f4f6';
                raEmailInput.style.cursor = 'not-allowed';
                // Add note below the field if not already present
                if (!document.getElementById('ra-email-note')) {
                  const note = document.createElement('p');
                  note.id = 'ra-email-note';
                  note.style.cssText = 'font-size:0.75rem;color:#6b7280;margin:0.25rem 0 0;';
                  note.textContent = 'Using your account email';
                  raEmailInput.parentNode.appendChild(note);
                }
              }
              // Pre-fill the history email field
              const histEmailEl = document.getElementById('ra-history-email');
              if (histEmailEl && email) {
                histEmailEl.value = email;
                histEmailEl.readOnly = true;
                histEmailEl.style.backgroundColor = '#f3f4f6';
                histEmailEl.style.cursor = 'not-allowed';
              }
            }
          } catch {
            // Profile fetch failed — fall back to username from session
            const username = data.data && data.data.username;
            if (username && username.includes('@') && raEmailInput) {
              raEmailInput.value = username;
            }
            const histEmailEl = document.getElementById('ra-history-email');
            if (username && username.includes('@') && histEmailEl) {
              histEmailEl.value = username;
            }
          }
        } else {
          authGate.style.display = '';
          uploadForm.style.display = 'none';
        }
      } catch {
        // If session check fails, show gate (safe default)
        authGate.style.display = '';
        uploadForm.style.display = 'none';
      }
    }

    checkSession();

    // ----- Tab switching -----
    const tabAnalyze = document.getElementById('ra-tab-analyze');
    const tabHistory = document.getElementById('ra-tab-history');
    const panelAnalyze = document.getElementById('ra-panel-analyze');
    const panelHistory = document.getElementById('ra-panel-history');

    function switchRaTab(tab) {
      if (tab === 'analyze') {
        tabAnalyze.classList.add('ra-tab-btn--active');
        tabHistory.classList.remove('ra-tab-btn--active');
        panelAnalyze.style.display = '';
        panelHistory.style.display = 'none';
      } else {
        tabHistory.classList.add('ra-tab-btn--active');
        tabAnalyze.classList.remove('ra-tab-btn--active');
        panelHistory.style.display = '';
        panelAnalyze.style.display = 'none';
      }
    }

    tabAnalyze.addEventListener('click', () => switchRaTab('analyze'));
    tabHistory.addEventListener('click', () => {
      switchRaTab('history');
      // Auto-load if email is already filled
      const histEmail = document.getElementById('ra-history-email');
      if (histEmail && histEmail.value.trim()) {
        loadHistory(histEmail.value.trim());
      }
    });

    // ----- Drag-and-drop -----
    const dropZone = document.getElementById('ra-drop-zone');
    const fileInput = document.getElementById('ra-resume-file');
    const fileNameDisplay = document.getElementById('ra-file-name-display');
    const filePreviewRow = document.getElementById('ra-file-preview-row');
    const filePreviewName = document.getElementById('ra-file-preview-name');
    const filePreviewSize = document.getElementById('ra-file-preview-size');
    const viewResumeLocalBtn = document.getElementById('ra-view-resume-btn-local');
    const removeFileBtn = document.getElementById('ra-remove-file-btn');

    let localFileObjectUrl = null;

    function formatBytes(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / 1048576).toFixed(1) + ' MB';
    }

    function showFilePreview(file) {
      filePreviewName.textContent = file.name;
      filePreviewSize.textContent = formatBytes(file.size);
      filePreviewRow.style.display = 'flex';
      fileNameDisplay.textContent = file.name;
      if (localFileObjectUrl) URL.revokeObjectURL(localFileObjectUrl);
      localFileObjectUrl = URL.createObjectURL(file);
    }

    function clearFilePreview() {
      filePreviewRow.style.display = 'none';
      fileNameDisplay.textContent = 'Accepts .pdf and .docx';
      filePreviewName.textContent = '';
      filePreviewSize.textContent = '';
      if (localFileObjectUrl) { URL.revokeObjectURL(localFileObjectUrl); localFileObjectUrl = null; }
    }

    dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('drag-over'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
      const files = e.dataTransfer && e.dataTransfer.files;
      if (files && files.length > 0) {
        fileInput.files = files;
        showFilePreview(files[0]);
      }
    });

    fileInput.addEventListener('change', () => {
      if (fileInput.files && fileInput.files.length > 0) {
        showFilePreview(fileInput.files[0]);
      }
    });

    viewResumeLocalBtn.addEventListener('click', () => {
      if (localFileObjectUrl) window.open(localFileObjectUrl, '_blank', 'noopener');
    });

    removeFileBtn.addEventListener('click', () => {
      fileInput.value = '';
      clearFilePreview();
    });

    // ----- Score helpers -----
    function raScoreClass(score) {
      if (score >= 75) return 'ra-score-green';
      if (score >= 50) return 'ra-score-amber';
      return 'ra-score-red';
    }

    function raTextClass(score) {
      if (score >= 75) return 'ra-text-green';
      if (score >= 50) return 'ra-text-amber';
      return 'ra-text-red';
    }

    function raGaugeColor(score) {
      if (score >= 75) return '#22c55e';
      if (score >= 50) return '#f59e0b';
      return '#ef4444';
    }

    // ----- Progress bar -----
    let progressInterval = null;

    function startProgress() {
      const wrap = document.getElementById('ra-upload-progress-wrap');
      const bar = document.getElementById('ra-upload-progress-bar');
      const text = document.getElementById('ra-upload-progress-text');
      const pct = document.getElementById('ra-upload-progress-pct');

      wrap.style.display = '';
      bar.style.width = '0%';
      pct.textContent = '0%';
      text.textContent = 'Uploading resume…';

      let current = 0;

      function animateTo(target, label, duration) {
        const steps = 20;
        const stepTime = duration / steps;
        const stepSize = (target - current) / steps;
        let step = 0;
        return new Promise((resolve) => {
          const iv = setInterval(() => {
            step++;
            current = Math.min(current + stepSize, target);
            bar.style.width = current + '%';
            pct.textContent = Math.round(current) + '%';
            text.textContent = label;
            if (step >= steps) { clearInterval(iv); resolve(); }
          }, stepTime);
          progressInterval = iv;
        });
      }

      // Run stages sequentially
      animateTo(30, 'Uploading resume…', 1000)
        .then(() => animateTo(60, 'Analyzing with AI…', 1000))
        .then(() => animateTo(90, 'Matching against job listings…', 2000));
    }

    function completeProgress() {
      if (progressInterval) { clearInterval(progressInterval); progressInterval = null; }
      const bar = document.getElementById('ra-upload-progress-bar');
      const text = document.getElementById('ra-upload-progress-text');
      const pct = document.getElementById('ra-upload-progress-pct');
      bar.style.width = '100%';
      pct.textContent = '100%';
      text.textContent = 'Complete!';
      setTimeout(() => {
        document.getElementById('ra-upload-progress-wrap').style.display = 'none';
      }, 1200);
    }

    function resetProgress() {
      if (progressInterval) { clearInterval(progressInterval); progressInterval = null; }
      document.getElementById('ra-upload-progress-wrap').style.display = 'none';
    }

    // ----- Render results -----
    function renderRaResults(data) {
      document.getElementById('ra-results-section').style.display = '';

      const ats = data.ats || {};
      const score = ats.score || 0;

      // Circular gauge
      const circ = 314;
      const dashFilled = (score / 100) * circ;
      const arc = document.getElementById('ra-ats-arc');
      arc.setAttribute('stroke-dasharray', `${dashFilled} ${circ - dashFilled}`);
      arc.style.stroke = raGaugeColor(score);

      const scoreVal = document.getElementById('ra-ats-score-value');
      scoreVal.textContent = score;
      scoreVal.className = `ra-ats-gauge__score ${raTextClass(score)}`;

      // Breakdown bars
      const maxPts = { contact_info: 15, sections: 20, bullet_points: 15, length: 15, keywords_density: 20, formatting: 15 };
      const breakdown = ats.breakdown || {};
      const barsEl = document.getElementById('ra-breakdown-bars');
      barsEl.innerHTML = '';
      for (const [key, pts] of Object.entries(breakdown)) {
        const max = maxPts[key] || 20;
        const p = Math.round((pts / max) * 100);
        const label = key.replace(/_/g, ' ');
        barsEl.insertAdjacentHTML('beforeend', `
          <div class="ra-breakdown-row">
            <span class="ra-breakdown-row__label">${label}</span>
            <div class="ra-breakdown-bar-track">
              <div class="ra-breakdown-bar-fill ${raScoreClass(p)}" style="width:${p}%"></div>
            </div>
            <span class="ra-breakdown-row__score">${pts}/${max}</span>
          </div>
        `);
      }

      // Feedback
      const feedbackEl = document.getElementById('ra-ats-feedback');
      feedbackEl.innerHTML = (ats.feedback || []).map(f =>
        `<div class="ra-feedback-item">${f}</div>`
      ).join('');

      // Missing keywords
      const improvements = data.improvements || {};
      const missingKws = improvements.missing_keywords || [];
      const kwEl = document.getElementById('ra-missing-keywords-tags');
      if (missingKws.length > 0) {
        kwEl.innerHTML = missingKws.map(kw => `<span class="ra-tag">${kw}</span>`).join('');
        document.getElementById('ra-keywords-card').style.display = '';
      } else {
        document.getElementById('ra-keywords-card').style.display = 'none';
      }

      // Job matches
      const matches = data.job_matches || [];
      const tbody = document.getElementById('ra-job-matches-body');
      tbody.innerHTML = '';
      if (matches.length > 0) {
        for (const m of matches) {
          const ms = m.match_score || 0;
          const shortKws = (m.missing_keywords || []).slice(0, 4).join(', ');
          const applyLink = m.apply_url
            ? `<a href="${m.apply_url}" target="_blank" rel="noopener" class="btn btn-primary" style="padding:0.3rem 0.75rem;font-size:0.8rem;">Apply</a>`
            : '—';
          tbody.insertAdjacentHTML('beforeend', `
            <tr>
              <td>${m.job_title || '—'}</td>
              <td>${m.company || '—'}</td>
              <td>${m.location || '—'}</td>
              <td>
                <div class="ra-match-progress-wrap">
                  <div class="ra-match-progress-track">
                    <div class="ra-match-progress-fill ${raScoreClass(ms)}" style="width:${ms}%"></div>
                  </div>
                  <span class="${raTextClass(ms)}">${ms}%</span>
                </div>
              </td>
              <td style="max-width:220px;font-size:0.78rem;color:#6b7280;">${shortKws || '—'}</td>
              <td>${applyLink}</td>
            </tr>
          `);
        }
        document.getElementById('ra-job-matches-card').style.display = '';
      } else {
        document.getElementById('ra-job-matches-card').style.display = 'none';
      }

      // LLM note
      const note = improvements.note || '';
      const llmNoteEl = document.getElementById('ra-llm-note');
      if (note) { llmNoteEl.textContent = note; llmNoteEl.style.display = ''; }
      else { llmNoteEl.style.display = 'none'; }

      // Summary rewrite
      document.getElementById('ra-original-summary').textContent = '(original summary not returned by API)';
      document.getElementById('ra-suggested-summary').textContent = improvements.summary_rewrite || '(no suggestion)';

      // Weak bullets
      const bulletsBody = document.getElementById('ra-weak-bullets-body');
      const weakBullets = improvements.weak_bullets || [];
      if (weakBullets.length > 0) {
        bulletsBody.innerHTML = weakBullets.map(b => `
          <div class="ra-bullet-item">
            <div class="ra-suggestion-comparison">
              <div class="ra-suggestion-panel ra-suggestion-panel--before">
                <div class="ra-suggestion-panel__label">Original</div>
                <div class="ra-suggestion-panel__text">${b.original || '—'}</div>
              </div>
              <div class="ra-suggestion-panel__arrow">→</div>
              <div class="ra-suggestion-panel ra-suggestion-panel--after">
                <div class="ra-suggestion-panel__label">Improved</div>
                <div class="ra-suggestion-panel__text">${b.improved || '—'}</div>
              </div>
            </div>
          </div>
        `).join('');
      } else {
        bulletsBody.innerHTML = '<p style="color:#9ca3af;font-size:0.875rem;">No weak bullets identified.</p>';
      }

      // Formatting tips
      const tipsList = document.getElementById('ra-formatting-tips-list');
      const tips = improvements.formatting_tips || [];
      tipsList.innerHTML = tips.length > 0
        ? tips.map(t => `<li>${t}</li>`).join('')
        : '<li style="color:#9ca3af;">No formatting tips generated.</li>';

      // View uploaded resume link
      if (data.file_url) {
        const viewRow = document.getElementById('ra-view-resume-row');
        const viewLink = document.getElementById('ra-view-resume-link');
        viewLink.href = data.file_url;
        viewRow.style.display = '';
      }

      document.getElementById('ra-results-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // ----- Form submit -----
    const form = document.getElementById('ra-resume-form');
    const analyzeBtn = document.getElementById('ra-analyze-btn');
    const btnText = document.getElementById('ra-btn-text');
    const btnSpinner = document.getElementById('ra-btn-spinner');
    const uploadError = document.getElementById('ra-upload-error');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      uploadError.style.display = 'none';

      const file = fileInput.files && fileInput.files[0];
      const email = raEmailInput ? raEmailInput.value.trim() : '';

      if (!file) {
        uploadError.textContent = 'Please select a resume file.';
        uploadError.style.display = '';
        return;
      }
      if (!email) {
        uploadError.textContent = 'Please enter your email address.';
        uploadError.style.display = '';
        return;
      }

      analyzeBtn.disabled = true;
      btnText.textContent = 'Analyzing…';
      btnSpinner.style.display = '';
      startProgress();

      try {
        const formData = new FormData();
        formData.append('document', file);
        formData.append('email', email);

        const response = await fetch('/api/resume/analyze', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();
        completeProgress();

        if (!response.ok || !data.success) {
          throw new Error(data.message || 'Analysis failed. Please try again.');
        }

        renderRaResults(data);
      } catch (err) {
        resetProgress();
        uploadError.textContent = err.message || 'An unexpected error occurred.';
        uploadError.style.display = '';
      } finally {
        analyzeBtn.disabled = false;
        btnText.textContent = 'Analyze Resume';
        btnSpinner.style.display = 'none';
      }
    });

    // ----- History tab -----
    async function loadHistory(email) {
      const historyError = document.getElementById('ra-history-error');
      const historyLoading = document.getElementById('ra-history-loading');
      const historyTableWrap = document.getElementById('ra-history-table-wrap');
      const historyEmpty = document.getElementById('ra-history-empty');
      const historyBody = document.getElementById('ra-history-table-body');

      historyError.style.display = 'none';
      historyTableWrap.style.display = 'none';
      historyEmpty.style.display = 'none';

      if (!email) {
        historyError.textContent = 'Please enter your email.';
        historyError.style.display = '';
        return;
      }

      historyLoading.style.display = '';

      try {
        const res = await fetch(`/api/resume/history?email=${encodeURIComponent(email)}`);
        const data = await res.json();
        if (!res.ok || !data.success) throw new Error(data.message || 'Failed to load history');

        const analyses = data.analyses || [];
        if (analyses.length === 0) {
          historyEmpty.style.display = '';
        } else {
          historyBody.innerHTML = '';
          for (const a of analyses) {
            const date = new Date(a.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
            const atsClass = raTextClass(a.ats_score || 0);
            const matchClass = raTextClass(a.match_score || 0);
            historyBody.insertAdjacentHTML('beforeend', `
              <tr>
                <td>${date}</td>
                <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${a.file_name || ''}">${a.file_name || '—'}</td>
                <td><span class="${atsClass}">${a.ats_score != null ? a.ats_score + '/100' : '—'}</span></td>
                <td><span class="${matchClass}">${a.match_score != null ? a.match_score + '%' : '—'}</span></td>
                <td>${a.file_url ? `<a href="${a.file_url}" target="_blank" rel="noopener" style="color:var(--color-primary,#22c55e);font-weight:600;">View</a>` : '—'}</td>
              </tr>
            `);
          }
          historyTableWrap.style.display = '';
        }
      } catch (err) {
        historyError.textContent = err.message || 'Failed to load history.';
        historyError.style.display = '';
      } finally {
        historyLoading.style.display = 'none';
      }
    }

    document.getElementById('ra-load-history-btn').addEventListener('click', () => {
      const email = document.getElementById('ra-history-email').value.trim();
      loadHistory(email);
    });

    // Deep-link: if URL hash is #resume-analyzer, scroll to it.
    // The 300ms delay allows the auth check fetch to complete so the section is visible before scrolling.
    if (window.location.hash === '#resume-analyzer') {
      setTimeout(() => {
        document.getElementById('resume-analyzer').scrollIntoView({ behavior: 'smooth' });
      }, 300);
    }

    // Revoke any object URL when the user navigates away to prevent memory leaks
    window.addEventListener('beforeunload', () => {
      if (localFileObjectUrl) { URL.revokeObjectURL(localFileObjectUrl); localFileObjectUrl = null; }
    });
  })();
</script>