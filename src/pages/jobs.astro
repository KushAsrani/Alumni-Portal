import Layout from '../layouts/Layout.astro';
import JobBoard from '../components/JobBoard.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon';

export const prerender = false; // Enable SSR for dynamic filtering

// Get all jobs from content collection
const jobsData = await getCollection('jobs');
const allJobs = jobsData.map(entry => entry.data);

// Get unique locations for filter dropdown
const uniqueLocations = [...new Set(allJobs.map(job => job.location))].sort();

// Get unique companies
const uniqueCompanies = [...new Set(allJobs.map(job => job.company))].sort();

// Get unique sources
const uniqueSources = [...new Set(allJobs.map(job => job.source))].sort();

// Get query parameters for filtering
const url = new URL(Astro.request.url);
const searchQuery = url.searchParams.get('search')?.toLowerCase() || '';
const experienceFilter = url.searchParams.get('experience') || '';
const locationFilter = url.searchParams.get('location') || '';
const companyFilter = url.searchParams.get('company') || '';
const jobTypeFilter = url.searchParams.get('jobType') || '';
const salaryFilter = url.searchParams.get('minSalary') || '';
const sourceFilter = url.searchParams.get('source') || '';
const skillsFilter = url.searchParams.getAll('skills') || [];
const qualificationsFilter = url.searchParams.get('qualifications') || '';
const featuredOnly = url.searchParams.get('featured') === 'true';
const currentPage = parseInt(url.searchParams.get('page') || '1');

// Apply filters
let filteredJobs = allJobs;

// Search filter
if (searchQuery) {
  filteredJobs = filteredJobs.filter(job => {
    const searchableText = `${job.title} ${job.company} ${job.location} ${job.description} ${job.skills} ${job.jobType} ${job.experienceLevel} ${job.source} ${job.jobType === "full-time" ? "fulltime" : job.jobType} ${job.jobType === "full-time" ? "full time" : job.jobType} ${job.jobType === "part-time" ? "part time" : job.jobType} ${job.jobType === "part-time" ? "parttime" : job.jobType} ${job.experienceLevel === "entry" ? "entry level" : job.experienceLevel === "mid" ? "mid level" : job.experienceLevel === "senior" ? "senior level" : job.experienceLevel === "executive" ? "executive level" : job.experienceLevel}`.toLowerCase();
    return searchableText.includes(searchQuery);
  });
}

// Experience level filter
if (experienceFilter) {
  filteredJobs = filteredJobs.filter(job => job.experienceLevel === experienceFilter);
}

// Location filter.
if (locationFilter) {
  const effectiveLocationFilters =
    locationFilter === 'India' || locationFilter === 'Remote'
      ? ['India', 'Remote']
      : locationFilter === 'Bangalore' || locationFilter === 'Bengaluru'
      ? ['Bangalore', 'Bengaluru']
      : locationFilter === 'Karnataka' || locationFilter === 'Karnātaka'
      ? ['Karnataka', 'Karnātaka']
      : [locationFilter];

  filteredJobs = filteredJobs.filter(job =>
    effectiveLocationFilters.some(filter =>
      job.location.includes(filter) || job.company.includes(filter) || job.description.includes(filter)
    )
  );
}

else if (locationFilter) {
  const effectiveLocationFilters = locationFilter === 'Bangalore' || locationFilter === 'Bengaluru' 
    ? ['Bangalore', 'Bengaluru'] 
    : [locationFilter];

    filteredJobs = filteredJobs.filter(job => 
      effectiveLocationFilters.some(filter => job.location.includes(filter))
    );
}

// Job type filter
if (jobTypeFilter) {
  filteredJobs = filteredJobs.filter(job => job.jobType === jobTypeFilter);
}

// Salary filter - FIXED
if (salaryFilter) {
  const minSalary = parseInt(salaryFilter);
  filteredJobs = filteredJobs.filter(job => {
    // Check if job has salary and if minimum salary meets the filter
    if (!job.salary || !job.salary.min) return false;
    return job.salary.min >= minSalary;
  });
}

// Source filter
if (sourceFilter) {
  filteredJobs = filteredJobs.filter(job => job.source === sourceFilter);
}

// Skills filter
if (skillsFilter.length > 0) {
  filteredJobs = filteredJobs.filter(job =>
    skillsFilter.every(skill => job.skills?.includes(skill)) &&
    searchQuery.split(' ').every(term => 
      job.title.toLowerCase().includes(term) ||
      job.description.toLowerCase().includes(term) ||
      job.skills?.some(s => s.toLowerCase().includes(term))
    )
  );
}

// Qualifications filter
if (qualificationsFilter) {
  filteredJobs = filteredJobs.filter(job => {
    return job.qualifications?.some(qualification =>
      qualification.toLowerCase().includes(qualificationsFilter.toLowerCase())
    );
  });
}

// Featured only filter
if (featuredOnly) {
  filteredJobs = filteredJobs.filter(job => job.featured);
}

// Sort by posted date (newest first)
filteredJobs.sort((a, b) => {
  const dateA = new Date(a.posted_date).getTime();
  const dateB = new Date(b.posted_date).getTime();
  return dateB - dateA;
});

// Calculate statistics
const totalJobs = allJobs.length;
const entryJobs = allJobs.filter(j => j.experienceLevel === 'entry').length;
const midJobs = allJobs.filter(j => j.experienceLevel === 'mid').length;
const seniorJobs = allJobs.filter(j => j.experienceLevel === 'senior').length;
const executiveJobs = allJobs.filter(j => j.experienceLevel === 'executive').length;

// Calculate salary statistics
const jobsWithSalary = allJobs.filter(j => j.salary && j.salary.min && j.salary.max);
const avgMinSalary = jobsWithSalary.length > 0
  ? Math.round(jobsWithSalary.reduce((sum, j) => sum + j.salary.min, 0) / jobsWithSalary.length)
  : 500000; // Default 5 LPA
const avgMaxSalary = jobsWithSalary.length > 0
  ? Math.round(jobsWithSalary.reduce((sum, j) => sum + j.salary.max, 0) / jobsWithSalary.length)
  : 1500000; // Default 15 LPA

// Get top skills
const skillCounts = new Map();
allJobs.forEach(job => {
  job.skills?.forEach(skill => {
    skillCounts.set(skill, (skillCounts.get(skill) || 0) + 1);
  });
});
const topSkills = Array.from(skillCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5)
  .map(([skill]) => skill);

// Get top certifications
const certCounts = new Map();
allJobs.forEach(job => {
  job.certifications?.forEach(cert => {
    certCounts.set(cert, (certCounts.get(cert) || 0) + 1);
  });
});
const topCertifications = Array.from(certCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 3)
  .map(([cert]) => cert);
