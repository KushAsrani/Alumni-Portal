---
export const prerender = false;

return Astro.redirect('/jobs#resume-analyzer', 301);
---

  <!-- Hero Section -->
  <section class="resume-hero">
    <div class="resume-hero__inner">
      <h1 class="resume-hero__title">AI Resume Analyzer</h1>
      <p class="resume-hero__subtitle">
        Upload your resume and get an instant ATS score, keyword analysis, and AI-powered improvement suggestions matched against real job listings.
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <div class="resume-container">

    <!-- Tab navigation -->
    <div class="tab-nav">
      <button class="tab-btn tab-btn--active" id="tab-analyze" type="button">Analyze New</button>
      <button class="tab-btn" id="tab-history" type="button">Past Analyses</button>
    </div>

    <!-- ===== ANALYZE TAB ===== -->
    <div id="panel-analyze">

      <!-- Upload Card -->
      <div class="card upload-card">
        <h2 class="card__title">Upload Your Resume</h2>
        <p class="card__subtitle">PDF or DOCX — max 10 MB</p>

        <form id="resume-form" novalidate>
          <!-- Drag-and-drop zone -->
          <div class="drop-zone" id="drop-zone" tabindex="0" role="button" aria-label="Click or drag to upload resume">
            <div class="drop-zone__icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <p class="drop-zone__text">Drag &amp; drop your resume here, or <span class="drop-zone__link">click to browse</span></p>
            <p class="drop-zone__hint" id="file-name-display">Accepts .pdf and .docx</p>
            <input type="file" id="resume-file" name="document" accept=".pdf,.doc,.docx" class="drop-zone__input" aria-label="Resume file upload" />
          </div>

          <!-- Email input -->
          <div class="form-group">
            <label for="alumni-email" class="form-label">Your Email</label>
            <input
              type="email"
              id="alumni-email"
              name="email"
              class="form-input"
              placeholder="you@example.com"
              required
              autocomplete="email"
            />
          </div>

          <!-- Error display -->
          <div class="alert alert--error" id="upload-error" role="alert" style="display:none;"></div>

          <!-- Submit button -->
          <button type="submit" class="btn btn--primary btn--full" id="analyze-btn">
            <span id="btn-text">Analyze Resume</span>
            <span id="btn-spinner" class="spinner" style="display:none;" aria-hidden="true"></span>
          </button>
        </form>
      </div>

      <!-- Results Dashboard (hidden until analysis completes) -->
      <div id="results-section" style="display:none;">

        <!-- ATS Score Card -->
        <div class="card results-card">
          <h2 class="card__title">ATS Score</h2>
          <div class="ats-score-layout">
            <!-- Circular gauge -->
            <div class="ats-gauge-wrap">
              <svg class="ats-gauge" viewBox="0 0 120 120" aria-label="ATS Score gauge">
                <circle class="ats-gauge__track" cx="60" cy="60" r="50" />
                <circle class="ats-gauge__fill" id="ats-arc" cx="60" cy="60" r="50"
                  stroke-dasharray="0 314"
                  stroke-dashoffset="78.5"
                  stroke-linecap="round" />
              </svg>
              <div class="ats-gauge__label">
                <span class="ats-gauge__score" id="ats-score-value">—</span>
                <span class="ats-gauge__max">/100</span>
              </div>
            </div>

            <!-- Breakdown bars -->
            <div class="ats-breakdown">
              <h3 class="breakdown-title">Category Breakdown</h3>
              <div id="breakdown-bars"></div>
            </div>
          </div>

          <!-- Feedback list -->
          <div id="ats-feedback" class="feedback-list"></div>
        </div>

        <!-- Missing Keywords -->
        <div class="card results-card" id="keywords-card">
          <h2 class="card__title">Missing Keywords</h2>
          <p class="card__subtitle">Keywords found in job descriptions but absent from your resume</p>
          <div id="missing-keywords-tags" class="tags-container"></div>
        </div>

        <!-- Job Matches -->
        <div class="card results-card" id="job-matches-card">
          <h2 class="card__title">Top Job Matches</h2>
          <div class="table-wrap">
            <table class="match-table" id="job-matches-table">
              <thead>
                <tr>
                  <th>Job Title</th>
                  <th>Company</th>
                  <th>Location</th>
                  <th>Match</th>
                  <th>Missing Keywords</th>
                  <th>Apply</th>
                </tr>
              </thead>
              <tbody id="job-matches-body"></tbody>
            </table>
          </div>
        </div>

        <!-- AI Suggestions Accordion -->
        <div class="card results-card" id="suggestions-card">
          <h2 class="card__title">AI Improvement Suggestions</h2>
          <div id="llm-note" class="alert alert--info" style="display:none;"></div>

          <!-- Summary Rewrite -->
          <details class="accordion" id="acc-summary">
            <summary class="accordion__header">
              <span>✏️ Summary Rewrite</span>
              <span class="accordion__arrow">▾</span>
            </summary>
            <div class="accordion__body">
              <div class="suggestion-comparison">
                <div class="suggestion-panel suggestion-panel--before">
                  <div class="suggestion-panel__label">Original</div>
                  <div id="original-summary" class="suggestion-panel__text">—</div>
                </div>
                <div class="suggestion-panel__arrow">→</div>
                <div class="suggestion-panel suggestion-panel--after">
                  <div class="suggestion-panel__label">Suggested</div>
                  <div id="suggested-summary" class="suggestion-panel__text">—</div>
                </div>
              </div>
            </div>
          </details>

          <!-- Weak Bullets -->
          <details class="accordion" id="acc-bullets">
            <summary class="accordion__header">
              <span>🔄 Weak Bullet Rewrites</span>
              <span class="accordion__arrow">▾</span>
            </summary>
            <div class="accordion__body" id="weak-bullets-body"></div>
          </details>

          <!-- Formatting Tips -->
          <details class="accordion" id="acc-formatting">
            <summary class="accordion__header">
              <span>📐 Formatting Tips</span>
              <span class="accordion__arrow">▾</span>
            </summary>
            <div class="accordion__body">
              <ul id="formatting-tips-list" class="tips-list"></ul>
            </div>
          </details>
        </div>

      </div><!-- /results-section -->
    </div><!-- /panel-analyze -->

    <!-- ===== HISTORY TAB ===== -->
    <div id="panel-history" style="display:none;">
      <div class="card">
        <h2 class="card__title">Past Analyses</h2>
        <div class="form-group">
          <label for="history-email" class="form-label">Enter your email to load history</label>
          <div class="input-row">
            <input type="email" id="history-email" class="form-input" placeholder="you@example.com" />
            <button type="button" class="btn btn--primary" id="load-history-btn">Load</button>
          </div>
        </div>
        <div id="history-error" class="alert alert--error" style="display:none;"></div>
        <div id="history-loading" style="display:none;" class="loading-state">Loading history…</div>
        <div class="table-wrap" id="history-table-wrap" style="display:none;">
          <table class="match-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>File</th>
                <th>ATS Score</th>
                <th>Match Score</th>
                <th>Download</th>
              </tr>
            </thead>
            <tbody id="history-table-body"></tbody>
          </table>
        </div>
        <div id="history-empty" class="empty-state" style="display:none;">No past analyses found for this email.</div>
      </div>
    </div><!-- /panel-history -->

  </div><!-- /resume-container -->
</Layout>

<style>
  /* =========================================================
     Hero
  ========================================================= */
  .resume-hero {
    background: linear-gradient(135deg, var(--color-primary, #22c55e) 0%, #15803d 100%);
    color: #fff;
    padding: 4rem 1.5rem;
    text-align: center;
  }
  .resume-hero__inner {
    max-width: 700px;
    margin: 0 auto;
  }
  .resume-hero__title {
    font-size: 2.5rem;
    font-weight: 800;
    margin: 0 0 1rem;
    letter-spacing: -0.5px;
  }
  .resume-hero__subtitle {
    font-size: 1.15rem;
    opacity: 0.9;
    line-height: 1.6;
    margin: 0;
  }

  /* =========================================================
     Container
  ========================================================= */
  .resume-container {
    max-width: 1200px;
    margin: 2.5rem auto;
    padding: 0 1.5rem 4rem;
  }

  /* =========================================================
     Tabs
  ========================================================= */
  .tab-nav {
    display: flex;
    gap: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
    margin-bottom: 2rem;
  }
  .tab-btn {
    padding: 0.6rem 1.4rem;
    border: none;
    background: none;
    font-size: 0.95rem;
    font-weight: 600;
    color: #6b7280;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: color 0.15s, border-color 0.15s;
  }
  .tab-btn--active {
    color: var(--color-primary, #22c55e);
    border-bottom-color: var(--color-primary, #22c55e);
  }
  .tab-btn:hover:not(.tab-btn--active) {
    color: #374151;
  }

  /* =========================================================
     Cards
  ========================================================= */
  .card {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    padding: 2rem;
    margin-bottom: 1.5rem;
    border: 1px solid #f3f4f6;
  }
  .card__title {
    font-size: 1.35rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 0.35rem;
  }
  .card__subtitle {
    font-size: 0.9rem;
    color: #6b7280;
    margin: 0 0 1.25rem;
  }
  .results-card {
    animation: fadeIn 0.35s ease both;
  }
  @keyframes fadeIn {
    from { opacity:0; transform: translateY(12px); }
    to   { opacity:1; transform: translateY(0); }
  }

  /* =========================================================
     Upload / Form
  ========================================================= */
  .upload-card {
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }
  .drop-zone {
    border: 2px dashed #d1d5db;
    border-radius: 10px;
    padding: 2.5rem 1.5rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    position: relative;
    margin-bottom: 1.25rem;
  }
  .drop-zone:hover, .drop-zone.drag-over {
    border-color: var(--color-primary, #22c55e);
    background: #f0fdf4;
  }
  .drop-zone__input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }
  .drop-zone__icon {
    color: #9ca3af;
    margin-bottom: 0.75rem;
  }
  .drop-zone__icon svg { display: inline-block; }
  .drop-zone__text {
    font-size: 0.95rem;
    color: #374151;
    margin: 0 0 0.25rem;
  }
  .drop-zone__link {
    color: var(--color-primary, #22c55e);
    font-weight: 600;
    text-decoration: underline;
  }
  .drop-zone__hint {
    font-size: 0.8rem;
    color: #9ca3af;
    margin: 0;
  }
  .form-group { margin-bottom: 1.25rem; }
  .form-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 0.4rem;
  }
  .form-input {
    width: 100%;
    padding: 0.6rem 0.9rem;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 0.95rem;
    color: #111827;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.15s;
  }
  .form-input:focus { border-color: var(--color-primary, #22c55e); }

  /* =========================================================
     Buttons
  ========================================================= */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.65rem 1.4rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: background 0.15s, opacity 0.15s;
  }
  .btn--primary {
    background: var(--color-primary, #22c55e);
    color: #fff;
  }
  .btn--primary:hover { opacity: 0.9; }
  .btn--primary:disabled { opacity: 0.6; cursor: not-allowed; }
  .btn--full { width: 100%; }

  /* =========================================================
     Spinner
  ========================================================= */
  .spinner {
    width: 18px;
    height: 18px;
    border: 2px solid rgba(255,255,255,0.35);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* =========================================================
     Alerts
  ========================================================= */
  .alert {
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }
  .alert--error { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }
  .alert--info  { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }

  /* =========================================================
     ATS Score
  ========================================================= */
  .ats-score-layout {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .ats-gauge-wrap {
    position: relative;
    width: 130px;
    height: 130px;
    flex-shrink: 0;
  }
  .ats-gauge {
    width: 130px;
    height: 130px;
    transform: rotate(-90deg);
  }
  .ats-gauge__track {
    fill: none;
    stroke: #e5e7eb;
    stroke-width: 10;
  }
  .ats-gauge__fill {
    fill: none;
    stroke: var(--color-primary, #22c55e);
    stroke-width: 10;
    transition: stroke-dasharray 0.8s ease, stroke 0.4s;
  }
  .ats-gauge__label {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .ats-gauge__score {
    font-size: 2rem;
    font-weight: 800;
    color: #111827;
    line-height: 1;
  }
  .ats-gauge__max {
    font-size: 0.75rem;
    color: #9ca3af;
  }

  /* Breakdown bars */
  .ats-breakdown { flex: 1; min-width: 220px; }
  .breakdown-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: #374151;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .breakdown-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.55rem;
  }
  .breakdown-row__label {
    width: 130px;
    font-size: 0.8rem;
    color: #6b7280;
    text-align: right;
    flex-shrink: 0;
    text-transform: capitalize;
  }
  .breakdown-bar-track {
    flex: 1;
    height: 8px;
    background: #e5e7eb;
    border-radius: 4px;
    overflow: hidden;
  }
  .breakdown-bar-fill {
    height: 100%;
    border-radius: 4px;
    background: var(--color-primary, #22c55e);
    transition: width 0.6s ease;
  }
  .breakdown-row__score {
    font-size: 0.8rem;
    font-weight: 600;
    color: #374151;
    width: 30px;
    text-align: right;
  }

  /* Feedback list */
  .feedback-list { display: flex; flex-direction: column; gap: 0.4rem; }
  .feedback-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #374151;
    padding: 0.45rem 0.75rem;
    background: #f9fafb;
    border-radius: 6px;
  }
  .feedback-item::before { content: '•'; color: var(--color-primary, #22c55e); font-size: 1.1rem; flex-shrink: 0; }

  /* =========================================================
     Tags
  ========================================================= */
  .tags-container { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem; }
  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    background: #fef9c3;
    color: #713f12;
    border: 1px solid #fde047;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 500;
  }

  /* =========================================================
     Table
  ========================================================= */
  .table-wrap { overflow-x: auto; margin-top: 0.75rem; }
  .match-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .match-table th {
    text-align: left;
    padding: 0.6rem 0.75rem;
    background: #f9fafb;
    font-weight: 700;
    color: #374151;
    border-bottom: 2px solid #e5e7eb;
    white-space: nowrap;
  }
  .match-table td {
    padding: 0.65rem 0.75rem;
    border-bottom: 1px solid #f3f4f6;
    color: #374151;
    vertical-align: middle;
  }
  .match-table tr:hover td { background: #f9fafb; }

  /* Match score progress */
  .match-progress-wrap { display: flex; align-items: center; gap: 0.5rem; }
  .match-progress-track {
    flex: 1;
    height: 8px;
    background: #e5e7eb;
    border-radius: 4px;
    overflow: hidden;
    min-width: 60px;
  }
  .match-progress-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.6s ease;
  }
  .score-green  { background: #22c55e; }
  .score-amber  { background: #f59e0b; }
  .score-red    { background: #ef4444; }
  .text-green   { color: #15803d; font-weight: 700; }
  .text-amber   { color: #b45309; font-weight: 700; }
  .text-red     { color: #b91c1c; font-weight: 700; }

  /* =========================================================
     Accordion
  ========================================================= */
  .accordion {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    margin-bottom: 0.75rem;
    overflow: hidden;
  }
  .accordion__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.1rem;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    color: #374151;
    background: #f9fafb;
    list-style: none;
    user-select: none;
  }
  .accordion__header::-webkit-details-marker { display: none; }
  .accordion[open] .accordion__arrow { transform: rotate(180deg); }
  .accordion__arrow { transition: transform 0.2s; color: #9ca3af; }
  .accordion__body { padding: 1rem 1.1rem; }

  /* Suggestion comparison */
  .suggestion-comparison {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }
  .suggestion-panel {
    flex: 1;
    min-width: 200px;
    border-radius: 8px;
    padding: 0.85rem 1rem;
  }
  .suggestion-panel--before { background: #fef2f2; border: 1px solid #fecaca; }
  .suggestion-panel--after  { background: #f0fdf4; border: 1px solid #bbf7d0; }
  .suggestion-panel__label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }
  .suggestion-panel--before .suggestion-panel__label { color: #b91c1c; }
  .suggestion-panel--after  .suggestion-panel__label { color: #15803d; }
  .suggestion-panel__text {
    font-size: 0.875rem;
    color: #374151;
    line-height: 1.6;
  }
  .suggestion-panel__arrow {
    align-self: center;
    font-size: 1.25rem;
    color: #9ca3af;
    flex-shrink: 0;
  }

  /* Bullet comparison list */
  .bullet-item { margin-bottom: 1rem; }
  .bullet-item:last-child { margin-bottom: 0; }

  /* Tips list */
  .tips-list { margin: 0; padding-left: 1.25rem; }
  .tips-list li {
    font-size: 0.875rem;
    color: #374151;
    margin-bottom: 0.45rem;
    line-height: 1.6;
  }

  /* =========================================================
     History tab
  ========================================================= */
  .input-row { display: flex; gap: 0.5rem; }
  .input-row .form-input { flex: 1; }
  .loading-state { text-align: center; padding: 2rem; color: #6b7280; }
  .empty-state {
    text-align: center;
    padding: 2.5rem;
    color: #9ca3af;
    font-size: 0.95rem;
  }

  /* =========================================================
     Responsive
  ========================================================= */
  @media (max-width: 640px) {
    .resume-hero__title { font-size: 1.75rem; }
    .ats-score-layout { flex-direction: column; align-items: center; }
    .breakdown-row__label { width: 90px; font-size: 0.72rem; }
    .suggestion-comparison { flex-direction: column; }
    .suggestion-panel__arrow { display: none; }
    .input-row { flex-direction: column; }
  }
</style>

<script>
  // ---------------------------------------------------------------
  // Tab switching
  // ---------------------------------------------------------------
  const tabAnalyze = document.getElementById('tab-analyze');
  const tabHistory = document.getElementById('tab-history');
  const panelAnalyze = document.getElementById('panel-analyze');
  const panelHistory = document.getElementById('panel-history');

  function switchTab(tab) {
    if (tab === 'analyze') {
      tabAnalyze.classList.add('tab-btn--active');
      tabHistory.classList.remove('tab-btn--active');
      panelAnalyze.style.display = '';
      panelHistory.style.display = 'none';
    } else {
      tabHistory.classList.add('tab-btn--active');
      tabAnalyze.classList.remove('tab-btn--active');
      panelHistory.style.display = '';
      panelAnalyze.style.display = 'none';
    }
  }

  tabAnalyze.addEventListener('click', () => switchTab('analyze'));
  tabHistory.addEventListener('click', () => switchTab('history'));

  // ---------------------------------------------------------------
  // Drag-and-drop handling
  // ---------------------------------------------------------------
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('resume-file');
  const fileNameDisplay = document.getElementById('file-name-display');

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('drag-over');
  });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const files = e.dataTransfer && e.dataTransfer.files;
    if (files && files.length > 0) {
      fileInput.files = files;
      fileNameDisplay.textContent = files[0].name;
    }
  });
  fileInput.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) {
      fileNameDisplay.textContent = fileInput.files[0].name;
    }
  });

  // ---------------------------------------------------------------
  // Score colour helpers
  // ---------------------------------------------------------------
  function scoreClass(score) {
    if (score >= 75) return 'score-green';
    if (score >= 50) return 'score-amber';
    return 'score-red';
  }
  function textClass(score) {
    if (score >= 75) return 'text-green';
    if (score >= 50) return 'text-amber';
    return 'text-red';
  }
  function gaugeColor(score) {
    if (score >= 75) return '#22c55e';
    if (score >= 50) return '#f59e0b';
    return '#ef4444';
  }

  // ---------------------------------------------------------------
  // Render results
  // ---------------------------------------------------------------
  function renderResults(data) {
    document.getElementById('results-section').style.display = '';

    const ats = data.ats || {};
    const score = ats.score || 0;

    // Circular gauge (circumference ≈ 314 for r=50)
    const circ = 314;
    const dashFilled = (score / 100) * circ;
    const arc = document.getElementById('ats-arc');
    arc.setAttribute('stroke-dasharray', `${dashFilled} ${circ - dashFilled}`);
    arc.style.stroke = gaugeColor(score);

    document.getElementById('ats-score-value').textContent = score;
    document.getElementById('ats-score-value').className = `ats-gauge__score ${textClass(score)}`;

    // Breakdown bars
    const maxPts = { contact_info: 15, sections: 20, bullet_points: 15, length: 15, keywords_density: 20, formatting: 15 };
    const breakdown = ats.breakdown || {};
    const barsEl = document.getElementById('breakdown-bars');
    barsEl.innerHTML = '';
    for (const [key, pts] of Object.entries(breakdown)) {
      const max = maxPts[key] || 20;
      const pct = Math.round((pts / max) * 100);
      const label = key.replace(/_/g, ' ');
      barsEl.insertAdjacentHTML('beforeend', `
        <div class="breakdown-row">
          <span class="breakdown-row__label">${label}</span>
          <div class="breakdown-bar-track">
            <div class="breakdown-bar-fill ${scoreClass(pct)}" style="width:${pct}%"></div>
          </div>
          <span class="breakdown-row__score">${pts}/${max}</span>
        </div>
      `);
    }

    // Feedback
    const feedbackEl = document.getElementById('ats-feedback');
    feedbackEl.innerHTML = (ats.feedback || []).map(f =>
      `<div class="feedback-item">${f}</div>`
    ).join('');

    // Missing keywords from improvements
    const improvements = data.improvements || {};
    const missingKws = improvements.missing_keywords || [];
    const kwEl = document.getElementById('missing-keywords-tags');
    if (missingKws.length > 0) {
      kwEl.innerHTML = missingKws.map(kw => `<span class="tag">${kw}</span>`).join('');
      document.getElementById('keywords-card').style.display = '';
    } else {
      document.getElementById('keywords-card').style.display = 'none';
    }

    // Job matches table
    const matches = data.job_matches || [];
    const tbody = document.getElementById('job-matches-body');
    tbody.innerHTML = '';
    if (matches.length > 0) {
      for (const m of matches) {
        const ms = m.match_score || 0;
        const missingKwsShort = (m.missing_keywords || []).slice(0, 4).join(', ');
        const applyLink = m.apply_url
          ? `<a href="${m.apply_url}" target="_blank" rel="noopener" class="btn btn--primary" style="padding:0.3rem 0.75rem;font-size:0.8rem;">Apply</a>`
          : '—';
        tbody.insertAdjacentHTML('beforeend', `
          <tr>
            <td>${m.job_title || '—'}</td>
            <td>${m.company || '—'}</td>
            <td>${m.location || '—'}</td>
            <td>
              <div class="match-progress-wrap">
                <div class="match-progress-track">
                  <div class="match-progress-fill ${scoreClass(ms)}" style="width:${ms}%"></div>
                </div>
                <span class="${textClass(ms)}">${ms}%</span>
              </div>
            </td>
            <td style="max-width:220px;font-size:0.78rem;color:#6b7280;">${missingKwsShort || '—'}</td>
            <td>${applyLink}</td>
          </tr>
        `);
      }
      document.getElementById('job-matches-card').style.display = '';
    } else {
      document.getElementById('job-matches-card').style.display = 'none';
    }

    // LLM suggestions
    const note = improvements.note || '';
    const llmNoteEl = document.getElementById('llm-note');
    if (note) { llmNoteEl.textContent = note; llmNoteEl.style.display = ''; }
    else { llmNoteEl.style.display = 'none'; }

    // Summary rewrite
    document.getElementById('suggested-summary').textContent = improvements.summary_rewrite || '(no suggestion)';

    // Weak bullets
    const bulletsBody = document.getElementById('weak-bullets-body');
    const weakBullets = improvements.weak_bullets || [];
    if (weakBullets.length > 0) {
      bulletsBody.innerHTML = weakBullets.map(b => `
        <div class="bullet-item">
          <div class="suggestion-comparison">
            <div class="suggestion-panel suggestion-panel--before">
              <div class="suggestion-panel__label">Original</div>
              <div class="suggestion-panel__text">${b.original || '—'}</div>
            </div>
            <div class="suggestion-panel__arrow">→</div>
            <div class="suggestion-panel suggestion-panel--after">
              <div class="suggestion-panel__label">Improved</div>
              <div class="suggestion-panel__text">${b.improved || '—'}</div>
            </div>
          </div>
        </div>
      `).join('');
    } else {
      bulletsBody.innerHTML = '<p style="color:#9ca3af;font-size:0.875rem;">No weak bullets identified.</p>';
    }

    // Formatting tips
    const tipsList = document.getElementById('formatting-tips-list');
    const tips = improvements.formatting_tips || [];
    if (tips.length > 0) {
      tipsList.innerHTML = tips.map(t => `<li>${t}</li>`).join('');
    } else {
      tipsList.innerHTML = '<li style="color:#9ca3af;">No formatting tips generated.</li>';
    }

    // Scroll to results
    document.getElementById('results-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // ---------------------------------------------------------------
  // Form submit — analyze
  // ---------------------------------------------------------------
  const form = document.getElementById('resume-form');
  const analyzeBtn = document.getElementById('analyze-btn');
  const btnText = document.getElementById('btn-text');
  const btnSpinner = document.getElementById('btn-spinner');
  const uploadError = document.getElementById('upload-error');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    uploadError.style.display = 'none';

    const file = fileInput.files && fileInput.files[0];
    const email = document.getElementById('alumni-email').value.trim();

    if (!file) {
      uploadError.textContent = 'Please select a resume file.';
      uploadError.style.display = '';
      return;
    }
    if (!email) {
      uploadError.textContent = 'Please enter your email address.';
      uploadError.style.display = '';
      return;
    }

    // Set loading state
    analyzeBtn.disabled = true;
    btnText.textContent = 'Analyzing…';
    btnSpinner.style.display = '';

    try {
      const formData = new FormData();
      formData.append('document', file);
      formData.append('email', email);

      const response = await fetch('/api/resume/analyze', {
        method: 'POST',
        body: formData,
      });

      const data = await response.json();

      if (!response.ok || !data.success) {
        throw new Error(data.message || 'Analysis failed. Please try again.');
      }

      renderResults(data);
    } catch (err) {
      uploadError.textContent = err.message || 'An unexpected error occurred.';
      uploadError.style.display = '';
    } finally {
      analyzeBtn.disabled = false;
      btnText.textContent = 'Analyze Resume';
      btnSpinner.style.display = 'none';
    }
  });

  // ---------------------------------------------------------------
  // History tab
  // ---------------------------------------------------------------
  document.getElementById('load-history-btn').addEventListener('click', async () => {
    const email = document.getElementById('history-email').value.trim();
    const historyError = document.getElementById('history-error');
    const historyLoading = document.getElementById('history-loading');
    const historyTableWrap = document.getElementById('history-table-wrap');
    const historyEmpty = document.getElementById('history-empty');
    const historyBody = document.getElementById('history-table-body');

    historyError.style.display = 'none';
    historyTableWrap.style.display = 'none';
    historyEmpty.style.display = 'none';

    if (!email) {
      historyError.textContent = 'Please enter your email.';
      historyError.style.display = '';
      return;
    }

    historyLoading.style.display = '';

    try {
      const res = await fetch(`/api/resume/history?email=${encodeURIComponent(email)}`);
      const data = await res.json();

      if (!res.ok || !data.success) throw new Error(data.message || 'Failed to load history');

      const analyses = data.analyses || [];
      if (analyses.length === 0) {
        historyEmpty.style.display = '';
      } else {
        historyBody.innerHTML = '';
        for (const a of analyses) {
          const date = new Date(a.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
          const atsClass = textClass(a.ats_score || 0);
          const matchClass = textClass(a.match_score || 0);
          historyBody.insertAdjacentHTML('beforeend', `
            <tr>
              <td>${date}</td>
              <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${a.file_name || ''}">${a.file_name || '—'}</td>
              <td><span class="${atsClass}">${a.ats_score != null ? a.ats_score + '/100' : '—'}</span></td>
              <td><span class="${matchClass}">${a.match_score != null ? a.match_score + '%' : '—'}</span></td>
              <td>${a.file_url ? `<a href="${a.file_url}" target="_blank" rel="noopener" style="color:var(--color-primary,#22c55e);font-weight:600;">View</a>` : '—'}</td>
            </tr>
          `);
        }
        historyTableWrap.style.display = '';
      }
    } catch (err) {
      historyError.textContent = err.message || 'Failed to load history.';
      historyError.style.display = '';
    } finally {
      historyLoading.style.display = 'none';
    }
  });
</script>
