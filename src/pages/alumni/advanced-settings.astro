---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getCurrentAlumni, isAlumniAuthenticated } from '../../lib/alumni-auth';
import { connectToDatabase } from '../../lib/mongodb';
import type { AlumniRegistration } from '../../lib/mongodb';
import { ObjectId } from 'mongodb';

if (!isAlumniAuthenticated(Astro.cookies)) {
  return Astro.redirect('/alumni/login');
}

const session = getCurrentAlumni(Astro.cookies);
if (!session) {
  return Astro.redirect('/alumni/login');
}

type AlumniDocument = AlumniRegistration & { _id: ObjectId | string; username?: string };

const defaultAdvancedSettings = {
  profile_visibility: {
    show_in_directory: true,
    show_email_publicly: false,
    allow_connection_requests: true,
  },
  mentorship_preferences: {
    open_to_mentorship: false,
    looking_for_mentor: false,
    preferred_mode: 'either' as const,
  },
  notification_preferences: {
    connection_requests: true,
    upcoming_events: true,
    mentorship_requests: true,
    weekly_digest: false,
    digest_frequency: 'weekly' as const,
    notify_on_verification: true,
  },
  connected_accounts: {
    linkedin_connected: false,
    github_connected: false,
    linkedin_url: '',
    github_url: '',
  },
  accessibility: {
    preferred_language: 'en',
  },
};

let alumni: AlumniDocument | null = null;
let fetchError = '';

try {
  const { db } = await connectToDatabase();
  const collection = db.collection<AlumniDocument>('alumni_registrations');

  try {
    alumni = await collection.findOne({ _id: new ObjectId(session.alumniId) });
  } catch {
    alumni = await collection.findOne({
      $or: [{ username: session.username }, { email: session.username }],
    });
  }

  if (!alumni) {
    fetchError = 'Unable to load your advanced settings right now.';
  }
} catch (error) {
  console.error('Advanced settings page fetch error:', error);
  fetchError = 'Unable to load your advanced settings right now.';
}

const linkedinUrl = typeof alumni?.linkedin === 'string' ? alumni.linkedin.trim() : '';
const githubUrl = typeof alumni?.github === 'string' ? alumni.github.trim() : '';

const advancedSettings = {
  profile_visibility: {
    ...defaultAdvancedSettings.profile_visibility,
    ...(alumni?.profile_visibility || {}),
  },
  mentorship_preferences: {
    ...defaultAdvancedSettings.mentorship_preferences,
    ...(alumni?.mentorship_preferences || {}),
    open_to_mentorship: alumni?.open_to_mentorship ?? false,
  },
  notification_preferences: {
    ...defaultAdvancedSettings.notification_preferences,
    ...(alumni?.notification_preferences || {}),
  },
  connected_accounts: {
    ...defaultAdvancedSettings.connected_accounts,
    linkedin_connected: linkedinUrl.length > 0,
    github_connected: githubUrl.length > 0,
    linkedin_url: linkedinUrl,
    github_url: githubUrl,
  },
  accessibility: {
    preferred_language: alumni?.accessibility?.preferred_language || defaultAdvancedSettings.accessibility.preferred_language,
  },
};
---

<Layout title="Advanced Settings | Alumni Portal">
  <main class="min-h-screen bg-slate-50 py-8 md:py-12">
    <div class="container-custom mx-auto max-w-4xl px-4">
      <a
        href="/alumni/settings"
        class="inline-flex items-center gap-2 text-sm font-medium text-[#2e4096] transition hover:text-[#24367d]"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        Back to Settings
      </a>

      <section class="mt-4 rounded-3xl border border-slate-200 bg-white px-6 py-6 shadow-sm md:px-8">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#2e4096]">Alumni Settings</p>
        <h1 class="mt-2 text-3xl font-bold text-slate-900">Advanced Settings</h1>
        <p class="mt-2 text-sm text-slate-600">
          Configure visibility, mentorship, notifications, connected accounts, and accessibility.
        </p>
      </section>

      {fetchError && (
        <div class="mt-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
          {fetchError}
        </div>
      )}

      {!fetchError && (
        <form id="advancedSettingsForm" class="mt-6 space-y-6">
          <div id="settingsMessage" class="hidden rounded-2xl border px-4 py-3 text-sm"></div>

          <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <div class="rounded-2xl bg-[#2e4096]/10 p-3 text-[#2e4096]">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M2 12s4-6 10-6 10 6 10 6-4 6-10 6S2 12 2 12z"></path>
                  <circle cx="12" cy="12" r="3"></circle>
                </svg>
              </div>
              <div>
                <h2 class="text-xl font-semibold text-slate-900">Profile Visibility</h2>
              </div>
            </div>

            <div class="mt-6 space-y-4">
              <label class="flex items-start justify-between gap-4 rounded-2xl border border-slate-200 px-4 py-4">
                <div>
                  <p class="font-medium text-slate-900">Show in Alumni Directory</p>
                  <p class="text-sm text-slate-500">Your profile is visible in the public alumni directory. Disable to hide yourself from directory listings.</p>
                </div>
                <input id="show_in_directory" name="show_in_directory" type="checkbox" class="mt-1 h-4 w-4 rounded border-slate-300 text-[#2e4096] focus:ring-[#2e4096]" checked={advancedSettings.profile_visibility.show_in_directory} />
              </label>

              <label class="flex items-start justify-between gap-4 rounded-2xl border border-slate-200 px-4 py-4">
                <div>
                  <p class="font-medium text-slate-900">Show Email Address Publicly</p>
                  <p class="text-sm text-slate-500">Allow other users to see your email address on your public profile.</p>
                </div>
                <input id="show_email_publicly" name="show_email_publicly" type="checkbox" class="mt-1 h-4 w-4 rounded border-slate-300 text-[#2e4096] focus:ring-[#2e4096]" checked={advancedSettings.profile_visibility.show_email_publicly} />
              </label>

              <label class="flex items-start justify-between gap-4 rounded-2xl border border-slate-200 px-4 py-4">
                <div>
                  <p class="font-medium text-slate-900">Allow Connection Requests</p>
                  <p class="text-sm text-slate-500">Allow other alumni to send you connection requests.</p>
                </div>
                <input id="allow_connection_requests" name="allow_connection_requests" type="checkbox" class="mt-1 h-4 w-4 rounded border-slate-300 text-[#2e4096] focus:ring-[#2e4096]" checked={advancedSettings.profile_visibility.allow_connection_requests} />
              </label>
            </div>
          </section>

          <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <div class="rounded-2xl bg-[#2e4096]/10 p-3 text-[#2e4096]">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
              </div>
              <div>
                <h2 class="text-xl font-semibold text-slate-900">Mentorship Preferences</h2>
              </div>
            </div>

            <div class="mt-6 space-y-4">
              <label class="flex items-start justify-between gap-4 rounded-2xl border border-slate-200 px-4 py-4">
                <div>
                  <p class="font-medium text-slate-900">Open to Mentorship</p>
                  <p class="text-sm text-slate-500">Appear as available for mentorship in the alumni directory.</p>
                </div>
                <input id="open_to_mentorship" name="open_to_mentorship" type="checkbox" class="mt-1 h-4 w-4 rounded border-slate-300 text-[#2e4096] focus:ring-[#2e4096]" checked={advancedSettings.mentorship_preferences.open_to_mentorship} />
              </label>

              <label class="flex items-start justify-between gap-4 rounded-2xl border border-slate-200 px-4 py-4">
                <div>
                  <p class="font-medium text-slate-900">Looking for a Mentor</p>
                  <p class="text-sm text-slate-500">Indicate that you are actively seeking a mentor.</p>
                </div>
                <input id="looking_for_mentor" name="looking_for_mentor" type="checkbox" class="mt-1 h-4 w-4 rounded border-slate-300 text-[#2e4096] focus:ring-[#2e4096]" checked={advancedSettings.mentorship_preferences.looking_for_mentor} />
              </label>

              <label class="block rounded-2xl border border-slate-200 px-4 py-4">
                <p class="font-medium text-slate-900">Preferred Mentorship Mode</p>
                <p class="mt-1 text-sm text-slate-500">How do you prefer to conduct mentorship sessions?</p>
                <select id="preferred_mode" name="preferred_mode" class="mt-3 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-[#2e4096] focus:outline-none focus:ring-2 focus:ring-[#2e4096]/20">
                  <option value="online" selected={advancedSettings.mentorship_preferences.preferred_mode === 'online'}>Online (Video call, chat)</option>
                  <option value="in-person" selected={advancedSettings.mentorship_preferences.preferred_mode === 'in-person'}>In-person (Face-to-face)</option>
                  <option value="either" selected={advancedSettings.mentorship_preferences.preferred_mode === 'either'}>Either (No preference)</option>
                </select>
              </label>
            </div>
          </section>

          <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <div class="rounded-2xl bg-[#2e4096]/10 p-3 text-[#2e4096]">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path>
                  <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                </svg>
              </div>
              <div>
                <h2 class="text-xl font-semibold text-slate-900">Notifications</h2>
              </div>
            </div>

            <div class="mt-6 space-y-4">
              <label class="flex items-start justify-between gap-4 rounded-2xl border border-slate-200 px-4 py-4">
                <p class="font-medium text-slate-900">Email me when someone connects with me</p>
                <input id="connection_requests" name="connection_requests" type="checkbox" class="mt-1 h-4 w-4 rounded border-slate-300 text-[#2e4096] focus:ring-[#2e4096]" checked={advancedSettings.notification_preferences.connection_requests} />
              </label>

              <label class="flex items-start justify-between gap-4 rounded-2xl border border-slate-200 px-4 py-4">
                <p class="font-medium text-slate-900">Email me about upcoming events</p>
                <input id="upcoming_events" name="upcoming_events" type="checkbox" class="mt-1 h-4 w-4 rounded border-slate-300 text-[#2e4096] focus:ring-[#2e4096]" checked={advancedSettings.notification_preferences.upcoming_events} />
              </label>

              <label class="flex items-start justify-between gap-4 rounded-2xl border border-slate-200 px-4 py-4">
                <p class="font-medium text-slate-900">Email me mentorship request notifications</p>
                <input id="mentorship_requests" name="mentorship_requests" type="checkbox" class="mt-1 h-4 w-4 rounded border-slate-300 text-[#2e4096] focus:ring-[#2e4096]" checked={advancedSettings.notification_preferences.mentorship_requests} />
              </label>

              <label class="flex items-start justify-between gap-4 rounded-2xl border border-slate-200 px-4 py-4">
                <p class="font-medium text-slate-900">Weekly digest of new alumni</p>
                <input id="weekly_digest" name="weekly_digest" type="checkbox" class="mt-1 h-4 w-4 rounded border-slate-300 text-[#2e4096] focus:ring-[#2e4096]" checked={advancedSettings.notification_preferences.weekly_digest} />
              </label>

              <label class="block rounded-2xl border border-slate-200 px-4 py-4">
                <p class="font-medium text-slate-900">Email Digest Frequency</p>
                <select id="digest_frequency" name="digest_frequency" class="mt-3 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-[#2e4096] focus:outline-none focus:ring-2 focus:ring-[#2e4096]/20">
                  <option value="daily" selected={advancedSettings.notification_preferences.digest_frequency === 'daily'}>Daily</option>
                  <option value="weekly" selected={advancedSettings.notification_preferences.digest_frequency === 'weekly'}>Weekly</option>
                  <option value="never" selected={advancedSettings.notification_preferences.digest_frequency === 'never'}>Never</option>
                </select>
                <p class="mt-2 text-sm text-slate-500">Controls how often you receive digest emails. 'Never' disables all digest emails.</p>
              </label>

              <label class="flex items-start justify-between gap-4 rounded-2xl border border-slate-200 px-4 py-4">
                <div>
                  <p class="font-medium text-slate-900">Notify me when admin verifies my profile</p>
                  <p class="text-sm text-slate-500">Receive an email notification when an administrator verifies your alumni profile.</p>
                </div>
                <input id="notify_on_verification" name="notify_on_verification" type="checkbox" class="mt-1 h-4 w-4 rounded border-slate-300 text-[#2e4096] focus:ring-[#2e4096]" checked={advancedSettings.notification_preferences.notify_on_verification} />
              </label>
            </div>
          </section>

          <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <div class="rounded-2xl bg-[#2e4096]/10 p-3 text-[#2e4096]">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10 13a5 5 0 0 1 7 0l1 1a5 5 0 0 1-7 7l-1-1"></path>
                  <path d="M14 11a5 5 0 0 1-7 0l-1-1a5 5 0 0 1 7-7l1 1"></path>
                </svg>
              </div>
              <div>
                <h2 class="text-xl font-semibold text-slate-900">Connected Accounts</h2>
              </div>
            </div>

            <div class="mt-6 space-y-4">
              <div class="rounded-2xl border border-slate-200 px-4 py-4">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex gap-3">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="#0a66c2" aria-hidden="true">
                      <path d="M20.45 20.45h-3.56v-5.58c0-1.33-.03-3.05-1.86-3.05-1.86 0-2.14 1.45-2.14 2.95v5.68H9.33V9h3.42v1.56h.05c.48-.9 1.64-1.86 3.37-1.86 3.6 0 4.27 2.37 4.27 5.46v6.29zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45z"></path>
                    </svg>
                    <div>
                      <p class="font-medium text-slate-900">LinkedIn</p>
                      <p class="text-sm text-slate-500">Your LinkedIn URL is used to display your profile link in the alumni directory.</p>
                    </div>
                  </div>
                  <span class={`inline-flex rounded-full px-3 py-1 text-xs font-semibold ${advancedSettings.connected_accounts.linkedin_connected ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600'}`}>
                    {advancedSettings.connected_accounts.linkedin_connected ? 'Connected' : 'Not connected'}
                  </span>
                </div>
                {advancedSettings.connected_accounts.linkedin_connected && (
                  <a href={advancedSettings.connected_accounts.linkedin_url} target="_blank" rel="noopener noreferrer" class="mt-2 block truncate text-sm text-[#2e4096] hover:underline">
                    {advancedSettings.connected_accounts.linkedin_url}
                  </a>
                )}
                <label class="mt-3 block">
                  <input id="linkedin_url" name="linkedin_url" type="url" placeholder="https://linkedin.com/in/yourprofile" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-[#2e4096] focus:outline-none focus:ring-2 focus:ring-[#2e4096]/20" value={advancedSettings.connected_accounts.linkedin_url} />
                  <p id="linkedin_url_error" class="mt-1 hidden text-sm text-red-600"></p>
                </label>
              </div>

              <div class="rounded-2xl border border-slate-200 px-4 py-4">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex gap-3">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="#111827" aria-hidden="true">
                      <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.38 7.86 10.9.57.1.78-.25.78-.56 0-.27-.01-1.17-.02-2.13-3.2.69-3.88-1.36-3.88-1.36-.53-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.16.08 1.77 1.18 1.77 1.18 1.02 1.76 2.68 1.25 3.33.96.1-.74.4-1.25.73-1.53-2.56-.29-5.26-1.28-5.26-5.69 0-1.26.45-2.3 1.18-3.12-.12-.29-.51-1.47.11-3.06 0 0 .97-.31 3.18 1.19a10.94 10.94 0 0 1 5.79 0c2.2-1.5 3.17-1.19 3.17-1.19.63 1.59.24 2.77.12 3.06.74.82 1.18 1.86 1.18 3.12 0 4.42-2.71 5.4-5.29 5.68.41.36.78 1.05.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.2.67.79.55A11.52 11.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z"></path>
                    </svg>
                    <div>
                      <p class="font-medium text-slate-900">GitHub</p>
                      <p class="text-sm text-slate-500">Your GitHub URL is displayed on your profile and used for technical networking.</p>
                    </div>
                  </div>
                  <span class={`inline-flex rounded-full px-3 py-1 text-xs font-semibold ${advancedSettings.connected_accounts.github_connected ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600'}`}>
                    {advancedSettings.connected_accounts.github_connected ? 'Connected' : 'Not connected'}
                  </span>
                </div>
                {advancedSettings.connected_accounts.github_connected && (
                  <a href={advancedSettings.connected_accounts.github_url} target="_blank" rel="noopener noreferrer" class="mt-2 block truncate text-sm text-[#2e4096] hover:underline">
                    {advancedSettings.connected_accounts.github_url}
                  </a>
                )}
                <label class="mt-3 block">
                  <input id="github_url" name="github_url" type="url" placeholder="https://github.com/yourusername" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-[#2e4096] focus:outline-none focus:ring-2 focus:ring-[#2e4096]/20" value={advancedSettings.connected_accounts.github_url} />
                  <p id="github_url_error" class="mt-1 hidden text-sm text-red-600"></p>
                </label>
              </div>
            </div>

            <p class="mt-4 text-sm text-slate-500">Updating these URLs also updates your public profile links. Clearing a URL removes the connection.</p>
          </section>

          <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <div class="rounded-2xl bg-[#2e4096]/10 p-3 text-[#2e4096]">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="2" y1="12" x2="22" y2="12"></line>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </svg>
              </div>
              <div>
                <h2 class="text-xl font-semibold text-slate-900">Accessibility</h2>
              </div>
            </div>

            <label class="mt-6 block rounded-2xl border border-slate-200 px-4 py-4">
              <p class="font-medium text-slate-900">Preferred Language / Locale</p>
              <p class="mt-1 text-sm text-slate-500">Select your preferred display language. Additional languages will be available in future updates.</p>
              <select id="preferred_language" name="preferred_language" class="mt-3 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-[#2e4096] focus:outline-none focus:ring-2 focus:ring-[#2e4096]/20">
                <option value="en" selected={advancedSettings.accessibility.preferred_language === 'en'}>English (Default)</option>
                <option value="hi" selected={advancedSettings.accessibility.preferred_language === 'hi'}>Hindi / हिंदी</option>
                <option value="mr" selected={advancedSettings.accessibility.preferred_language === 'mr'}>Marathi / मराठी</option>
                <option value="gu" selected={advancedSettings.accessibility.preferred_language === 'gu'}>Gujarati / ગુજરાતી</option>
                <option value="ta" selected={advancedSettings.accessibility.preferred_language === 'ta'}>Tamil / தமிழ்</option>
                <option value="te" selected={advancedSettings.accessibility.preferred_language === 'te'}>Telugu / తెలుగు</option>
                <option value="kn" selected={advancedSettings.accessibility.preferred_language === 'kn'}>Kannada / ಕನ್ನಡ</option>
                <option value="bn" selected={advancedSettings.accessibility.preferred_language === 'bn'}>Bengali / বাংলা</option>
                <option value="fr" selected={advancedSettings.accessibility.preferred_language === 'fr'}>French / Français</option>
                <option value="de" selected={advancedSettings.accessibility.preferred_language === 'de'}>German / Deutsch</option>
                <option value="es" selected={advancedSettings.accessibility.preferred_language === 'es'}>Spanish / Español</option>
                <option value="ar" selected={advancedSettings.accessibility.preferred_language === 'ar'}>Arabic / العربية</option>
                <option value="zh" selected={advancedSettings.accessibility.preferred_language === 'zh'}>Chinese / 中文</option>
                <option value="ja" selected={advancedSettings.accessibility.preferred_language === 'ja'}>Japanese / 日本語</option>
                <option value="pt" selected={advancedSettings.accessibility.preferred_language === 'pt'}>Portuguese / Português</option>
              </select>
              <p class="mt-2 text-sm text-slate-500">Language preference is saved but full i18n support is coming in a future release. Currently affects date/number formatting.</p>
            </label>
          </section>

          <button type="submit" id="saveBtn" class="flex w-full items-center justify-center gap-2 rounded-xl bg-[#2e4096] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#24367d] disabled:opacity-70 disabled:cursor-not-allowed">
            <svg id="saveBtnIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform">
              <path d="M20 6L9 17l-5-5"></path>
            </svg>
            <span id="saveBtnText">Save All Settings</span>
          </button>
        </form>
      )}
    </div>
  </main>
</Layout>

<script is:inline>
  const form = document.getElementById('advancedSettingsForm');
  const message = document.getElementById('settingsMessage');
  const saveBtn = document.getElementById('saveBtn');
  const saveBtnText = document.getElementById('saveBtnText');
  const saveBtnIcon = document.getElementById('saveBtnIcon');

  const linkedinInput = document.getElementById('linkedin_url');
  const githubInput = document.getElementById('github_url');
  const linkedinError = document.getElementById('linkedin_url_error');
  const githubError = document.getElementById('github_url_error');

  const setBanner = (text, isError = false) => {
    if (!message) return;
    message.textContent = text;
    message.className = `rounded-2xl border px-4 py-3 text-sm ${isError ? 'border-red-200 bg-red-50 text-red-700' : 'border-emerald-200 bg-emerald-50 text-emerald-700'}`;
  };

  const clearBanner = () => {
    if (!message) return;
    message.textContent = '';
    message.className = 'hidden rounded-2xl border px-4 py-3 text-sm';
  };

  const setUrlError = (target, errorTarget, text) => {
    if (!(target instanceof HTMLInputElement) || !(errorTarget instanceof HTMLElement)) return;
    if (!text) {
      errorTarget.textContent = '';
      errorTarget.classList.add('hidden');
      target.classList.remove('border-red-400', 'focus:border-red-500', 'focus:ring-red-200');
      return;
    }

    errorTarget.textContent = text;
    errorTarget.classList.remove('hidden');
    target.classList.add('border-red-400', 'focus:border-red-500', 'focus:ring-red-200');
  };

  const validateHttpsUrl = (target, errorTarget) => {
    if (!(target instanceof HTMLInputElement)) return true;
    const value = target.value.trim();

    if (!value) {
      setUrlError(target, errorTarget, '');
      return true;
    }

    if (!value.startsWith('https://')) {
      setUrlError(target, errorTarget, 'URL must start with https://');
      return false;
    }

    try {
      new URL(value);
      setUrlError(target, errorTarget, '');
      return true;
    } catch {
      setUrlError(target, errorTarget, 'Please enter a valid URL.');
      return false;
    }
  };

  linkedinInput?.addEventListener('input', () => validateHttpsUrl(linkedinInput, linkedinError));
  githubInput?.addEventListener('input', () => validateHttpsUrl(githubInput, githubError));

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const linkedinValid = validateHttpsUrl(linkedinInput, linkedinError);
    const githubValid = validateHttpsUrl(githubInput, githubError);

    if (!linkedinValid || !githubValid) {
      setBanner('Please correct the URL errors before saving.', true);
      return;
    }

    clearBanner();

    const checkboxValue = (id) => {
      const element = document.getElementById(id);
      return element instanceof HTMLInputElement ? element.checked : false;
    };

    const selectValue = (id) => {
      const element = document.getElementById(id);
      return element instanceof HTMLSelectElement ? element.value : '';
    };

    const inputValue = (id) => {
      const element = document.getElementById(id);
      return element instanceof HTMLInputElement ? element.value.trim() : '';
    };

    const payload = {
      profile_visibility: {
        show_in_directory: checkboxValue('show_in_directory'),
        show_email_publicly: checkboxValue('show_email_publicly'),
        allow_connection_requests: checkboxValue('allow_connection_requests'),
      },
      mentorship_preferences: {
        open_to_mentorship: checkboxValue('open_to_mentorship'),
        looking_for_mentor: checkboxValue('looking_for_mentor'),
        preferred_mode: selectValue('preferred_mode'),
      },
      notification_preferences: {
        connection_requests: checkboxValue('connection_requests'),
        upcoming_events: checkboxValue('upcoming_events'),
        mentorship_requests: checkboxValue('mentorship_requests'),
        weekly_digest: checkboxValue('weekly_digest'),
        digest_frequency: selectValue('digest_frequency'),
        notify_on_verification: checkboxValue('notify_on_verification'),
      },
      connected_accounts: {
        linkedin_url: inputValue('linkedin_url'),
        github_url: inputValue('github_url'),
      },
      accessibility: {
        preferred_language: selectValue('preferred_language'),
      },
    };

    if (saveBtn instanceof HTMLButtonElement) {
      saveBtn.disabled = true;
    }
    if (saveBtnText instanceof HTMLElement) {
      saveBtnText.textContent = 'Saving...';
    }
    if (saveBtnIcon instanceof SVGElement) {
      saveBtnIcon.innerHTML = '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" opacity="0.3"></circle><path d="M21 12a9 9 0 0 1-9 9" stroke="currentColor" stroke-width="2"><animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="1s" repeatCount="indefinite"/></path>';
    }

    try {
      const response = await fetch('/api/alumni/advanced-settings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await response.json();

      if (!response.ok) {
        throw new Error(data?.error || 'Failed to save settings.');
      }

      setBanner('Settings saved successfully.');
    } catch (error) {
      setBanner(error instanceof Error ? error.message : 'Failed to save settings.', true);
    } finally {
      if (saveBtn instanceof HTMLButtonElement) {
        saveBtn.disabled = false;
      }
      if (saveBtnText instanceof HTMLElement) {
        saveBtnText.textContent = 'Save All Settings';
      }
      if (saveBtnIcon instanceof SVGElement) {
        saveBtnIcon.innerHTML = '<path d="M20 6L9 17l-5-5"></path>';
      }
    }
  });
</script>
