---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getSiteConfig } from '../../utils/config';

const config = getSiteConfig();
const tempToken = Astro.url.searchParams.get('tempToken') || '';
const redirect = Astro.url.searchParams.get('redirect') || '/';
---

<Layout title={`Two-Factor Challenge | ${config.site.name}`}>
  <main class="min-h-screen bg-slate-50 px-4 py-16">
    <div class="mx-auto max-w-md rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
      <h1 class="text-2xl font-bold text-slate-900">Two-Factor Authentication</h1>
      <p class="mt-2 text-sm text-slate-600">Enter the 6-digit code from your authenticator app or one of your backup codes.</p>

      <form id="twoFaChallengeForm" class="mt-6 space-y-4">
        <input type="hidden" id="tempToken" value={tempToken} />
        <input type="hidden" id="redirectPath" value={redirect} />
        <div>
          <label for="totpCode" class="block text-sm font-medium text-slate-700">Verification code</label>
          <input id="totpCode" maxlength="8" inputmode="numeric" class="mt-2 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-200" placeholder="123456" required />
        </div>
        <button type="submit" class="w-full rounded-lg bg-primary-600 px-4 py-2 text-sm font-semibold text-white hover:bg-primary-700">Verify and continue</button>
        <p id="challengeMessage" class="text-sm"></p>
      </form>
    </div>
  </main>
</Layout>

<script>
  document.getElementById('twoFaChallengeForm')?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const message = document.getElementById('challengeMessage');
    const tempToken = document.getElementById('tempToken')?.value || '';
    const totpCode = document.getElementById('totpCode')?.value || '';
    const redirectPath = document.getElementById('redirectPath')?.value || '/';

    try {
      const response = await fetch('/api/auth/2fa-login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tempToken, totpCode }),
      });
      const result = await response.json();

      if (!response.ok || !result.success) {
        throw new Error('Invalid verification code. Please try again.');
      }

      window.location.href = redirectPath.startsWith('/') ? redirectPath : '/';
    } catch (error) {
      console.error('2FA challenge error:', error);
      message.textContent = error.message || 'Unable to verify the code.';
      message.className = 'text-sm text-red-700';
    }
  });
</script>
