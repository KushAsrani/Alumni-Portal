---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { isAlumniAuthenticated } from '../../lib/alumni-auth';

if (!isAlumniAuthenticated(Astro.cookies)) {
  return Astro.redirect('/alumni/login');
}
---

<Layout title="Change Password | Alumni Portal">
  <main class="min-h-screen bg-slate-50 py-8 md:py-12">
    <div class="container-custom mx-auto max-w-3xl px-4">
      <a
        href="/alumni/settings"
        class="inline-flex items-center gap-2 text-sm font-medium text-[#2e4096] transition hover:text-[#24367d]"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        Back to Settings
      </a>

      <section class="mt-4 rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="flex items-center gap-3">
          <div class="rounded-2xl bg-[#2e4096]/10 p-3 text-[#2e4096]">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="10" rx="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-slate-900">Change Password</h1>
            <p class="text-sm text-slate-500">Update your sign-in credentials.</p>
          </div>
        </div>

        <div id="changePasswordMessage" class="mt-6 hidden rounded-2xl border px-4 py-3 text-sm" role="status"></div>

        <form id="changePasswordForm" class="mt-6 space-y-5" novalidate>
          <div>
            <label for="currentPassword" class="block text-sm font-medium text-slate-700">Old Password</label>
            <div class="relative mt-2">
              <input
                id="currentPassword"
                name="currentPassword"
                type="password"
                class="w-full rounded-2xl border border-slate-300 px-4 py-3 pr-12 text-sm text-slate-900 outline-none transition focus:border-[#2e4096] focus:ring-2 focus:ring-[#2e4096]/20"
                autocomplete="current-password"
                aria-describedby="currentPassword-error"
                required
              />
              <button type="button" class="password-toggle absolute inset-y-0 right-0 flex items-center px-4 text-slate-500 hover:text-slate-700" data-target="currentPassword" aria-label="Show old password">
                <svg class="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"></path>
                  <circle cx="12" cy="12" r="3"></circle>
                </svg>
                <svg class="eye-closed hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17.94 17.94A10.94 10.94 0 0 1 12 20C5 20 1 12 1 12a21.87 21.87 0 0 1 5.06-7.94"></path>
                  <path d="M9.9 4.24A10.83 10.83 0 0 1 12 4c7 0 11 8 11 8a21.77 21.77 0 0 1-3.22 5.07"></path>
                  <path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"></path>
                  <line x1="1" y1="1" x2="23" y2="23"></line>
                </svg>
              </button>
            </div>
            <p id="currentPassword-error" class="error-text hidden text-xs mt-1 text-red-600" data-error-for="currentPassword" role="alert"></p>
          </div>

          <div>
            <label for="newPassword" class="block text-sm font-medium text-slate-700">New Password</label>
            <div class="relative mt-2">
              <input
                id="newPassword"
                name="newPassword"
                type="password"
                class="w-full rounded-2xl border border-slate-300 px-4 py-3 pr-12 text-sm text-slate-900 outline-none transition focus:border-[#2e4096] focus:ring-2 focus:ring-[#2e4096]/20"
                autocomplete="new-password"
                aria-describedby="newPassword-error"
                required
              />
              <button type="button" class="password-toggle absolute inset-y-0 right-0 flex items-center px-4 text-slate-500 hover:text-slate-700" data-target="newPassword" aria-label="Show new password">
                <svg class="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"></path>
                  <circle cx="12" cy="12" r="3"></circle>
                </svg>
                <svg class="eye-closed hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17.94 17.94A10.94 10.94 0 0 1 12 20C5 20 1 12 1 12a21.87 21.87 0 0 1 5.06-7.94"></path>
                  <path d="M9.9 4.24A10.83 10.83 0 0 1 12 4c7 0 11 8 11 8a21.77 21.77 0 0 1-3.22 5.07"></path>
                  <path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"></path>
                  <line x1="1" y1="1" x2="23" y2="23"></line>
                </svg>
              </button>
            </div>
            <p class="mt-1 text-xs text-slate-500">Minimum 8 characters, must include uppercase, lowercase, and a number.</p>
            <div class="mt-2 h-2 w-full rounded-full bg-slate-200">
              <div id="passwordStrengthBar" class="h-2 w-0 rounded-full bg-red-500 transition-all duration-200"></div>
            </div>
            <p id="newPassword-error" class="error-text hidden text-xs mt-1 text-red-600" data-error-for="newPassword" role="alert"></p>
          </div>

          <div>
            <label for="confirmNewPassword" class="block text-sm font-medium text-slate-700">Confirm New Password</label>
            <div class="relative mt-2">
              <input
                id="confirmNewPassword"
                name="confirmNewPassword"
                type="password"
                class="w-full rounded-2xl border border-slate-300 px-4 py-3 pr-12 text-sm text-slate-900 outline-none transition focus:border-[#2e4096] focus:ring-2 focus:ring-[#2e4096]/20"
                autocomplete="new-password"
                aria-describedby="confirmNewPassword-error"
                required
              />
              <button type="button" class="password-toggle absolute inset-y-0 right-0 flex items-center px-4 text-slate-500 hover:text-slate-700" data-target="confirmNewPassword" aria-label="Show confirm new password">
                <svg class="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"></path>
                  <circle cx="12" cy="12" r="3"></circle>
                </svg>
                <svg class="eye-closed hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17.94 17.94A10.94 10.94 0 0 1 12 20C5 20 1 12 1 12a21.87 21.87 0 0 1 5.06-7.94"></path>
                  <path d="M9.9 4.24A10.83 10.83 0 0 1 12 4c7 0 11 8 11 8a21.77 21.77 0 0 1-3.22 5.07"></path>
                  <path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"></path>
                  <line x1="1" y1="1" x2="23" y2="23"></line>
                </svg>
              </button>
            </div>
            <p id="confirmNewPassword-error" class="error-text hidden text-xs mt-1 text-red-600" data-error-for="confirmNewPassword" role="alert"></p>
          </div>

          <button
            id="changePasswordSubmit"
            type="submit"
            class="inline-flex items-center justify-center rounded-2xl bg-[#2e4096] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#24367d]"
          >
            Update Password
          </button>
        </form>
      </section>
    </div>
  </main>
</Layout>

<style>
  .input-error {
    border-color: rgb(220 38 38);
  }

  .error-text.hidden {
    display: none;
  }
</style>

<script>
  const form = document.getElementById('changePasswordForm');
  const message = document.getElementById('changePasswordMessage');
  const submitButton = document.getElementById('changePasswordSubmit');
  const newPasswordInput = document.getElementById('newPassword');
  const strengthBar = document.getElementById('passwordStrengthBar');

  function getErrorElement(fieldName) {
    return document.querySelector('[data-error-for="' + fieldName + '"]');
  }

  function getInputElement(fieldName) {
    return document.querySelector('[name="' + fieldName + '"]');
  }

  function showFieldError(fieldName, text) {
    const errorElement = getErrorElement(fieldName);
    const inputElement = getInputElement(fieldName);

    if (errorElement) {
      errorElement.textContent = text;
      errorElement.classList.remove('hidden');
    }

    if (inputElement) {
      inputElement.classList.add('input-error');
      inputElement.setAttribute('aria-invalid', 'true');
    }
  }

  function clearFieldError(fieldName) {
    const errorElement = getErrorElement(fieldName);
    const inputElement = getInputElement(fieldName);

    if (errorElement) {
      errorElement.textContent = '';
      errorElement.classList.add('hidden');
    }

    if (inputElement) {
      inputElement.classList.remove('input-error');
      inputElement.removeAttribute('aria-invalid');
    }
  }

  function clearAllErrors() {
    ['currentPassword', 'newPassword', 'confirmNewPassword'].forEach(clearFieldError);
  }

  function setMessage(text, type) {
    message.textContent = text;
    message.className = 'mt-6 rounded-2xl border px-4 py-3 text-sm';
    message.classList.remove('hidden');

    if (type === 'success') {
      message.classList.add('border-emerald-200', 'bg-emerald-50', 'text-emerald-700');
      return;
    }

    message.classList.add('border-red-200', 'bg-red-50', 'text-red-700');
  }

  function updateStrengthMeter(password) {
    const checks = [
      password.length >= 8,
      /[A-Z]/.test(password),
      /[a-z]/.test(password),
      /[0-9]/.test(password),
    ];
    const score = checks.filter(Boolean).length;
    const width = Math.max((score / 4) * 100, password.length > 0 ? 10 : 0);

    strengthBar.style.width = width + '%';
    strengthBar.classList.remove('bg-red-500', 'bg-amber-500', 'bg-emerald-500');

    if (score <= 1) {
      strengthBar.classList.add('bg-red-500');
    } else if (score <= 3) {
      strengthBar.classList.add('bg-amber-500');
    } else {
      strengthBar.classList.add('bg-emerald-500');
    }
  }

  document.querySelectorAll('.password-toggle').forEach((button) => {
    button.addEventListener('click', () => {
      const targetId = button.getAttribute('data-target');
      const input = targetId ? document.getElementById(targetId) : null;
      if (!input) return;

      const isPassword = input.getAttribute('type') === 'password';
      input.setAttribute('type', isPassword ? 'text' : 'password');
      button.querySelector('.eye-open')?.classList.toggle('hidden', isPassword);
      button.querySelector('.eye-closed')?.classList.toggle('hidden', !isPassword);
    });
  });

  form?.querySelectorAll('input').forEach((input) => {
    input.addEventListener('input', (event) => {
      const target = event.target;
      const fieldName = target.getAttribute('name');
      if (fieldName) {
        clearFieldError(fieldName);
      }
      if (message) {
        message.classList.add('hidden');
      }
    });
  });

  newPasswordInput?.addEventListener('input', () => {
    updateStrengthMeter(newPasswordInput.value);
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    clearAllErrors();
    if (message) {
      message.classList.add('hidden');
      message.textContent = '';
    }

    const currentPassword = form.querySelector('[name="currentPassword"]')?.value || '';
    const newPassword = form.querySelector('[name="newPassword"]')?.value || '';
    const confirmNewPassword = form.querySelector('[name="confirmNewPassword"]')?.value || '';

    let hasError = false;

    if (!currentPassword.trim()) {
      showFieldError('currentPassword', 'Old password is required');
      hasError = true;
    }

    if (!newPassword) {
      showFieldError('newPassword', 'New password is required');
      hasError = true;
    }

    if (newPassword.length < 8) {
      showFieldError('newPassword', 'Password must be at least 8 characters');
      hasError = true;
    }

    if (!/[A-Z]/.test(newPassword) || !/[a-z]/.test(newPassword) || !/[0-9]/.test(newPassword)) {
      showFieldError('newPassword', 'Password must include uppercase, lowercase characters, and a number');
      hasError = true;
    }

    if (newPassword !== confirmNewPassword) {
      showFieldError('confirmNewPassword', 'Passwords do not match');
      hasError = true;
    }

    if (currentPassword && newPassword && currentPassword === newPassword) {
      showFieldError('newPassword', 'New password must be different from your old password');
      hasError = true;
    }

    if (hasError) {
      return;
    }

    try {
      submitButton.disabled = true;
      submitButton.classList.add('opacity-70', 'cursor-not-allowed');

      const response = await fetch('/api/alumni/change-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ currentPassword, newPassword, confirmNewPassword }),
      });

      const result = await response.json();

      if (!response.ok) {
        setMessage(result?.error || 'An error occurred. Please try again.', 'error');
        return;
      }

      setMessage('Your password has been changed successfully.', 'success');
      form.reset();
      updateStrengthMeter('');

      window.setTimeout(() => {
        window.location.href = '/alumni/settings';
      }, 2000);
    } catch (error) {
      console.error('Change password page error:', error);
      setMessage('An error occurred. Please try again.', 'error');
    } finally {
      submitButton.disabled = false;
      submitButton.classList.remove('opacity-70', 'cursor-not-allowed');
    }
  });
</script>
