---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { isAlumniAuthenticated } from '../../lib/alumni-auth';

if (!isAlumniAuthenticated(Astro.cookies)) {
  return Astro.redirect('/alumni/login');
}
---

<Layout title="Change Password | Alumni Portal">
  <main class="min-h-screen bg-slate-50 py-8 md:py-12">
    <div class="container-custom mx-auto max-w-3xl px-4">
      <a
        href="/alumni/settings"
        class="inline-flex items-center gap-2 text-sm font-medium text-[#2e4096] transition hover:text-[#24367d]"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        Back to Settings
      </a>

      <section class="mt-4 rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="flex items-center gap-3">
          <div class="rounded-2xl bg-[#2e4096]/10 p-3 text-[#2e4096]">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="10" rx="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-slate-900">Change Password</h1>
            <p class="text-sm text-slate-500">This screen is ready for the password update flow.</p>
          </div>
        </div>

        <div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 p-5">
          <p class="text-sm text-slate-600">
            Password management will be available here soon. Until then, use the rest of the settings page to manage your profile,
            security, and privacy preferences.
          </p>
        </div>
      </section>
    </div>
  </main>
</Layout>
