---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
---

<Layout title="Alumni Analytics">
  <!-- Page Header with gradient -->
  <div class="bg-gradient-to-r from-primary-700 via-primary-600 to-primary-500 text-white py-10 md:py-14">
    <div class="container mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div class="flex items-start gap-4">
          <div class="bg-white/20 rounded-2xl p-3 shrink-0">
            <iconify-icon icon="mdi:chart-areaspline" width="32" height="32"></iconify-icon>
          </div>
          <div>
            <div class="flex items-center gap-3 mb-1">
              <h1 class="text-3xl md:text-4xl font-bold">Alumni Analytics</h1>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-green-400/20 text-green-100 border border-green-300/30">
                <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
                Live Data
              </span>
            </div>
            <p class="text-primary-100">Live insights from approved alumni profiles.</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <span id="last-updated" class="text-sm text-primary-200">Last updated: --</span>
          <button
            id="refresh-btn"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/20 text-white hover:bg-white/30 border border-white/30 transition-colors font-medium"
            type="button"
          >
            <iconify-icon icon="mdi:refresh" width="18" height="18"></iconify-icon>
            Refresh
          </button>
        </div>
      </div>
    </div>
  </div>

  <section class="py-8 md:py-12 bg-gray-50 min-h-screen">
    <div class="container mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 space-y-8">

      <div id="loading-state" class="rounded-2xl border border-gray-100 bg-white shadow-sm p-12 flex items-center justify-center gap-3">
        <div class="w-6 h-6 rounded-full border-2 border-primary-600 border-t-transparent animate-spin"></div>
        <span class="text-accent-600 font-medium">Loading analytics...</span>
      </div>

      <div id="error-state" class="hidden rounded-2xl border border-red-100 bg-red-50 p-8 shadow-sm">
        <div class="flex flex-col items-center text-center gap-4">
          <div class="w-14 h-14 bg-red-100 rounded-full flex items-center justify-center">
            <iconify-icon icon="mdi:alert-circle" width="32" height="32" class="text-red-500"></iconify-icon>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-red-700 mb-1">Failed to load analytics</h3>
            <p id="error-message" class="text-sm text-red-600 mb-4">Unable to load analytics right now. Please try again.</p>
          </div>
          <button
            id="retry-btn"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-red-600 text-white hover:bg-red-700 transition-colors font-medium text-sm"
            type="button"
          >
            <iconify-icon icon="mdi:refresh" width="16" height="16"></iconify-icon>
            Try Again
          </button>
        </div>
      </div>

      <div id="dashboard-content" class="hidden space-y-8">

        <!-- Hero Stats Section -->
        <section>
          <p class="text-xs font-semibold uppercase tracking-widest text-accent-400 mb-4">Overview</p>
          <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-4">
            <div class="bg-white rounded-2xl border-l-4 border-l-primary-500 border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-4">
              <div class="flex items-center justify-between mb-3">
                <p class="text-xs uppercase tracking-wide text-accent-500 font-medium">Total Alumni</p>
                <div class="bg-primary-50 rounded-full p-2">
                  <iconify-icon icon="mdi:account-group" width="18" height="18" class="text-primary-600"></iconify-icon>
                </div>
              </div>
              <p id="total-alumni" class="text-3xl font-extrabold text-accent-900">0</p>
            </div>
            <div class="bg-white rounded-2xl border-l-4 border-l-blue-500 border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-4">
              <div class="flex items-center justify-between mb-3">
                <p class="text-xs uppercase tracking-wide text-accent-500 font-medium">Faculties</p>
                <div class="bg-blue-50 rounded-full p-2">
                  <iconify-icon icon="mdi:school" width="18" height="18" class="text-blue-600"></iconify-icon>
                </div>
              </div>
              <p id="total-faculties" class="text-3xl font-extrabold text-accent-900">0</p>
            </div>
            <div class="bg-white rounded-2xl border-l-4 border-l-violet-500 border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-4">
              <div class="flex items-center justify-between mb-3">
                <p class="text-xs uppercase tracking-wide text-accent-500 font-medium">Grad. Years</p>
                <div class="bg-violet-50 rounded-full p-2">
                  <iconify-icon icon="mdi:calendar-range" width="18" height="18" class="text-violet-600"></iconify-icon>
                </div>
              </div>
              <p id="total-years" class="text-3xl font-extrabold text-accent-900">0</p>
            </div>
            <div class="bg-white rounded-2xl border-l-4 border-l-emerald-500 border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-4">
              <div class="flex items-center justify-between mb-3">
                <p class="text-xs uppercase tracking-wide text-accent-500 font-medium">Open to Mentor</p>
                <div class="bg-emerald-50 rounded-full p-2">
                  <iconify-icon icon="mdi:handshake" width="18" height="18" class="text-emerald-600"></iconify-icon>
                </div>
              </div>
              <p id="open-mentor" class="text-3xl font-extrabold text-accent-900">0</p>
              <p id="open-mentor-pct" class="text-xs text-accent-500 mt-1"></p>
            </div>
            <div class="bg-white rounded-2xl border-l-4 border-l-amber-500 border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-4">
              <div class="flex items-center justify-between mb-3">
                <p class="text-xs uppercase tracking-wide text-accent-500 font-medium">Open to Work</p>
                <div class="bg-amber-50 rounded-full p-2">
                  <iconify-icon icon="mdi:briefcase-search" width="18" height="18" class="text-amber-600"></iconify-icon>
                </div>
              </div>
              <p id="open-work" class="text-3xl font-extrabold text-accent-900">0</p>
              <p id="open-work-pct" class="text-xs text-accent-500 mt-1"></p>
            </div>
            <div class="bg-white rounded-2xl border-l-4 border-l-rose-500 border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-4">
              <div class="flex items-center justify-between mb-3">
                <p class="text-xs uppercase tracking-wide text-accent-500 font-medium">Recently Joined</p>
                <div class="bg-rose-50 rounded-full p-2">
                  <iconify-icon icon="mdi:account-plus" width="18" height="18" class="text-rose-600"></iconify-icon>
                </div>
              </div>
              <p id="recently-joined" class="text-3xl font-extrabold text-accent-900">0</p>
              <p class="text-xs text-accent-500 mt-1">Last 30 days</p>
            </div>
          </div>
        </section>

        <!-- Skills Cloud -->
        <section class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="bg-primary-50 rounded-full p-2">
              <iconify-icon icon="mdi:tag-multiple" width="20" height="20" class="text-primary-600"></iconify-icon>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-accent-400">Skills</p>
              <h2 class="text-lg font-semibold text-accent-900">Top Skills Across Alumni</h2>
            </div>
          </div>
          <div id="skills-cloud" class="flex flex-wrap items-center gap-3"></div>
        </section>

        <!-- Faculty + Year Charts -->
        <section class="grid grid-cols-1 xl:grid-cols-2 gap-6">
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-6">
            <div class="flex items-center gap-3 mb-5">
              <div class="bg-blue-50 rounded-full p-2">
                <iconify-icon icon="mdi:chart-bar" width="20" height="20" class="text-blue-600"></iconify-icon>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-accent-400">Distribution</p>
                <h2 class="text-lg font-semibold text-accent-900">Alumni by Faculty</h2>
              </div>
            </div>
            <div id="faculty-chart" class="space-y-3"></div>
          </div>

          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-6">
            <div class="flex items-center gap-3 mb-5">
              <div class="bg-violet-50 rounded-full p-2">
                <iconify-icon icon="mdi:chart-timeline-variant" width="20" height="20" class="text-violet-600"></iconify-icon>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-accent-400">Timeline</p>
                <h2 class="text-lg font-semibold text-accent-900">Alumni by Graduation Year</h2>
              </div>
            </div>
            <!-- h-72 = 288px; 228px usable bar area (60px reserved for count + year labels) -->
            <div id="year-chart" class="h-72 bg-gray-50 border border-gray-100 rounded-xl p-3 flex items-end gap-1.5 overflow-x-auto"></div>
          </div>
        </section>

        <!-- Companies + Locations -->
        <section class="grid grid-cols-1 xl:grid-cols-2 gap-6">
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-6">
            <div class="flex items-center gap-3 mb-5">
              <div class="bg-amber-50 rounded-full p-2">
                <iconify-icon icon="mdi:office-building" width="20" height="20" class="text-amber-600"></iconify-icon>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-accent-400">Industry</p>
                <h2 class="text-lg font-semibold text-accent-900">Top Companies / Industries</h2>
              </div>
            </div>
            <div id="companies-list" class="space-y-2"></div>
          </div>

          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-6">
            <div class="flex items-center gap-3 mb-5">
              <div class="bg-emerald-50 rounded-full p-2">
                <iconify-icon icon="mdi:map-marker-multiple" width="20" height="20" class="text-emerald-600"></iconify-icon>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-accent-400">Geography</p>
                <h2 class="text-lg font-semibold text-accent-900">Alumni by Location</h2>
              </div>
            </div>
            <div id="locations-list" class="space-y-2"></div>
          </div>
        </section>

        <!-- Profile Completeness -->
        <section>
          <p class="text-xs font-semibold uppercase tracking-widest text-accent-400 mb-4">Profile Quality</p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-5">
              <div class="flex items-center gap-3 mb-4">
                <div class="bg-primary-50 rounded-full p-2">
                  <iconify-icon icon="mdi:account-circle" width="20" height="20" class="text-primary-600"></iconify-icon>
                </div>
                <p class="text-sm font-medium text-accent-700">Profiles with Photo</p>
              </div>
              <p id="profiles-photo" class="text-3xl font-extrabold text-accent-900">0</p>
              <div class="mt-3 h-2 bg-gray-100 rounded-full overflow-hidden">
                <div id="profiles-photo-bar" class="h-full bg-gradient-to-r from-primary-500 to-primary-400 rounded-full transition-all duration-700" style="width: 0%"></div>
              </div>
              <div class="mt-2 flex items-center justify-between">
                <p id="profiles-photo-pct" class="text-xs text-accent-500"></p>
                <p id="profiles-photo-label" class="text-xs font-semibold"></p>
              </div>
            </div>
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-5">
              <div class="flex items-center gap-3 mb-4">
                <div class="bg-blue-50 rounded-full p-2">
                  <iconify-icon icon="mdi:linkedin" width="20" height="20" class="text-blue-600"></iconify-icon>
                </div>
                <p class="text-sm font-medium text-accent-700">Profiles with LinkedIn</p>
              </div>
              <p id="profiles-linkedin" class="text-3xl font-extrabold text-accent-900">0</p>
              <div class="mt-3 h-2 bg-gray-100 rounded-full overflow-hidden">
                <div id="profiles-linkedin-bar" class="h-full bg-gradient-to-r from-blue-500 to-blue-400 rounded-full transition-all duration-700" style="width: 0%"></div>
              </div>
              <div class="mt-2 flex items-center justify-between">
                <p id="profiles-linkedin-pct" class="text-xs text-accent-500"></p>
                <p id="profiles-linkedin-label" class="text-xs font-semibold"></p>
              </div>
            </div>
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-5">
              <div class="flex items-center gap-3 mb-4">
                <div class="bg-emerald-50 rounded-full p-2">
                  <iconify-icon icon="mdi:handshake" width="20" height="20" class="text-emerald-600"></iconify-icon>
                </div>
                <p class="text-sm font-medium text-accent-700">Mentorship Available</p>
              </div>
              <p id="profiles-mentorship" class="text-3xl font-extrabold text-accent-900">0</p>
              <div class="mt-3 h-2 bg-gray-100 rounded-full overflow-hidden">
                <div id="profiles-mentorship-bar" class="h-full bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full transition-all duration-700" style="width: 0%"></div>
              </div>
              <div class="mt-2 flex items-center justify-between">
                <p id="profiles-mentorship-pct" class="text-xs text-accent-500"></p>
                <p id="profiles-mentorship-label" class="text-xs font-semibold"></p>
              </div>
            </div>
          </div>
        </section>

      </div>
    </div>
  </section>

  <script>
    const $ = (id) => document.getElementById(id);

    const loadingState = $('loading-state');
    const errorState = $('error-state');
    const dashboardContent = $('dashboard-content');
    const refreshButton = $('refresh-btn');
    const retryButton = $('retry-btn');
    const lastUpdated = $('last-updated');

    const formatCount = (value) => Number(value || 0).toLocaleString();
    const formatPercent = (value, total) => {
      if (!total) return '0% of total';
      return `${((value / total) * 100).toFixed(1)}% of total`;
    };
    const calcPct = (value, total) => {
      if (!total) return 0;
      return (Number(value || 0) / total) * 100;
    };
    const completenessLabel = (pct) => {
      if (pct >= 80) return { text: 'Excellent', cls: 'text-emerald-600' };
      if (pct >= 50) return { text: 'Good', cls: 'text-amber-500' };
      return { text: 'Needs improvement', cls: 'text-red-500' };
    };

    const escapeHtml = (value) =>
      String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const showLoading = (isLoading) => {
      loadingState?.classList.toggle('hidden', !isLoading);
      if (isLoading) {
        errorState?.classList.add('hidden');
        dashboardContent?.classList.add('hidden');
      }
    };

    const medalClass = (index) => {
      if (index === 0) return 'text-yellow-500 font-bold';
      if (index === 1) return 'text-gray-400 font-bold';
      if (index === 2) return 'text-amber-600 font-bold';
      return 'text-primary-600 font-semibold';
    };

    const renderRankedList = (items, key, mountId) => {
      const mount = $(mountId);
      if (!mount) return;
      if (!items.length) {
        mount.innerHTML = `<div class="flex flex-col items-center py-8 gap-2 text-accent-400">
          <iconify-icon icon="mdi:inbox-outline" width="32" height="32"></iconify-icon>
          <p class="text-sm">No data available.</p>
        </div>`;
        return;
      }
      const maxCount = Math.max(...items.map((item) => item.count || 0), 1);
      mount.innerHTML = items
        .map((item, index) => {
          const width = ((item.count || 0) / maxCount) * 100;
          return `
            <div class="rounded-xl border border-gray-100 p-3 hover:border-primary-100 transition-colors">
              <div class="flex items-center justify-between gap-3">
                <p class="text-sm text-accent-700 truncate">
                  <span class="${medalClass(index)}">#${index + 1}</span>
                  <span class="ml-1">${escapeHtml(item[key])}</span>
                </p>
                <span class="shrink-0 px-2 py-0.5 text-xs rounded-full bg-primary-50 text-primary-700 font-medium">${formatCount(item.count)}</span>
              </div>
              <div class="mt-2 h-1.5 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full bg-gradient-to-r from-primary-500 to-primary-400 rounded-full transition-all duration-700" style="width: 0%" data-width="${width}"></div>
              </div>
            </div>`;
        })
        .join('');
      // Double rAF so the browser registers initial width:0 before transitioning
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          mount.querySelectorAll('[data-width]').forEach((bar) => {
            bar.style.width = `${bar.getAttribute('data-width')}%`;
          });
        });
      });
    };

    const renderData = (data) => {
      const totalAlumni = Number(data.totalAlumni || 0);

      $('total-alumni').textContent = formatCount(totalAlumni);
      $('total-faculties').textContent = formatCount(data.totalFaculties);
      $('total-years').textContent = formatCount(data.totalGraduationYears);
      $('open-mentor').textContent = formatCount(data.mentorshipAvailable);
      $('open-mentor-pct').textContent = formatPercent(data.mentorshipAvailable || 0, totalAlumni);
      $('open-work').textContent = formatCount(data.openToWork);
      $('open-work-pct').textContent = formatPercent(data.openToWork || 0, totalAlumni);
      $('recently-joined').textContent = formatCount(data.recentlyJoined);

      // Skills heatmap
      const skills = Array.isArray(data.topSkills) ? data.topSkills : [];
      const maxSkill = Math.max(...skills.map((item) => item.count || 0), 1);
      $('skills-cloud').innerHTML = skills.length
        ? skills
            .map((item) => {
              const ratio = (item.count || 0) / maxSkill;
              const fontSize = 0.75 + ratio * 0.9;
              const paddingY = 0.3 + ratio * 0.25;
              const paddingX = 0.55 + ratio * 0.4;
              return `<span
                  title="${formatCount(item.count)} alumni"
                  class="inline-flex items-start gap-1 rounded-full border border-primary-100 bg-gradient-to-r from-primary-50 to-blue-50 text-primary-700 hover:shadow-sm hover:scale-105 transition-transform cursor-default"
                  style="font-size: ${fontSize.toFixed(2)}rem; padding: ${paddingY.toFixed(2)}rem ${paddingX.toFixed(2)}rem;"
                >${escapeHtml(item.skill)}<sup class="text-[10px] opacity-70">${formatCount(item.count)}</sup></span>`;
            })
            .join('')
        : `<div class="flex flex-col items-center py-8 gap-2 text-accent-400 w-full">
            <iconify-icon icon="mdi:tag-off-outline" width="32" height="32"></iconify-icon>
            <p class="text-sm">No skills data available.</p>
          </div>`;

      // Faculty chart (horizontal bars)
      const facultyData = [...(data.facultyDistribution || [])].sort((a, b) => (b.count || 0) - (a.count || 0));
      const facultyMax = Math.max(...facultyData.map((item) => item.count || 0), 1);
      $('faculty-chart').innerHTML = facultyData.length
        ? facultyData
            .map((item) => {
              const width = ((item.count || 0) / facultyMax) * 100;
              return `<div class="space-y-1">
                <div class="flex items-center justify-between text-sm">
                  <span class="text-accent-700 truncate pr-2">${escapeHtml(item.faculty)}</span>
                  <span class="text-accent-500 shrink-0">${formatCount(item.count)}</span>
                </div>
                <div class="h-2.5 rounded-full bg-gray-100 overflow-hidden">
                  <div class="h-full bg-gradient-to-r from-primary-500 to-primary-600 rounded-full transition-all duration-700 hover:opacity-80" style="width: 0%" data-width="${width}"></div>
                </div>
              </div>`;
            })
            .join('')
        : `<div class="flex flex-col items-center py-8 gap-2 text-accent-400">
            <iconify-icon icon="mdi:chart-bar-stacked" width="32" height="32"></iconify-icon>
            <p class="text-sm">No faculty distribution data available.</p>
          </div>`;
      // Double rAF for smooth transition on faculty bars
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          $('faculty-chart')?.querySelectorAll('[data-width]').forEach((bar) => {
            bar.style.width = `${bar.getAttribute('data-width')}%`;
          });
        });
      });

      // Year chart (vertical bars) — pixel-based heights (228px usable area)
      const yearData = data.yearDistribution || [];
      const yearMax = Math.max(...yearData.map((item) => item.count || 0), 1);
      $('year-chart').innerHTML = yearData.length
        ? yearData
            .map((item) => {
              const barHeightPx = Math.round(((item.count || 0) / yearMax) * 228);
              return `<div class="min-w-[52px] flex-1 flex flex-col items-center justify-end gap-1 pb-1">
                <span class="text-[11px] font-medium text-accent-600">${formatCount(item.count)}</span>
                <div class="w-9 bg-gradient-to-t from-primary-600 to-primary-400 rounded-t-md transition-all duration-700 ease-out hover:opacity-80" style="height: 0px" data-height="${barHeightPx}px"></div>
                <span class="text-[11px] text-accent-500 mt-1">${escapeHtml(item.year)}</span>
              </div>`;
            })
            .join('')
        : `<div class="flex flex-col items-center justify-center w-full gap-2 text-accent-400">
            <iconify-icon icon="mdi:chart-timeline-variant-shimmer" width="32" height="32"></iconify-icon>
            <p class="text-sm">No graduation year data available.</p>
          </div>`;
      // Double rAF: first frame registers height:0px, second triggers the transition
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          $('year-chart')?.querySelectorAll('[data-height]').forEach((bar) => {
            bar.style.height = bar.getAttribute('data-height');
          });
        });
      });

      renderRankedList(data.industryDistribution || [], 'company', 'companies-list');
      renderRankedList(data.locationDistribution || [], 'location', 'locations-list');

      // Profile completeness cards
      const photoPct = calcPct(data.profilesWithPhoto, totalAlumni);
      const linkedinPct = calcPct(data.profilesWithLinkedIn, totalAlumni);
      const mentorPct = calcPct(data.mentorshipAvailable, totalAlumni);

      $('profiles-photo').textContent = formatCount(data.profilesWithPhoto);
      $('profiles-photo-pct').textContent = formatPercent(data.profilesWithPhoto || 0, totalAlumni);
      $('profiles-linkedin').textContent = formatCount(data.profilesWithLinkedIn);
      $('profiles-linkedin-pct').textContent = formatPercent(data.profilesWithLinkedIn || 0, totalAlumni);
      $('profiles-mentorship').textContent = formatCount(data.mentorshipAvailable);
      $('profiles-mentorship-pct').textContent = formatPercent(data.mentorshipAvailable || 0, totalAlumni);

      const photoLabel = completenessLabel(photoPct);
      const linkedinLabel = completenessLabel(linkedinPct);
      const mentorLabel = completenessLabel(mentorPct);

      const photoLabelEl = $('profiles-photo-label');
      if (photoLabelEl) { photoLabelEl.textContent = photoLabel.text; photoLabelEl.className = `text-xs font-semibold ${photoLabel.cls}`; }
      const linkedinLabelEl = $('profiles-linkedin-label');
      if (linkedinLabelEl) { linkedinLabelEl.textContent = linkedinLabel.text; linkedinLabelEl.className = `text-xs font-semibold ${linkedinLabel.cls}`; }
      const mentorLabelEl = $('profiles-mentorship-label');
      if (mentorLabelEl) { mentorLabelEl.textContent = mentorLabel.text; mentorLabelEl.className = `text-xs font-semibold ${mentorLabel.cls}`; }

      // Animate profile completeness progress bars (double rAF)
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          const photoBar = $('profiles-photo-bar');
          if (photoBar) photoBar.style.width = `${photoPct.toFixed(1)}%`;
          const linkedinBar = $('profiles-linkedin-bar');
          if (linkedinBar) linkedinBar.style.width = `${linkedinPct.toFixed(1)}%`;
          const mentorBar = $('profiles-mentorship-bar');
          if (mentorBar) mentorBar.style.width = `${mentorPct.toFixed(1)}%`;
        });
      });

      lastUpdated.textContent = `Last updated: just now (${new Date().toLocaleTimeString()})`;
      dashboardContent?.classList.remove('hidden');
    };

    const fetchStats = async () => {
      showLoading(true);
      refreshButton?.setAttribute('disabled', 'true');
      refreshButton?.classList.add('opacity-70', 'cursor-not-allowed');

      try {
        const response = await fetch('/api/alumni/stats', { cache: 'no-store' });
        const payload = await response.json();

        if (!response.ok) {
          throw new Error(payload?.message || payload?.error || 'Unable to load analytics right now.');
        }

        renderData(payload);
      } catch (error) {
        const msg = error?.message || 'Unable to load analytics right now. Please try again.';
        const msgEl = $('error-message');
        if (msgEl) msgEl.textContent = msg;
        errorState?.classList.remove('hidden');
      } finally {
        showLoading(false);
        refreshButton?.removeAttribute('disabled');
        refreshButton?.classList.remove('opacity-70', 'cursor-not-allowed');
      }
    };

    document.addEventListener('DOMContentLoaded', () => {
      fetchStats();
      refreshButton?.addEventListener('click', fetchStats);
      retryButton?.addEventListener('click', fetchStats);
    });
  </script>
</Layout>
