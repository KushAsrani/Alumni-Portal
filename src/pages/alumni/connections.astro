---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { isAlumniAuthenticated, getCurrentAlumni } from '../../lib/alumni-auth';

if (!isAlumniAuthenticated(Astro.cookies)) {
  return Astro.redirect('/alumni/login?redirect=/alumni/connections');
}

const session = getCurrentAlumni(Astro.cookies)!;
---

<Layout title="My Connections">
  <section class="section py-12">
    <div class="container mx-auto px-4">
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">My Connections</h1>
        <p class="text-gray-500 mt-1">Manage your alumni network connections.</p>
      </div>

      <!-- Tabs -->
      <div class="flex border-b border-gray-200 mb-6 gap-0 overflow-x-auto">
        <button
          id="tab-connections"
          onclick="switchTab('connections')"
          class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-primary-600 text-primary-600 transition-colors whitespace-nowrap"
        >
          My Connections
        </button>
        <button
          id="tab-pending"
          onclick="switchTab('pending')"
          class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition-colors whitespace-nowrap"
        >
          Pending Incoming
        </button>
        <button
          id="tab-sent"
          onclick="switchTab('sent')"
          class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition-colors whitespace-nowrap"
        >
          Sent Requests
        </button>
        <button
          id="tab-declined"
          onclick="switchTab('declined')"
          class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition-colors whitespace-nowrap"
        >
          Declined
        </button>
      </div>

      <!-- Loading -->
      <div id="loading" class="text-center py-12 text-gray-400">Loading…</div>

      <!-- My Connections panel -->
      <div id="panel-connections" class="hidden space-y-4"></div>

      <!-- Pending Incoming panel -->
      <div id="panel-pending" class="hidden space-y-4"></div>

      <!-- Sent Requests panel -->
      <div id="panel-sent" class="hidden space-y-4"></div>

      <!-- Declined panel -->
      <div id="panel-declined" class="hidden space-y-4"></div>
    </div>
  </section>

  <!-- Toast -->
  <div id="toast" class="fixed bottom-6 right-6 z-50 hidden max-w-sm bg-white border border-gray-200 shadow-lg rounded-xl px-4 py-3 flex items-center gap-3">
    <span id="toast-icon"></span>
    <p id="toast-msg" class="text-sm text-gray-800"></p>
  </div>

  <!-- Accept / Decline Confirmation Modal -->
  <div
    id="respond-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="respond-modal-title"
  >
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6" id="respond-modal-box">
      <div class="flex items-center gap-3 mb-4">
        <div id="respond-modal-icon" class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0"></div>
        <h2 id="respond-modal-title" class="text-lg font-semibold text-gray-900"></h2>
      </div>
      <p id="respond-modal-body" class="text-sm text-gray-600 mb-6"></p>
      <div class="flex gap-3 justify-end">
        <button id="respond-modal-cancel" class="btn btn-outline btn-sm" type="button">Cancel</button>
        <button id="respond-modal-confirm" class="btn btn-primary btn-sm" type="button"></button>
      </div>
    </div>
  </div>

  <!-- Remove Connection Confirmation Modal -->
  <div
    id="remove-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="remove-modal-title"
  >
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6" id="remove-modal-box">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
            <path d="M10 11v6"/><path d="M14 11v6"/>
            <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
          </svg>
        </div>
        <h2 id="remove-modal-title" class="text-lg font-semibold text-gray-900">Remove Connection</h2>
      </div>
      <p id="remove-modal-body" class="text-sm text-gray-600 mb-6"></p>
      <div class="flex gap-3 justify-end">
        <button id="remove-modal-cancel" class="btn btn-outline btn-sm" type="button">Cancel</button>
        <button id="remove-modal-confirm" class="btn btn-sm bg-red-600 hover:bg-red-700 text-white border-0" type="button">Yes, Remove</button>
      </div>
    </div>
  </div>

  <!-- Cancel Sent Request Confirmation Modal -->
  <div
    id="cancel-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="cancel-modal-title"
  >
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6" id="cancel-modal-box">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-full bg-yellow-100 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-yellow-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
          </svg>
        </div>
        <h2 id="cancel-modal-title" class="text-lg font-semibold text-gray-900">Cancel Request</h2>
      </div>
      <p id="cancel-modal-body" class="text-sm text-gray-600 mb-6"></p>
      <div class="flex gap-3 justify-end">
        <button id="cancel-modal-cancel" class="btn btn-outline btn-sm" type="button">Keep Request</button>
        <button id="cancel-modal-confirm" class="btn btn-sm bg-yellow-500 hover:bg-yellow-600 text-white border-0" type="button">Yes, Cancel Request</button>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ currentAlumniId: session.alumniId }}>
  let currentTab = 'connections';

  // ---------- Toast ----------
  function showToast(message, success) {
    const toast = document.getElementById('toast');
    document.getElementById('toast-msg').textContent = message;
    const iconEl = document.getElementById('toast-icon');
    if (success) {
      iconEl.innerHTML = '<svg class="w-5 h-5 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
    } else {
      iconEl.innerHTML = '<svg class="w-5 h-5 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
    }
    toast.classList.remove('hidden');
    toast.classList.add('flex');
    setTimeout(() => { toast.classList.add('hidden'); toast.classList.remove('flex'); }, 4000);
  }

  // ---------- Date Formatting ----------
  function formatDate(iso) {
    if (!iso) return '';
    return new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
  }

  // ---------- Tab Switching ----------
  function switchTab(tab) {
    currentTab = tab;
    ['connections', 'pending', 'sent', 'declined'].forEach((t) => {
      const tabEl = document.getElementById(`tab-${t}`);
      if (tabEl) {
        tabEl.className =
          t === tab
            ? 'tab-btn px-5 py-3 text-sm font-medium border-b-2 border-primary-600 text-primary-600 transition-colors whitespace-nowrap'
            : 'tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition-colors whitespace-nowrap';
      }
      const panelEl = document.getElementById(`panel-${t}`);
      if (panelEl) panelEl.classList.toggle('hidden', t !== tab);
    });
  }
  window.switchTab = switchTab;

  // ---------- Modal Utilities ----------
  function openModal(id) {
    const m = document.getElementById(id);
    m.classList.remove('hidden');
    m.classList.add('flex');
  }
  function closeModal(id) {
    const m = document.getElementById(id);
    m.classList.add('hidden');
    m.classList.remove('flex');
  }
  function trapFocus(boxId) {
    document.getElementById(boxId).addEventListener('keydown', (e) => {
      if (e.key !== 'Tab') return;
      const focusable = document.getElementById(boxId).querySelectorAll('button, [tabindex]:not([tabindex="-1"])');
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) { if (document.activeElement === first) { e.preventDefault(); last.focus(); } }
      else { if (document.activeElement === last) { e.preventDefault(); first.focus(); } }
    });
  }

  // Close modals on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    ['respond-modal', 'remove-modal', 'cancel-modal'].forEach((id) => {
      if (!document.getElementById(id).classList.contains('hidden')) closeModal(id);
    });
  });

  // Close modals on backdrop click
  ['respond-modal', 'remove-modal', 'cancel-modal'].forEach((id) => {
    document.getElementById(id).addEventListener('click', (e) => {
      if (e.target === document.getElementById(id)) closeModal(id);
    });
  });

  // Cancel buttons
  document.getElementById('respond-modal-cancel').addEventListener('click', () => closeModal('respond-modal'));
  document.getElementById('remove-modal-cancel').addEventListener('click', () => closeModal('remove-modal'));
  document.getElementById('cancel-modal-cancel').addEventListener('click', () => closeModal('cancel-modal'));

  // Trap focus
  trapFocus('respond-modal-box');
  trapFocus('remove-modal-box');
  trapFocus('cancel-modal-box');

  // ---------- Respond (Accept / Decline) ----------
  async function respond(requestId, action) {
    const requesterName = document.querySelector(`[data-req-id="${requestId}"]`)?.dataset?.requesterName || 'this person';

    const isAccept = action === 'accept';
    const iconEl = document.getElementById('respond-modal-icon');
    const titleEl = document.getElementById('respond-modal-title');
    const bodyEl = document.getElementById('respond-modal-body');
    const confirmBtn = document.getElementById('respond-modal-confirm');

    if (isAccept) {
      iconEl.className = 'w-10 h-10 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0';
      iconEl.innerHTML = '<svg class="w-5 h-5 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
      titleEl.textContent = 'Accept Connection Request';
      bodyEl.innerHTML = `Are you sure you want to accept the connection request from <strong>${requesterName}</strong>?`;
      confirmBtn.textContent = 'Yes, Accept';
      confirmBtn.className = 'btn btn-primary btn-sm';
    } else {
      iconEl.className = 'w-10 h-10 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0';
      iconEl.innerHTML = '<svg class="w-5 h-5 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
      titleEl.textContent = 'Decline Connection Request';
      bodyEl.innerHTML = `Are you sure you want to decline the connection request from <strong>${requesterName}</strong>? This action cannot be undone.`;
      confirmBtn.textContent = 'Yes, Decline';
      confirmBtn.className = 'btn btn-sm bg-red-600 hover:bg-red-700 text-white border-0';
    }

    openModal('respond-modal');
    setTimeout(() => confirmBtn.focus(), 50);

    // Replace listener (clone to remove old one)
    const newConfirm = confirmBtn.cloneNode(true);
    confirmBtn.parentNode.replaceChild(newConfirm, confirmBtn);
    newConfirm.textContent = isAccept ? 'Yes, Accept' : 'Yes, Decline';
    newConfirm.className = isAccept ? 'btn btn-primary btn-sm' : 'btn btn-sm bg-red-600 hover:bg-red-700 text-white border-0';
    newConfirm.addEventListener('click', async () => {
      newConfirm.disabled = true;
      newConfirm.textContent = 'Processing…';
      try {
        const res = await fetch('/api/connections/respond', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ requestId, action }),
        });
        const data = await res.json();
        closeModal('respond-modal');
        if (data.success) {
          showToast(isAccept ? `Connected with ${requesterName}!` : `Request from ${requesterName} declined.`, true);
          await loadConnections();
        } else {
          showToast(data.message || 'Failed to respond.', false);
        }
      } catch {
        closeModal('respond-modal');
        showToast('Network error. Please try again.', false);
      }
    });
  }
  window.respond = respond;

  // ---------- Remove Connection ----------
  async function removeConnection(connectionId, otherName) {
    document.getElementById('remove-modal-body').innerHTML =
      `Are you sure you want to remove your connection with <strong>${otherName}</strong>? This cannot be undone.`;
    openModal('remove-modal');
    const confirmBtn = document.getElementById('remove-modal-confirm');
    const newConfirm = confirmBtn.cloneNode(true);
    confirmBtn.parentNode.replaceChild(newConfirm, confirmBtn);
    newConfirm.textContent = 'Yes, Remove';
    newConfirm.className = 'btn btn-sm bg-red-600 hover:bg-red-700 text-white border-0';
    setTimeout(() => newConfirm.focus(), 50);
    newConfirm.addEventListener('click', async () => {
      newConfirm.disabled = true;
      newConfirm.textContent = 'Removing…';
      try {
        const res = await fetch('/api/connections/remove', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ connectionId }),
        });
        const data = await res.json();
        closeModal('remove-modal');
        if (data.success) {
          showToast(`Connection with ${otherName} removed.`, true);
          await loadConnections();
        } else {
          showToast(data.message || 'Failed to remove connection.', false);
        }
      } catch {
        closeModal('remove-modal');
        showToast('Network error. Please try again.', false);
      }
    });
  }
  window.removeConnection = removeConnection;

  // ---------- Cancel Sent Request ----------
  async function cancelRequest(connectionId, targetName) {
    document.getElementById('cancel-modal-body').innerHTML =
      `Are you sure you want to cancel your connection request to <strong>${targetName}</strong>?`;
    openModal('cancel-modal');
    const confirmBtn = document.getElementById('cancel-modal-confirm');
    const newConfirm = confirmBtn.cloneNode(true);
    confirmBtn.parentNode.replaceChild(newConfirm, confirmBtn);
    newConfirm.textContent = 'Yes, Cancel Request';
    newConfirm.className = 'btn btn-sm bg-yellow-500 hover:bg-yellow-600 text-white border-0';
    setTimeout(() => newConfirm.focus(), 50);
    newConfirm.addEventListener('click', async () => {
      newConfirm.disabled = true;
      newConfirm.textContent = 'Cancelling…';
      try {
        const res = await fetch('/api/connections/cancel', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ connectionId }),
        });
        const data = await res.json();
        closeModal('cancel-modal');
        if (data.success) {
          showToast(`Request to ${targetName} cancelled.`, true);
          await loadConnections();
        } else {
          showToast(data.message || 'Failed to cancel request.', false);
        }
      } catch {
        closeModal('cancel-modal');
        showToast('Network error. Please try again.', false);
      }
    });
  }
  window.cancelRequest = cancelRequest;

  // ---------- Card Renderers ----------
  function renderConnectionCard(conn) {
    const other = conn.otherAlumni || {};
    const name = other.name || (conn.requesterId === currentAlumniId ? conn.targetName : conn.requesterName) || 'Unknown';
    const initial = (name[0] || '?').toUpperCase();
    const slug = other.slug || '';
    const jobTitle = other.job_designation || '';
    const company = other.company || '';
    const faculty = other.faculty || '';
    const year = other.year || '';
    const location = other.location || '';
    const openToMentorship = other.open_to_mentorship || false;
    const otherId = other._id || (conn.requesterId === currentAlumniId ? conn.targetId : conn.requesterId);
    const connectedSince = conn.acceptedAt || conn.updatedAt || conn.createdAt;

    const jobLine = [jobTitle, company].filter(Boolean).join(' · ');
    const eduLine = [faculty ? `${faculty}` : '', year ? `${year}` : ''].filter(Boolean).join(', ');

    const viewProfileHref = slug ? `/alumni/profiles/${slug}` : '#';
    const mentorshipHref = `/alumni/mentorship?mentor=${otherId}`;

    return `
      <div class="bg-white shadow-md rounded-2xl p-6">
        <div class="flex items-start gap-4">
          <a href="${viewProfileHref}" class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-lg flex-shrink-0 hover:opacity-80 transition-opacity" aria-label="View ${name}'s profile">
            ${initial}
          </a>
          <div class="min-w-0 flex-1">
            <div class="flex items-start justify-between gap-2 flex-wrap">
              <a href="${viewProfileHref}" class="font-semibold text-gray-900 hover:text-primary-600 transition-colors truncate">${name}</a>
              <span class="badge bg-green-100 text-green-700 text-xs font-medium px-2 py-1 rounded-full shrink-0 flex items-center gap-1">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Connected
              </span>
            </div>
            ${jobLine ? `<p class="text-sm text-gray-600 mt-0.5">${jobLine}</p>` : ''}
            ${eduLine ? `<p class="text-sm text-gray-500 mt-0.5">${eduLine}</p>` : ''}
            ${location ? `<p class="text-sm text-gray-500 mt-0.5">${location}</p>` : ''}
            ${connectedSince ? `<p class="text-xs text-gray-400 mt-1">Connected since ${formatDate(connectedSince)}</p>` : ''}
          </div>
        </div>
        <div class="flex flex-wrap gap-2 mt-4">
          <a href="${viewProfileHref}" class="btn btn-outline btn-sm text-xs">View Profile</a>
          ${openToMentorship ? `<a href="${mentorshipHref}" class="btn btn-outline btn-sm text-xs text-primary-600 border-primary-300 hover:bg-primary-50">Request Mentorship</a>` : ''}
          <button onclick="removeConnection('${conn._id}', '${name.replace(/'/g, "\\'")}');return false;" class="btn btn-outline btn-sm text-xs text-red-600 border-red-300 hover:bg-red-50">Remove</button>
        </div>
      </div>`;
  }

  function renderPendingCard(req) {
    const name = req.otherAlumni?.name || req.requesterName || 'Unknown';
    const initial = (name[0] || '?').toUpperCase();
    return `
      <div class="bg-white shadow-md rounded-2xl p-6" data-req-id="${req._id}" data-requester-name="${name.replace(/"/g, '&quot;')}">
        <div class="flex items-start justify-between gap-4">
          <div class="flex items-center gap-4 min-w-0">
            <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-lg flex-shrink-0">
              ${initial}
            </div>
            <div class="min-w-0">
              <h3 class="font-semibold text-gray-900 truncate">${name}</h3>
              ${req.message ? `<p class="text-sm text-gray-500 mt-1 italic">"${req.message}"</p>` : ''}
              <p class="text-xs text-gray-400 mt-1">Received ${formatDate(req.createdAt)}</p>
            </div>
          </div>
          <span class="badge bg-yellow-100 text-yellow-700 text-xs font-medium px-2 py-1 rounded-full shrink-0">Pending</span>
        </div>
        <div class="flex gap-2 mt-4">
          <button onclick="respond('${req._id}','accept')" class="btn btn-primary btn-sm">Accept</button>
          <button onclick="respond('${req._id}','decline')" class="btn btn-outline btn-sm text-red-600 border-red-300 hover:bg-red-50">Decline</button>
        </div>
      </div>`;
  }

  function renderSentCard(req) {
    const other = req.otherAlumni || {};
    const name = other.name || req.targetName || 'Unknown';
    const initial = (name[0] || '?').toUpperCase();
    const slug = other.slug || '';
    const profileHref = slug ? `/alumni/profiles/${slug}` : '#';
    const status = req.status || 'pending';

    const statusBadge = {
      pending: '<span class="badge bg-yellow-100 text-yellow-700 text-xs font-medium px-2 py-1 rounded-full shrink-0">Pending</span>',
      accepted: '<span class="badge bg-green-100 text-green-700 text-xs font-medium px-2 py-1 rounded-full shrink-0">Accepted</span>',
      declined: '<span class="badge bg-red-100 text-red-700 text-xs font-medium px-2 py-1 rounded-full shrink-0">Declined</span>',
    }[status] || `<span class="badge bg-gray-100 text-gray-600 text-xs font-medium px-2 py-1 rounded-full shrink-0">${status}</span>`;

    const dateInfo = status === 'accepted' && req.acceptedAt
      ? `<p class="text-xs text-gray-400 mt-1">Accepted ${formatDate(req.acceptedAt)}</p>`
      : status === 'declined' && req.declinedAt
      ? `<p class="text-xs text-gray-400 mt-1">Declined ${formatDate(req.declinedAt)}</p>`
      : `<p class="text-xs text-gray-400 mt-1">Sent ${formatDate(req.createdAt)}</p>`;

    return `
      <div class="bg-white shadow-md rounded-2xl p-6">
        <div class="flex items-start justify-between gap-4">
          <div class="flex items-center gap-4 min-w-0">
            <a href="${profileHref}" class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-lg flex-shrink-0 hover:opacity-80 transition-opacity">
              ${initial}
            </a>
            <div class="min-w-0">
              <a href="${profileHref}" class="font-semibold text-gray-900 hover:text-primary-600 transition-colors truncate">${name}</a>
              ${req.message ? `<p class="text-sm text-gray-500 mt-1 italic">"${req.message}"</p>` : ''}
              ${dateInfo}
            </div>
          </div>
          ${statusBadge}
        </div>
        ${status === 'pending' ? `
        <div class="flex gap-2 mt-4">
          <button onclick="cancelRequest('${req._id}', '${name.replace(/'/g, "\\'")}');return false;" class="btn btn-outline btn-sm text-xs text-yellow-700 border-yellow-300 hover:bg-yellow-50">Cancel Request</button>
        </div>` : ''}
      </div>`;
  }

  function renderDeclinedCard(item) {
    // item can be: a request I declined (I was target), or a sent request declined by other (I was requester)
    const other = item.otherAlumni || {};
    const iDeclined = item.targetId === currentAlumniId && item.status === 'declined';
    const name = other.name || (iDeclined ? item.requesterName : item.targetName) || 'Unknown';
    const initial = (name[0] || '?').toUpperCase();
    const slug = other.slug || '';
    const profileHref = slug ? `/alumni/profiles/${slug}` : '#';

    const declinedDate = item.declinedAt || item.updatedAt;
    const sentDate = item.createdAt;

    return `
      <div class="bg-white shadow-md rounded-2xl p-6 opacity-80">
        <div class="flex items-start gap-4">
          <a href="${profileHref}" class="w-12 h-12 rounded-full bg-gray-100 flex items-center justify-center text-gray-500 font-bold text-lg flex-shrink-0 hover:opacity-80 transition-opacity">
            ${initial}
          </a>
          <div class="min-w-0 flex-1">
            <div class="flex items-start justify-between gap-2 flex-wrap">
              <a href="${profileHref}" class="font-semibold text-gray-700 hover:text-primary-600 transition-colors truncate">${name}</a>
              <span class="badge bg-red-100 text-red-700 text-xs font-medium px-2 py-1 rounded-full shrink-0">Declined</span>
            </div>
            <p class="text-xs text-gray-400 mt-1">
              ${iDeclined ? `Request received ${formatDate(sentDate)}` : `Request sent ${formatDate(sentDate)}`}
            </p>
            ${declinedDate ? `<p class="text-xs text-gray-400">Declined ${formatDate(declinedDate)}</p>` : ''}
            <p class="text-xs text-gray-500 mt-1 italic">${iDeclined ? 'You declined this request.' : 'Your request was declined.'}</p>
          </div>
        </div>
      </div>`;
  }

  // ---------- Load All Data ----------
  async function loadConnections() {
    try {
      const res = await fetch('/api/connections/my-connections');
      const data = await res.json();
      if (data.success) {
        const connPanel = document.getElementById('panel-connections');
        const pendingPanel = document.getElementById('panel-pending');
        const sentPanel = document.getElementById('panel-sent');
        const declinedPanel = document.getElementById('panel-declined');

        const connections = data.connections || [];
        const pendingIncoming = data.pendingIncoming || [];
        const sentRequests = data.sentRequests || [];
        const declinedByMe = data.declinedByMe || [];

        // My Connections tab
        connPanel.innerHTML = connections.length
          ? connections.map(renderConnectionCard).join('')
          : '<p class="text-center text-gray-400 py-12">No connections yet. Start networking!</p>';

        // Pending Incoming tab — update badge
        const pendingTabBtn = document.getElementById('tab-pending');
        pendingTabBtn.innerHTML = pendingIncoming.length
          ? `Pending Incoming <span class="ml-1 inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-primary-600 rounded-full">${pendingIncoming.length}</span>`
          : 'Pending Incoming';

        pendingPanel.innerHTML = pendingIncoming.length
          ? pendingIncoming.map(renderPendingCard).join('')
          : '<p class="text-center text-gray-400 py-12">No pending requests.</p>';

        // Sent Requests tab
        sentPanel.innerHTML = sentRequests.length
          ? sentRequests.map(renderSentCard).join('')
          : '<p class="text-center text-gray-400 py-12">You haven\'t sent any connection requests yet.</p>';

        // Declined tab — combine declinedByMe + sent requests declined by others
        const sentDeclined = sentRequests.filter(r => r.status === 'declined');
        const allDeclined = [...declinedByMe, ...sentDeclined];
        declinedPanel.innerHTML = allDeclined.length
          ? allDeclined.map(renderDeclinedCard).join('')
          : '<p class="text-center text-gray-400 py-12">No declined connections.</p>';
      }
    } catch {
      document.getElementById('panel-connections').innerHTML = '<p class="text-center text-red-400 py-12">Failed to load connections.</p>';
    } finally {
      document.getElementById('loading').classList.add('hidden');
      document.getElementById(`panel-${currentTab}`).classList.remove('hidden');
    }
  }

  loadConnections();
</script>
