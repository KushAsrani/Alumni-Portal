---
export const prerender = false;

import Layout from '@/layouts/Layout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Icon from '../../../components/Icon.astro';
import { connectToDatabase } from '../../../lib/mongodb';
import { getCollection } from 'astro:content';
import { isAlumniAuthenticated, getCurrentAlumni } from '../../../lib/alumni-auth';

const { slug } = Astro.params;

function generateSlug(name: string): string {
  return (name || '')
    .toLowerCase()
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-');
}

function toStringArray(value: unknown) {
  if (Array.isArray(value)) return value.map((item) => String(item).trim()).filter(Boolean);
  if (typeof value === 'string') return value.split(',').map((item) => item.trim()).filter(Boolean);
  return [];
}

function toProjectsArray(value: unknown) {
  if (Array.isArray(value)) return value;
  if (!value) return [];

  if (typeof value === 'string') {
    try {
      const parsed = JSON.parse(value);
      if (Array.isArray(parsed)) return parsed;
      if (parsed && typeof parsed === 'object') return [parsed];
    } catch {
      return [];
    }
    return [];
  }

  if (typeof value === 'object') return [value];
  return [];
}

let alum: any = null;

if (slug) {
  try {
    const { db } = await connectToDatabase();
    const collection = db.collection('alumni_registrations');
    const allApproved = await collection.find({ status: 'approved' }).toArray();

    const found = allApproved.find((entry: any) => {
      const entrySlug = generateSlug(entry?.name || '');
      const entryId = entry?._id?.toString?.();
      return entrySlug === slug || entryId === slug;
    });

    if (found) {
      const normalizedSkills = toStringArray(found.skills);
      const normalizedInterests = toStringArray(found.interests);
      alum = {
        ...found,
        slug: found.slug || generateSlug(found.name || ''),
        skills: normalizedSkills,
        interests: normalizedInterests,
        projects: toProjectsArray(found.projects),
        photo: found.photo_blob_url || found.photo || null,
        short_bio: found.short_bio || '',
        long_bio: found.long_bio || found.short_bio || '',
        social: {
          linkedin: found.linkedin || null,
          github: found.github || null,
          twitter: found.twitter || null,
          portfolio: found.portfolio || null,
        },
        position: found.job_designation || found.position || null,
        work_experience: found.work_experience
          ? (typeof found.work_experience === 'string'
              ? [
                  {
                    company: found.company || 'N/A',
                    position: found.job_designation || found.position || 'N/A',
                    duration: `${found.year || ''} - Present`,
                    description: found.work_experience,
                  },
                ]
              : found.work_experience)
          : [],
        education: found.education || (found.university
          ? [
              {
                degree: `${found.degree || 'Degree'} ${found.faculty || ''}`.trim(),
                institution: found.university,
                year: found.year,
                gpa: found.gpa || null,
              },
            ]
          : []),
      };
    }
  } catch {
    // handled by fallback below
  }
}

if (!alum && slug) {
  try {
    const allAlumni = await getCollection('alumni');
    const entry = allAlumni.find((item) => item.data.slug === slug);
    if (entry) alum = entry.data;
  } catch {
    // no-op
  }
}

if (alum) {
  alum = {
    ...alum,
    projects: toProjectsArray(alum.projects),
  };
}

if (!alum) {
  return Astro.redirect('/404');
}

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Profiles', href: '/alumni/profiles' },
  { label: alum.name },
];

const socials = alum.social || {};

// Check if viewer is logged in and is not viewing their own profile
const viewerSession = getCurrentAlumni(Astro.cookies);
const viewerAlumniId = viewerSession?.alumniId || '';
const targetAlumniId = alum._id?.toString() || '';
const targetAlumniName = alum.name || '';
const showNetworkButtons = viewerSession !== null && viewerAlumniId !== targetAlumniId;
---

<Layout title={alum.name} description={alum.short_bio}>
  <Breadcrumbs items={breadcrumbItems} />

  <section class="section py-12">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Sidebar -->
        <aside class="lg:col-span-1 bg-white shadow-md rounded-2xl p-6 text-center">
          <img
            src={alum.photo || '/logo.svg'}
            alt={alum.name}
            class="w-36 h-36 sm:w-40 sm:h-40 rounded-full object-cover border mx-auto mb-4"
          />
          <h1 class="text-2xl font-bold">{alum.name}</h1>
          <p class="text-primary-600 mt-1">{alum.faculty}, {alum.year}</p>

          <div class="mt-4 space-y-2 text-sm text-gray-700">
            {alum.position && <p><strong>Position:</strong> {alum.position}</p>}
            {alum.company && <p><strong>Company:</strong> {alum.company}</p>}
            {alum.location && <p><strong>Location:</strong> {alum.location}</p>}
            {alum.email && (
              <p>
                <strong>Email:</strong>
                <a href={`mailto:${alum.email}`} class="text-primary-600 hover:underline ml-1">
                  {alum.email}
                </a>
              </p>
            )}
          </div>

          {Object.values(socials).some(Boolean) && (
            <div class="mt-6 flex justify-center gap-5 text-gray-600">
              {socials.linkedin && (
                <a href={socials.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-primary-600" aria-label="LinkedIn">
                  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              )}
              {socials.github && (
                <a href={socials.github} target="_blank" rel="noopener noreferrer" class="hover:text-primary-600" aria-label="GitHub">
                  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                  </svg>
                </a>
              )}
              {socials.twitter && (
                <a href={socials.twitter} target="_blank" rel="noopener noreferrer" class="hover:text-primary-600" aria-label="Twitter / X">
                  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                </a>
              )}
              {socials.portfolio && (
                <a href={socials.portfolio} target="_blank" rel="noopener noreferrer" class="hover:text-primary-600" aria-label="Portfolio">
                  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="2" y1="12" x2="22" y2="12"/>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                  </svg>
                </a>
              )}
            </div>
          )}

          {showNetworkButtons && (
            <div class="mt-6 flex flex-col gap-2">
              {alum.open_to_mentorship && (
                <a
                  href={`/alumni/mentorship?mentor=${targetAlumniId}`}
                  class="btn btn-primary btn-sm w-full justify-center"
                >
                  <Icon name="mdi:handshake-outline" class="w-4 h-4 mr-1" />
                  Request Mentorship
                </a>
              )}
              <button
                id="connect-btn"
                class="btn btn-outline btn-sm w-full justify-center"
                onclick="sendConnectionRequest()"
              >
                <Icon name="mdi:account-plus-outline" class="w-4 h-4 mr-1" />
                Connect
              </button>
            </div>
          )}
        </aside>

        <!-- Main content -->
        <main class="lg:col-span-2 space-y-8">
          <!-- About -->
          <section class="bg-white shadow-md rounded-2xl p-6">
            <h2 class="text-xl font-semibold mb-3">About</h2>
            <p class="text-gray-700">{alum.long_bio}</p>
          </section>

          <!-- Skills -->
          {alum.skills?.length > 0 && (
            <section class="bg-white shadow-md rounded-2xl p-6">
              <h2 class="text-xl font-semibold mb-3">Skills</h2>
              <div class="flex flex-wrap gap-2">
                {alum.skills.map((skill: string) => (
                  <span class="badge badge-primary">{skill}</span>
                ))}
              </div>
            </section>
          )}

          <!-- Projects -->
          {Array.isArray(alum.projects) && alum.projects.length > 0 && (
            <section class="bg-white shadow-md rounded-2xl p-6">
              <h2 class="text-xl font-semibold mb-3">Projects</h2>
              <div class="space-y-4">
                {alum.projects.map((project: any) => (
                  <div>
                    <h3 class="font-semibold">{project.name}</h3>
                    <p class="text-gray-700 text-sm">{project.description}</p>
                    {project.url && (
                      <a
                        href={project.url}
                        target="_blank"
                        class="text-primary-600 text-sm hover:underline"
                      >
                        View Project
                      </a>
                    )}
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Work Experience -->
          {alum.work_experience?.length > 0 && (
            <section class="bg-white shadow-md rounded-2xl p-6">
              <h2 class="text-xl font-semibold mb-3">Work Experience</h2>
              <div class="space-y-4">
                {alum.work_experience.map((exp: any) => (
                  <div>
                    <h3 class="font-semibold">{exp.position} - {exp.company}</h3>
                    <p class="text-gray-500 text-sm">{exp.duration}</p>
                    <p class="text-gray-700 text-sm">{exp.description}</p>
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Education -->
          {alum.education?.length > 0 && (
            <section class="bg-white shadow-md rounded-2xl p-6">
              <h2 class="text-xl font-semibold mb-3">Education</h2>
              <div class="space-y-4">
                {alum.education.map((ed: any) => (
                  <div>
                    <h3 class="font-semibold">{ed.degree}</h3>
                    <p class="text-gray-700 text-sm">{ed.institution} ({ed.year})</p>
                    {ed.gpa && <p class="text-gray-500 text-sm">GPA: {ed.gpa}</p>}
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Achievements -->
          {alum.achievements?.length > 0 && (
            <section class="bg-white shadow-md rounded-2xl p-6">
              <h2 class="text-xl font-semibold mb-3">Achievements</h2>
              <ul class="list-disc list-inside text-gray-700">
                {alum.achievements.map((a: string) => (<li>{a}</li>))}
              </ul>
            </section>
          )}

          <!-- Interests -->
          {alum.interests?.length > 0 && (
            <section class="bg-white shadow-md rounded-2xl p-6">
              <h2 class="text-xl font-semibold mb-3">Interests</h2>
              <div class="flex flex-wrap gap-2">
                {alum.interests.map((i: string) => (
                  <span class="badge badge-secondary">{i}</span>
                ))}
              </div>
            </section>
          )}
        </main>
      </div>
    </div>
  </section>

  <!-- Toast -->
  <div id="profile-toast" class="fixed bottom-6 right-6 z-50 hidden max-w-sm bg-white border border-gray-200 shadow-lg rounded-xl px-4 py-3 flex items-center gap-3">
    <span id="profile-toast-icon"></span>
    <p id="profile-toast-msg" class="text-sm text-gray-800"></p>
  </div>

  <!-- Connection Request Modal -->
  <div
    id="connect-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="connect-modal-title"
  >
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6" id="connect-modal-box">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-primary-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <line x1="19" y1="8" x2="19" y2="14"/>
            <line x1="22" y1="11" x2="16" y2="11"/>
          </svg>
        </div>
        <h2 id="connect-modal-title" class="text-lg font-semibold text-gray-900">Send Connection Request</h2>
      </div>
      <p id="connect-modal-body" class="text-sm text-gray-600 mb-4"></p>
      <textarea
        id="connect-modal-note"
        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-primary-500"
        rows="3"
        maxlength="300"
        placeholder="Add a short note... (optional)"
      ></textarea>
      <p class="text-xs text-gray-400 text-right mt-1"><span id="connect-note-count">0</span>/300</p>
      <div class="flex gap-3 mt-5 justify-end">
        <button
          id="connect-modal-cancel"
          class="btn btn-outline btn-sm"
          type="button"
        >Cancel</button>
        <button
          id="connect-modal-send"
          class="btn btn-primary btn-sm"
          type="button"
        >Send Request</button>
      </div>
    </div>
  </div>

  <div
    id="connect-success-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="connect-success-title"
  >
    <div id="connect-success-box" class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6 text-center profile-modal-fade">
      <div class="w-16 h-16 rounded-full bg-green-100 text-green-600 mx-auto flex items-center justify-center">
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </div>
      <h2 id="connect-success-title" class="text-xl font-bold text-gray-900 mt-4">Request Sent Successfully!</h2>
      <p id="connect-success-body" class="text-sm text-gray-600 mt-2 mb-6"></p>
      <button id="connect-success-done" type="button" class="btn btn-primary btn-sm">Done</button>
    </div>
  </div>
</Layout>

<style>
  @keyframes profileModalFadeIn {
    from { opacity: 0; transform: translateY(10px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .profile-modal-fade { animation: profileModalFadeIn 180ms ease-out; }
</style>

<script define:vars={{ targetAlumniId, targetAlumniName, viewerAlumniId, showNetworkButtons }}>
  function showToast(message, success) {
    const toast = document.getElementById('profile-toast');
    document.getElementById('profile-toast-msg').textContent = message;
    const iconEl = document.getElementById('profile-toast-icon');
    if (success) {
      iconEl.innerHTML = '<svg class="w-5 h-5 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
    } else {
      iconEl.innerHTML = '<svg class="w-5 h-5 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
    }
    toast.classList.remove('hidden');
    toast.classList.add('flex');
    setTimeout(() => { toast.classList.add('hidden'); toast.classList.remove('flex'); }, 4000);
  }

  // Profile view tracking (fire-and-forget)
  if (viewerAlumniId && viewerAlumniId !== targetAlumniId) {
    (async () => {
      try {
        const sessionRes = await fetch('/api/auth/alumni-session');
        const sessionData = await sessionRes.json();
        if (sessionData.authenticated) {
          await fetch('/api/admin/track-engagement', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              type: 'profile_view',
              alumniId: viewerAlumniId,
              alumniName: sessionData.data?.name || '',
              targetAlumniId,
              targetAlumniName,
              status: 'completed',
            }),
          });
        }
      } catch {
        // silently ignore
      }
    })();
  }

  // --- Connection Request Modal ---
  const modal = document.getElementById('connect-modal');
  const modalBox = document.getElementById('connect-modal-box');
  const noteArea = document.getElementById('connect-modal-note');
  const noteCount = document.getElementById('connect-note-count');
  const sendBtn = document.getElementById('connect-modal-send');
  const cancelBtn = document.getElementById('connect-modal-cancel');
  const successModal = document.getElementById('connect-success-modal');
  const successBox = document.getElementById('connect-success-box');
  const successBody = document.getElementById('connect-success-body');
  const successDone = document.getElementById('connect-success-done');
  let successTimer = null;

  function openConnectModal() {
    document.getElementById('connect-modal-body').innerHTML =
      `You're about to send a connection request to <strong>${targetAlumniName}</strong>. You can optionally add a short note to introduce yourself.`;
    noteArea.value = '';
    noteCount.textContent = '0';
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    // focus first focusable element
    setTimeout(() => noteArea.focus(), 50);
  }

  function closeConnectModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  function openConnectSuccessModal() {
    successBody.textContent = `Your connection request has been sent to ${targetAlumniName}. You'll be notified once they accept. You can track it under "Sent Requests".`;
    successModal.classList.remove('hidden');
    successModal.classList.add('flex');
    setTimeout(() => successDone.focus(), 50);
    clearTimeout(successTimer);
    successTimer = setTimeout(() => closeConnectSuccessModal(), 4000);
  }

  function closeConnectSuccessModal() {
    clearTimeout(successTimer);
    successModal.classList.add('hidden');
    successModal.classList.remove('flex');
  }

  noteArea.addEventListener('input', () => {
    noteCount.textContent = noteArea.value.length;
  });

  cancelBtn.addEventListener('click', closeConnectModal);

  // Close on backdrop click
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeConnectModal();
  });
  successModal.addEventListener('click', (e) => {
    if (e.target === successModal) closeConnectSuccessModal();
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      closeConnectModal();
    }
    if (e.key === 'Escape' && !successModal.classList.contains('hidden')) {
      closeConnectSuccessModal();
    }
  });

  // Trap focus inside modal
  modalBox.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab') return;
    const focusable = modalBox.querySelectorAll('button, textarea, [tabindex]:not([tabindex="-1"])');
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  });
  successBox.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab') return;
    const focusable = successBox.querySelectorAll('button, [tabindex]:not([tabindex="-1"])');
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  });
  successDone.addEventListener('click', closeConnectSuccessModal);

  sendBtn.addEventListener('click', async () => {
    const btn = document.getElementById('connect-btn');
    sendBtn.disabled = true;
    sendBtn.textContent = 'Sending…';
    const note = noteArea.value.trim().slice(0, 300);

    try {
      const res = await fetch('/api/connections/request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ targetId: targetAlumniId, message: note }),
      });
      const data = await res.json();
      closeConnectModal();
      if (data.success) {
        if (btn) {
          btn.textContent = 'Request Sent ✓';
          btn.className = 'btn btn-sm w-full justify-center bg-green-50 text-green-700 border border-green-200 cursor-default';
          btn.disabled = true;
        }
        openConnectSuccessModal();
      } else if (res.status === 409) {
        if (btn) {
          btn.textContent = 'Connected ✓';
          btn.className = 'btn btn-sm w-full justify-center bg-green-50 text-green-700 border border-green-200 cursor-default';
          btn.disabled = true;
        }
      } else {
        if (btn) { btn.disabled = false; btn.textContent = 'Connect'; }
        showToast(data.message || 'Failed to send request.', false);
      }
    } catch {
      closeConnectModal();
      if (btn) { btn.disabled = false; btn.textContent = 'Connect'; }
      showToast('Network error. Please try again.', false);
    } finally {
      sendBtn.disabled = false;
      sendBtn.textContent = 'Send Request';
    }
  });

  // Connect button opens modal
  function sendConnectionRequest() {
    const btn = document.getElementById('connect-btn');
    if (!btn || btn.disabled) return;
    openConnectModal();
  }
  window.sendConnectionRequest = sendConnectionRequest;

  // Check if already connected / pending
  if (showNetworkButtons) {
    (async () => {
      try {
        const res = await fetch('/api/connections/my-connections');
        const data = await res.json();
        if (data.success) {
          const isConnected = (data.connections || []).some(
            (c) => c.requesterId === targetAlumniId || c.targetId === targetAlumniId
          );
          const isPendingIncoming = (data.pendingIncoming || []).some(
            (c) => c.requesterId === targetAlumniId
          );
          const isSentPending = (data.sentRequests || []).some(
            (c) => c.targetId === targetAlumniId && c.status === 'pending'
          );
          const btn = document.getElementById('connect-btn');
          if (btn) {
            if (isConnected) {
              btn.textContent = 'Connected ✓';
              btn.className = 'btn btn-sm w-full justify-center bg-green-50 text-green-700 border border-green-200 cursor-default';
              btn.disabled = true;
            } else if (isPendingIncoming || isSentPending) {
              btn.textContent = 'Request Pending';
              btn.className = 'btn btn-sm w-full justify-center bg-yellow-50 text-yellow-700 border border-yellow-200 cursor-default';
              btn.disabled = true;
            }
          }
        }
      } catch {
        // silently ignore
      }
    })();
  }
</script>
