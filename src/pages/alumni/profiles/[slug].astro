---
export const prerender = false;

import Layout from '@/layouts/Layout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Icon from '../../../components/Icon.astro';
import { connectToDatabase } from '../../../lib/mongodb';
import { getCollection } from 'astro:content';
import { isAlumniAuthenticated, getCurrentAlumni } from '../../../lib/alumni-auth';

const { slug } = Astro.params;

function generateSlug(name: string): string {
  return (name || '')
    .toLowerCase()
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-');
}

function toStringArray(value: unknown) {
  if (Array.isArray(value)) return value.map((item) => String(item).trim()).filter(Boolean);
  if (typeof value === 'string') return value.split(',').map((item) => item.trim()).filter(Boolean);
  return [];
}

function toProjectsArray(value: unknown) {
  if (Array.isArray(value)) return value;
  if (!value) return [];

  if (typeof value === 'string') {
    try {
      const parsed = JSON.parse(value);
      if (Array.isArray(parsed)) return parsed;
      if (parsed && typeof parsed === 'object') return [parsed];
    } catch {
      return [];
    }
    return [];
  }

  if (typeof value === 'object') return [value];
  return [];
}

let alum: any = null;

if (slug) {
  try {
    const { db } = await connectToDatabase();
    const collection = db.collection('alumni_registrations');
    const allApproved = await collection.find({ status: 'approved' }).toArray();

    const found = allApproved.find((entry: any) => {
      const entrySlug = generateSlug(entry?.name || '');
      const entryId = entry?._id?.toString?.();
      return entrySlug === slug || entryId === slug;
    });

    if (found) {
      const normalizedSkills = toStringArray(found.skills);
      const normalizedInterests = toStringArray(found.interests);
      alum = {
        ...found,
        slug: found.slug || generateSlug(found.name || ''),
        skills: normalizedSkills,
        interests: normalizedInterests,
        projects: toProjectsArray(found.projects),
        photo: found.photo_blob_url || found.photo || null,
        short_bio: found.short_bio || '',
        long_bio: found.long_bio || found.short_bio || '',
        social: {
          linkedin: found.linkedin || null,
          github: found.github || null,
          twitter: found.twitter || null,
          portfolio: found.portfolio || null,
        },
        position: found.job_designation || found.position || null,
        work_experience: found.work_experience
          ? (typeof found.work_experience === 'string'
              ? [
                  {
                    company: found.company || 'N/A',
                    position: found.job_designation || found.position || 'N/A',
                    duration: `${found.year || ''} - Present`,
                    description: found.work_experience,
                  },
                ]
              : found.work_experience)
          : [],
        education: found.education || (found.university
          ? [
              {
                degree: `${found.degree || 'Degree'} ${found.faculty || ''}`.trim(),
                institution: found.university,
                year: found.year,
                gpa: found.gpa || null,
              },
            ]
          : []),
      };
    }
  } catch {
    // handled by fallback below
  }
}

if (!alum && slug) {
  try {
    const allAlumni = await getCollection('alumni');
    const entry = allAlumni.find((item) => item.data.slug === slug);
    if (entry) alum = entry.data;
  } catch {
    // no-op
  }
}

if (alum) {
  alum = {
    ...alum,
    projects: toProjectsArray(alum.projects),
  };
}

if (!alum) {
  return Astro.redirect('/404');
}

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Profiles', href: '/alumni/profiles' },
  { label: alum.name },
];

const socials = alum.social || {};

// Check if viewer is logged in and is not viewing their own profile
const viewerSession = getCurrentAlumni(Astro.cookies);
const viewerAlumniId = viewerSession?.alumniId || '';
const targetAlumniId = alum._id?.toString() || '';
const targetAlumniName = alum.name || '';
const showNetworkButtons = viewerSession !== null && viewerAlumniId !== targetAlumniId;
---

<Layout title={alum.name} description={alum.short_bio}>
  <Breadcrumbs items={breadcrumbItems} />

  <section class="section py-12">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Sidebar -->
        <aside class="lg:col-span-1 bg-white shadow-md rounded-2xl p-6 text-center">
          <img
            src={alum.photo || '/logo.svg'}
            alt={alum.name}
            class="w-36 h-36 sm:w-40 sm:h-40 rounded-full object-cover border mx-auto mb-4"
          />
          <h1 class="text-2xl font-bold">{alum.name}</h1>
          <p class="text-primary-600 mt-1">{alum.faculty}, {alum.year}</p>

          <div class="mt-4 space-y-2 text-sm text-gray-700">
            {alum.position && <p><strong>Position:</strong> {alum.position}</p>}
            {alum.company && <p><strong>Company:</strong> {alum.company}</p>}
            {alum.location && <p><strong>Location:</strong> {alum.location}</p>}
            {alum.email && (
              <p>
                <strong>Email:</strong>
                <a href={`mailto:${alum.email}`} class="text-primary-600 hover:underline ml-1">
                  {alum.email}
                </a>
              </p>
            )}
          </div>

          {Object.values(socials).some(Boolean) && (
            <div class="mt-6 flex justify-center gap-5 text-gray-600">
              {socials.linkedin && (
                <a href={socials.linkedin} target="_blank" class="hover:text-primary-600">
                  <Icon name="mdi:linkedin" class="w-6 h-6" />
                </a>
              )}
              {socials.github && (
                <a href={socials.github} target="_blank" class="hover:text-primary-600">
                  <Icon name="mdi:github" class="w-6 h-6" />
                </a>
              )}
              {socials.twitter && (
                <a href={socials.twitter} target="_blank" class="hover:text-primary-600">
                  <Icon name="mdi:twitter" class="w-6 h-6" />
                </a>
              )}
              {socials.portfolio && (
                <a href={socials.portfolio} target="_blank" class="hover:text-primary-600">
                  <Icon name="mdi:web" class="w-6 h-6" />
                </a>
              )}
            </div>
          )}

          {showNetworkButtons && (
            <div class="mt-6 flex flex-col gap-2">
              {alum.open_to_mentorship && (
                <a
                  href={`/alumni/mentorship?mentor=${targetAlumniId}`}
                  class="btn btn-primary btn-sm w-full justify-center"
                >
                  <Icon name="mdi:handshake-outline" class="w-4 h-4 mr-1" />
                  Request Mentorship
                </a>
              )}
              <button
                id="connect-btn"
                class="btn btn-outline btn-sm w-full justify-center"
                onclick="sendConnectionRequest()"
              >
                <Icon name="mdi:account-plus-outline" class="w-4 h-4 mr-1" />
                Connect
              </button>
            </div>
          )}
        </aside>

        <!-- Main content -->
        <main class="lg:col-span-2 space-y-8">
          <!-- About -->
          <section class="bg-white shadow-md rounded-2xl p-6">
            <h2 class="text-xl font-semibold mb-3">About</h2>
            <p class="text-gray-700">{alum.long_bio}</p>
          </section>

          <!-- Skills -->
          {alum.skills?.length > 0 && (
            <section class="bg-white shadow-md rounded-2xl p-6">
              <h2 class="text-xl font-semibold mb-3">Skills</h2>
              <div class="flex flex-wrap gap-2">
                {alum.skills.map((skill: string) => (
                  <span class="badge badge-primary">{skill}</span>
                ))}
              </div>
            </section>
          )}

          <!-- Projects -->
          {Array.isArray(alum.projects) && alum.projects.length > 0 && (
            <section class="bg-white shadow-md rounded-2xl p-6">
              <h2 class="text-xl font-semibold mb-3">Projects</h2>
              <div class="space-y-4">
                {alum.projects.map((project: any) => (
                  <div>
                    <h3 class="font-semibold">{project.name}</h3>
                    <p class="text-gray-700 text-sm">{project.description}</p>
                    {project.url && (
                      <a
                        href={project.url}
                        target="_blank"
                        class="text-primary-600 text-sm hover:underline"
                      >
                        View Project
                      </a>
                    )}
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Work Experience -->
          {alum.work_experience?.length > 0 && (
            <section class="bg-white shadow-md rounded-2xl p-6">
              <h2 class="text-xl font-semibold mb-3">Work Experience</h2>
              <div class="space-y-4">
                {alum.work_experience.map((exp: any) => (
                  <div>
                    <h3 class="font-semibold">{exp.position} - {exp.company}</h3>
                    <p class="text-gray-500 text-sm">{exp.duration}</p>
                    <p class="text-gray-700 text-sm">{exp.description}</p>
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Education -->
          {alum.education?.length > 0 && (
            <section class="bg-white shadow-md rounded-2xl p-6">
              <h2 class="text-xl font-semibold mb-3">Education</h2>
              <div class="space-y-4">
                {alum.education.map((ed: any) => (
                  <div>
                    <h3 class="font-semibold">{ed.degree}</h3>
                    <p class="text-gray-700 text-sm">{ed.institution} ({ed.year})</p>
                    {ed.gpa && <p class="text-gray-500 text-sm">GPA: {ed.gpa}</p>}
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Achievements -->
          {alum.achievements?.length > 0 && (
            <section class="bg-white shadow-md rounded-2xl p-6">
              <h2 class="text-xl font-semibold mb-3">Achievements</h2>
              <ul class="list-disc list-inside text-gray-700">
                {alum.achievements.map((a: string) => (<li>{a}</li>))}
              </ul>
            </section>
          )}

          <!-- Interests -->
          {alum.interests?.length > 0 && (
            <section class="bg-white shadow-md rounded-2xl p-6">
              <h2 class="text-xl font-semibold mb-3">Interests</h2>
              <div class="flex flex-wrap gap-2">
                {alum.interests.map((i: string) => (
                  <span class="badge badge-secondary">{i}</span>
                ))}
              </div>
            </section>
          )}
        </main>
      </div>
    </div>
  </section>

  <!-- Toast -->
  <div id="profile-toast" class="fixed bottom-6 right-6 z-50 hidden max-w-sm bg-white border border-gray-200 shadow-lg rounded-xl px-4 py-3 flex items-center gap-3">
    <span id="profile-toast-icon" class="text-xl"></span>
    <p id="profile-toast-msg" class="text-sm text-gray-800"></p>
  </div>
</Layout>

<script define:vars={{ targetAlumniId, targetAlumniName, viewerAlumniId, showNetworkButtons }}>
  function showToast(message, success) {
    const toast = document.getElementById('profile-toast');
    document.getElementById('profile-toast-msg').textContent = message;
    document.getElementById('profile-toast-icon').textContent = success ? '✅' : '❌';
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 4000);
  }

  // Profile view tracking (fire-and-forget)
  if (viewerAlumniId && viewerAlumniId !== targetAlumniId) {
    (async () => {
      try {
        const sessionRes = await fetch('/api/auth/alumni-session');
        const sessionData = await sessionRes.json();
        if (sessionData.authenticated) {
          await fetch('/api/admin/track-engagement', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              type: 'profile_view',
              alumniId: viewerAlumniId,
              alumniName: sessionData.data?.name || '',
              targetAlumniId,
              targetAlumniName,
              status: 'completed',
            }),
          });
        }
      } catch {
        // silently ignore
      }
    })();
  }

  // Connect button logic
  async function sendConnectionRequest() {
    const btn = document.getElementById('connect-btn');
    if (!btn || btn.disabled) return;
    btn.disabled = true;
    btn.textContent = 'Sending…';

    try {
      const res = await fetch('/api/connections/request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ targetId: targetAlumniId, message: '' }),
      });
      const data = await res.json();
      if (data.success) {
        btn.textContent = 'Request Sent ✓';
        btn.className = 'btn btn-sm w-full justify-center bg-green-50 text-green-700 border border-green-200 cursor-default';
        showToast('Connection request sent!', true);
      } else if (res.status === 409) {
        btn.textContent = 'Connected ✓';
        btn.className = 'btn btn-sm w-full justify-center bg-green-50 text-green-700 border border-green-200 cursor-default';
      } else {
        btn.disabled = false;
        btn.textContent = 'Connect';
        showToast(data.message || 'Failed to send request.', false);
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Connect';
      showToast('Network error. Please try again.', false);
    }
  }

  // Check if already connected
  if (showNetworkButtons) {
    (async () => {
      try {
        const res = await fetch('/api/connections/my-connections');
        const data = await res.json();
        if (data.success) {
          const isConnected = data.connections.some(
            (c) => c.requesterId === targetAlumniId || c.targetId === targetAlumniId
          );
          const isPending = data.pendingIncoming.some((c) => c.requesterId === targetAlumniId);
          const btn = document.getElementById('connect-btn');
          if (btn && (isConnected || isPending)) {
            btn.textContent = isConnected ? 'Connected ✓' : 'Request Pending';
            btn.className = 'btn btn-sm w-full justify-center bg-green-50 text-green-700 border border-green-200 cursor-default';
            btn.disabled = true;
          }
        }
      } catch {
        // silently ignore
      }
    })();
  }
</script>
