---
export const prerender = false;

import Layout from '@/layouts/Layout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Icon from '../../../components/Icon.astro';
import ViewModeToggle from '@/components/alumni/ViewModeToggle.astro';
import AlumniMap from '@/components/alumni/AlumniMap.astro';
import ShareModal from '@/components/alumni/ShareModal.astro';
import AlumniListCard from '@/components/alumni/AlumniListCard.astro';
import AlumniSkeleton from '@/components/alumni/AlumniSkeleton.astro';
import Toast from '@/components/alumni/Toast.astro';
import { getCollection } from 'astro:content';
import { getSiteConfig } from '@/utils/config';

const config = getSiteConfig();
const contentAlumni = await getCollection('alumni');

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Profiles', href: '/alumni' },
  { label: 'Directory' },
];

const parseCsvParam = (params: URLSearchParams, key: string) =>
  (params.get(key) || '')
    .split(',')
    .map((item) => item.trim())
    .filter(Boolean);

const escapeRegex = (value: string) => value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
const generateSlug = (name: string) =>
  (name || '')
    .toLowerCase()
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-');
const normalizeSkills = (value: unknown) => {
  if (Array.isArray(value)) return value.map((item) => String(item).trim()).filter(Boolean);
  if (typeof value === 'string') return value.split(',').map((item) => item.trim()).filter(Boolean);
  return [];
};

const searchParams = Astro.url.searchParams;
const queryState = {
  q: (searchParams.get('q') || '').trim(),
  faculty: parseCsvParam(searchParams, 'faculty'),
  year: parseCsvParam(searchParams, 'year'),
  skills: parseCsvParam(searchParams, 'skills'),
  location: parseCsvParam(searchParams, 'location'),
  company: parseCsvParam(searchParams, 'company'),
  availability: parseCsvParam(searchParams, 'availability').filter((value) =>
    ['mentorship', 'open_to_work', 'open_to_referral'].includes(value)
  ),
  page: Math.max(1, parseInt(searchParams.get('page') || '1', 10) || 1),
  limit: Math.max(1, parseInt(searchParams.get('limit') || String(config.content.alumni_per_page || 12), 10) || (config.content.alumni_per_page || 12)),
  sort: (['name', 'year', 'faculty'].includes(searchParams.get('sort') || '') ? searchParams.get('sort') : 'name') as 'name' | 'year' | 'faculty',
};

const fallbackAlumni = contentAlumni.map((entry) => ({
  ...entry.data,
  _id: entry.id,
  status: 'approved',
  job_designation: entry.data.position,
  open_to_mentorship: false,
  open_to_work: false,
  open_to_referral: false,
  skill_readiness: {},
}));

const toFacetEntries = (map: Map<any, number>) =>
  [...map.entries()].map(([value, count]) => ({ value, count }));

function fallbackSearch() {
  let filtered = fallbackAlumni.filter((alum) => alum.status === 'approved');

  if (queryState.q) {
    const regex = new RegExp(escapeRegex(queryState.q), 'i');
    filtered = filtered.filter((alum) =>
      regex.test(alum.name || '') ||
      regex.test(alum.faculty || '') ||
      regex.test(alum.short_bio || '') ||
      regex.test((alum.skills || []).join(' ')) ||
      regex.test(alum.company || '') ||
      regex.test(alum.location || '')
    );
  }

  if (queryState.faculty.length) {
    filtered = filtered.filter((alum) => queryState.faculty.includes(alum.faculty || ''));
  }

  if (queryState.year.length) {
    filtered = filtered.filter((alum) => queryState.year.includes(String(alum.year || '')));
  }

  if (queryState.skills.length) {
    filtered = filtered.filter((alum) => {
      const skills = normalizeSkills(alum.skills);
      return queryState.skills.some((skill) => skills.includes(skill));
    });
  }

  if (queryState.location.length) {
    filtered = filtered.filter((alum) => queryState.location.includes(alum.location || ''));
  }

  if (queryState.company.length) {
    filtered = filtered.filter((alum) => queryState.company.includes(alum.company || ''));
  }

  if (queryState.availability.length) {
    filtered = filtered.filter((alum) => {
      const availability = [
        queryState.availability.includes('mentorship') && alum.open_to_mentorship,
        queryState.availability.includes('open_to_work') && alum.open_to_work,
        queryState.availability.includes('open_to_referral') && alum.open_to_referral,
      ];
      return availability.some(Boolean);
    });
  }

  const sorters: Record<string, (a: any, b: any) => number> = {
    name: (a, b) => String(a.name || '').localeCompare(String(b.name || '')),
    year: (a, b) => Number(b.year || 0) - Number(a.year || 0),
    faculty: (a, b) => String(a.faculty || '').localeCompare(String(b.faculty || '')),
  };

  filtered.sort(sorters[queryState.sort] || sorters.name);

  const total = filtered.length;
  const totalPages = Math.max(1, Math.ceil(total / queryState.limit));
  const page = Math.min(queryState.page, totalPages);
  const start = (page - 1) * queryState.limit;

  const faculties = new Map<string, number>();
  const years = new Map<string, number>();
  const skills = new Map<string, number>();
  const locations = new Map<string, number>();
  const companies = new Map<string, number>();

  filtered.forEach((alum) => {
    if (alum.faculty) faculties.set(alum.faculty, (faculties.get(alum.faculty) || 0) + 1);
    if (alum.year) years.set(String(alum.year), (years.get(String(alum.year)) || 0) + 1);
    if (alum.location) locations.set(alum.location, (locations.get(alum.location) || 0) + 1);
    if (alum.company) companies.set(alum.company, (companies.get(alum.company) || 0) + 1);
    normalizeSkills(alum.skills).forEach((skill) => {
      skills.set(skill, (skills.get(skill) || 0) + 1);
    });
  });

  return {
    alumni: filtered.slice(start, start + queryState.limit),
    total,
    page,
    totalPages,
    facets: {
      faculties: toFacetEntries(faculties).sort((a, b) => b.count - a.count || String(a.value).localeCompare(String(b.value))),
      years: toFacetEntries(years).sort((a, b) => b.count - a.count || Number(b.value) - Number(a.value)),
      skills: toFacetEntries(skills).sort((a, b) => b.count - a.count || String(a.value).localeCompare(String(b.value))),
      locations: toFacetEntries(locations).sort((a, b) => b.count - a.count || String(a.value).localeCompare(String(b.value))),
      companies: toFacetEntries(companies).sort((a, b) => b.count - a.count || String(a.value).localeCompare(String(b.value))),
    },
  };
}

let initialResponse: any = null;
let searchUnavailable = false;

const serverParams = new URLSearchParams();
if (queryState.q) serverParams.set('q', queryState.q);
if (queryState.faculty.length) serverParams.set('faculty', queryState.faculty.join(','));
if (queryState.year.length) serverParams.set('year', queryState.year.join(','));
if (queryState.skills.length) serverParams.set('skills', queryState.skills.join(','));
if (queryState.location.length) serverParams.set('location', queryState.location.join(','));
if (queryState.company.length) serverParams.set('company', queryState.company.join(','));
if (queryState.availability.length) serverParams.set('availability', queryState.availability.join(','));
serverParams.set('page', String(queryState.page));
serverParams.set('limit', String(queryState.limit));
serverParams.set('sort', queryState.sort);

try {
  const apiResponse = await fetch(`${Astro.url.origin}/api/alumni/search?${serverParams.toString()}`);
  if (!apiResponse.ok) throw new Error('Search API unavailable');
  initialResponse = await apiResponse.json();
} catch {
  searchUnavailable = true;
  initialResponse = fallbackSearch();
}

const alumni = initialResponse?.alumni || [];
const total = initialResponse?.total || 0;
const totalPages = initialResponse?.totalPages || 1;
const page = initialResponse?.page || 1;
const facets = initialResponse?.facets || { faculties: [], skills: [], locations: [], companies: [], years: [] };
const statsTotalAlumni = total;
const statsFaculties = (facets.faculties || []).length;
const statsYears = (facets.years || []).length;

const initialPayload = {
  state: queryState,
  data: { alumni, total, totalPages, page, facets },
  fallbackData: {
    faculties: facets.faculties || [],
    years: facets.years || [],
    skills: (facets.skills || []).slice(0, 20),
    locations: facets.locations || [],
    companies: facets.companies || [],
  },
  searchUnavailable,
};

const skillReadinessColor: Record<string, string> = {
  beginner: '#93c5fd',
  intermediate: '#34d399',
  advanced: '#f59e0b',
  expert: '#ef4444',
};

const getSkills = (alum: any) => normalizeSkills(alum.skills).slice(0, 3);
const calcCompleteness = (alum: any): number => {
  const fields = ['photo', 'faculty', 'year', 'short_bio', 'long_bio', 'location', 'company', 'position', 'skills', 'linkedin'];
  const filled = fields.filter((f) => {
    const val = alum[f];
    if (f === 'skills') return Array.isArray(val) ? val.length > 0 : (typeof val === 'string' && val.trim().length > 0);
    return val !== undefined && val !== null && String(val).trim() !== '';
  });
  return Math.round((filled.length / fields.length) * 100);
};
const getCompletenessColor = (pct: number) => (pct >= 70 ? '#22c55e' : pct >= 40 ? '#f59e0b' : '#ef4444');
const isRecentlyActive = (alum: any): boolean => {
  const date = alum.updated_at || alum.updatedAt || alum.created_at || alum.createdAt;
  if (!date) return false;
  const d = new Date(date);
  return !isNaN(d.getTime()) && (Date.now() - d.getTime()) < 90 * 24 * 60 * 60 * 1000;
};
---

<Layout title="Alumni Directory" description="Browse alumni by faculty, year, and search.">
  <Breadcrumbs items={breadcrumbItems} />

  <section class="section">
    <div class="container-custom">
      <div class="relative text-center mb-12">
        <button id="theme-toggle" type="button" class="absolute right-0 top-0 h-11 w-11 rounded-lg border border-accent-200 bg-white text-accent-700 transition-colors" aria-label="Toggle dark mode">
          <svg id="theme-icon-light" viewBox="0 0 24 24" class="mx-auto h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
          </svg>
          <svg id="theme-icon-dark" viewBox="0 0 24 24" class="mx-auto hidden h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8Z"></path>
          </svg>
        </button>
        <h1 class="text-4xl md:text-5xl font-bold text-accent-900 mb-4">Alumni Directory</h1>
        <p class="text-xl text-accent-600 max-w-3xl mx-auto">
          Connect with fellow alumni from {config.organization.name}. Discover alumni by faculty, year, skills, location, and availability.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="bg-gradient-to-br from-primary-50 to-primary-100 p-6 rounded-2xl text-center">
          <div class="w-16 h-16 bg-primary-500 rounded-full flex items-center justify-center mx-auto mb-4">
            <Icon name="mdi:account-group" class="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold text-primary-900">{statsTotalAlumni}</h3>
          <p class="text-primary-700">Total Alumni</p>
        </div>
        <div class="bg-gradient-to-br from-secondary-50 to-secondary-100 p-6 rounded-2xl text-center">
          <div class="w-16 h-16 bg-secondary-500 rounded-full flex items-center justify-center mx-auto mb-4">
            <Icon name="mdi:school" class="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold text-secondary-900">{statsFaculties}</h3>
          <p class="text-secondary-700">Faculties</p>
        </div>
        <div class="bg-gradient-to-br from-accent-50 to-accent-100 p-6 rounded-2xl text-center">
          <div class="w-16 h-16 bg-accent-500 rounded-full flex items-center justify-center mx-auto mb-4">
            <Icon name="mdi:calendar" class="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold text-accent-900">{statsYears}</h3>
          <p class="text-accent-700">Graduation Years</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-accent-100 p-6 mb-8 space-y-5">
        <button id="filters-toggle" type="button" class="md:hidden btn btn-outline w-full min-h-11">Filters & Search</button>
        <div id="filters-panel" class="space-y-5">
        <div class="space-y-3">
          <button id="nl-toggle" type="button" class="btn btn-outline btn-sm">Ask in plain English</button>
          <div id="nl-panel" class="hidden bg-primary-50 border border-primary-100 rounded-xl p-4 space-y-3">
            <input id="nl-query" type="text" class="input input-bordered w-full" placeholder="e.g. Find alumni working in fintech in Mumbai with Python skills" />
            <div class="flex flex-wrap items-center gap-2">
              <button id="nl-submit" type="button" class="btn btn-primary btn-sm">Apply AI Search</button>
              <span id="nl-loading" class="hidden text-sm text-primary-700 inline-flex items-center gap-2">
                <svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"></circle>
                  <path d="M22 12a10 10 0 0 1-10 10" stroke="currentColor" stroke-width="3"></path>
                </svg>
                Parsing your query...
              </span>
              <span id="nl-message" class="text-sm text-amber-700"></span>
            </div>
          </div>
        </div>

        <div>
          <label for="search" class="block text-sm font-medium text-accent-700 mb-2">Search</label>
          <input id="search" type="text" class="input input-bordered w-full" placeholder="Search by name, faculty, bio, skills, location, company..." value={queryState.q} />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
          <div class="relative">
            <button id="faculty-toggle" class="filter-toggle" type="button">Faculty <span id="faculty-selected-count" class="selected-count"></span></button>
            <div id="faculty-panel" class="filter-panel hidden">
              <div id="faculty-options" class="space-y-2 max-h-48 overflow-auto"></div>
            </div>
          </div>

          <div class="relative">
            <button id="year-toggle" class="filter-toggle" type="button">Year <span id="year-selected-count" class="selected-count"></span></button>
            <div id="year-panel" class="filter-panel hidden">
              <div id="year-options" class="space-y-2 max-h-48 overflow-auto"></div>
            </div>
          </div>

          <div class="relative">
            <button id="location-toggle" class="filter-toggle" type="button">Location <span id="location-selected-count" class="selected-count"></span></button>
            <div id="location-panel" class="filter-panel hidden">
              <input id="location-search" class="input input-bordered w-full mb-2" type="text" placeholder="Search location" />
              <div id="location-options" class="space-y-2 max-h-40 overflow-auto"></div>
            </div>
          </div>

          <div class="relative">
            <button id="company-toggle" class="filter-toggle" type="button">Company <span id="company-selected-count" class="selected-count"></span></button>
            <div id="company-panel" class="filter-panel hidden">
              <input id="company-search" class="input input-bordered w-full mb-2" type="text" placeholder="Search company" />
              <div id="company-options" class="space-y-2 max-h-40 overflow-auto"></div>
            </div>
          </div>
        </div>

        <div>
          <p class="text-sm font-medium text-accent-700 mb-2">Skills</p>
          <div id="skills-cloud" class="flex flex-wrap gap-2"></div>
        </div>

        <div>
          <p class="text-sm font-medium text-accent-700 mb-2">Availability</p>
          <div class="flex flex-wrap gap-4">
            <label class="inline-flex items-center gap-2"><input id="availability-mentorship" type="checkbox" class="rounded border-accent-300" /> Open to Mentorship</label>
            <label class="inline-flex items-center gap-2"><input id="availability-open_to_work" type="checkbox" class="rounded border-accent-300" /> Open to Work</label>
            <label class="inline-flex items-center gap-2"><input id="availability-open_to_referral" type="checkbox" class="rounded border-accent-300" /> Open to Referral</label>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-2">
          <div id="active-filters" class="flex flex-wrap gap-2"></div>
          <button id="clear-all-filters" type="button" class="btn btn-outline btn-sm">Clear All Filters</button>
        </div>
        </div>
      </div>

      <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
        <p class="text-accent-600">
          Showing <span id="results-count">{alumni.length}</span> of <span id="results-total">{total}</span> alumni
        </p>
        <div class="flex flex-wrap items-center gap-2">
          <label class="inline-flex items-center gap-2 rounded-lg border border-accent-200 bg-white px-3 py-2 min-h-11">
            <input id="infinite-scroll-toggle" type="checkbox" class="rounded border-accent-300" />
            <span class="text-sm text-accent-700">Infinite Scroll</span>
          </label>
          <button id="bookmarked-filter" type="button" class="btn btn-outline min-h-11" aria-pressed="false">Bookmarked Alumni (0)</button>
          <button id="export-csv" type="button" class="btn btn-outline min-h-11 w-full sm:w-auto">
            <span id="export-csv-label">Export CSV</span>
          </button>
          <ViewModeToggle />
          <span class="text-sm text-accent-600">Sort by:</span>
          <select id="sort-by" class="select w-auto">
            <option value="name" selected={queryState.sort === 'name'}>Name</option>
            <option value="year" selected={queryState.sort === 'year'}>Graduation Year</option>
            <option value="faculty" selected={queryState.sort === 'faculty'}>Faculty</option>
          </select>
        </div>
      </div>

      <p id="search-status" class={`text-sm mb-4 ${searchUnavailable ? 'text-amber-700' : 'hidden'}`}>
        Search unavailable from MongoDB. Showing content collection fallback results.
      </p>
      <div id="error-banner" class="hidden mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
      <div id="loading-more" class="hidden mb-4 text-sm text-accent-600">Loading more...</div>
      <AlumniSkeleton count={12} />
      <AlumniMap />
      <AlumniListCard />

      <div id="alumni-grid" class="grid-responsive-lg mb-8">
        {alumni.map((alum: any) => {
          const pct = calcCompleteness(alum);
          const barColor = getCompletenessColor(pct);
          const recent = isRecentlyActive(alum);
          const allSkills = normalizeSkills(alum.skills);
          const topSkills = allSkills.slice(0, 3);
          const extraSkills = allSkills.slice(3);
          const latestJob = (alum.work_experience && alum.work_experience.length > 0) ? alum.work_experience[0] : null;
          return (
            <div class="profile-card">
              <div class="absolute top-3 right-3">
                <span class="badge badge-primary text-xs">{alum.faculty || 'Alumni'}</span>
              </div>

              <div class="mb-3">
                {alum.photo || alum.photo_blob_url ? (
                  <img src={alum.photo || alum.photo_blob_url} alt={alum.name} class="profile-avatar" loading="lazy" />
                ) : (
                  <div class="profile-avatar-placeholder">
                    {String(alum.name || '').split(' ').map((p: string) => p[0]).join('').toUpperCase()}
                  </div>
                )}
              </div>

              <h3 class="text-lg font-semibold text-accent-900 mb-1">
                {alum.name}
                {recent && <span class="recently-active-badge">🟢 Active</span>}
              </h3>
              {alum.bio_category && <span class="bio-category-badge">{alum.bio_category}</span>}

              <div class="completeness-bar-wrap mb-2" title={`Profile ${pct}% complete`}>
                <div class="completeness-bar-track">
                  <div class="completeness-bar-fill" style={`width: ${pct}%; background-color: ${barColor};`}></div>
                </div>
                <span class="completeness-pct">{pct}%</span>
              </div>

              <p class="text-accent-500 text-sm mb-3 line-clamp-2">{alum.short_bio || 'No bio available'}</p>

              {topSkills.length > 0 && (
                <div class="flex flex-wrap gap-1.5 justify-center mb-3">
                  {topSkills.map((skill: string) => {
                    const readiness = alum.skill_readiness?.[skill];
                    return (
                      <span class="skill-tag">
                        {readiness && <span class="skill-dot" style={`background-color: ${skillReadinessColor[readiness] || '#9ca3af'};`}></span>}
                        {skill}
                      </span>
                    );
                  })}
                </div>
              )}

              {(alum.company || alum.job_designation || alum.position) && (
                <p class="text-sm font-medium text-accent-700 mb-1">
                  {alum.company || ''}{(alum.job_designation || alum.position) ? ` • ${alum.job_designation || alum.position}` : ''}
                </p>
              )}
              {alum.location && <p class="text-sm text-accent-500 mb-2">📍 {alum.location}</p>}
              {alum.open_to_mentorship && (
                <span class="mentor-badge mb-3">🤝 Open to Mentor</span>
              )}

              {(latestJob || extraSkills.length > 0) && (
                <div class="card-expand">
                  <div class="card-expand-inner">
                    {latestJob && (
                      <div class="expand-section">
                        <p class="expand-title">Latest Role</p>
                        <p class="expand-role">{latestJob.position} at {latestJob.company}</p>
                        {latestJob.duration && <p class="expand-duration">{latestJob.duration}</p>}
                      </div>
                    )}
                    {allSkills.length > 3 && (
                      <div class="expand-section">
                        <p class="expand-title">All Skills</p>
                        <div class="flex flex-wrap gap-1.5 justify-center">
                          {allSkills.map((skill: string) => (
                            <span class="skill-tag-sm">{skill}</span>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              )}

              <div class="card-footer">
                <span class="text-xs text-accent-400">Class of {alum.year || '—'}</span>
                {(alum.slug || generateSlug(alum.name || '')) && (
                  <a href={`/alumni/profiles/${alum.slug || generateSlug(alum.name || '')}`} class="view-profile-link">View Profile →</a>
                )}
              </div>
            </div>
          );
        })}
      </div>

      <div class="flex items-center justify-center space-x-2" id="pagination-controls">
        <button id="prev-page" class="btn btn-outline btn-sm" disabled={page <= 1}>
          <Icon name="mdi:chevron-left" class="w-4 h-4 mr-1" />
          Previous
        </button>

        <div id="page-numbers" class="flex items-center space-x-1"></div>

        <button id="next-page" class="btn btn-outline btn-sm" disabled={page >= totalPages}>
          Next
          <Icon name="mdi:chevron-right" class="w-4 h-4 ml-1" />
        </button>
      </div>
      <div id="empty-state" class="hidden rounded-2xl border border-accent-200 bg-white p-10 text-center">
        <svg class="mx-auto mb-4 h-10 w-10 text-accent-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M3 12h18M3 6h18M3 18h18"></path>
        </svg>
        <p class="font-semibold text-accent-700">No alumni found for your current search.</p>
        <p class="mt-1 text-sm text-accent-500">Try clearing filters or changing your query.</p>
      </div>
    </div>
  </section>
  <ShareModal />
  <Toast />
</Layout>

<script id="alumni-initial-data" type="application/json" set:html={JSON.stringify(initialPayload)}></script>

<script>
  import { applyTheme, getStoredTheme, persistTheme } from '../../../utils/theme';
  import { loadBookmarks, saveBookmarks, toggleBookmark } from '../../../utils/bookmarks';
  import { exportAlumniToCsv } from '../../../utils/export';

  const payloadEl = document.getElementById('alumni-initial-data');
  const payload = payloadEl ? JSON.parse(payloadEl.textContent || '{}') : {};

  const VIEW_MODE_KEY = 'alumni-directory-view-mode';
  const INFINITE_SCROLL_KEY = 'alumni-directory-infinite-scroll';
  const BOOKMARK_FILTER_KEY = 'alumni-directory-show-bookmarked';

  const getStored = (key, fallback = '') => {
    try {
      return localStorage.getItem(key) ?? fallback;
    } catch {
      return fallback;
    }
  };

  const setStored = (key, value) => {
    try {
      localStorage.setItem(key, value);
    } catch {
      // no-op
    }
  };

  const state = {
    ...(payload.state || {}),
    faculty: payload.state?.faculty || [],
    year: payload.state?.year || [],
    skills: payload.state?.skills || [],
    location: payload.state?.location || [],
    company: payload.state?.company || [],
    availability: payload.state?.availability || [],
    viewMode: ['grid', 'list', 'map'].includes(getStored(VIEW_MODE_KEY, 'grid')) ? getStored(VIEW_MODE_KEY, 'grid') : 'grid',
    infiniteScrollEnabled: getStored(INFINITE_SCROLL_KEY, 'false') === 'true',
    theme: getStoredTheme(),
    bookmarks: loadBookmarks(),
    showBookmarked: getStored(BOOKMARK_FILTER_KEY, 'false') === 'true',
  };

  const resultState = {
    data: payload.data || { alumni: [], total: 0, page: 1, totalPages: 1, facets: {} },
    facets: payload.data?.facets || payload.fallbackData || {
      faculties: [], years: [], skills: [], locations: [], companies: [],
    },
  };

  const mapState = {
    map: null,
    leaflet: null,
    markers: [],
    geocodeCache: new Map(),
    visibleIds: null,
  };

  let isLoadingMore = false;
  let shareTarget = null;
  let toastTimer = null;

  const elements = {
    search: document.getElementById('search'),
    sort: document.getElementById('sort-by'),
    grid: document.getElementById('alumni-grid'),
    resultsCount: document.getElementById('results-count'),
    resultsTotal: document.getElementById('results-total'),
    searchStatus: document.getElementById('search-status'),
    activeFilters: document.getElementById('active-filters'),
    clearAll: document.getElementById('clear-all-filters'),
    prev: document.getElementById('prev-page'),
    next: document.getElementById('next-page'),
    pageNumbers: document.getElementById('page-numbers'),
    nlToggle: document.getElementById('nl-toggle'),
    nlPanel: document.getElementById('nl-panel'),
    nlQuery: document.getElementById('nl-query'),
    nlSubmit: document.getElementById('nl-submit'),
    nlLoading: document.getElementById('nl-loading'),
    nlMessage: document.getElementById('nl-message'),
    themeToggle: document.getElementById('theme-toggle'),
    themeIconLight: document.getElementById('theme-icon-light'),
    themeIconDark: document.getElementById('theme-icon-dark'),
    filtersToggle: document.getElementById('filters-toggle'),
    filtersPanel: document.getElementById('filters-panel'),
    viewGrid: document.getElementById('view-grid'),
    viewList: document.getElementById('view-list'),
    viewMap: document.getElementById('view-map'),
    infiniteScrollToggle: document.getElementById('infinite-scroll-toggle'),
    bookmarkedFilter: document.getElementById('bookmarked-filter'),
    exportCsv: document.getElementById('export-csv'),
    exportCsvLabel: document.getElementById('export-csv-label'),
    paginationControls: document.getElementById('pagination-controls'),
    loadingMore: document.getElementById('loading-more'),
    skeletons: document.getElementById('alumni-skeletons'),
    mapWrapper: document.getElementById('alumni-map-wrapper'),
    mapContainer: document.getElementById('alumni-map'),
    mapError: document.getElementById('map-error'),
    emptyState: document.getElementById('empty-state'),
    errorBanner: document.getElementById('error-banner'),
    shareModalOverlay: document.getElementById('share-modal-overlay'),
    shareClose: document.getElementById('share-close'),
    shareTarget: document.getElementById('share-target'),
    shareCopy: document.getElementById('share-copy'),
    shareEmail: document.getElementById('share-email'),
    shareLinkedin: document.getElementById('share-linkedin'),
    shareTwitter: document.getElementById('share-twitter'),
    toast: document.getElementById('directory-toast'),
    toastMessage: document.getElementById('directory-toast-message'),
    toastAction: document.getElementById('directory-toast-action'),
    faculty: { toggle: document.getElementById('faculty-toggle'), panel: document.getElementById('faculty-panel'), options: document.getElementById('faculty-options'), count: document.getElementById('faculty-selected-count') },
    year: { toggle: document.getElementById('year-toggle'), panel: document.getElementById('year-panel'), options: document.getElementById('year-options'), count: document.getElementById('year-selected-count') },
    location: { toggle: document.getElementById('location-toggle'), panel: document.getElementById('location-panel'), options: document.getElementById('location-options'), search: document.getElementById('location-search'), count: document.getElementById('location-selected-count') },
    company: { toggle: document.getElementById('company-toggle'), panel: document.getElementById('company-panel'), options: document.getElementById('company-options'), search: document.getElementById('company-search'), count: document.getElementById('company-selected-count') },
    skillsCloud: document.getElementById('skills-cloud'),
    availability: {
      mentorship: document.getElementById('availability-mentorship'),
      open_to_work: document.getElementById('availability-open_to_work'),
      open_to_referral: document.getElementById('availability-open_to_referral'),
    },
  };

  const availabilityLabels = {
    mentorship: 'Open to Mentorship',
    open_to_work: 'Open to Work',
    open_to_referral: 'Open to Referral',
  };

  const skillReadinessColor = {
    beginner: '#93c5fd',
    intermediate: '#34d399',
    advanced: '#f59e0b',
    expert: '#ef4444',
  };

  const normalizeSkills = (value) => {
    if (Array.isArray(value)) return value.map((item) => String(item).trim()).filter(Boolean);
    if (typeof value === 'string') return value.split(',').map((item) => item.trim()).filter(Boolean);
    return [];
  };

  const esc = (value) =>
    String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  const generateSlug = (name) => (name || '')
    .toLowerCase()
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-');
  const calcCompleteness = (alum) => {
    const fields = ['photo', 'faculty', 'year', 'short_bio', 'long_bio', 'location', 'company', 'position', 'skills', 'linkedin'];
    const filled = fields.filter((f) => {
      const val = alum[f];
      if (f === 'skills') return Array.isArray(val) ? val.length > 0 : (typeof val === 'string' && val.trim().length > 0);
      return val !== undefined && val !== null && String(val).trim() !== '';
    });
    return Math.round((filled.length / fields.length) * 100);
  };
  const getCompletenessColor = (pct) => (pct >= 70 ? '#22c55e' : pct >= 40 ? '#f59e0b' : '#ef4444');
  const isRecentlyActive = (alum) => {
    const date = alum.updated_at || alum.updatedAt || alum.created_at || alum.createdAt;
    if (!date) return false;
    const d = new Date(date);
    return !isNaN(d.getTime()) && (Date.now() - d.getTime()) < 90 * 24 * 60 * 60 * 1000;
  };

  function formatMultiSelectLabel(values, singular) {
    return values.length ? `(${values.length})` : '';
  }

  const getAlumniKey = (alum) => String(alum._id || alum.slug || generateSlug(alum.name || ''));

  const getFilteredAlumni = () => {
    let alumni = [...(resultState.data.alumni || [])];
    if (state.showBookmarked) {
      alumni = alumni.filter((alum) => state.bookmarks.includes(getAlumniKey(alum)));
    }
    if (state.viewMode === 'map' && mapState.visibleIds) {
      alumni = alumni.filter((alum) => mapState.visibleIds.has(getAlumniKey(alum)));
    }
    return alumni;
  };

  function showToast(message, options = {}) {
    if (!elements.toast || !elements.toastMessage) return;
    elements.toastMessage.textContent = message;
    if (toastTimer) clearTimeout(toastTimer);
    const { actionLabel, onAction, duration = 5000 } = options;
    if (actionLabel && elements.toastAction) {
      elements.toastAction.textContent = actionLabel;
      elements.toastAction.classList.remove('hidden');
      elements.toastAction.onclick = () => {
        onAction?.();
        elements.toast?.classList.add('hidden');
      };
    } else if (elements.toastAction) {
      elements.toastAction.classList.add('hidden');
      elements.toastAction.onclick = null;
    }
    elements.toast.classList.remove('hidden');
    toastTimer = setTimeout(() => elements.toast?.classList.add('hidden'), duration);
  }

  function setErrorBanner(message = '', details = '') {
    if (!elements.errorBanner) return;
    if (!message) {
      elements.errorBanner.classList.add('hidden');
      elements.errorBanner.textContent = '';
      return;
    }
    elements.errorBanner.classList.remove('hidden');
    elements.errorBanner.textContent = details ? `${message}: ${details}` : message;
  }

  function showSkeletons(visible) {
    elements.skeletons?.classList.toggle('hidden', !visible);
    if (visible) {
      elements.grid?.classList.add('hidden');
      elements.emptyState?.classList.add('hidden');
    }
  }

  function persistPreferenceState() {
    setStored(VIEW_MODE_KEY, state.viewMode);
    setStored(INFINITE_SCROLL_KEY, String(state.infiniteScrollEnabled));
    setStored(BOOKMARK_FILTER_KEY, String(state.showBookmarked));
    persistTheme(state.theme);
  }

  function renderTheme() {
    applyTheme(state.theme);
    elements.themeIconLight?.classList.toggle('hidden', state.theme === 'dark');
    elements.themeIconDark?.classList.toggle('hidden', state.theme !== 'dark');
  }

  function renderViewModeControls() {
    const modes = [
      ['grid', elements.viewGrid],
      ['list', elements.viewList],
      ['map', elements.viewMap],
    ];
    modes.forEach(([mode, button]) => {
      button?.classList.toggle('is-active', state.viewMode === mode);
      button?.setAttribute('aria-pressed', String(state.viewMode === mode));
    });
    elements.mapWrapper?.classList.toggle('hidden', state.viewMode !== 'map');
    elements.grid?.classList.toggle('hidden', state.viewMode === 'map');
    if (elements.paginationControls) {
      elements.paginationControls.classList.toggle('opacity-50', state.infiniteScrollEnabled);
      elements.paginationControls.classList.toggle('pointer-events-none', state.infiniteScrollEnabled);
    }
  }

  function renderPreferenceControls() {
    if (elements.infiniteScrollToggle) elements.infiniteScrollToggle.checked = state.infiniteScrollEnabled;
    if (elements.bookmarkedFilter) {
      const count = state.bookmarks.length;
      elements.bookmarkedFilter.textContent = `Bookmarked Alumni (${count})`;
      elements.bookmarkedFilter.setAttribute('aria-pressed', String(state.showBookmarked));
      elements.bookmarkedFilter.classList.toggle('btn-primary', state.showBookmarked);
    }
  }

  function mergeFacetWithSelections(items = [], selected = []) {
    const map = new Map(items.map((item) => [String(item.value), item]));
    selected.forEach((value) => {
      const key = String(value);
      if (!map.has(key)) map.set(key, { value, count: 0 });
    });
    return [...map.values()];
  }

  function renderMultiSelectOptions(groupKey, facetKey, filterText = '') {
    const selected = state[groupKey] || [];
    const facetItems = mergeFacetWithSelections(resultState.facets[facetKey] || [], selected)
      .filter((item) => String(item.value).toLowerCase().includes(filterText.toLowerCase()));

    elements[groupKey].count.textContent = formatMultiSelectLabel(selected, groupKey);

    elements[groupKey].options.innerHTML = facetItems.length
      ? facetItems
          .map(
            (item) => `<label class="flex items-center justify-between gap-2 text-sm">
              <span class="flex items-center gap-2">
                <input type="checkbox" data-group="${groupKey}" data-value="${esc(item.value)}" ${selected.includes(String(item.value)) ? 'checked' : ''}>
                <span>${esc(item.value)}</span>
              </span>
              <span class="text-xs text-accent-500">${item.count ?? 0}</span>
            </label>`
          )
          .join('')
      : '<p class="text-sm text-accent-500">No options available</p>';
  }

  function renderSkills() {
    const selectedSkills = state.skills || [];
    const skillItems = mergeFacetWithSelections(resultState.facets.skills || [], selectedSkills)
      .sort((a, b) => (b.count || 0) - (a.count || 0))
      .slice(0, 20);

    elements.skillsCloud.innerHTML = skillItems
      .map((item) => {
        const active = selectedSkills.includes(String(item.value));
        return `<button type="button" data-skill="${esc(item.value)}" class="px-3 py-1 rounded-full border text-sm ${active ? 'bg-primary-600 text-white border-primary-600' : 'bg-white text-accent-700 border-accent-300'}">
          <span class="inline-block w-2 h-2 rounded-full bg-primary-300 mr-1"></span>
          ${esc(item.value)} <span class="text-xs opacity-80">${item.count ?? 0}</span>
        </button>`;
      })
      .join('');
  }

  function renderActiveFilters() {
    const chips = [];
    const chip = (group, value, label = value) => `<button type="button" class="chip" data-remove-group="${group}" data-remove-value="${esc(value)}">${esc(label)} ✕</button>`;

    if (state.q) chips.push(chip('q', state.q, `Search: ${state.q}`));
    state.faculty.forEach((value) => chips.push(chip('faculty', value)));
    state.year.forEach((value) => chips.push(chip('year', value)));
    state.skills.forEach((value) => chips.push(chip('skills', value)));
    state.location.forEach((value) => chips.push(chip('location', value)));
    state.company.forEach((value) => chips.push(chip('company', value)));
    state.availability.forEach((value) => chips.push(chip('availability', value, availabilityLabels[value] || value)));

    elements.activeFilters.innerHTML = chips.length ? chips.join('') : '<span class="text-sm text-accent-500">No active filters</span>';
  }

  function renderCards() {
    const alumni = getFilteredAlumni();
    const isList = state.viewMode === 'list';
    elements.grid.className = `${isList ? 'space-y-4' : 'grid-responsive-lg'} mb-8`;
    elements.grid.classList.toggle('hidden', state.viewMode === 'map');
    elements.emptyState?.classList.toggle('hidden', alumni.length > 0 || state.viewMode === 'map');

    elements.grid.innerHTML = alumni.length
      ? alumni
          .map((alum) => {
            const initials = esc(String(alum.name || '').split(' ').map((part) => part[0]).join('').toUpperCase());
            const photo = alum.photo || alum.photo_blob_url;
            const allSkills = normalizeSkills(alum.skills);
            const topSkills = allSkills.slice(0, 3);
            const profileSlug = alum.slug || generateSlug(alum.name);
            const pct = calcCompleteness(alum);
            const barColor = getCompletenessColor(pct);
            const recent = isRecentlyActive(alum);
            const latestJob = (alum.work_experience && alum.work_experience.length > 0) ? alum.work_experience[0] : null;
            const alumKey = getAlumniKey(alum);
            const isBookmarked = state.bookmarks.includes(alumKey);
            const profileHref = profileSlug ? `/alumni/profiles/${encodeURIComponent(profileSlug)}` : '#';

            const avatarHtml = photo
              ? `<img src="${esc(photo)}" alt="${esc(alum.name)}" class="profile-avatar" loading="lazy" />`
              : `<div class="profile-avatar-placeholder">${initials}</div>`;

            const topSkillBadges = topSkills.map((skill) => {
              const readiness = alum.skill_readiness?.[skill];
              const color = readiness ? (skillReadinessColor[readiness] || '#9ca3af') : null;
              const dot = color ? `<span class="skill-dot" style="background-color:${color};"></span>` : '';
              return `<span class="skill-tag">${dot}${esc(skill)}</span>`;
            }).join('');

            const expandHtml = (() => {
              const parts = [];
              if (latestJob) {
                parts.push(`<div class="expand-section">
                  <p class="expand-title">Latest Role</p>
                  <p class="expand-role">${esc(latestJob.position || '')} at ${esc(latestJob.company || '')}</p>
                  ${latestJob.duration ? `<p class="expand-duration">${esc(latestJob.duration)}</p>` : ''}
                </div>`);
              }
              if (allSkills.length > 3) {
                const allSkillTags = allSkills.map((s) => `<span class="skill-tag-sm">${esc(s)}</span>`).join('');
                parts.push(`<div class="expand-section">
                  <p class="expand-title">All Skills</p>
                  <div class="flex flex-wrap gap-1.5 justify-center">${allSkillTags}</div>
                </div>`);
              }
              if (parts.length === 0) return '';
              return `<div class="card-expand"><div class="card-expand-inner">${parts.join('')}</div></div>`;
            })();
            const bookmarkButton = `<button type="button" class="bookmark-btn h-11 w-11 rounded-full border border-accent-200 bg-white ${isBookmarked ? 'text-rose-500' : 'text-accent-500'}" data-bookmark="${esc(alumKey)}" aria-label="Toggle bookmark">
              <svg viewBox="0 0 24 24" class="mx-auto h-5 w-5" fill="${isBookmarked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="1.8"><path d="M12.1 21s-7.1-4.5-9.1-8.2a5.2 5.2 0 0 1 9.1-5.2 5.2 5.2 0 0 1 9.1 5.2C19.2 16.5 12.1 21 12.1 21Z"></path></svg>
            </button>`;
            const shareButton = `<button type="button" class="share-btn h-11 w-11 rounded-full border border-accent-200 bg-white text-accent-500" data-share="${esc(alumKey)}" aria-label="Share profile">
              <svg viewBox="0 0 24 24" class="mx-auto h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7"></path><path d="M16 6l-4-4-4 4"></path><path d="M12 2v13"></path></svg>
            </button>`;

            if (isList) {
              return `<article class="profile-card list-card flex flex-col sm:flex-row sm:items-center gap-4">
                <div class="flex-shrink-0">${avatarHtml}</div>
                <div class="min-w-0 flex-1">
                  <div class="mb-1 flex flex-wrap items-center gap-2">
                    <h3 class="text-lg font-semibold text-accent-900">${esc(alum.name)}${recent ? '<span class="recently-active-badge">Active</span>' : ''}</h3>
                    <span class="badge badge-primary text-xs">${esc(alum.faculty || 'Alumni')}</span>
                  </div>
                  <p class="text-sm text-accent-500 line-clamp-2 mb-2">${esc(alum.short_bio || 'No bio available')}</p>
                  <p class="text-sm text-accent-700">${esc(alum.company || '')}${alum.job_designation || alum.position ? ` • ${esc(alum.job_designation || alum.position)}` : ''}</p>
                  ${alum.location ? `<p class="text-sm text-accent-500">${esc(alum.location)}</p>` : ''}
                  ${topSkillBadges ? `<div class="mt-2 flex flex-wrap gap-1.5">${topSkillBadges}</div>` : ''}
                </div>
                <div class="flex items-center gap-2">${bookmarkButton}${shareButton}<a href="${profileHref}" class="btn btn-outline min-h-11">View</a></div>
              </article>`;
            }

            return `<div class="profile-card">
              <div class="absolute right-3 top-3 flex items-center gap-2">${bookmarkButton}${shareButton}<span class="badge badge-primary text-xs">${esc(alum.faculty || 'Alumni')}</span></div>
              <div class="mb-3">${avatarHtml}</div>
              <h3 class="text-lg font-semibold text-accent-900 mb-1">${esc(alum.name)}${recent ? '<span class="recently-active-badge">Active</span>' : ''}</h3>
              ${alum.bio_category ? `<span class="bio-category-badge">${esc(alum.bio_category)}</span>` : ''}
              <div class="completeness-bar-wrap mb-2" title="Profile ${pct}% complete">
                <div class="completeness-bar-track"><div class="completeness-bar-fill" style="width:${pct}%;background-color:${barColor};"></div></div>
                <span class="completeness-pct">${pct}%</span>
              </div>
              <p class="text-accent-500 text-sm mb-3 line-clamp-2">${esc(alum.short_bio || 'No bio available')}</p>
              ${topSkillBadges ? `<div class="flex flex-wrap gap-1.5 justify-center mb-3">${topSkillBadges}</div>` : ''}
              ${alum.company || alum.job_designation || alum.position ? `<p class="text-sm font-medium text-accent-700 mb-1">${esc(alum.company || '')}${alum.job_designation || alum.position ? ` • ${esc(alum.job_designation || alum.position)}` : ''}</p>` : ''}
              ${alum.location ? `<p class="text-sm text-accent-500 mb-2">${esc(alum.location)}</p>` : ''}
              ${alum.open_to_mentorship ? '<span class="mentor-badge mb-3">Open to Mentor</span>' : ''}
              ${expandHtml}
              <div class="card-footer">
                <span class="text-xs text-accent-400">Class of ${esc(String(alum.year || '—'))}</span>
                ${profileSlug ? `<a href="${profileHref}" class="view-profile-link">View Profile →</a>` : '<span class="text-accent-400 text-xs">Profile unavailable</span>'}
              </div>
            </div>`;
          })
          .join('')
      : '';

    elements.resultsCount.textContent = String(alumni.length);
    elements.resultsTotal.textContent = String(state.showBookmarked ? alumni.length : (resultState.data.total || 0));
  }

  function renderPagination() {
    const totalPages = resultState.data.totalPages || 1;
    const currentPage = resultState.data.page || 1;

    elements.prev.disabled = currentPage <= 1;
    elements.next.disabled = currentPage >= totalPages;
    if (state.infiniteScrollEnabled) return;

    elements.pageNumbers.innerHTML = '';
    const maxButtons = 7;
    const start = Math.max(1, currentPage - Math.floor(maxButtons / 2));
    const end = Math.min(totalPages, start + maxButtons - 1);

    for (let i = start; i <= end; i++) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = `w-10 h-10 rounded-lg text-sm font-medium transition-colors duration-200 ${
        i === currentPage
          ? 'bg-primary-600 text-white'
          : 'text-accent-600 hover:text-accent-900 hover:bg-accent-100'
      }`;
      btn.textContent = String(i);
      btn.addEventListener('click', () => {
        if (i !== currentPage) {
          state.page = i;
          fetchResults(false);
        }
      });
      elements.pageNumbers.appendChild(btn);
    }
  }

  function updateURL() {
    const params = new URLSearchParams();
    if (state.q) params.set('q', state.q);
    if (state.faculty.length) params.set('faculty', state.faculty.join(','));
    if (state.year.length) params.set('year', state.year.join(','));
    if (state.skills.length) params.set('skills', state.skills.join(','));
    if (state.location.length) params.set('location', state.location.join(','));
    if (state.company.length) params.set('company', state.company.join(','));
    if (state.availability.length) params.set('availability', state.availability.join(','));
    if (state.sort && state.sort !== 'name') params.set('sort', state.sort);
    if ((state.page || 1) > 1) params.set('page', String(state.page));
    if (state.limit) params.set('limit', String(state.limit));

    const next = `${window.location.pathname}${params.toString() ? `?${params.toString()}` : ''}`;
    history.replaceState({}, '', next);
  }

  function syncAvailabilityUI() {
    Object.keys(elements.availability).forEach((key) => {
      elements.availability[key].checked = state.availability.includes(key);
    });
  }

  function syncSortAndSearchUI() {
    elements.search.value = state.q || '';
    elements.sort.value = state.sort || 'name';
  }

  function toggleArrayValue(group, value) {
    const list = state[group] || [];
    if (list.includes(value)) state[group] = list.filter((item) => item !== value);
    else state[group] = [...list, value];
  }

  function renderAllControls() {
    renderMultiSelectOptions('faculty', 'faculties');
    renderMultiSelectOptions('year', 'years');
    renderMultiSelectOptions('location', 'locations', elements.location.search.value || '');
    renderMultiSelectOptions('company', 'companies', elements.company.search.value || '');
    renderSkills();
    renderActiveFilters();
    syncAvailabilityUI();
    syncSortAndSearchUI();
  }

  const debounce = (fn, delay = 300) => {
    let timer = null;
    return (...args) => {
      if (timer) clearTimeout(timer);
      timer = setTimeout(() => fn(...args), delay);
    };
  };

  async function fetchResults(resetPage = true) {
    showSkeletons(true);
    setErrorBanner();
    if (resetPage) state.page = 1;
    state.sort = elements.sort.value || 'name';
    state.q = elements.search.value.trim();

    updateURL();

    const params = new URLSearchParams();
    if (state.q) params.set('q', state.q);
    if (state.faculty.length) params.set('faculty', state.faculty.join(','));
    if (state.year.length) params.set('year', state.year.join(','));
    if (state.skills.length) params.set('skills', state.skills.join(','));
    if (state.location.length) params.set('location', state.location.join(','));
    if (state.company.length) params.set('company', state.company.join(','));
    if (state.availability.length) params.set('availability', state.availability.join(','));
    params.set('page', String(state.page || 1));
    params.set('limit', String(state.limit || 12));
    params.set('sort', state.sort || 'name');

    try {
      const response = await fetch(`/api/alumni/search?${params.toString()}`);
      if (!response.ok) throw new Error('Search failed');
      const data = await response.json();
      if (state.infiniteScrollEnabled && !resetPage && isLoadingMore) {
       const existing = resultState.data.alumni || [];
       const incoming = data.alumni || [];
       const seen = new Set(existing.map((alum) => getAlumniKey(alum)));
       const merged = [...existing, ...incoming.filter((alum) => !seen.has(getAlumniKey(alum)))];
       resultState.data = { ...data, alumni: merged };
      } else {
       resultState.data = data;
      }
      resultState.facets = data.facets || resultState.facets;
      elements.searchStatus.classList.add('hidden');
      mapState.visibleIds = null;
    } catch {
      elements.searchStatus.classList.remove('hidden');
      elements.searchStatus.textContent = 'Search unavailable. Please try again later.';
      showToast('Failed to load alumni. Please try again.', {
       actionLabel: 'Retry',
       onAction: () => fetchResults(resetPage),
      });
      setErrorBanner('Search error', 'Failed to load alumni data');
    }

    showSkeletons(false);
    renderCards();
    renderPagination();
    renderAllControls();
    renderViewModeControls();
    renderPreferenceControls();
    if (state.viewMode === 'map') await renderMap();
  }

  const debouncedSearch = debounce(() => fetchResults(true), 300);

  async function runNaturalLanguageSearch() {
    const query = (elements.nlQuery?.value || '').trim();
    if (!query) {
      if (elements.nlMessage) elements.nlMessage.textContent = 'Please enter a natural language query.';
      return;
    }

    if (elements.nlMessage) elements.nlMessage.textContent = '';
    elements.nlLoading?.classList.remove('hidden');

    try {
      const response = await fetch('/api/ai/nl-search', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query }),
      });
      const data = await response.json();

      if (!data?.success || !data?.filters) {
        if (elements.nlMessage) {
          elements.nlMessage.textContent = /OPENAI_API_KEY|AI configuration/i.test(data?.message || '')
            ? 'Natural language search requires AI configuration'
            : (data?.message || 'Unable to parse your query.');
        }
        return;
      }

      const filters = data.filters;
      state.q = String(filters.q || '').trim();
      state.faculty = Array.isArray(filters.faculty) ? filters.faculty.map(String) : [];
      state.skills = Array.isArray(filters.skills) ? filters.skills.map(String) : [];
      state.location = Array.isArray(filters.location) ? filters.location.map(String) : [];
      state.company = Array.isArray(filters.company) ? filters.company.map(String) : [];
      state.year = Array.isArray(filters.year) ? filters.year.map(String) : [];
      state.page = 1;

      elements.search.value = state.q;
      await fetchResults(true);
    } catch {
      if (elements.nlMessage) elements.nlMessage.textContent = 'Unable to parse your query right now.';
    } finally {
      elements.nlLoading?.classList.add('hidden');
    }
  }

  [['faculty', 'faculties'], ['year', 'years'], ['location', 'locations'], ['company', 'companies']].forEach(([group, facet]) => {
    elements[group].options.addEventListener('change', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement) || target.type !== 'checkbox') return;
      const value = target.getAttribute('data-value');
      if (!value) return;
      toggleArrayValue(group, value);
      fetchResults(true);
    });
  });

  elements.skillsCloud.addEventListener('click', (event) => {
    if (!(event.target instanceof Element)) return;
    const target = event.target.closest('[data-skill]');
    if (!target) return;
    toggleArrayValue('skills', target.getAttribute('data-skill'));
    fetchResults(true);
  });

  elements.activeFilters.addEventListener('click', (event) => {
    if (!(event.target instanceof Element)) return;
    const target = event.target.closest('[data-remove-group]');
    if (!target) return;
    const group = target.getAttribute('data-remove-group');
    const value = target.getAttribute('data-remove-value');

    if (group === 'q') {
      state.q = '';
      elements.search.value = '';
    } else if (group && value) {
      state[group] = (state[group] || []).filter((item) => String(item) !== value);
    }

    fetchResults(true);
  });

  elements.clearAll.addEventListener('click', () => {
    state.q = '';
    state.faculty = [];
    state.year = [];
    state.skills = [];
    state.location = [];
    state.company = [];
    state.availability = [];
    state.sort = 'name';
    state.page = 1;
    elements.location.search.value = '';
    elements.company.search.value = '';
    fetchResults(true);
  });

  elements.grid?.addEventListener('click', (event) => {
    if (!(event.target instanceof Element)) return;
    const bookmarkTarget = event.target.closest('[data-bookmark]');
    if (bookmarkTarget) {
      const id = bookmarkTarget.getAttribute('data-bookmark');
      if (!id) return;
      const next = toggleBookmark(state.bookmarks, id);
      state.bookmarks = next.bookmarks;
      if (!saveBookmarks(state.bookmarks)) {
        showToast('Unable to save bookmark');
      }
      renderCards();
      renderPreferenceControls();
      persistPreferenceState();
      return;
    }

    const shareTargetEl = event.target.closest('[data-share]');
    if (shareTargetEl) {
      const id = shareTargetEl.getAttribute('data-share');
      const alum = (resultState.data.alumni || []).find((item) => getAlumniKey(item) === id);
      if (!alum) return;
      openShareModal(alum);
    }
  });

  elements.search.addEventListener('input', () => debouncedSearch());
  elements.sort.addEventListener('change', () => fetchResults(true));
  elements.nlToggle?.addEventListener('click', () => elements.nlPanel?.classList.toggle('hidden'));
  elements.nlSubmit?.addEventListener('click', () => runNaturalLanguageSearch());
  elements.nlQuery?.addEventListener('keydown', (event) => {
    if (event.key === 'Enter') {
      event.preventDefault();
      runNaturalLanguageSearch();
    }
  });

  Object.keys(elements.availability).forEach((key) => {
    elements.availability[key].checked = state.availability.includes(key);
    elements.availability[key].addEventListener('change', () => {
      toggleArrayValue('availability', key);
      fetchResults(true);
    });
  });

  elements.prev.addEventListener('click', () => {
    if ((state.page || 1) > 1) {
      state.page = (state.page || 1) - 1;
      fetchResults(false);
    }
  });

  elements.next.addEventListener('click', () => {
    if ((state.page || 1) < (resultState.data.totalPages || 1)) {
      state.page = (state.page || 1) + 1;
      fetchResults(false);
    }
  });

  elements.location.search.addEventListener('input', () => {
    renderMultiSelectOptions('location', 'locations', elements.location.search.value || '');
  });
  elements.company.search.addEventListener('input', () => {
    renderMultiSelectOptions('company', 'companies', elements.company.search.value || '');
  });

  elements.filtersToggle?.addEventListener('click', () => {
    elements.filtersPanel?.classList.toggle('hidden');
  });

  function setViewMode(mode) {
    state.viewMode = mode;
    mapState.visibleIds = null;
    renderCards();
    renderViewModeControls();
    if (mode === 'map') renderMap();
    persistPreferenceState();
  }

  elements.viewGrid?.addEventListener('click', () => setViewMode('grid'));
  elements.viewList?.addEventListener('click', () => setViewMode('list'));
  elements.viewMap?.addEventListener('click', () => setViewMode('map'));

  elements.themeToggle?.addEventListener('click', () => {
    state.theme = state.theme === 'dark' ? 'light' : 'dark';
    renderTheme();
    persistPreferenceState();
  });

  elements.infiniteScrollToggle?.addEventListener('change', () => {
    state.infiniteScrollEnabled = !!elements.infiniteScrollToggle?.checked;
    persistPreferenceState();
    renderViewModeControls();
  });

  elements.bookmarkedFilter?.addEventListener('click', () => {
    state.showBookmarked = !state.showBookmarked;
    renderCards();
    renderPreferenceControls();
    persistPreferenceState();
  });

  elements.exportCsv?.addEventListener('click', () => {
    const rows = getFilteredAlumni();
    if (!rows.length) {
      showToast('Export failed. Please try again.');
      return;
    }
    elements.exportCsvLabel.textContent = 'Exporting...';
    try {
      exportAlumniToCsv(rows);
    } catch {
      showToast('Export failed. Please try again.');
    } finally {
      elements.exportCsvLabel.textContent = 'Export CSV';
    }
  });

  function closeShareModal() {
    elements.shareModalOverlay?.classList.add('hidden');
    shareTarget = null;
  }

  function openShareModal(alum) {
    shareTarget = alum;
    const slug = alum.slug || generateSlug(alum.name || '');
    const link = `${window.location.origin}/alumni/profiles/${encodeURIComponent(slug)}`;
    const title = `Check out ${alum.name}'s profile`;
    elements.shareTarget.textContent = alum.name || 'Alumni profile';
    elements.shareEmail.setAttribute('href', `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(link)}`);
    elements.shareLinkedin.setAttribute('href', `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(link)}`);
    elements.shareTwitter.setAttribute('href', `https://twitter.com/intent/tweet?url=${encodeURIComponent(link)}&text=${encodeURIComponent(title)}`);
    elements.shareCopy.onclick = async () => {
      try {
        await navigator.clipboard.writeText(link);
        showToast('Link copied!');
      } catch {
        showToast('Unable to copy link');
      }
    };
    elements.shareModalOverlay?.classList.remove('hidden');
  }

  elements.shareClose?.addEventListener('click', closeShareModal);
  elements.shareModalOverlay?.addEventListener('click', (event) => {
    if (event.target === elements.shareModalOverlay) closeShareModal();
  });
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeShareModal();
  });

  async function geocodeLocation(location) {
    if (!location) return null;
    if (mapState.geocodeCache.has(location)) return mapState.geocodeCache.get(location);
    try {
      const response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&limit=1&q=${encodeURIComponent(location)}`);
      const data = await response.json();
      const coords = data?.[0] ? [Number(data[0].lat), Number(data[0].lon)] : null;
      mapState.geocodeCache.set(location, coords);
      return coords;
    } catch {
      mapState.geocodeCache.set(location, null);
      return null;
    }
  }

  async function ensureMap() {
    if (mapState.map) return true;
    try {
      mapState.leaflet = await import('leaflet');
      mapState.map = mapState.leaflet.map(elements.mapContainer).setView([20.5937, 78.9629], 4);
      mapState.leaflet.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 18,
      }).addTo(mapState.map);
      mapState.map.on('moveend', () => {
        const bounds = mapState.map.getBounds();
        const visible = new Set();
        mapState.markers.forEach((item) => {
          if (bounds.contains(item.latlng)) {
            item.ids.forEach((id) => visible.add(id));
          }
        });
        mapState.visibleIds = visible;
        renderCards();
      });
      return true;
    } catch {
      elements.mapError?.classList.remove('hidden');
      elements.mapError.textContent = 'Map failed to load. Showing grid view instead.';
      setViewMode('grid');
      return false;
    }
  }

  async function renderMap() {
    if (state.viewMode !== 'map') return;
    const ok = await ensureMap();
    if (!ok) return;
    mapState.markers.forEach((entry) => entry.marker.remove());
    mapState.markers = [];

    const grouped = new Map();
    getFilteredAlumni().forEach((alum) => {
      if (!alum.location) return;
      const location = String(alum.location);
      if (!grouped.has(location)) grouped.set(location, []);
      grouped.get(location).push(alum);
    });

    const bounds = [];
    for (const [location, alumni] of grouped.entries()) {
      const coords = await geocodeLocation(location);
      if (!coords) continue;
      const [lat, lng] = coords;
      const marker = mapState.leaflet.marker([lat, lng]).addTo(mapState.map);
      const names = alumni.slice(0, 3).map((alum) => esc(alum.name)).join(', ');
      const first = alumni[0];
      const slug = first.slug || generateSlug(first.name || '');
      marker.bindPopup(`<div class="text-sm"><p class="font-semibold">${esc(location)} (${alumni.length})</p><p>${names}${alumni.length > 3 ? '...' : ''}</p><a class="view-profile-link" href="/alumni/profiles/${encodeURIComponent(slug)}">View profile</a></div>`);
      const ids = alumni.map((alum) => getAlumniKey(alum));
      mapState.markers.push({ marker, latlng: mapState.leaflet.latLng(lat, lng), ids });
      bounds.push([lat, lng]);
    }
    mapState.visibleIds = null;
    if (bounds.length) mapState.map.fitBounds(bounds, { padding: [20, 20] });
  }

  const handleScroll = debounce(() => {
    if (!state.infiniteScrollEnabled || isLoadingMore || state.viewMode === 'map') return;
    const totalPages = resultState.data.totalPages || 1;
    const currentPage = state.page || 1;
    if (currentPage >= totalPages) return;
    const threshold = window.innerWidth < 768 ? 100 : 200;
    const scrollPosition = window.innerHeight + window.scrollY;
    const target = document.body.offsetHeight - threshold;
    if (scrollPosition >= target) {
      isLoadingMore = true;
      elements.loadingMore?.classList.remove('hidden');
      state.page = currentPage + 1;
      fetchResults(false).finally(() => {
        isLoadingMore = false;
        elements.loadingMore?.classList.add('hidden');
      });
    }
  }, 200);

  window.addEventListener('scroll', handleScroll);

  function wireDropdown(key) {
    const { toggle, panel } = elements[key];
    toggle.addEventListener('click', () => {
      ['faculty', 'year', 'location', 'company'].forEach((group) => {
        if (group !== key) elements[group].panel.classList.add('hidden');
      });
      panel.classList.toggle('hidden');
    });
  }

  ['faculty', 'year', 'location', 'company'].forEach(wireDropdown);

  document.addEventListener('click', (event) => {
    ['faculty', 'year', 'location', 'company'].forEach((key) => {
      const { toggle, panel } = elements[key];
      if (!panel.contains(event.target) && !toggle.contains(event.target)) {
        panel.classList.add('hidden');
      }
    });
  });

  renderCards();
  renderPagination();
  renderAllControls();
  renderTheme();
  renderViewModeControls();
  renderPreferenceControls();
  if (window.innerWidth < 768) elements.filtersPanel?.classList.add('hidden');
  if (state.viewMode === 'map') renderMap();
  persistPreferenceState();
</script>

