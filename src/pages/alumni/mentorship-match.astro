---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
---

<Layout title="AI Mentorship Match">
  <section class="section">
    <div class="container-custom max-w-5xl">
      <div class="bg-white border border-accent-100 rounded-2xl shadow-sm p-6 md:p-8 mb-8">
        <h1 class="text-3xl font-bold text-accent-900 mb-2">AI Mentorship Matching</h1>
        <p class="text-accent-600 mb-6">Share your goals and discover alumni mentors aligned with your career path.</p>

        <form id="mentorship-form" class="grid grid-cols-1 gap-4">
          <div>
            <label for="goals" class="block text-sm font-medium text-accent-700 mb-1">What are your career goals?</label>
            <textarea id="goals" rows="4" class="input input-bordered w-full" placeholder="I want to move into data science roles in fintech..."></textarea>
          </div>

          <div>
            <label for="skills_wanted" class="block text-sm font-medium text-accent-700 mb-1">Skills you want to learn</label>
            <input id="skills_wanted" type="text" class="input input-bordered w-full" placeholder="Python, SQL, Product Strategy" />
          </div>

          <div>
            <label for="faculty" class="block text-sm font-medium text-accent-700 mb-1">Your faculty / department</label>
            <input id="faculty" type="text" class="input input-bordered w-full" placeholder="Computer Science" />
          </div>

          <div class="flex items-center gap-3">
            <button type="submit" class="btn btn-primary">Find Mentors</button>
            <p id="match-status" class="text-sm text-accent-500"></p>
          </div>
        </form>
      </div>

      <div id="mentors-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('mentorship-form');
  const goalsEl = document.getElementById('goals');
  const skillsWantedEl = document.getElementById('skills_wanted');
  const facultyEl = document.getElementById('faculty');
  const statusEl = document.getElementById('match-status');
  const grid = document.getElementById('mentors-grid');

  const esc = (value) => String(value || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');

  function renderMentors(mentors = []) {
    if (!grid) return;

    if (!mentors.length) {
      grid.innerHTML = '<p class="text-accent-500 col-span-full">No mentor matches found yet. Try broadening your goals or skills.</p>';
      return;
    }

    grid.innerHTML = mentors.map((mentor) => {
      const score = Math.max(0, Math.min(100, Number(mentor.match_score || 0)));
      const skills = Array.isArray(mentor.skills) ? mentor.skills.slice(0, 3) : [];
      const slug = mentor.slug || '';
      const profileLink = slug ? `/alumni/profiles/${encodeURIComponent(slug)}` : '#';
      const mailto = mentor.email ? `mailto:${mentor.email}` : profileLink;

      return `
        <article class="bg-white border border-accent-100 rounded-xl p-4 shadow-sm">
          <div class="flex items-start gap-3">
            ${mentor.photo_blob_url ? `<img src="${esc(mentor.photo_blob_url)}" alt="${esc(mentor.name)}" class="w-14 h-14 rounded-full object-cover" />` : `<div class="w-14 h-14 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center font-bold">${esc(String(mentor.name || '?').slice(0, 1).toUpperCase())}</div>`}
            <div class="flex-1">
              <h3 class="font-semibold text-accent-900">${esc(mentor.name || 'Mentor')}</h3>
              <p class="text-sm text-accent-600">${esc(mentor.company || '')}${mentor.job_designation ? ` • ${esc(mentor.job_designation)}` : ''}</p>
              <p class="text-xs text-accent-500">${esc(mentor.faculty || '')}${mentor.year ? ` • Class of ${esc(mentor.year)}` : ''}</p>
            </div>
          </div>

          ${skills.length ? `<div class="flex flex-wrap gap-1.5 mt-3">${skills.map((skill) => `<span class="px-2 py-1 rounded-full text-xs bg-primary-50 text-primary-700 border border-primary-100">${esc(skill)}</span>`).join('')}</div>` : ''}

          <div class="mt-3">
            <div class="h-2 bg-accent-100 rounded-full overflow-hidden">
              <div class="h-full bg-primary-600" style="width:${score}%"></div>
            </div>
            <p class="text-xs text-accent-500 mt-1">Match score: ${score.toFixed(1)}%</p>
          </div>

          ${mentor.match_reason ? `<p class="text-sm text-accent-700 mt-3">${esc(mentor.match_reason)}</p>` : ''}

          <div class="mt-4 flex items-center justify-between">
            <a href="${profileLink}" class="text-sm text-primary-700 hover:underline">View Profile</a>
            <a href="${mailto}" class="btn btn-sm btn-primary">Connect</a>
          </div>
        </article>
      `;
    }).join('');
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const goals = goalsEl?.value?.trim() || '';
    const skillsWanted = (skillsWantedEl?.value || '')
      .split(',')
      .map((value) => value.trim())
      .filter(Boolean);
    const faculty = facultyEl?.value?.trim() || '';

    if (!goals && !skillsWanted.length) {
      if (statusEl) statusEl.textContent = 'Add your goals or skills to begin matching.';
      return;
    }

    if (statusEl) statusEl.textContent = 'Finding mentor matches...';

    try {
      const response = await fetch('/api/ai/mentorship-match', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ goals, skills_wanted: skillsWanted, faculty }),
      });

      const data = await response.json();
      renderMentors(Array.isArray(data.mentors) ? data.mentors : []);
      if (statusEl) statusEl.textContent = '';
    } catch {
      if (statusEl) statusEl.textContent = 'Unable to fetch mentorship matches right now.';
    }
  });
</script>
