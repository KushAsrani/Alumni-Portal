---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { ObjectId } from 'mongodb';
import { connectToDatabase, type AlumniRegistration } from '../../lib/mongodb';
import { getCurrentAlumni, isAlumniAuthenticated, verifyAlumniSessionToken } from '../../lib/alumni-auth';

if (!isAlumniAuthenticated(Astro.cookies)) {
  return Astro.redirect('/alumni/login');
}

const session = getCurrentAlumni(Astro.cookies);
const sessionToken = Astro.cookies.get('alumni_session');

if (!session || !sessionToken?.value) {
  return Astro.redirect('/alumni/login');
}

const verifiedSession = verifyAlumniSessionToken(sessionToken.value);

if (!verifiedSession.valid || !verifiedSession.alumniId) {
  return Astro.redirect('/alumni/login');
}

let sessionCreatedAt = new Date();

try {
  const decoded = JSON.parse(Buffer.from(sessionToken.value, 'base64').toString()) as { payload?: string };
  if (typeof decoded.payload === 'string') {
    const payload = JSON.parse(decoded.payload) as { timestamp?: number };
    if (typeof payload.timestamp === 'number' && Number.isFinite(payload.timestamp)) {
      sessionCreatedAt = new Date(payload.timestamp);
    }
  }
} catch {
  sessionCreatedAt = new Date();
}

const sessionExpiresAt = new Date(sessionCreatedAt.getTime() + (7 * 24 * 60 * 60 * 1000));

type AlumniDocument = AlumniRegistration & { _id: ObjectId; username?: string };
let alumni: AlumniDocument | null = null;

try {
  const { db } = await connectToDatabase();
  const collection = db.collection<AlumniDocument>('alumni_registrations');

  try {
    alumni = await collection.findOne({ _id: new ObjectId(verifiedSession.alumniId) });
  } catch {
    alumni = await collection.findOne({
      $or: [{ username: session.username }, { email: session.username }],
    });
  }
} catch (error) {
  console.error('Active sessions page error:', error);
}

function formatDate(value: Date | string | null | undefined): string {
  if (!value) return 'Not available';
  return new Date(value).toLocaleString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
  });
}
---

<Layout title="Active Sessions | Alumni Portal">
  <main class="min-h-screen bg-slate-50 py-8 md:py-12">
    <div class="container-custom mx-auto max-w-3xl px-4">
      <a
        href="/alumni/settings"
        class="inline-flex items-center gap-2 text-sm font-medium text-[#2e4096] transition hover:text-[#24367d]"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        Back to Settings
      </a>

      <section class="mt-4 rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="flex items-center gap-3">
          <div class="rounded-2xl bg-[#2e4096]/10 p-3 text-[#2e4096]">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="4" width="20" height="14" rx="2"></rect>
              <path d="M8 20h8"></path>
              <path d="M12 18v2"></path>
            </svg>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-slate-900">Active Sessions</h1>
            <p class="text-sm text-slate-500">Manage your current sign-in sessions.</p>
          </div>
        </div>

        <div class="mt-6 rounded-2xl border border-slate-200 p-5">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div class="flex gap-3">
              <svg class="mt-0.5 text-[#2e4096]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="4" width="20" height="14" rx="2"></rect>
                <path d="M8 20h8"></path>
                <path d="M12 18v2"></path>
              </svg>
              <div>
                <p class="font-medium text-slate-900">Current session</p>
                <p class="mt-1 text-sm text-slate-500">Signed in: {formatDate(sessionCreatedAt)}</p>
                <p class="text-sm text-slate-500">Expires: {formatDate(sessionExpiresAt)}</p>
                <p class="mt-2 text-sm text-slate-600">Sessions expire automatically after 7 days of inactivity.</p>
              </div>
            </div>
            <div class="flex flex-col items-start gap-2 sm:items-end">
              <span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">Current session</span>
              <button type="button" class="signout-trigger inline-flex items-center rounded-xl border border-red-300 px-3 py-2 text-sm font-medium text-red-700 transition hover:bg-red-50">
                Sign out
              </button>
            </div>
          </div>
        </div>

        <p class="mt-4 text-sm text-slate-600">Last login recorded: {formatDate(alumni?.last_login)}</p>

        <div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 p-5">
          <p class="text-sm text-slate-600">
            For security, your session cookie is stored securely (HttpOnly, SameSite=Lax) and automatically expires. If you believe your account is compromised, use the button below to sign out immediately.
          </p>
        </div>

        <button
          type="button"
          class="signout-trigger mt-6 inline-flex w-full items-center justify-center gap-2 rounded-2xl border border-red-300 bg-white px-5 py-3 text-sm font-semibold text-red-700 transition hover:bg-red-50"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
          </svg>
          Sign out of current session
        </button>
      </section>
    </div>
  </main>
</Layout>

<script>
  async function signOutNow() {
    const buttons = document.querySelectorAll('.signout-trigger');
    buttons.forEach((button) => {
      button.disabled = true;
      button.classList.add('opacity-70', 'cursor-not-allowed');
    });

    try {
      await fetch('/api/auth/alumni-logout', {
        method: 'GET',
        credentials: 'same-origin',
      });
    } catch (error) {
      console.error('Active sessions logout error:', error);
    } finally {
      window.location.href = '/alumni/login';
    }
  }

  document.querySelectorAll('.signout-trigger').forEach((button) => {
    button.addEventListener('click', signOutNow);
  });
</script>
