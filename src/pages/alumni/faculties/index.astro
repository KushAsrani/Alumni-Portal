---
import Layout from '@/layouts/Layout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getSiteConfig } from '@/utils/config';

const config = getSiteConfig();
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Profiles', href: '/alumni' },
  { label: 'Faculties' },
];
---

<Layout title="Departments" description="Explore alumni profiles by department and connect with professionals from your field.">
  <Breadcrumbs items={breadcrumbItems} />
  <section class="section bg-gray-50">
    <div class="container-custom">
      <h1 class="text-3xl text-center font-bold mb-6">Browse Alumni by Department</h1>
      <p class="text-gray-700 text-center mb-8">Explore alumni profiles based on their department or faculty. Connect with professionals from your field and discover their career journeys. Click on a department to see alumni associated with it.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {config.faculties.map(f => (
          <a class="card p-6" href={`/alumni/faculties/${f.slug}`}>
            <h3 class="text-lg font-semibold">{f.name}</h3>
            <p class="text-gray-600 text-sm">{f.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
