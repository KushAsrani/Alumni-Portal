---
export const prerender = false;

import Layout from '@/layouts/Layout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getSiteConfig } from '@/utils/config';
import { connectToDatabase } from '@/lib/mongodb';
import { ALUMNI_PROFILES_COLLECTION, generateProfileSlug, toStringArray } from '@/lib/alumni-profile-service';

const config = getSiteConfig();
const { faculty = '' } = Astro.params;
const selectedFaculty = config.faculties.find((f) => f.slug === faculty);
const facultyName = selectedFaculty?.name || faculty;
const facultySlug = selectedFaculty?.slug || faculty;

const normalizeFaculty = (value: unknown) => String(value || '').toLowerCase().replace(/[^a-z0-9]/g, '');
const selectedFacultyTokens = [facultySlug, facultyName, facultyName.match(/\(([^)]+)\)/)?.[1]]
  .filter(Boolean)
  .map(normalizeFaculty);

function profileMatchesFaculty(profile: any) {
  const normalizedProfileFaculty = normalizeFaculty(profile.faculty);
  return selectedFacultyTokens.some((token) => token && normalizedProfileFaculty.includes(token));
}

function normalizeProfile(profile: any) {
  const skills = toStringArray(profile.skills);
  const slug = profile.slug || generateProfileSlug(profile.name || '');
  return {
    ...profile,
    id: profile._id?.toString?.() || profile.id || slug,
    slug,
    skills,
    photo: profile.photo || profile.photo_blob_url || '',
    position: profile.position || profile.job_designation || '',
    short_bio: profile.short_bio || '',
    work_experience: Array.isArray(profile.work_experience) ? profile.work_experience : [],
  };
}

let alumni: any[] = [];
let alumniLoadError = '';

try {
  const { db } = await connectToDatabase();
  const profiles = await db
    .collection(ALUMNI_PROFILES_COLLECTION)
    .find({ status: 'approved' })
    .sort({ updated_at: -1, name: 1 })
    .toArray();

  alumni = profiles.map(normalizeProfile).filter(profileMatchesFaculty);
} catch (error) {
  alumniLoadError = error instanceof Error ? error.message : 'Unable to load alumni profiles from MongoDB';
  console.error('Unable to load faculty alumni profiles:', error);
}

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Profiles', href: '/alumni' },
  { label: 'Faculties', href: '/alumni/faculties' },
  { label: facultyName },
];
const calcCompleteness = (alum: any): number => {
  const fields = ['photo', 'faculty', 'year', 'short_bio', 'long_bio', 'location', 'company', 'position', 'skills', 'linkedin'];
  const filled = fields.filter((field) => {
    const value = field === 'linkedin' ? alum.social?.linkedin || alum.linkedin : alum[field];
    if (field === 'skills') {
      return Array.isArray(value) ? value.length > 0 : typeof value === 'string' && value.trim().length > 0;
    }
    return Boolean(value);
  });
  return Math.round((filled.length / fields.length) * 100);
};
const completenessColor = (pct: number) => (pct >= 70 ? '#22c55e' : pct >= 40 ? '#f59e0b' : '#ef4444');
const isRecentlyActive = (alum: any): boolean => {
  const rawDate = alum.updated_at || alum.createdAt || alum.created_at;
  if (!rawDate) return false;
  const parsed = new Date(rawDate);
  if (Number.isNaN(parsed.getTime())) return false;
  const ninetyDaysMs = 90 * 24 * 60 * 60 * 1000;
  const age = Date.now() - parsed.getTime();
  return age >= 0 && age <= ninetyDaysMs;
};
const getInitials = (name: string) => name.split(' ').map((part) => part[0]).join('').slice(0, 2).toUpperCase();
const facultyBadge = facultyName.match(/\(([^)]+)\)/)?.[1] || facultySlug.toUpperCase();
const truncateBio = (bio: string) => (bio && bio.length > 90 ? `${bio.slice(0, 87)}...` : bio);
---

<Layout title={facultyName}>
  <Breadcrumbs items={breadcrumbItems} />
  <section class="section">
    <div class="container-custom">
      <h1 class="text-3xl text-center font-bold mb-6">{facultyName}</h1>
      <p class="text-justify text-accent-600 mb-12">Explore profiles of alumni from {facultyName} department. Discover their career paths, skills, and achievements. Connect with fellow alumni and find inspiration for your own journey. If you're an alumni from the {facultyName} department and don't see your profile here, consider creating one to share your story and connect with others!</p>
      {alumniLoadError && (
        <div class="mb-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
          Could not load alumni profiles from MongoDB. Check your <code>MONGODB_URI</code> and make sure the <code>alumni_profiles</code> collection exists.
        </div>
      )}

      {alumni.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {alumni.map((a) => {
            const profileCompleteness = calcCompleteness(a);
            const profileCompletenessColor = completenessColor(profileCompleteness);
            const allSkills = a.skills.slice(0, 5);
            const latestWork = Array.isArray(a.work_experience) ? a.work_experience[0] : null;
            const recentlyActive = isRecentlyActive(a);
            const company = a.company || latestWork?.company || '';
            const position = a.position || latestWork?.position || '';
            const location = a.location || '';
            const isOpenToMentor = a.open_to_mentorship || a.mentorship_preferences?.looking_for_mentor;

            return (
              <article class="faculty-profile-card">
                <div class="faculty-badge">{facultyBadge}</div>

                <div class="avatar-wrap">
                  {a.photo ? (
                    <img src={a.photo} alt={a.name} class="profile-avatar-img" />
                  ) : (
                    <div class="profile-avatar-placeholder-card" aria-hidden="true">
                      <svg viewBox="0 0 96 96" class="avatar-icon">
                        <circle cx="48" cy="48" r="45" fill="#f8fafc" />
                        <circle cx="48" cy="34" r="16" fill="#d1d5db" />
                        <path d="M20 78c5.5-16 16-25 28-25s22.5 9 28 25" fill="#d1d5db" />
                      </svg>
                      <span class="sr-only">{getInitials(a.name || 'Alumni')}</span>
                    </div>
                  )}
                </div>

                <div class="name-row mb-2">
                  <h3>{a.name}</h3>
                </div>

                {a.short_bio && <p class="profile-bio">{truncateBio(a.short_bio)}</p>}

                {allSkills.length > 0 && (
                  <p class="skills-label text-sm font-medium text-accent-700"><b>Skills:</b></p>
                  <div class="skill-list" aria-label="Skills">
                    {allSkills.map((skill) => <span class="skill-pill mt-4 mb-4">{skill}</span>)}
                  </div>
                )}

                {(company || position) && (
                  <p class="role-line text-left">
                    {company && <span class="text-accent-700 text-center font-medium"><b>Company:</b> {company}</span>}
                  </p>
                  <p class="role-line">
                    {position && <span class="text-accent-700 text-center font-medium"><b>Position:</b> {position}</span>}
                  </p>
                )}

                {location && <p class="location-line text-accent-700 text-center font-medium"><b>Location:</b> {location}</p>}

                {isOpenToMentor && <div class="mentor-pill mb-4 mt-2">🤝 Open to Mentor</div>}

                <div class="card-footer">
                  <span>{a.year ? `Class of ${a.year}` : 'Alumni Profile'}</span>
                  <a href={`/alumni/profiles/${a.slug}`} class="view-profile-link" aria-label={`View ${a.name}'s profile`}>
                    View Profile <span aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-12">
          <div class="mb-6">
            <svg class="w-16 h-16 text-primary-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-accent-900 mb-2">No Alumni Found</h3>
          <p class="text-accent-600 mb-6">We don't have any alumni records for the {facultyName} faculty yet.</p>
          <a href="/alumni/profiles" class="btn btn-primary">
            Browse All Alumni
          </a>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .faculty-profile-card {
    position: relative;
    display: flex;
    min-height: 430px;
    flex-direction: column;
    align-items: center;
    border: 1px solid #e5e7eb;
    border-radius: 1.25rem;
    background: #ffffff;
    padding: 2rem 1.35rem 1.15rem;
    text-align: center;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .faculty-profile-card:hover {
    transform: translateY(-2px);
    border-color: #dbeafe;
    box-shadow: 0 16px 34px rgba(15, 23, 42, 0.08);
  }

  .faculty-badge {
    position: absolute;
    right: 1rem;
    top: 1rem;
    border-radius: 9999px;
    background: #eef2ff;
    color: #3730a3;
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1;
    padding: 0.38rem 0.7rem;
  }

  .avatar-wrap {
    margin-top: 0.45rem;
    margin-bottom: 1rem;
  }

  .profile-avatar-img,
  .profile-avatar-placeholder-card {
    width: 7rem;
    height: 7rem;
    border-radius: 9999px;
    border: 6px solid #ffffff;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.15);
  }

  .profile-avatar-img {
    object-fit: cover;
    background: #f8fafc;
  }

  .profile-avatar-placeholder-card {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f8fafc;
  }

  .avatar-icon {
    width: 100%;
    height: 100%;
  }

  .name-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-width: 0;
  }

  .name-row h3 {
    color: #0f172a;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .active-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    border-radius: 9999px;
    background: #dcfce7;
    color: #15803d;
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.18rem 0.42rem;
  }

  .active-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 9999px;
    background: #22c55e;
  }

  .completeness-bar-container {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.55rem;
    width: min(9.5rem, 100%);
    margin: 0.55rem auto 0.8rem;
  }

  .completeness-bar-track {
    height: 4px;
    overflow: hidden;
    border-radius: 9999px;
    background: #e5e7eb;
  }

  .completeness-bar-fill {
    height: 100%;
    border-radius: 9999px;
    transition: width 0.4s ease;
  }

  .completeness-label {
    color: #6b7280;
    font-size: 0.66rem;
    white-space: nowrap;
  }

  .profile-bio {
    min-height: 2.4rem;
    color: #64748b;
    font-size: 0.88rem;
    line-height: 1.45;
    margin-bottom: 0.8rem;
  }

  .skill-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.45rem;
    margin-bottom: 0.8rem;
  }

  .skill-pill {
    border-radius: 9999px;
    background: #f5f8ff;
    color: #1e3a8a;
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.2rem 0.55rem;
  }

  .role-line {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: 0.25rem;
  }

  .role-separator,

  .location-line {
    font-size: 0.86rem;
    margin-bottom: 0.8rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: 0.25rem;
  }

  .mentor-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: #fef3c7;
    color: #92400e;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.28rem 0.7rem;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    margin-top: auto;
    padding-top: 1.1rem;
    border-top: 1px solid #eef2f7;
    color: #94a3b8;
    font-size: 0.82rem;
  }

  .view-profile-link {
    color: #2563eb;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  .view-profile-link:hover {
    color: #1d4ed8;
  }
</style>
