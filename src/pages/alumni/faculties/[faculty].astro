---
export const prerender = false;

import Layout from '@/layouts/Layout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getSiteConfig } from '@/utils/config';
import { connectToDatabase } from '@/lib/mongodb';
import { ALUMNI_PROFILES_COLLECTION, generateProfileSlug, toStringArray } from '@/lib/alumni-profile-service';

const config = getSiteConfig();
const { faculty = '' } = Astro.params;
const selectedFaculty = config.faculties.find((f) => f.slug === faculty);
const facultyName = selectedFaculty?.name || faculty;
const facultySlug = selectedFaculty?.slug || faculty;

const normalizeFaculty = (value: unknown) => String(value || '').toLowerCase().replace(/[^a-z0-9]/g, '');
const selectedFacultyTokens = [facultySlug, facultyName, facultyName.match(/\(([^)]+)\)/)?.[1]]
  .filter(Boolean)
  .map(normalizeFaculty);

function profileMatchesFaculty(profile: any) {
  const normalizedProfileFaculty = normalizeFaculty(profile.faculty);
  return selectedFacultyTokens.some((token) => token && normalizedProfileFaculty.includes(token));
}

function normalizeProfile(profile: any) {
  const skills = toStringArray(profile.skills);
  const slug = profile.slug || generateProfileSlug(profile.name || '');
  return {
    ...profile,
    id: profile._id?.toString?.() || profile.id || slug,
    slug,
    skills,
    photo: profile.photo || profile.photo_blob_url || '',
    position: profile.position || profile.job_designation || '',
    short_bio: profile.short_bio || '',
    work_experience: Array.isArray(profile.work_experience) ? profile.work_experience : [],
  };
}

let alumni: any[] = [];
let alumniLoadError = '';

try {
  const { db } = await connectToDatabase();
  const profiles = await db
    .collection(ALUMNI_PROFILES_COLLECTION)
    .find({ status: 'approved' })
    .sort({ updated_at: -1, name: 1 })
    .toArray();

  alumni = profiles.map(normalizeProfile).filter(profileMatchesFaculty);
} catch (error) {
  alumniLoadError = error instanceof Error ? error.message : 'Unable to load alumni profiles from MongoDB';
  console.error('Unable to load faculty alumni profiles:', error);
}

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Profiles', href: '/alumni' },
  { label: 'Faculties', href: '/alumni/faculties' },
  { label: facultyName },
];
const calcCompleteness = (alum: any): number => {
  const fields = ['photo', 'faculty', 'year', 'short_bio', 'long_bio', 'location', 'company', 'position', 'skills', 'linkedin'];
  const filled = fields.filter((field) => {
    const value = field === 'linkedin' ? alum.social?.linkedin || alum.linkedin : alum[field];
    if (field === 'skills') {
      return Array.isArray(value) ? value.length > 0 : typeof value === 'string' && value.trim().length > 0;
    }
    return Boolean(value);
  });
  return Math.round((filled.length / fields.length) * 100);
};
const completenessColor = (pct: number) => (pct >= 70 ? '#22c55e' : pct >= 40 ? '#f59e0b' : '#ef4444');
const isRecentlyActive = (alum: any): boolean => {
  const rawDate = alum.updated_at || alum.createdAt || alum.created_at;
  if (!rawDate) return false;
  const parsed = new Date(rawDate);
  if (Number.isNaN(parsed.getTime())) return false;
  const ninetyDaysMs = 90 * 24 * 60 * 60 * 1000;
  const age = Date.now() - parsed.getTime();
  return age >= 0 && age <= ninetyDaysMs;
};
const getInitials = (name: string) => name.split(' ').map((part) => part[0]).join('').slice(0, 2).toUpperCase();
---

<Layout title={facultyName}>
  <Breadcrumbs items={breadcrumbItems} />
  <section class="section">
    <div class="container-custom">
      <h1 class="text-3xl font-bold mb-6">{facultyName}</h1>
      {alumniLoadError && (
        <div class="mb-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
          Could not load alumni profiles from MongoDB. Check your <code>MONGODB_URI</code> and make sure the <code>alumni_profiles</code> collection exists.
        </div>
      )}

      {alumni.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {alumni.map((a) => {
            const profileCompleteness = calcCompleteness(a);
            const profileCompletenessColor = completenessColor(profileCompleteness);
            const allSkills = a.skills;
            const latestWork = Array.isArray(a.work_experience) ? a.work_experience[0] : null;
            const recentlyActive = isRecentlyActive(a);

            return (
              <a href={`/alumni/profiles/${a.slug}`} class="card card-hover block profile-card">
                <div class="p-6 relative z-10">
                  <div class="flex items-center gap-4 mb-4 text-left">
                    {a.photo ? (
                      <img src={a.photo} alt={a.name} class="w-16 h-16 rounded-full object-cover border" />
                    ) : (
                      <div class="w-16 h-16 rounded-full bg-gradient-to-br from-primary-400 to-secondary-400 flex items-center justify-center text-white font-bold text-lg border">
                        {getInitials(a.name || 'Alumni')}
                      </div>
                    )}
                    <div>
                      <h3 class="text-lg font-semibold">
                        {a.name}
                        {recentlyActive && <span class="recently-active-badge">🟢 Recently Active</span>}
                      </h3>
                      <p class="text-sm text-primary-600">{a.faculty}{a.year ? `, ${a.year}` : ''}</p>
                    </div>
                  </div>

                  <div class="completeness-bar-container" title={`Profile ${profileCompleteness}% complete`}>
                    <div class="completeness-bar-track">
                      <div class="completeness-bar-fill" style={`width: ${profileCompleteness}%; background-color: ${profileCompletenessColor};`}></div>
                    </div>
                    <span class="completeness-label">{profileCompleteness}% complete</span>
                  </div>

                  <p class="text-gray-600 text-sm">{a.short_bio}</p>

                  <div class="card-hover-panel" aria-hidden="true">
                    <div class="card-hover-content">
                      {latestWork && (latestWork.position || latestWork.company || latestWork.duration) && (
                        <div class="hover-section">
                          <p class="hover-section-title">Latest Role</p>
                          <p class="hover-role">{latestWork.position || 'Role'} at {latestWork.company || 'Company'}</p>
                          {latestWork.duration && <p class="hover-duration">{latestWork.duration}</p>}
                        </div>
                      )}
                      {allSkills.length > 0 && (
                        <div class="hover-section">
                          <p class="hover-section-title">All Skills</p>
                          <div class="hover-skills-cloud">
                            {allSkills.map((skill) => <span class="hover-skill-tag">{skill}</span>)}
                          </div>
                        </div>
                      )}
                      <span class="hover-cta-btn">View Full Profile →</span>
                    </div>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-12">
          <div class="mb-6">
            <svg class="w-16 h-16 text-primary-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-accent-900 mb-2">No Alumni Found</h3>
          <p class="text-accent-600 mb-6">We don't have any alumni records for the {facultyName} faculty yet.</p>
          <a href="/alumni/profiles" class="btn btn-primary">
            Browse All Alumni
          </a>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .profile-card {
    position: relative;
    overflow: hidden;
  }

  .completeness-bar-container {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .completeness-bar-track {
    flex: 1;
    height: 4px;
    background: #e5e7eb;
    border-radius: 9999px;
    overflow: hidden;
  }

  .completeness-bar-fill {
    height: 100%;
    border-radius: 9999px;
    transition: width 0.4s ease;
  }

  .completeness-label {
    font-size: 0.65rem;
    color: #6b7280;
    white-space: nowrap;
  }

  .recently-active-badge {
    display: inline-block;
    font-size: 0.65rem;
    color: #15803d;
    background: #dcfce7;
    border-radius: 9999px;
    padding: 0.1rem 0.45rem;
    margin-left: 0.4rem;
    vertical-align: middle;
  }

  .card-hover-panel {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.92);
    color: white;
    border-radius: inherit;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    pointer-events: none;
    z-index: 20;
  }

  .profile-card:hover .card-hover-panel,
  .profile-card:focus-within .card-hover-panel {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .card-hover-content {
    overflow-y: auto;
    max-height: 100%;
  }

  .hover-section {
    margin-bottom: 0.6rem;
  }

  .hover-section-title {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #94a3b8;
    margin-bottom: 0.2rem;
  }

  .hover-role {
    font-size: 0.8rem;
    font-weight: 600;
  }

  .hover-duration {
    font-size: 0.7rem;
    color: #cbd5e1;
  }

  .hover-skills-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    max-height: 80px;
    overflow-y: auto;
  }

  .hover-skill-tag {
    font-size: 0.65rem;
    padding: 0.1rem 0.4rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.15);
    color: #e2e8f0;
  }

  .hover-cta-btn {
    display: block;
    margin-top: 0.6rem;
    text-align: center;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.4rem 0.8rem;
    background: #2563eb;
    border-radius: 0.5rem;
    color: white;
    text-decoration: none;
  }
</style>
