---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { isAlumniAuthenticated, getCurrentAlumni } from '../../lib/alumni-auth';
import { getProfileHistory } from '../../lib/profile-history';
import { formatDate, timeAgo } from '../../utils/date-format';

if (!isAlumniAuthenticated(Astro.cookies)) {
  return Astro.redirect('/alumni/login');
}

const session = getCurrentAlumni(Astro.cookies);
const history = session ? await getProfileHistory(session.alumniId, 50) : [];
---

<Layout title="Profile History | Alumni Portal">
  <main class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <a href="/alumni/settings" class="text-sm font-medium text-primary-700 hover:text-primary-800"> <svg xmlns="http://www.w3.org/2000/svg" class="inline-block mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
          Back to settings</a>
        <h1 class="mt-2 text-center text-3xl font-bold text-slate-900">
          Profile Update History</h1>
        <p class="mt-2 text-slate-600">View the latest changes made to your alumni profile. This log includes updates made by you and any administrators, helping you keep track of your profile's evolution over time. Administrators may make changes to ensure the accuracy and quality of the information displayed on your profile.</p>
      </div>
    </div>

    {history.length === 0 ? (
      <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center text-slate-600 shadow-sm">
        No profile updates have been recorded yet.
      </div>
    ) : (
      <div class="space-y-4">
        {history.map((entry) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <div class="flex flex-wrap items-center gap-2">
                  <span class={`inline-flex rounded-full px-3 py-1 text-xs font-semibold ${entry.changedBy === 'admin' ? 'bg-blue-100 text-blue-700' : 'bg-emerald-100 text-emerald-700'}`}>
                    {entry.changedBy === 'admin' ? 'Changed by admin' : 'Changed by alumni'}
                  </span>
                  <span class="text-sm text-slate-500">{timeAgo(entry.changedAt)}</span>
                </div>
                <p class="mt-3 text-sm text-slate-700">Updated fields: {entry.changedFields.join(', ')}</p>
              </div>
              <div class="text-sm text-slate-500">{formatDate(entry.changedAt)}</div>
            </div>
          </div>
        ))}
      </div>
    )}
  </main>
</Layout>
