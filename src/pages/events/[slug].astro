---
export const prerender = false;

import { isAlumniAuthenticated, getCurrentAlumni } from '../../lib/alumni-auth';
if (!isAlumniAuthenticated(Astro.cookies)) {
  return Astro.redirect(`/alumni/login?redirect=/events/${Astro.params.slug}`);
}
const currentAlumni = getCurrentAlumni(Astro.cookies);

import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { connectToDatabase } from '../../lib/mongodb';
import { ObjectId } from 'mongodb';

const { slug } = Astro.params;
const base = Astro.url.origin;

let event: any = null;
let fetchError = '';

try {
  const res = await fetch(`${base}/api/events?slug=${encodeURIComponent(slug!)}`);
  if (res.ok) {
    const data = await res.json();
    event = data.event || null;
  } else {
    fetchError = 'Event not found';
  }
} catch (e) {
  fetchError = 'Failed to load event';
}

if (!event) {
  return Astro.redirect('/events');
}

// Look up host name from alumni_registrations
let hostName: string = event.hostName || event.hostEmail;
try {
  const { db } = await connectToDatabase();
  if (!event.hostName) {
    const hostAlumni = await db.collection('alumni_registrations').findOne(
      { email: event.hostEmail },
      { projection: { name: 1 } }
    );
    if (hostAlumni?.name) hostName = hostAlumni.name;
  }
} catch {}

// Fetch logged-in alumni's profile for pre-filling the form
let alumniProfile: any = null;
try {
  const { db } = await connectToDatabase();
  let query: any = { $or: [
    { username: currentAlumni?.username },
    { email: currentAlumni?.username },
  ]};
  if (currentAlumni?.alumniId) {
    try { query = { _id: new ObjectId(currentAlumni.alumniId) }; } catch {}
  }
  alumniProfile = await db.collection('alumni_registrations').findOne(query, {
    projection: { name: 1, email: 1, mobile: 1, faculty: 1, year: 1 }
  });
} catch {}

const spotsLeft = Math.max(0, event.capacity - (event.confirmedCount || 0));
const isFull = spotsLeft === 0;
const isEnded = event.status === 'ended';

// Check if user is already subscribed to notify-me
let isNotifyMeSubscribed = false;
try {
  if (currentAlumni?.username && alumniProfile?.email) {
    const notifyRes = await fetch(`${base}/api/events/${event._id}/notify-me?userEmail=${encodeURIComponent(alumniProfile.email)}`);
    if (notifyRes.ok) {
      const notifyData = await notifyRes.json();
      isNotifyMeSubscribed = notifyData.subscribed;
    }
  }
} catch {}

// Sanitize bannerUrl to only allow http/https URLs
const safeBannerUrl = (() => {
  if (!event.bannerUrl) return '';
  try {
    const u = new URL(event.bannerUrl);
    return (u.protocol === 'https:' || u.protocol === 'http:') ? event.bannerUrl : '';
  } catch {
    return '';
  }
})();

// Build "Add to Calendar" URLs
function toGCalDate(d: Date) {
  return d.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
}

const gcalUrl = (() => {
  const params = new URLSearchParams({
    action: 'TEMPLATE',
    text: event.title,
    dates: `${toGCalDate(new Date(event.startTime))}/${toGCalDate(new Date(event.endTime))}`,
    details: event.description || '',
    location: event.venue
      ? `${event.venue}${event.location ? ', ' + event.location : ''}`
      : event.eventType === 'webinar' ? 'Online' : '',
  });
  return `https://calendar.google.com/calendar/render?${params.toString()}`;
})();

const outlookUrl = (() => {
  const params = new URLSearchParams({
    path: '/calendar/action/compose',
    rru: 'addevent',
    subject: event.title,
    startdt: new Date(event.startTime).toISOString(),
    enddt: new Date(event.endTime).toISOString(),
    body: event.description || '',
    location: event.venue
      ? `${event.venue}${event.location ? ', ' + event.location : ''}`
      : event.eventType === 'webinar' ? 'Online' : '',
  });
  return `https://outlook.live.com/calendar/0/action/compose?${params.toString()}`;
})();

const icalDownloadUrl = `/api/events/${event._id}/ical`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Events', href: '/events' },
  { label: event.title },
];

const eventTypeLabels: Record<string, string> = {
  webinar: 'Webinar',
  ama: 'AMA',
  workshop: 'Workshop',
};

// Activities options based on event type
const activitiesMap: Record<string, string[]> = {
  webinar: ['Q&A Session', 'Panel Discussion', 'Networking Session', 'Live Demo', 'Guest Lectures'],
  ama: ['Ask Me Anything', 'Networking Session', 'Career Guidance', 'Industry Insights'],
  workshop: ['Hands-on Workshop', 'Group Activities', 'Networking Session', 'Mentorship Circles', 'Campus Tours', 'Alumni Awards Ceremony', 'Talent Showcases & Concerts'],
};
const activities = activitiesMap[event.eventType] || ['Networking Session', 'Panel Discussion', 'Workshops', 'Guest Lectures', 'Alumni Awards Ceremony', 'Campus Tours/Revisiting Dorms', 'Talent Showcases & Concerts', 'Industry Panels/Mentorship Circles'];
---

<Layout title={event.title} description={event.description}>
  <Breadcrumbs items={breadcrumbItems} />

  <!-- Event Banner -->
  <div class={`w-full py-16 px-6 relative overflow-hidden border-t border-b ${
    event.eventType === 'ama'      ? 'bg-gradient-to-br from-white to-white text-black' :
    event.eventType === 'workshop' ? 'bg-gradient-to-br from-white to-white text-black' :
    event.eventType === 'webinar'  ? 'bg-gradient-to-br from-white to-white text-black' :
                                     'bg-gradient-to-br from-white to-white text-black'             
  }`}
    style={safeBannerUrl ? `background-image: url('${safeBannerUrl}'); background-size: cover; background-position: center;` : ''}>
    {safeBannerUrl && <div class="absolute inset-0 bg-black/50"></div>}
    <div class="container-custom relative z-10 text-white text-center">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="badge badge-primary backdrop-blur-sm text-black text-sm font-semibold px-4 py-1 rounded-full tracking-wide" style="width: max-content; height: 30px;">
          {eventTypeLabels[event.eventType] || event.eventType}
        </span>
        <span class={`text-sm font-semibold px-4 py-1 rounded-full tracking-wide ${
          event.status === 'live'      ? 'bg-red-500' :
          event.status === 'ended'     ? 'bg-gray-500' :
          event.status === 'cancelled' ? 'bg-red-700' :
                                         'bg-green-500'
        }`}>
          {event.status === 'live' ? '🔴 Live Now' : event.status.charAt(0).toUpperCase() + event.status.slice(1)}
        </span>
      </div>
      <h1 class="text-3xl text-black md:text-5xl font-bold mb-4 drop-shadow-md">{event.title}</h1>
      {event.description && (
        <p class="text-black/85 text-lg max-w-2xl mx-auto mb-6">{event.description}</p>
      )}
      <div class="flex items-center justify-center gap-6 text-sm text-black/80 flex-wrap">
        <span><b>Date:</b> {new Date(event.startTime).toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' })}</span>
        <span><b>Time:</b> {new Date(event.startTime).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })} - {new Date(event.endTime).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })}</span>
        <span><b>Hosted by:</b> {hostName}</span>
        <span><b>Venue/Location:</b> {event.venue || (event.eventType === 'webinar' ? 'Online' : 'TBD')}, {event.location || (event.eventType === 'webinar' ? 'Online' : 'TBD')}</span>
        {!isFull && !isEnded && <span><b>Spots Left:</b> <span class="text-green-600 font-medium">{spotsLeft} spot{spotsLeft !== 1 ? 's' : ''} left</span></span>}
        {isFull && !isEnded && <span class="text-yellow-300 font-medium">⚠️ This event is full please join the waitlist.</span>}
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Main content -->
        <div class="lg:col-span-2 space-y-6">

          {event.meetingUrlActive === true && !isEnded && (
            <div class="bg-red-50 border border-red-200 rounded-xl p-4 flex items-center gap-3">
              <span class="flex-shrink-0 w-3 h-3 rounded-full bg-red-500 animate-pulse"></span>
              <div>
                <p class="font-semibold text-red-700 text-sm">🔴 The join link is now live!</p>
                <p class="text-red-600 text-xs mt-0.5">The host has activated the join link. You can join the event now from the sidebar.</p>
              </div>
            </div>
          )}

          <div class="card p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="badge badge-primary">{eventTypeLabels[event.eventType] || event.eventType}</span>
              <span class={`badge ${event.status === 'upcoming' ? 'badge-primary' : event.status === 'live' ? 'badge-accent' : 'badge-secondary'}`}>
                {event.status.charAt(0).toUpperCase() + event.status.slice(1)}
              </span>
            </div>
            <h1 class="text-3xl font-bold mb-2">{event.title}</h1>
            {event.description && <p class="text-gray-600 mb-4">{event.description}</p>}
            {event.tags && event.tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {event.tags.map((tag: string) => (
                  <span class="badge badge-secondary text-xs">{tag}</span>
                ))}
              </div>
            )}
          </div>

          <!-- Event Registration Form (only for non-ended events) -->
          {!isEnded && (
            <div class="card p-6" id="rsvp-section">
              <h2 class="text-xl font-semibold mb-1">Event Registration Form</h2>
              <p class="text-sm text-gray-500 mb-4">
                Last Date to Register — {new Date(event.startTime).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </p>

              {isFull && (
                <div class="bg-amber-50 border border-amber-200 text-amber-700 rounded p-3 mb-4 text-sm font-medium">
                  ⚠️ This event is full — submitting will add you to the waitlist.
                </div>
              )}

              <form id="rsvp-form" class="space-y-6">
                <input type="hidden" id="event-id" value={event._id} />

                <!-- SECTION: Attendee Information -->
                <div>
                  <h3 class="text-base font-semibold text-gray-800 border-b pb-2 mb-4">Attendee Information</h3>
                  <p class="text-xs text-gray-500 mb-4">Your information is pre-filled from your profile and cannot be edited here.</p>

                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="md:col-span-2">
                      <label class="block text-sm font-medium mb-1" for="rsvp-name">Full Name <span class="text-red-500">*</span></label>
                      <input id="rsvp-name" name="userName" type="text" class="input w-full bg-gray-100 cursor-not-allowed opacity-75" value={alumniProfile?.name || ''} readonly />
                      <span class="text-xs text-gray-500">Enter your full name</span>
                      <p id="rsvp-name-error" class="text-red-500 text-xs mt-1 hidden">Full Name is required.</p>
                    </div>
                    <div>
                      <label class="block text-sm font-medium mb-1" for="rsvp-email">Email Address <span class="text-red-500">*</span></label>
                      <input id="rsvp-email" name="userEmail" type="email" class="input w-full bg-gray-100 cursor-not-allowed opacity-75" value={alumniProfile?.email || ''} readonly />
                      <span class="text-xs text-gray-500">Enter your email address</span>
                      <p id="rsvp-email-error" class="text-red-500 text-xs mt-1 hidden">Email Address is required.</p>
                    </div>
                    <div>
                      <label class="block text-sm font-medium mb-1" for="rsvp-mobile">Contact Number <span class="text-red-500">*</span></label>
                      <input id="rsvp-mobile" name="mobile" type="tel" class="input w-full bg-gray-100 cursor-not-allowed opacity-75" value={alumniProfile?.mobile || ''} readonly />
                      <span class="text-xs text-gray-500">Enter your contact number</span>
                      <p id="rsvp-mobile-error" class="text-red-500 text-xs mt-1 hidden">A valid contact number (min 10 digits) is required.</p>
                    </div>
                    <div>
                      <label class="block text-sm font-medium mb-1" for="rsvp-faculty">Faculty / Department</label>
                      <input id="rsvp-faculty" name="faculty" type="text" class="input w-full bg-gray-100 cursor-not-allowed opacity-75" value={alumniProfile?.faculty || ''} readonly />
                      <span class="text-xs text-gray-500">Enter your faculty or department e.g. Computer Science, IT, Engineering</span>
                    </div>
                    <div>
                      <label class="block text-sm font-medium mb-1" for="rsvp-year">Graduation Year</label>
                      <input id="rsvp-year" name="graduationYear" type="number" class="input w-full bg-gray-100 cursor-not-allowed opacity-75" min="1950" max="2100" value={alumniProfile?.year || ''} readonly />
                      <span class="text-xs text-gray-500">Enter your graduation year</span>
                    </div>
                  </div>
                </div>

                <!-- SECTION: Guest -->
                <div>
                  <h3 class="text-base font-semibold text-gray-800 border-b pb-2 mb-4">Will you have guests with you?</h3>
                  <div class="flex gap-6 mb-4">
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="radio" name="hasGuest" value="yes" id="guest-yes" class="w-4 h-4 text-primary-600" />
                      <span class="text-sm">Yes</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="radio" name="hasGuest" value="no" id="guest-no" class="w-4 h-4 text-primary-600" checked />
                      <span class="text-sm">No</span>
                    </label>
                  </div>

                  <!-- Guest fields (hidden by default) -->
                  <div id="guest-fields" class="hidden space-y-4 bg-gray-50 rounded-lg p-4 border border-gray-100">
                    <div>
                      <label class="block text-sm font-medium mb-1" for="guest-count">Number of Guests</label>
                      <input id="guest-count" name="guestCount" type="number" class="input w-full" placeholder="" min="1" max="5" value="1" />
                      <span class="text-xs text-gray-500">You can register up to 5 guests. Please provide their details after entering the number of guests.</span>
                    </div>
                    <!-- Per-guest dynamic sections rendered by JS -->
                    <div id="guest-entries"></div>
                  </div>
                </div>

                <!-- SECTION: Activities -->
                <div>
                  <h3 class="text-base font-semibold text-gray-800 border-b pb-2 mb-4">
                    Which activities would you like to participate in?
                  </h3>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                    {activities.map((activity: string) => (
                      <label class="flex items-center gap-3 cursor-pointer p-2 rounded hover:bg-gray-50">
                        <input type="checkbox" name="activities" value={activity} class="w-4 h-4 text-primary-600 rounded" />
                        <span class="text-sm text-gray-700">{activity}</span>
                      </label>
                    ))}
                  </div>
                </div>

                <!-- SECTION: Additional Comments -->
                <div>
                  <label class="block text-sm font-medium mb-1" for="rsvp-comments">
                    Additional Comments or Special Requests
                  </label>
                  <textarea id="rsvp-comments" name="comments" class="input w-full" rows={3}
                    placeholder="Any dietary requirements, accessibility needs, or other requests..."></textarea>
                </div>

                <div id="rsvp-msg" class="hidden mb-4 p-3 rounded text-sm"></div>

                <!-- Submit buttons -->
                <div class="flex gap-3 pt-2">
                  <button type="submit" id="rsvp-submit-btn" class="btn btn-primary">
                    {isFull ? 'Join Waitlist' : 'Confirm Registration'}
                  </button>
                  <button type="button" id="cancel-rsvp-btn" class="btn btn-outline hidden">
                    Cancel Registration
                  </button>
                </div>
              </form>
            </div>
          )}

          <!-- Networking Rooms (only for ended events) -->
          {isEnded && (
            <div class="card p-6" id="rooms-section">
              <h2 class="text-xl font-semibold mb-4">Post-Event Networking Rooms</h2>
              <div id="rooms-list" data-event-id={event._id}>
                <p class="text-gray-500 text-sm">Loading rooms…</p>
              </div>
              <!-- Chat panel (hidden until a room is selected) -->
              <div id="chat-panel" class="hidden mt-6">
                <div class="flex items-center justify-between mb-3">
                  <h3 id="chat-room-name" class="font-semibold"></h3>
                  <button id="close-chat" class="btn btn-outline btn-sm">Close</button>
                </div>
                <div id="chat-messages" class="border rounded p-3 h-64 overflow-y-auto space-y-2 bg-gray-50 text-sm"></div>
                <form id="chat-form" class="mt-3 flex gap-2">
                  <input id="chat-email" type="email" class="input flex-1" placeholder="Your email" required />
                  <input id="chat-name" type="text" class="input flex-1" placeholder="Your name" />
                  <input id="chat-msg" type="text" class="input flex-1" placeholder="Type a message…" required />
                  <button type="submit" class="btn btn-primary btn-sm">Send</button>
                </form>
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1 space-y-4">
          <div class="card p-6">
            <h2 class="font-semibold mb-3">Event Details</h2>
            <ul class="text-sm text-gray-700 space-y-2">
              <li><strong>Date:</strong> {new Date(event.startTime).toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' })}</li>
              <li><strong>Time:</strong> {new Date(event.startTime).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })} - {new Date(event.endTime).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })}</li>
              <li><strong>Host:</strong> {hostName}</li>
              <li>
                <strong>Venue/Location:</strong>{' '}
                {event.venue
                  ? event.venue
                  : (event.eventType === 'webinar' ? 'Online / Remote' : 'TBD')},
                  {event.location}
              </li>
              
              <li>
                <strong>No. of Guests:</strong> {event.capacity}
              <li>
                <strong>Spots Left:</strong> {spotsLeft} / {event.capacity} - {isFull
                  ? <span class="text-red-500 font-medium">No spots left, please join the waitlist.</span>
                  : <span class="text-green-600 font-medium">{spotsLeft} spot{spotsLeft !== 1 ? 's' : ''} left</span>
                }
              </li>
            </ul>
            <div class="w-full bg-gray-200 rounded-full h-2 mt-3">
              <div
                class="bg-primary h-2 rounded-full"
                style={`width: ${Math.min(100, Math.round(((event.confirmedCount || 0) / event.capacity) * 100))}%`}
              />
            </div>
            {event.waitlistCount > 0 && (
              <p class="text-xs text-amber-600 mt-1">{event.waitlistCount} on waitlist</p>
            )}

            {/* Admin-gated join link — only shown when meetingUrlActive is true */}
            {event.meetingUrl && event.meetingUrlActive === true ? (
              <div class="mt-4 pt-4 border-t border-gray-100">
                <p class="text-sm font-semibold text-gray-700 mb-2">Join Link</p>
                <a href={`/api/events/${event._id}/join`} target="_blank" rel="noopener noreferrer"
                   class="btn btn-primary btn-sm w-full text-center">
                  Join the webinar
                </a>
              </div>
            ) : event.meetingUrl ? (
              <div class="mt-4 pt-4 border-t border-gray-100">
                <div class="bg-gray-50 border border-gray-200 rounded p-3 text-sm text-gray-500">
                  <span class="font-medium">The event has not started yet. Join link not yet available.</span>
                  <p class="mt-1 text-xs">The host will activate the join link before the event starts. Check back closer to the event time.</p>
                </div>
              </div>
            ) : null}
          </div>

          {!isEnded && event.status !== 'cancelled' && (
            <div class="card p-6">
              <h2 class="font-semibold mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Add to Calendar
              </h2>
              <div class="space-y-2">
                <!-- Google Calendar -->
                <a
                  href={gcalUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 w-full px-4 py-2.5 rounded-xl border border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition-all duration-200 text-sm font-medium text-gray-700 hover:text-primary-700"
                >
                  <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M21.5 9.5h-1V6a2 2 0 00-2-2h-3.5V2.5h-2V4H11V2.5H9V4H5.5a2 2 0 00-2 2v3.5h-1v2h1V21a2 2 0 002 2h13a2 2 0 002-2V11.5h1v-2zm-3 11.5h-13V11.5h13V21zm0-11.5h-13V6h13v3.5z" fill="#4285F4"/>
                  </svg>
                  Google Calendar
                </a>

                <!-- Outlook Calendar -->
                <a
                  href={outlookUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 w-full px-4 py-2.5 rounded-xl border border-gray-200 hover:border-blue-300 hover:bg-blue-50 transition-all duration-200 text-sm font-medium text-gray-700 hover:text-blue-700"
                >
                  <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="#0078D4">
                    <path d="M22 6.5V17a2 2 0 01-2 2H9a2 2 0 01-2-2V6.5l7 4.5 8-4.5zM20 5H9l5.5 3.5L20 5zM7 8.5V17a2 2 0 002 2H7a2 2 0 01-2-2V9l2-0.5z"/>
                    <rect x="2" y="7" width="7" height="10" rx="1" fill="#0078D4" opacity="0.3"/>
                  </svg>
                  Outlook Calendar
                </a>

                <!-- Download .ics -->
                <a
                  href={icalDownloadUrl}
                  download
                  class="flex items-center gap-3 w-full px-4 py-2.5 rounded-xl border border-gray-200 hover:border-gray-400 hover:bg-gray-50 transition-all duration-200 text-sm font-medium text-gray-700"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                  </svg>
                  Download .ics
                  <span class="ml-auto text-xs text-gray-400">Apple / Outlook</span>
                </a>
              </div>
            </div>
          )}

          {event.meetingUrl && event.meetingUrlActive !== true && !isEnded && event.status !== 'cancelled' && (
            <div class="card p-6" id="notify-me-card">
              <h2 class="font-semibold mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
                Get Notified
              </h2>
              <p class="text-sm text-gray-500 mb-4">The join link isn't active yet. Get an email the moment the host activates it.</p>

              <button
                id="notify-me-btn"
                data-event-id={event._id}
                data-user-email={alumniProfile?.email || ''}
                data-user-name={alumniProfile?.name || ''}
                data-subscribed={isNotifyMeSubscribed ? 'true' : 'false'}
                class={`btn w-full text-sm ${isNotifyMeSubscribed ? 'btn-outline' : 'btn-primary'}`}
              >
                {isNotifyMeSubscribed ? '🔔 Subscribed — Click to Unsubscribe' : '🔔 Notify Me When Live'}
              </button>
              <p id="notify-me-msg" class="text-xs text-gray-500 mt-2 hidden"></p>
            </div>
          )}
        </div>

      </div>
    </div>
  </section>

  <!-- Confirmation Modal: Register -->
  <div id="confirm-register-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50">
    <div class="bg-white rounded-xl shadow-xl p-6 max-w-md w-full mx-4">
      <h3 class="text-lg font-semibold mb-2">Confirm Registration</h3>
      <p class="text-sm text-gray-600 mb-6">Are you sure you want to register for <strong>{event.title}</strong>? Please confirm your details before submitting. Make sure that the information you provided is correct. You can contact the admin if you need to make any changes after submitting.</p>
      <div class="flex gap-3 justify-end">
        <button id="modal-register-cancel" class="btn btn-primary text-white bg-blue-600">No</button>
        <button id="modal-register-confirm" class="btn btn-primary">Yes, Confirm</button>
      </div>
    </div>
  </div>

  <!-- Confirmation Modal: Cancel Registration -->
  <div id="confirm-cancel-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50">
    <div class="bg-white rounded-xl shadow-xl p-6 max-w-md w-full mx-4">
      <h3 class="text-lg font-semibold mb-2">Cancel Registration</h3>
      <p class="text-sm text-gray-600 mb-6">Are you sure you want to cancel your registration for <strong>{event.title}</strong>? This action cannot be undone.</p>
      <div class="flex gap-3 justify-end">
        <button id="modal-keep-registration" class="btn btn-primary text-white bg-blue-600">No</button>
        <button id="modal-cancel-confirm" class="btn btn-danger text-white bg-red-600 hover:bg-red-700 border-red-600">Yes</button>
      </div>
    </div>
  </div>

  <script>
    // -----------------------------------------------------------------------
    // Utility: show/hide modal
    // -----------------------------------------------------------------------
    function showModal(id: string) {
      const el = document.getElementById(id);
      if (el) { el.classList.remove('hidden'); el.classList.add('flex'); }
    }
    function hideModal(id: string) {
      const el = document.getElementById(id);
      if (el) { el.classList.add('hidden'); el.classList.remove('flex'); }
    }

    // -----------------------------------------------------------------------
    // Dynamic per-guest sections
    // -----------------------------------------------------------------------
    function buildGuestEntries(count: number) {
      const container = document.getElementById('guest-entries');
      if (!container) return;
      let html = '';
      for (let i = 1; i <= count; i++) {
        html += `
          <div class="border border-gray-200 rounded-lg p-4 mb-4 bg-white">
            <p class="text-sm font-semibold text-gray-700 mb-3">Guest ${i}</p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="md:col-span-2">
                <label class="block text-sm font-medium mb-1" for="guestName_${i}">Guest Full Name <span class="text-red-500">*</span></label>
                <input id="guestName_${i}" name="guestName_${i}" type="text" class="input w-full" placeholder="Enter the full name of Guest ${i}" aria-required="true" />
                <p id="guestName_${i}_error" class="text-red-500 text-xs mt-1 hidden">Guest Full Name is required.</p>
              </div>
              <div>
                <label class="block text-sm font-medium mb-1" for="guestEmail_${i}">Guest Email</label>
                <input id="guestEmail_${i}" name="guestEmail_${i}" type="email" class="input w-full" placeholder="Enter the email of Guest ${i}" />
              </div>
              <div>
                <label class="block text-sm font-medium mb-1" for="guestMobile_${i}">Guest Contact Number</label>
                <input id="guestMobile_${i}" name="guestMobile_${i}" type="tel" class="input w-full" placeholder="Enter the contact number of Guest ${i}" />
              </div>
              <div>
                <label class="block text-sm font-medium mb-1" for="guestFaculty_${i}">Guest Faculty / Department</label>
                <input id="guestFaculty_${i}" name="guestFaculty_${i}" type="text" class="input w-full" placeholder="Enter the faculty or department of Guest ${i}" />
              </div>
              <div>
                <label class="block text-sm font-medium mb-1" for="guestYear_${i}">Guest Graduation Year</label>
                <input id="guestYear_${i}" name="guestYear_${i}" type="number" class="input w-full" placeholder="Enter the graduation year of Guest ${i}" min="1950" max="2100" />
              </div>
            </div>
          </div>
        `;
      }
      container.innerHTML = html;
    }

    const guestCountInput = document.getElementById('guest-count') as HTMLInputElement | null;
    guestCountInput?.addEventListener('input', () => {
      const count = Math.min(5, Math.max(1, parseInt(guestCountInput.value) || 1));
      buildGuestEntries(count);
    });

    // Guest toggle — build per-guest entries only when "Yes" is selected
    document.querySelectorAll('input[name="hasGuest"]').forEach(r => {
      r.addEventListener('change', () => {
        const guestFields = document.getElementById('guest-fields');
        if ((document.getElementById('guest-yes') as HTMLInputElement).checked) {
          guestFields?.classList.remove('hidden');
          // Build guest entries on first reveal
          const count = Math.min(5, Math.max(1, parseInt((document.getElementById('guest-count') as HTMLInputElement)?.value) || 1));
          buildGuestEntries(count);
        } else {
          guestFields?.classList.add('hidden');
        }
      });
    });

    // -----------------------------------------------------------------------
    // RSVP form
    // -----------------------------------------------------------------------
    const rsvpForm = document.getElementById('rsvp-form') as HTMLFormElement | null;
    if (rsvpForm) {
      const eventId = (document.getElementById('event-id') as HTMLInputElement).value;
      const msgEl = document.getElementById('rsvp-msg')!;
      const cancelBtn = document.getElementById('cancel-rsvp-btn') as HTMLButtonElement;
      const submitBtn = document.getElementById('rsvp-submit-btn') as HTMLButtonElement;

      function showMsg(text: string, type: 'success' | 'error' | 'info') {
        msgEl.textContent = text;
        msgEl.className = `mb-4 p-3 rounded text-sm ${
          type === 'success' ? 'bg-green-100 text-green-800' :
          type === 'error'   ? 'bg-red-100 text-red-800' :
                               'bg-blue-100 text-blue-800'
        }`;
        msgEl.classList.remove('hidden');
      }

      // Phone number validation pattern
      const phonePattern = /^\+?[\d\s\-()\[\]]{10,}$/;

      function validateForm(): boolean {
        let valid = true;

        const nameVal = (document.getElementById('rsvp-name') as HTMLInputElement).value.trim();
        const nameErr = document.getElementById('rsvp-name-error')!;
        if (!nameVal) { nameErr.classList.remove('hidden'); valid = false; } else { nameErr.classList.add('hidden'); }

        const emailVal = (document.getElementById('rsvp-email') as HTMLInputElement).value.trim();
        const emailErr = document.getElementById('rsvp-email-error')!;
        if (!emailVal) { emailErr.classList.remove('hidden'); valid = false; } else { emailErr.classList.add('hidden'); }

        const mobileVal = (document.getElementById('rsvp-mobile') as HTMLInputElement).value.trim();
        const mobileErr = document.getElementById('rsvp-mobile-error')!;
        if (!mobileVal || !phonePattern.test(mobileVal)) { mobileErr.classList.remove('hidden'); valid = false; } else { mobileErr.classList.add('hidden'); }

        // Validate guest names if guests are enabled
        const hasGuest = (document.getElementById('guest-yes') as HTMLInputElement).checked;
        if (hasGuest) {
          const count = Math.min(5, Math.max(1, parseInt((document.getElementById('guest-count') as HTMLInputElement)?.value) || 1));
          for (let i = 1; i <= count; i++) {
            const gNameVal = (document.getElementById(`guestName_${i}`) as HTMLInputElement)?.value?.trim();
            const gNameErr = document.getElementById(`guestName_${i}_error`);
            if (!gNameVal) { gNameErr?.classList.remove('hidden'); valid = false; } else { gNameErr?.classList.add('hidden'); }
          }
        }

        return valid;
      }

      async function submitRsvp() {
        const email = (document.getElementById('rsvp-email') as HTMLInputElement).value.trim();
        const name  = (document.getElementById('rsvp-name')  as HTMLInputElement).value.trim();
        const hasGuest = (document.getElementById('guest-yes') as HTMLInputElement).checked;
        const count = hasGuest ? Math.min(5, Math.max(1, parseInt((document.getElementById('guest-count') as HTMLInputElement)?.value) || 1)) : 0;

        // Collect per-guest data as array
        const guestsArr: Array<{ name?: string; email?: string; mobile?: string; faculty?: string; year?: number }> = [];
        for (let i = 1; i <= count; i++) {
          const gName = (document.getElementById(`guestName_${i}`) as HTMLInputElement)?.value?.trim();
          const gEmail = (document.getElementById(`guestEmail_${i}`) as HTMLInputElement)?.value?.trim();
          const gMobile = (document.getElementById(`guestMobile_${i}`) as HTMLInputElement)?.value?.trim();
          const gFaculty = (document.getElementById(`guestFaculty_${i}`) as HTMLInputElement)?.value?.trim();
          const gYear = (document.getElementById(`guestYear_${i}`) as HTMLInputElement)?.value;
          guestsArr.push({ name: gName || undefined, email: gEmail || undefined, mobile: gMobile || undefined, faculty: gFaculty || undefined, year: gYear ? parseInt(gYear) : undefined });
        }

        const formData = {
          userEmail: email,
          userName: name || undefined,
          mobile: (document.getElementById('rsvp-mobile') as HTMLInputElement).value.trim(),
          faculty: (document.getElementById('rsvp-faculty') as HTMLInputElement).value.trim(),
          graduationYear: (document.getElementById('rsvp-year') as HTMLInputElement).value,
          hasGuest,
          guestCount: count > 0 ? count : undefined,
          guests: guestsArr.length > 0 ? guestsArr : undefined,
          activities: [...document.querySelectorAll('input[name="activities"]:checked')].map(cb => (cb as HTMLInputElement).value),
          comments: (document.getElementById('rsvp-comments') as HTMLTextAreaElement).value.trim(),
        };

        try {
          const res = await fetch(`/api/events/${eventId}/rsvp`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData),
          });
          const data = await res.json();
          if (res.ok && data.success) {
            if (data.status === 'waitlisted') {
              showMsg(`You've been added to the waitlist. We'll notify you if a spot opens up.`, 'success');
              if (submitBtn) { submitBtn.textContent = "You're on the waitlist"; }
            } else {
              showMsg(`Your registration is confirmed. The join link will be available once the host activates it.`, 'success');
              if (submitBtn) { submitBtn.textContent = 'Registered'; }
            }
            cancelBtn.classList.remove('hidden');
          } else if (res.status === 409) {
            showMsg('You are already registered for this event.', 'info');
            cancelBtn.classList.remove('hidden');
            if (submitBtn) { submitBtn.textContent = 'Registered'; }
          } else {
            showMsg(data.message || 'Something went wrong.', 'error');
          }
        } catch {
          showMsg('Network error. Please try again.', 'error');
        }
      }

      rsvpForm.addEventListener('submit', (e) => {
        e.preventDefault();
        if (!validateForm()) return;
        showModal('confirm-register-modal');
      });

      document.getElementById('modal-register-cancel')?.addEventListener('click', () => {
        hideModal('confirm-register-modal');
      });

      document.getElementById('modal-register-confirm')?.addEventListener('click', async () => {
        hideModal('confirm-register-modal');
        await submitRsvp();
      });

      cancelBtn?.addEventListener('click', () => {
        showModal('confirm-cancel-modal');
      });

      document.getElementById('modal-keep-registration')?.addEventListener('click', () => {
        hideModal('confirm-cancel-modal');
      });

      document.getElementById('modal-cancel-confirm')?.addEventListener('click', async () => {
        hideModal('confirm-cancel-modal');
        const email = (document.getElementById('rsvp-email') as HTMLInputElement).value.trim();
        if (!email) { showMsg('Enter your email first.', 'error'); return; }

        try {
          const res = await fetch(`/api/events/${eventId}/rsvp`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userEmail: email }),
          });
          const data = await res.json();
          if (res.ok && data.success) {
            showMsg('Your RSVP has been cancelled.', 'info');
            cancelBtn.classList.add('hidden');
            if (submitBtn) { submitBtn.textContent = 'Confirm Registration'; }
          } else {
            showMsg(data.message || 'Could not cancel RSVP.', 'error');
          }
        } catch {
          showMsg('Network error. Please try again.', 'error');
        }
      });
    }

    // -----------------------------------------------------------------------
    // Networking Rooms
    // -----------------------------------------------------------------------
    const roomsList = document.getElementById('rooms-list');
    if (roomsList) {
      const eventId = roomsList.getAttribute('data-event-id')!;
      let activeRoomId: string | null = null;
      let pollInterval: ReturnType<typeof setInterval> | null = null;

      async function loadRooms() {
        const res = await fetch(`/api/events/${eventId}/rooms`);
        const data = await res.json();
        if (!data.success || !data.rooms.length) {
          roomsList!.innerHTML = '<p class="text-gray-500 text-sm">No networking rooms available yet.</p>';
          return;
        }
        roomsList!.innerHTML = data.rooms.map((r: any) => `
          <div class="border rounded p-3 mb-2 cursor-pointer hover:bg-gray-50 room-card"
               data-room-id="${r._id}" data-room-name="${r.name}">
            <div class="flex items-center justify-between">
              <span class="font-medium">${r.name}</span>
              <span class="text-xs text-gray-500">${r.messageCount} message${r.messageCount !== 1 ? 's' : ''}</span>
            </div>
            ${r.topic ? `<p class="text-sm text-gray-500 mt-1">${r.topic}</p>` : ''}
          </div>
        `).join('');

        document.querySelectorAll('.room-card').forEach(card => {
          card.addEventListener('click', () => {
            const roomId = card.getAttribute('data-room-id')!;
            const roomName = card.getAttribute('data-room-name')!;
            openRoom(roomId, roomName);
          });
        });
      }

      function openRoom(roomId: string, roomName: string) {
        activeRoomId = roomId;
        document.getElementById('chat-room-name')!.textContent = roomName;
        document.getElementById('chat-panel')!.classList.remove('hidden');
        loadMessages();
        if (pollInterval) clearInterval(pollInterval);
        pollInterval = setInterval(loadMessages, 3000);
      }

      async function loadMessages() {
        if (!activeRoomId) return;
        const res = await fetch(`/api/rooms/${activeRoomId}/messages`);
        const data = await res.json();
        const container = document.getElementById('chat-messages')!;
        if (data.success) {
          container.innerHTML = data.messages.map((m: any) => `
            <div>
              <span class="font-medium text-xs text-gray-700">${m.userName || m.userEmail}</span>
              <span class="text-gray-400 text-xs ml-1">${new Date(m.createdAt).toLocaleTimeString()}</span>
              <p class="mt-0.5">${m.message}</p>
            </div>
          `).join('');
          container.scrollTop = container.scrollHeight;
        }
      }

      document.getElementById('close-chat')?.addEventListener('click', () => {
        document.getElementById('chat-panel')!.classList.add('hidden');
        if (pollInterval) { clearInterval(pollInterval); pollInterval = null; }
        activeRoomId = null;
      });

      document.getElementById('chat-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!activeRoomId) return;
        const email = (document.getElementById('chat-email') as HTMLInputElement).value.trim();
        const name  = (document.getElementById('chat-name')  as HTMLInputElement).value.trim();
        const msg   = (document.getElementById('chat-msg')   as HTMLInputElement).value.trim();
        if (!email || !msg) return;

        await fetch(`/api/rooms/${activeRoomId}/messages`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userEmail: email, userName: name || undefined, message: msg }),
        });
        (document.getElementById('chat-msg') as HTMLInputElement).value = '';
        loadMessages();
      });

      loadRooms();
    }

    // -----------------------------------------------------------------------
    // Notify Me Toggle
    // -----------------------------------------------------------------------
    const notifyMeBtn = document.getElementById('notify-me-btn') as HTMLButtonElement | null;
    if (notifyMeBtn) {
      const eventId = notifyMeBtn.getAttribute('data-event-id')!;
      const userEmail = notifyMeBtn.getAttribute('data-user-email')!;
      const userName = notifyMeBtn.getAttribute('data-user-name') || undefined;
      let subscribed = notifyMeBtn.getAttribute('data-subscribed') === 'true';
      const msgEl = document.getElementById('notify-me-msg')!;

      notifyMeBtn.addEventListener('click', async () => {
        notifyMeBtn.disabled = true;
        try {
          if (subscribed) {
            const res = await fetch(`/api/events/${eventId}/notify-me`, {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ userEmail }),
            });
            const data = await res.json();
            if (data.success) {
              subscribed = false;
              notifyMeBtn.textContent = '🔔 Notify Me When Live';
              notifyMeBtn.classList.remove('btn-outline');
              notifyMeBtn.classList.add('btn-primary');
              msgEl.textContent = 'You have been unsubscribed.';
              msgEl.classList.remove('hidden');
            }
          } else {
            const res = await fetch(`/api/events/${eventId}/notify-me`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ userEmail, userName }),
            });
            const data = await res.json();
            if (data.success) {
              subscribed = true;
              notifyMeBtn.textContent = '🔔 Subscribed — Click to Unsubscribe';
              notifyMeBtn.classList.remove('btn-primary');
              notifyMeBtn.classList.add('btn-outline');
              msgEl.textContent = "You'll receive an email when the join link goes live.";
              msgEl.classList.remove('hidden');
            }
          }
        } catch {
          msgEl.textContent = 'Something went wrong. Please try again.';
          msgEl.classList.remove('hidden');
        } finally {
          notifyMeBtn.disabled = false;
        }
      });
    }
  </script>
</Layout>
