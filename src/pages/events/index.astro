---
export const prerender = false;

import { isAlumniAuthenticated, getCurrentAlumni } from '../../lib/alumni-auth';
if (!isAlumniAuthenticated(Astro.cookies)) {
  return Astro.redirect('/alumni/login?redirect=/events');
}

import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { connectToDatabase } from '../../lib/mongodb';
import { ObjectId } from 'mongodb';

const base = Astro.url.origin;

const allEventsRes = await fetch(`${base}/api/events?limit=200`);
const allEventsData = allEventsRes.ok ? await allEventsRes.json() : { events: [] };
const allEvents: any[] = allEventsData.events || [];

// Collect unique event types and tags for filter dropdowns
const allTypes = [...new Set(allEvents.map((e: any) => e.eventType).filter(Boolean))];
const allTags = [...new Set(allEvents.flatMap((e: any) => e.tags || []).filter(Boolean))];

// Feature 11 — get logged-in alumni's email and RSVP event IDs
const currentAlumni = getCurrentAlumni(Astro.cookies);
let alumniEmail = '';
let myRsvpEventIds: string[] = [];

try {
  const { db } = await connectToDatabase();
  let query: any = { $or: [{ username: currentAlumni?.username }, { email: currentAlumni?.username }] };
  if (currentAlumni?.alumniId) {
    try { query = { _id: new ObjectId(currentAlumni.alumniId) }; } catch {}
  }
  const profile = await db.collection('alumni_registrations').findOne(query, { projection: { email: 1 } });
  alumniEmail = profile?.email || '';

  if (alumniEmail) {
    const myRsvps = await db.collection('event_rsvps')
      .find({ userEmail: alumniEmail, rsvpStatus: { $in: ['confirmed', 'waitlisted'] } })
      .project({ eventId: 1 })
      .toArray();
    myRsvpEventIds = myRsvps.map((r: any) => r.eventId?.toString()).filter(Boolean);
  }
} catch {}

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Events' },
];

// Feature 14 — fetch saved event IDs for the logged-in alumni
let savedEventIds: string[] = [];
try {
  if (alumniEmail) {
    const savedRes = await fetch(`${base}/api/events/saved?userEmail=${encodeURIComponent(alumniEmail)}`);
    if (savedRes.ok) {
      const savedData = await savedRes.json();
      savedEventIds = savedData.savedEventIds || [];
    }
  }
} catch {}
---

<Layout title="Events">
  <Breadcrumbs items={breadcrumbItems} />
  <section class="section">
    <div class="container-custom">
      <h1 class="text-3xl text-center font-bold mb-6">Events and Webinars</h1>
      <p class="text-black mb-6"> Stay updated with the latest events, webinars, workshops, reunions, and networking opportunities in our alumni community. Explore upcoming events, register for those that interest you, and connect with fellow alumni. Whether you're looking to learn new skills, catch up with old friends, or just have fun, there's something for everyone in our vibrant event calendar. </p>

      <!-- Featured Event Banner (populated by JS) -->
      <div id="featured-event-banner" class="hidden mb-8 bg-gradient-to-r from-indigo-50 to-purple-50 border border-indigo-200 rounded-2xl p-6">
        <p class="text-xs font-semibold text-indigo-500 uppercase tracking-widest mb-1">⭐ Featured Event</p>
        <h2 id="featured-title" class="text-xl font-bold text-gray-900 mb-1"></h2>
        <p id="featured-desc" class="text-sm text-gray-600 mb-3 line-clamp-2"></p>
        <div class="flex items-center gap-4 text-sm text-gray-500 mb-4">
          <span id="featured-date"></span>
          <span id="featured-type" class="badge badge-primary text-xs"></span>
        </div>
        <a id="featured-link" href="#" class="btn btn-primary btn-sm">View Event →</a>
      </div>

      <!-- Filter Bar -->
      <div class="mb-8 space-y-4">
        <!-- Search bar -->
        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            id="event-search"
            type="text"
            placeholder="Search events by title or description..."
            class="input w-full pl-10"
            style="padding: 0.875rem 1.25rem 0.875rem 2.75rem;"
          />
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" aria-hidden="true"></span>
        </div>

        <!-- Filter row -->
        <div class="flex flex-wrap gap-3 items-center">
          <!-- View Toggle -->
          <span class="text-black font-bold">View:</span>
          <div class="flex gap-1 border border-gray-200 rounded-lg p-1 bg-gray-50">
            <button id="view-grid" class="view-toggle-btn btn btn-sm btn-primary" data-view="grid" title="Grid View">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
              </svg>
              Grid View
            </button>
            <button id="view-month" class="view-toggle-btn btn btn-sm btn-outline" data-view="month" title="Month View">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              Month View
            </button>
            <button id="view-week" class="view-toggle-btn btn btn-sm btn-outline" data-view="week" title="Week View">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
              Week View
            </button>
          </div>

          <!-- Status filter (All / Upcoming / Past / My Events / Saved) -->
           <span class="text-black font-bold"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z" /></svg> Filter:</span>
          <div class="flex gap-2">
            <button class="filter-status-btn btn btn-sm btn-primary" data-status="all">All</button>
            <button class="filter-status-btn btn btn-sm btn-outline" data-status="upcoming">Upcoming</button>
            <button class="filter-status-btn btn btn-sm btn-outline" data-status="ended">Past</button>
            <button class="filter-status-btn btn btn-sm btn-outline" data-status="mine">My Registrations</button>
            <button class="filter-status-btn btn btn-sm btn-outline" data-status="saved"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v18l7-5 7 5V3z" /></svg>Bookmarks</button>
          </div>

          <!-- Type filter -->
          <select id="filter-type" class="input input-sm max-w-[160px]">
            <option value="">All Types</option>
            {allTypes.map((t: any) => <option value={t}>{String(t).charAt(0).toUpperCase() + String(t).slice(1)}</option>)}
          </select>

          <!-- Tag filter -->
          <select id="filter-tag" class="input input-sm max-w-[160px]">
            <option value="">All Tags</option>
            {allTags.map((t: any) => <option value={t}>{t}</option>)}
          </select>

          <!-- Sort dropdown -->
          <select id="filter-sort" class="input input-sm max-w-[160px]">
            <option value="soonest">Soonest First</option>
            <option value="newest">Newest Added</option>
            <option value="popular">Most Popular</option>
          </select>

          <!-- Result count -->
          <span id="result-count" class="text-sm text-gray-500 ml-auto"></span>
        </div>

        <!-- Advanced Filters toggle -->
        <div id="advanced-filters-toggle">
          <button id="toggle-advanced" class="btn btn-sm btn-outline text-xs"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z" /></svg>Advanced Filters</button>
        </div>
        <div id="advanced-filters" class="hidden mt-3 flex flex-wrap gap-3 items-center bg-gray-50 border border-gray-100 rounded-xl p-3">
          <div class="flex items-center gap-2 text-sm">
            <label class="text-gray-600 font-medium">From:</label>
            <input id="filter-date-from" type="date" class="input input-sm" />
          </div>
          <div class="flex items-center gap-2 text-sm">
            <label class="text-gray-600 font-medium">To:</label>
            <input id="filter-date-to" type="date" class="input input-sm" />
          </div>
          <button id="clear-advanced" class="btn btn-sm btn-outline text-xs text-gray-500">Clear</button>
        </div>
      </div>
      <div id="border" class="border-t border-gray-200 mb-8"></div>

      <div id="events-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 w-30/12 mx-auto gap-6">
        <!-- events rendered here by JS -->
      </div>
      <div id="events-empty" class="hidden text-center py-12 text-gray-500">
        No events match your filters.
      </div>

      <!-- Monthly Calendar View -->
      <div id="calendar-month-view" class="hidden">
        <div class="flex items-center justify-between mb-4">
          <button id="cal-prev-month" class="btn btn-outline btn-sm">&#8249; Prev</button>
          <h2 id="cal-month-label" class="text-lg font-semibold"></h2>
          <button id="cal-next-month" class="btn btn-outline btn-sm">Next &#8250;</button>
        </div>
        <div class="grid grid-cols-7 gap-px mb-1 text-center">
          {['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].map(d => (
            <div class="text-xs font-semibold text-gray-500 uppercase py-1">{d}</div>
          ))}
        </div>
        <div id="cal-month-grid" class="grid grid-cols-7 gap-px bg-gray-200 border border-gray-200 rounded-lg overflow-hidden"></div>
      </div>

      <!-- Weekly Calendar View -->
      <div id="calendar-week-view" class="hidden">
        <div class="flex items-center justify-between mb-4">
          <button id="cal-prev-week" class="btn btn-outline btn-sm">&#8249; Prev</button>
          <h2 id="cal-week-label" class="text-lg font-semibold"></h2>
          <button id="cal-next-week" class="btn btn-outline btn-sm">Next &#8250;</button>
        </div>
        <div id="cal-week-grid" class="grid grid-cols-7 gap-2"></div>
      </div>

      <!-- Event Series Section (populated by JS) -->
      <div id="series-section" class="hidden mt-12">
        <h2 class="text-2xl font-bold mb-6">📚 Event Series</h2>
        <div id="series-list" class="space-y-6"></div>
      </div>
    </div>
  </section>

  <script id="events-data" type="application/json" set:html={JSON.stringify(allEvents)}></script>
  <script id="alumni-data" type="application/json" set:html={JSON.stringify({ alumniEmail, myRsvpEventIds })}></script>
  <script id="saved-events-data" type="application/json" set:html={JSON.stringify({ savedEventIds, alumniEmail })}></script>

  <script>
    const raw: any[] = JSON.parse((document.getElementById('events-data') as HTMLScriptElement).text);
    const alumniDataEl = document.getElementById('alumni-data') as HTMLScriptElement | null;
    const alumniData = alumniDataEl ? JSON.parse(alumniDataEl.text) : { alumniEmail: '', myRsvpEventIds: [] };
    const myRsvpEventIds: string[] = alumniData.myRsvpEventIds || [];

    const savedDataEl = document.getElementById('saved-events-data') as HTMLScriptElement | null;
    const savedData = savedDataEl ? JSON.parse(savedDataEl.text) : { savedEventIds: [], alumniEmail: '' };
    let savedEventIds: string[] = savedData.savedEventIds || [];
    const alumniEmail: string = savedData.alumniEmail || alumniData.alumniEmail || '';

    let activeStatus = 'all';
    let activeType = '';
    let activeTag = '';
    let searchQuery = '';
    let activeSort: 'soonest' | 'newest' | 'popular' = 'soonest';
    let dateFrom = '';
    let dateTo = '';

    function spotsLeft(e: any) { return Math.max(0, e.capacity - (e.confirmedCount || 0)); }

    function getFilteredEvents() {
      const now = new Date();
      let result = raw.filter((e: any) => {
        if (activeStatus === 'upcoming' && new Date(e.startTime) < now) return false;
        if (activeStatus === 'ended' && new Date(e.startTime) >= now) return false;
        if (activeStatus === 'mine' && !myRsvpEventIds.includes(e._id)) return false;
        if (activeStatus === 'saved' && !savedEventIds.includes(e._id)) return false;
        if (activeType && e.eventType !== activeType) return false;
        if (activeTag && !(e.tags || []).includes(activeTag)) return false;
        if (searchQuery) {
          const q = searchQuery.toLowerCase();
          const haystack = `${e.title} ${e.description || ''}`.toLowerCase();
          if (!haystack.includes(q)) return false;
        }
        if (dateFrom && new Date(e.startTime) < new Date(dateFrom)) return false;
        if (dateTo) {
          const toDate = new Date(dateTo);
          toDate.setHours(23, 59, 59, 999);
          if (new Date(e.startTime) > toDate) return false;
        }
        return true;
      });

      if (activeSort === 'newest') {
        result.sort((a: any, b: any) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());
      } else if (activeSort === 'popular') {
        result.sort((a: any, b: any) => (b.confirmedCount || 0) - (a.confirmedCount || 0));
      } else {
        result.sort((a: any, b: any) => new Date(a.startTime).getTime() - new Date(b.startTime).getTime());
      }

      return result;
    }

    function renderEvents() {
      const filtered = getFilteredEvents();

      const grid = document.getElementById('events-grid')!;
      const empty = document.getElementById('events-empty')!;
      const count = document.getElementById('result-count')!;
      count.textContent = `${filtered.length} event${filtered.length !== 1 ? 's' : ''} found`;

      if (filtered.length === 0) {
        grid.innerHTML = '';
        empty.classList.remove('hidden');
        return;
      }
      empty.classList.add('hidden');

      const badgeClass = (status: string) => status === 'upcoming' ? 'badge-primary' :
        status === 'live' ? 'badge-accent' : 'badge-secondary';

      grid.innerHTML = filtered.map((e: any) => {
        const spots = spotsLeft(e);
        const isFull = spots === 0;
        const date = new Date(e.startTime).toDateString();
        const pct = Math.min(100, Math.round(((e.confirmedCount || 0) / e.capacity) * 100));
        const isLive = e.meetingUrlActive === true && e.status !== 'ended';
        const seriesBadge = e.seriesId ? `<span title="Part of a series" class="text-base">🔁</span>` : '';
        const featuredBadge = e.isFeatured ? `<span title="Featured Event" class="badge badge-primary text-black" style="background-color: #fcd34d;">⭐Featured</span>` : '';
        const isSaved = savedEventIds.includes(e._id);
        const bookmarkBtn = alumniEmail ? `
        <button class="btn-bookmark p-1.5 rounded-lg transition ${isSaved ? 'text-amber-500 bg-gray-50 hover:bg-gray-100' : 'text-gray-400 bg-gray-50 hover:bg-gray-100'}"
          data-id="${e._id}" data-saved="${isSaved}" title="${isSaved ? 'Remove bookmark' : 'Bookmark event'}">
          ${isSaved ? '<svg xmlns="http://www.w3.org/2000/svg" fill="#2e4096" viewBox="0 0 24 24" class="w-5 h-5"><path d="M5 3v18l7-5 7 5V3z"/></svg>' : '<svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="w-5 h-5"><path d="M5 3v18l7-5 7 5V3z"/></svg>'}
        </button>` : '';
        return `
          <div class="card card-hover${isLive ? ' ring-2 ring-red-400' : ''} relative">
            ${bookmarkBtn ? `<div class="absolute top-3 right-3 z-10">${bookmarkBtn}</div>` : ''}
            <a href="/events/${e.slug}" class="block">
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="badge ${badgeClass(e.status)} text-xs">${e.status.charAt(0).toUpperCase() + e.status.slice(1)}</span>
                ${e.eventType ? `<span class="badge badge-secondary text-xs uppercase">${e.eventType}</span>` : ''}
                <span class="flex items-center gap-1 text-sm text-gray-500">${seriesBadge}${featuredBadge}</span>
              </div>
              ${isLive ? `
              <div class="mb-2">
                <span class="inline-flex items-center gap-1 bg-red-100 text-red-700 text-xs font-semibold px-3 py-1 rounded-full animate-pulse">
                  <span class="w-2 h-2 rounded-full bg-red-500 inline-block"></span>
                  Join Link Live
                </span>
              </div>
              ` : ''}
              <h3 class="text-xl font-semibold mb-2">${e.title}</h3>
              ${e.description ? `<p class="text-gray-600 mb-3 text-sm line-clamp-2">${e.description}</p>` : ''} ${e.venue ? `<p class="text-gray-500 mb-3 text-sm"> <svg xmlns="http://www.w3.org/2000/svg" class="inline h-4 w-4 mr-1 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>${e.venue}, ${e.location}</p>` : ''}
              ${date ? `<p class="text-gray-500 mb-3 text-sm"><svg xmlns="http://www.w3.org/2000/svg" class="inline h-4 w-4 mr-1 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>${date}</p>` : ''}
              ${e.tags && e.tags.length ? `<div class="flex flex-wrap gap-1 mb-3">${e.tags.map((t: string) => `<span class="badge badge-secondary text-xs">${t}</span>`).join('')}</div>` : ''}
              <div class="mt-2">
                <div class="flex items-center justify-between text-sm mb-1">
                  <span class="text-gray-500">${isFull ? 'Full' : `${spots} spot${spots !== 1 ? 's' : ''} left`}</span>
                  ${isFull ? '<span class="badge badge-accent text-xs">Waitlist</span>' : ''}
                </div>
                <div class="w-full bg-gray-200 rounded-full h-2">
                  <div class="bg-primary h-2 rounded-full" style="width: ${pct}%"></div>
                </div>
              </div>
            </div>
            </a>
          </div>
        `;
      }).join('');

      // Attach bookmark click handlers after rendering
      if (alumniEmail) {
        grid.querySelectorAll('.btn-bookmark').forEach(btn => {
          btn.addEventListener('click', async (ev) => {
            ev.stopPropagation();
            const id = (btn as HTMLButtonElement).dataset.id;
            const isSaved = (btn as HTMLButtonElement).dataset.saved === 'true';
            if (!id) return;
            try {
              const res = await fetch(`/api/events/${id}/save`, {
                method: isSaved ? 'DELETE' : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userEmail: alumniEmail }),
              });
              if (res.ok) {
                if (isSaved) {
                  savedEventIds = savedEventIds.filter((sid: string) => sid !== id);
                } else {
                  savedEventIds.push(id);
                }
                renderEvents();
              }
            } catch {}
          });
        });
      }
    }

    document.querySelectorAll('.filter-status-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activeStatus = btn.getAttribute('data-status') || 'all';
        document.querySelectorAll('.filter-status-btn').forEach(b => {
          b.classList.remove('btn-primary');
          b.classList.add('btn-outline');
        });
        btn.classList.remove('btn-outline');
        btn.classList.add('btn-primary');
        renderEvents();
        if (activeView === 'month') renderMonthCalendar();
        if (activeView === 'week') renderWeekCalendar();
      });
    });

    (document.getElementById('filter-type') as HTMLSelectElement).addEventListener('change', (e) => {
      activeType = (e.target as HTMLSelectElement).value;
      renderEvents();
      if (activeView === 'month') renderMonthCalendar();
      if (activeView === 'week') renderWeekCalendar();
    });
    (document.getElementById('filter-tag') as HTMLSelectElement).addEventListener('change', (e) => {
      activeTag = (e.target as HTMLSelectElement).value;
      renderEvents();
      if (activeView === 'month') renderMonthCalendar();
      if (activeView === 'week') renderWeekCalendar();
    });
    (document.getElementById('event-search') as HTMLInputElement).addEventListener('input', (e) => {
      searchQuery = (e.target as HTMLInputElement).value;
      renderEvents();
      if (activeView === 'month') renderMonthCalendar();
      if (activeView === 'week') renderWeekCalendar();
    });

    (document.getElementById('filter-sort') as HTMLSelectElement)?.addEventListener('change', (e) => {
      activeSort = (e.target as HTMLSelectElement).value as 'soonest' | 'newest' | 'popular';
      renderEvents();
      if (activeView === 'month') renderMonthCalendar();
      if (activeView === 'week') renderWeekCalendar();
    });

    (document.getElementById('filter-date-from') as HTMLInputElement)?.addEventListener('change', (e) => {
      dateFrom = (e.target as HTMLInputElement).value;
      renderEvents();
      if (activeView === 'month') renderMonthCalendar();
      if (activeView === 'week') renderWeekCalendar();
    });

    (document.getElementById('filter-date-to') as HTMLInputElement)?.addEventListener('change', (e) => {
      dateTo = (e.target as HTMLInputElement).value;
      renderEvents();
      if (activeView === 'month') renderMonthCalendar();
      if (activeView === 'week') renderWeekCalendar();
    });

    document.getElementById('toggle-advanced')?.addEventListener('click', () => {
      document.getElementById('advanced-filters')?.classList.toggle('hidden');
    });

    document.getElementById('clear-advanced')?.addEventListener('click', () => {
      dateFrom = '';
      dateTo = '';
      (document.getElementById('filter-date-from') as HTMLInputElement).value = '';
      (document.getElementById('filter-date-to') as HTMLInputElement).value = '';
      renderEvents();
      if (activeView === 'month') renderMonthCalendar();
      if (activeView === 'week') renderWeekCalendar();
    });

    renderEvents();

    // Featured event banner
    function renderFeaturedBanner() {
      const featured = raw.find((e: any) => e.isFeatured && e.status === 'upcoming');
      const banner = document.getElementById('featured-event-banner');
      if (!banner || !featured) return;
      document.getElementById('featured-title')!.textContent = featured.title;
      document.getElementById('featured-desc')!.textContent = featured.description || '';
      document.getElementById('featured-date')!.textContent = new Date(featured.startTime).toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
      document.getElementById('featured-type')!.textContent = featured.eventType;
      (document.getElementById('featured-link') as HTMLAnchorElement).href = `/events/${featured.slug}`;
      banner.classList.remove('hidden');
    }
    renderFeaturedBanner();

    // Series grouping section
    function renderSeriesSection() {
      const seriesMap: Record<string, any[]> = {};
      raw.forEach((e: any) => {
        if (e.seriesId) {
          const key = typeof e.seriesId === 'string' ? e.seriesId : String(e.seriesId);
          if (!seriesMap[key]) seriesMap[key] = [];
          seriesMap[key].push(e);
        }
      });
      const seriesSection = document.getElementById('series-section');
      const seriesList = document.getElementById('series-list');
      if (!seriesSection || !seriesList) return;
      const seriesKeys = Object.keys(seriesMap).filter(k => seriesMap[k].length > 1);
      if (seriesKeys.length === 0) return;
      seriesSection.classList.remove('hidden');
      seriesList.innerHTML = seriesKeys.map(key => {
        const events = seriesMap[key].sort((a: any, b: any) => new Date(a.startTime).getTime() - new Date(b.startTime).getTime());
        const seriesName = events[0].title.replace(/\s*#\d+$/, '') + ' Series';
        return `
          <div class="card p-6">
            <h3 class="text-lg font-semibold mb-3">🔁 ${seriesName}</h3>
            <div class="flex flex-wrap gap-3">
              ${events.map((e: any) => `
                <a href="/events/${e.slug}" class="flex items-center gap-2 px-3 py-2 rounded-lg border border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition text-sm">
                  <span class="font-medium">${new Date(e.startTime).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
                  <span class="text-gray-500 truncate max-w-[120px]">${e.title}</span>
                  <span class="badge ${e.status === 'upcoming' ? 'badge-primary' : e.status === 'live' ? 'badge-accent' : 'badge-secondary'} text-xs">${e.status}</span>
                </a>
              `).join('')}
            </div>
          </div>
        `;
      }).join('');
    }
    renderSeriesSection();

    // -----------------------------------------------------------------------
    // Calendar views
    // -----------------------------------------------------------------------
    let activeView: 'grid' | 'month' | 'week' = 'grid';
    let calMonthDate = new Date();
    let calWeekDate = new Date();

    function switchView(view: 'grid' | 'month' | 'week') {
      activeView = view;
      document.getElementById('events-grid')!.classList.toggle('hidden', view !== 'grid');
      document.getElementById('events-empty')!.classList.add('hidden');
      document.getElementById('calendar-month-view')!.classList.toggle('hidden', view !== 'month');
      document.getElementById('calendar-week-view')!.classList.toggle('hidden', view !== 'week');
      document.querySelectorAll('.view-toggle-btn').forEach(btn => {
        const isActive = btn.getAttribute('data-view') === view;
        btn.classList.toggle('btn-primary', isActive);
        btn.classList.toggle('btn-outline', !isActive);
      });
      if (view === 'month') renderMonthCalendar();
      if (view === 'week') renderWeekCalendar();
      if (view === 'grid') renderEvents();
    }

    document.querySelectorAll('.view-toggle-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        switchView(btn.getAttribute('data-view') as 'grid' | 'month' | 'week');
      });
    });

    function renderMonthCalendar() {
      const year = calMonthDate.getFullYear();
      const month = calMonthDate.getMonth();

      document.getElementById('cal-month-label')!.textContent = calMonthDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });

      const events = getFilteredEvents();

      const eventsByDay: Record<string, any[]> = {};
      events.forEach((e: any) => {
        const d = new Date(e.startTime);
        const key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
        if (!eventsByDay[key]) eventsByDay[key] = [];
        eventsByDay[key].push(e);
      });

      const firstDay = new Date(year, month, 1).getDay();
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      const today = new Date();

      const grid = document.getElementById('cal-month-grid')!;
      let html = '';

      for (let i = 0; i < firstDay; i++) {
        html += `<div class="bg-gray-50 min-h-[100px] p-1"></div>`;
      }

      for (let day = 1; day <= daysInMonth; day++) {
        const key = `${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
        const dayEvents = eventsByDay[key] || [];
        const isToday = today.getFullYear() === year && today.getMonth() === month && today.getDate() === day;

        html += `
          <div class="bg-white min-h-[100px] p-1 ${isToday ? 'ring-2 ring-primary-500 ring-inset' : ''}">
            <span class="text-xs font-medium ${isToday ? 'bg-primary-600 text-white rounded-full w-5 h-5 flex items-center justify-center' : 'text-gray-600'} mb-1 block w-fit">
              ${day}
            </span>
            ${dayEvents.slice(0, 3).map((e: any) => `
              <a href="/events/${e.slug}" title="${e.title}" class="block truncate text-xs px-1 py-0.5 rounded mb-0.5 ${
                e.status === 'live' ? 'bg-red-100 text-red-700' :
                e.status === 'ended' ? 'bg-gray-100 text-gray-600' :
                'bg-primary-100 text-primary-700'
              } hover:opacity-80">
                ${e.title}
              </a>
            `).join('')}
            ${dayEvents.length > 3 ? `<span class="text-xs text-gray-400">+${dayEvents.length - 3} more</span>` : ''}
          </div>
        `;
      }

      const totalCells = firstDay + daysInMonth;
      const remainder = totalCells % 7;
      if (remainder !== 0) {
        for (let i = 0; i < 7 - remainder; i++) {
          html += `<div class="bg-gray-50 min-h-[100px] p-1"></div>`;
        }
      }

      grid.innerHTML = html;
    }

    document.getElementById('cal-prev-month')?.addEventListener('click', () => {
      calMonthDate = new Date(calMonthDate.getFullYear(), calMonthDate.getMonth() - 1, 1);
      renderMonthCalendar();
    });
    document.getElementById('cal-next-month')?.addEventListener('click', () => {
      calMonthDate = new Date(calMonthDate.getFullYear(), calMonthDate.getMonth() + 1, 1);
      renderMonthCalendar();
    });

    function renderWeekCalendar() {
      const startOfWeek = new Date(calWeekDate);
      const day = startOfWeek.getDay();
      const diff = day === 0 ? -6 : 1 - day;
      startOfWeek.setDate(startOfWeek.getDate() + diff);

      const endOfWeek = new Date(startOfWeek);
      endOfWeek.setDate(startOfWeek.getDate() + 6);

      document.getElementById('cal-week-label')!.textContent =
        `${startOfWeek.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })} \u2013 ${endOfWeek.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`;

      const events = getFilteredEvents();
      const today = new Date();

      const grid = document.getElementById('cal-week-grid')!;
      let html = '';

      for (let i = 0; i < 7; i++) {
        const cellDate = new Date(startOfWeek);
        cellDate.setDate(startOfWeek.getDate() + i);

        const key = `${cellDate.getFullYear()}-${String(cellDate.getMonth()+1).padStart(2,'0')}-${String(cellDate.getDate()).padStart(2,'0')}`;
        const dayEvents = events.filter((e: any) => {
          const d = new Date(e.startTime);
          const k = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
          return k === key;
        });

        const isToday = today.toDateString() === cellDate.toDateString();
        const dayName = cellDate.toLocaleDateString('en-US', { weekday: 'short' });
        const dayNum = cellDate.getDate();

        html += `
          <div class="border rounded-lg p-2 ${isToday ? 'border-primary-400 bg-primary-50' : 'border-gray-200 bg-white'} min-h-[120px]">
            <div class="text-center mb-2">
              <div class="text-xs text-gray-500 uppercase font-medium">${dayName}</div>
              <div class="text-sm font-bold ${isToday ? 'text-primary-700' : 'text-gray-700'}">${dayNum}</div>
            </div>
            ${dayEvents.length === 0
              ? `<div class="text-xs text-gray-400 text-center mt-4">No events</div>`
              : dayEvents.map((e: any) => `
                  <a href="/events/${e.slug}" title="${e.title}" class="block text-xs px-1.5 py-1 rounded mb-1 truncate ${
                    e.status === 'live' ? 'bg-red-100 text-red-700' :
                    e.status === 'ended' ? 'bg-gray-100 text-gray-600' :
                    'bg-primary-100 text-primary-700'
                  } hover:opacity-80">
                    <span class="font-medium">${new Date(e.startTime).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })}</span>
                    <span class="block truncate">${e.title}</span>
                  </a>
                `).join('')
            }
          </div>
        `;
      }

      grid.innerHTML = html;
    }

    document.getElementById('cal-prev-week')?.addEventListener('click', () => {
      calWeekDate = new Date(calWeekDate);
      calWeekDate.setDate(calWeekDate.getDate() - 7);
      renderWeekCalendar();
    });
    document.getElementById('cal-next-week')?.addEventListener('click', () => {
      calWeekDate = new Date(calWeekDate);
      calWeekDate.setDate(calWeekDate.getDate() + 7);
      renderWeekCalendar();
    });
  </script>
</Layout>
